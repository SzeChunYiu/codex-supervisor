def start_async_metric_refresh(name: str, target) -> bool:
    """Run slow overview telemetry off the pane-refresh critical path."""
    with ASYNC_METRIC_LOCK:
        if name in ASYNC_METRIC_IN_FLIGHT:
            return False
        ASYNC_METRIC_IN_FLIGHT.add(name)

    def runner():
        try:
            target()
        except Exception as e:
            print(f"{name} async refresh error: {e}", file=sys.stderr)
        finally:
            with ASYNC_METRIC_LOCK:
                ASYNC_METRIC_IN_FLIGHT.discard(name)

    thread = threading.Timer(max(0.0, ASYNC_METRIC_START_DELAY_SECS), runner)
    thread.name = f"csup-dashboard-{name}"
    thread.daemon = True
    thread.start()
    return True


def async_metric_names() -> list[str]:
