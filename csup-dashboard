    axis.appendChild(el('span', { cls: 'chart-axis-label', text: formatTick(maxValue * tick) }));
    const line = el('span', { cls: 'chart-gridline' + (tick === 1 || tick === 0.5 || tick === 0 ? ' major' : '') });
    line.style.bottom = (tick * 100) + '%';
    line.title = formatTick(maxValue * tick);
    box.appendChild(line);
  }
  frame.appendChild(axis);
  frame.appendChild(box);
