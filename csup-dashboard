}
.office-person.office-agent.at-seat.face-up .pixel-avatar.sprite-avatar {
  background-position: 0 -64px;
}
.office-person.office-agent.dead .pixel-avatar.sprite-avatar {
  animation: none;
  opacity: .55;
}
/* Seated-at-desk: clip to torso only, simulating sitting behind a desk */
.office-person.office-agent.seated-at-desk .pixel-avatar.sprite-avatar {
  height: 42px;
  margin-top: 24px;
  clip-path: inset(0 0 18px 0);
