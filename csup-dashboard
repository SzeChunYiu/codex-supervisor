  background: linear-gradient(180deg, #18181e, #121216);
}
.project-head .name { color: #fff; font-size: 13px; font-weight: 700; letter-spacing: .03em; }
.project-head .path { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--codex-muted); font-size: 10px; }
.instance { padding: 10px 12px 12px; border-bottom: 1px solid #18181e; }
.instance:last-child { border-bottom: none; }
.instance-head { display: flex; align-items: center; gap: 8px; margin-bottom: 9px; min-width: 0; font-size: 11px; }
.host-badge {
  color: #fff; padding: 2px 8px; border-radius: 999px;
  border: 1px solid rgba(255,255,255,.08);
  background: #24242d; font-weight: 700; letter-spacing: .02em;
}
.host-badge.mac-mini { background: rgba(200,169,238,.18); color: var(--codex-purple); }
.host-badge.laptop { background: rgba(171,223,167,.16); color: var(--codex-green); }
.session { color: var(--codex-dim); font-family: var(--mono); }
.conn {
  padding: 1px 7px; border-radius: 999px; border: 1px solid transparent;
  font-size: 9px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
}
.conn-ok { color: var(--codex-green); background: rgba(171,223,167,.10); border-color: rgba(171,223,167,.20); }
.conn-bad { color: var(--codex-orange); background: rgba(255,191,122,.10); border-color: rgba(255,191,122,.22); }
.prompts { color: var(--codex-muted); margin-left: auto; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.err { color: var(--codex-orange); }

.grid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(min(100%, 54ch), 1fr)); align-items: start; contain: layout style; }
.pane {
  --pane-lines: 28;
  background: var(--codex-bg);
  border: 1px solid var(--codex-border);
  border-radius: 9px;
  overflow: hidden;
  cursor: pointer;
  min-height: 190px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.035), 0 8px 20px rgba(0,0,0,.24);
  contain: layout paint style;
  transform: translateZ(0);
  backface-visibility: hidden;
  transition: border-color .12s ease, transform .12s ease, box-shadow .12s ease;
}
.pane:hover { border-color: #44444d; transform: translate3d(0,-1px,0); box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 12px 28px rgba(0,0,0,.30); will-change: transform, box-shadow; }
.pane-head {
  min-height: 34px;
  display: flex; align-items: center; gap: 7px;
  padding: 7px 9px;
  border-bottom: 1px solid var(--codex-border-soft);
  background: linear-gradient(180deg, #151519, #101013);
  color: var(--codex-dim);
  font-size: 10px;
}
.lane-tag { color: #fff; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; max-width: 18ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pane-idx, .pane-dims { color: var(--codex-muted); }
.state-badge {
  padding: 1px 7px; border-radius: 999px; border: 1px solid transparent;
  font-size: 9px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
}
.state-badge.working { color: var(--codex-green); background: rgba(171,223,167,.12); border-color: rgba(171,223,167,.22); }
.state-badge.goal-done { color: var(--codex-blue); background: rgba(125,211,252,.11); border-color: rgba(125,211,252,.20); }
.state-badge.ready { color: var(--codex-purple); background: rgba(200,169,238,.11); border-color: rgba(200,169,238,.20); }
.state-badge.idle { color: var(--codex-dim); background: rgba(255,255,255,.035); border-color: rgba(255,255,255,.055); }
.state-badge.dead { color: var(--codex-red); background: rgba(255,138,128,.10); border-color: rgba(255,138,128,.22); }
.state-badge.rate-limited { color: var(--codex-orange); background: rgba(255,191,122,.10); border-color: rgba(255,191,122,.22); }
.model-badge { margin-left: auto; color: var(--codex-yellow); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 28ch; }
.pane-terminal { padding: 9px 10px 11px; max-height: min(64vh, calc((var(--pane-lines, 28) * 1.36em) + 24px)); overflow: auto; overscroll-behavior: contain; scrollbar-gutter: stable both-edges; }
.terminal-pre {
  margin: 0;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  tab-size: 2;
  color: var(--codex-fg);
  font: 12px/1.36 var(--mono);
  letter-spacing: 0;
  contain: content;
}
body.wrap .terminal-pre { white-space: pre-wrap; overflow-wrap: anywhere; }
body.wrap .pane-terminal { overflow-x: hidden; }
.pane.s-dead { opacity: .72; }
.empty {
  color: var(--codex-muted); padding: 16px; border: 1px dashed var(--codex-border);
  border-radius: 9px; background: rgba(255,255,255,.018);
}

.modal { position: fixed; inset: 0; background: rgba(0,0,0,.88); display: none; align-items: center; justify-content: center; z-index: 100; padding: 18px; }
.modal.open { display: flex; }
.modal-body { width: min(1120px, 94vw); max-height: 92vh; overflow: hidden; background: var(--codex-bg); border: 1px solid var(--codex-border); border-radius: 10px; box-shadow: 0 20px 70px rgba(0,0,0,.55); }
.modal-title { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-bottom: 1px solid var(--codex-border-soft); background: #141418; color: #fff; font-weight: 700; font-size: 12px; }
.modal-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.modal-title button { margin-left: auto; }
.modal-scroll { max-height: calc(92vh - 48px); overflow: auto; padding: 12px; overscroll-behavior: contain; scrollbar-gutter: stable both-edges; }
.project, .metric-card, .chart-card, .activity-panel, .project-card-link { contain: layout paint style; }
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
  .pane:hover { transform: none; will-change: auto; }
}
@media (max-width: 720px) {
  body { padding: 10px; }
  .shellbar { grid-template-columns: 1fr; }
  .actions { justify-content: flex-start; }
  .project-head { grid-template-columns: 1fr; gap: 3px; }
  .metric-card { min-height: 82px; }
  .token-graphs { grid-template-columns: 1fr; }
  .activity-head { align-items: flex-start; flex-direction: column; }
  .activity-text { white-space: normal; }
  .prompts { display: none; }
}


