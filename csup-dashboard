class Handler(BaseHTTPRequestHandler):
    def log_message(self, *_):
        pass

    def handle(self):
        try:
            super().handle()
        except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError):
            # Browsers, curl pipelines, and SSE reconnects routinely close
            # sockets while the dashboard is writing. Treat that as normal
            # client churn instead of polluting the supervisor log.
            return

    def do_GET(self):
        parsed = urlparse(self.path)
        request_path = parsed.path
        if request_path == "/" or self.path.startswith("/project/"):
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(INDEX_HTML.encode())
            return
        if request_path in ("/api/state.json", "/api/refresh.json"):
            q = parse_qs(parsed.query)
            if request_path == "/api/refresh.json" or q.get("refresh", ["0"])[0].lower() in {"1", "true", "yes"}:
                try:
                    refresh_once()
                except Exception as e:
                    with CACHE_LOCK:
                        CACHE["last_refresh_error"] = str(e)[:200]
                    self.send_error(500, str(e)[:120])
                    return
            project_filter = q.get("project", [""])[0]
            if project_filter and not re.fullmatch(r"[a-z0-9_.\-]+", project_filter):
                self.send_error(400, "invalid project")
                return
            compact = q.get("compact", ["0"])[0].lower() in {"1", "true", "yes", "on"}
            try:
                tail_lines = max(1, min(50, int(q.get("tail", ["6"])[0])))
            except ValueError:
                tail_lines = 6
            payload = json.dumps(state_payload(project_filter, compact=compact, tail_lines=tail_lines)).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(payload)
            return
        if request_path == "/api/health.json":
            payload = json.dumps(health_payload()).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(payload)
            return
        if request_path == "/api/events":
            # Server-Sent Events: long-lived connection; pushes "update" event
            # each time the streaming cache gets new data from LUNARC.
            # Browser subscribes once and re-fetches /api/state.json on each event.
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.send_header("Access-Control-Allow-Origin", "*")
            self.end_headers()
            # Send initial ping so client knows it's connected
            try:
                self.wfile.write(b"event: connected\ndata: 1\n\n")
                self.wfile.flush()
            except Exception:
                return
            with SSE_CLIENTS_LOCK:
                SSE_CLIENTS.append(self.wfile)
            try:
                # Block until the client disconnects (wfile.write will throw)
                while True:
                    time.sleep(15)
                    try:
                        self.wfile.write(b": keepalive\n\n")
                        self.wfile.flush()
                    except Exception:
                        break
            finally:
                with SSE_CLIENTS_LOCK:
                    try:
                        SSE_CLIENTS.remove(self.wfile)
                    except ValueError:
                        pass
            return
        if self.path.startswith("/api/pane"):
            q = parse_qs(parsed.query)
            host = q.get("host", [""])[0]
            session = q.get("session", [""])[0]
            idx = q.get("index", ["0"])[0]
            wants_json = q.get("format", [""])[0] == "json"
            # Validate to keep shell-safe
            if not re.fullmatch(r"[A-Za-z0-9_.\-]+", host or "") or \
               not re.fullmatch(r"[A-Za-z0-9_.\-]+", session or "") or \
               not re.fullmatch(r"\d+", idx):
                self.send_error(400); return
            hosts = known_hosts()
            me = this_host_name(hosts)
            target = f"{session}:.{idx}"
            try:
                runner = host_runner(host, hosts, me, timeout=15, retries=1)
                if runner is None:
                    self.send_error(502, "host unavailable"); return
                raw_lines = q.get("lines", [str(REFRESH_LINES)])[0]
                try:
                    pane_lines = max(1, min(200, int(raw_lines)))
                except ValueError:
                    pane_lines = REFRESH_LINES
                r = runner(["tmux", "capture-pane", "-e", "-t", target,
                            "-p", "-S", f"-{pane_lines}"])
            except subprocess.TimeoutExpired:
                self.send_error(504, "pane capture timeout"); return
            if r.returncode != 0:
                msg = (r.stderr or r.stdout or f"tmux capture failed with {r.returncode}").strip()
                self.send_error(502, msg[:120]); return
            ansi_lines = (r.stdout or "").splitlines()
            ansi_text = "\n".join(ansi_lines[-pane_lines:])
            text = strip_ansi(ansi_text)
            self.send_response(200)
            if wants_json:
                payload = json.dumps({
                    "text": text,
                    "html": ansi_to_html(ansi_text),
                }).encode()
                self.send_header("Content-Type", "application/json")
                self.send_header("Cache-Control", "no-store")
                self.end_headers()
                self.wfile.write(payload)
                return
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Cache-Control", "no-store")
            self.end_headers()
            self.wfile.write(text.encode())
            return
        self.send_error(404)


def _cleanup_orphaned_streamers() -> None:
    """Kill srun --overlap python3 orphans from previous dashboard sessions.

    Called once at startup, before any StreamingConnections are created, so
    there is nothing legitimate to accidentally kill.  Runs synchronously with
    a short timeout so startup is not significantly delayed.
    """
    try:
        hosts = known_hosts()
        targets_done: set[str] = set()
        for host, info in hosts.items():
            if not host_is_slurm(host, hosts):
                continue
            ssh_target = info.get("ssh", "")
            if not ssh_target or ssh_target == "local":
                continue
            cmd_target = ssh_command_target(ssh_target)
            if cmd_target in targets_done:
                continue
            targets_done.add(cmd_target)
            try:
                subprocess.run(
                    ["ssh", *SSH_BASE_OPTS, *SSH_CONTROL_OPTS, cmd_target,
                     'pkill -u "$(whoami)" -f "srun.*overlap.*python3" 2>/dev/null; true'],
                    timeout=8, capture_output=True,
                )
                print(f"csup-dashboard: orphaned streamers cleaned on {cmd_target}",
                      file=sys.stderr)
            except Exception as e:
                print(f"csup-dashboard: streamer cleanup skipped ({cmd_target}): {e}",
                      file=sys.stderr)
    except Exception as e:
        print(f"csup-dashboard: streamer cleanup error: {e}", file=sys.stderr)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=7777)
    ap.add_argument("--lines", type=int, default=DEFAULT_TAIL)
    ap.add_argument("--refresh", type=float, default=DEFAULT_REFRESH)
    args = ap.parse_args()

    global REFRESH_LINES
    REFRESH_LINES = args.lines
    with CACHE_LOCK:
        CACHE["refresh_interval_secs"] = args.refresh
    def _close_all_streaming_conns():
        with STREAMING_CONNECTIONS_LOCK:
            conns = list(STREAMING_CONNECTIONS.values())
        for c in conns:
            try:
                c.close()
            except Exception:
                pass

    def _sigterm_handler(signum, frame):
        _close_all_streaming_conns()
        _kill_all_active_procs()
        sys.exit(0)

    atexit.register(_close_all_streaming_conns)
    atexit.register(_kill_all_active_procs)
    signal.signal(signal.SIGTERM, _sigterm_handler)
    # Keep a manually/background-launched localhost dashboard alive when the
    # parent shell exits. SIGTERM still performs cleanup; SIGHUP should behave
    # like nohup/service mode and be ignored.
    signal.signal(signal.SIGHUP, signal.SIG_IGN)

    print("csup-dashboard: cleaning up orphaned streamers asynchronously…", file=sys.stderr)
    threading.Thread(target=_cleanup_orphaned_streamers,
                     name="csup-dashboard-cleanup-streamers",
                     daemon=True).start()
    print("csup-dashboard: priming initial state…", file=sys.stderr)
    refresh_once(args.lines)
    threading.Thread(target=refresh_loop,
                     args=(args.refresh, args.lines), daemon=True).start()
    print(f"csup-dashboard: http://localhost:{args.port}", file=sys.stderr)
    socketserver.ThreadingTCPServer.allow_reuse_address = True
    socketserver.ThreadingTCPServer.daemon_threads = True
    with socketserver.ThreadingTCPServer(("127.0.0.1", args.port), Handler) as srv:
        try:
            srv.serve_forever()
        except KeyboardInterrupt:
            pass


if __name__ == "__main__":
    main()
