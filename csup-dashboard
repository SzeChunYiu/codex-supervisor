  timeCard.appendChild(renderToolCallBars(buckets));
  timeCard.appendChild(readingRow([
    { label: 'Visible calls', value: formatNumber(events.length), note: formatNumber(toolUsage.total_tool_calls || 0) + ' scanned tail calls' },
    { label: 'Latest tool', value: toolUsage.latest_tool || 'n/a', note: formatTime(toolUsage.latest_event_at) },
    { label: 'Arg deltas', value: formatNumber(toolUsage.streaming_arg_delta_events || 0), note: 'structured response.function_call_arguments.delta events' },
  ]));
