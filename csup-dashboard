def bounded_int(value: object, default: int, *, min_value: int, max_value: int | None = None) -> int:
    try:
        parsed = int(value)
    except (TypeError, ValueError, OverflowError):
        return default
    if parsed < min_value:
        return default
    if max_value is not None and parsed > max_value:
        return default
    return parsed


def bounded_float(value: object, default: float, *, min_value: float) -> float:
    try:
        parsed = float(value)
    except (TypeError, ValueError, OverflowError):
        return default
    if not math.isfinite(parsed) or parsed < min_value:
        return default
    return parsed


def cache_timestamp(value: object, default: float = 0.0) -> float:
    return bounded_float(value, default, min_value=0.0)


def cache_age(now: float, value: object) -> float:
    return max(0.0, now - cache_timestamp(value))


