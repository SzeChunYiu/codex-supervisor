function cleanActivityLine(line) {
  const text = String(line || '')
    .replace(/[╭╮╰╯│─━]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  if (!text) return '';
  if (text.length < 3) return '';
  const low = text.toLowerCase();
  if (low === 'codex' || low === 'working' || low === 'ready') return '';
  return text;
}

function lastMeaningfulPaneLine(pane) {
  const lines = (pane.tail || []).slice().reverse();
  for (const line of lines) {
    const cleaned = cleanActivityLine(line);
    if (cleaned) return cleaned;
  }
  return pane.state ? ('Pane is ' + pane.state) : 'No recent pane output captured';
}

function recentActivities(state) {
  const activities = [];
  for (const project of state.projects || []) {
    for (const inst of capturedInstances(project)) {
      for (const pane of inst.panes || []) {
        const lane = pane.lane || ('pane' + pane.index);
        const text = lastMeaningfulPaneLine(pane);
        activities.push({
          project: project.name,
          path: project.path,
          host: inst.host,
          session: inst.session,
          lane,
          pane: pane.index,
          state: pane.state || 'idle',
          model: pane.model || '',
          text,
          context: 'tmux ' + inst.session + ' · pane #' + pane.index + ' · ' + inst.host,
        });
      }
    }
  }
  const score = { working: 0, 'goal-done': 1, ready: 2, idle: 3, 'rate-limited': 4, dead: 5 };
  activities.sort((a, b) => (score[a.state] ?? 9) - (score[b.state] ?? 9) || a.project.localeCompare(b.project) || a.pane - b.pane);
  return activities.slice(0, 18);
}

function renderRecentActivities(state) {
  const activities = recentActivities(state);
  const panel = el('section', { cls: 'activity-panel', title: 'Recent activities across panes and projects' });
  const head = el('div', { cls: 'activity-head' });
  const titleWrap = el('div');
  titleWrap.appendChild(el('div', { cls: 'activity-title', text: 'Recent activities' }));
  titleWrap.appendChild(el('div', { cls: 'activity-subtitle', text: 'last meaningful pane output across projects and panes' }));
  head.appendChild(titleWrap);
  head.appendChild(pill('items', activities.length));
