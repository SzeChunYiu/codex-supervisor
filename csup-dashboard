def toml_read(path: pathlib.Path) -> dict:
    """Parse the limited subset csup uses: section.subsection + key='value'."""
    data: dict = {}
    cur = data
    try:
        if not path.exists():
            return data
        raw_lines = path.read_text().splitlines()
    except OSError as e:
        print(f"toml read skipped: {path}: {e}", file=sys.stderr)
        return data
    for raw in raw_lines:
        s = raw.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("[") and s.endswith("]"):
            cur = data
            for part in s[1:-1].split("."):
                cur = cur.setdefault(part.strip('"'), {})
            continue
        m = re.match(r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.+?)(\s*#.*)?$', s)
        if m:
            v = m.group(2).strip()
            if len(v) >= 2 and v[0] == '"' and v[-1] == '"':
                v = v[1:-1]
            cur[m.group(1)] = v
    return data


ANSI_SGR_RE = re.compile(r"\x1b\[([0-9;:]*)m")
ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
ANSI_OSC_RE = re.compile(r"\x1b\].*?(?:\x07|\x1b\\)", re.S)

# Codex emits a mix of truecolor and xterm-256 SGR codes. Truecolor is carried
# through exactly; the first 16 xterm entries are tuned to match Codex's dark
# terminal palette better than the very dull historical xterm defaults.
ANSI_16 = {
    0: "#111114", 1: "#ff7b72", 2: "#7ee787", 3: "#e3c16f",
    4: "#79c0ff", 5: "#d2a8ff", 6: "#7dd3fc", 7: "#d8d8d8",
    8: "#6e7681", 9: "#ffa198", 10: "#a7f3b5", 11: "#f6e2b7",
    12: "#a5d6ff", 13: "#e0b3ff", 14: "#b6e3ff", 15: "#ffffff",
}


def xterm_color(n: int) -> str:
    """Return a CSS hex color for an xterm-256 palette index."""
    n = max(0, min(255, n))
    if n < 16:
        return ANSI_16[n]
    if 16 <= n <= 231:
        n -= 16
        r, rem = divmod(n, 36)
        g, b = divmod(rem, 6)
        scale = [0, 95, 135, 175, 215, 255]
        return f"#{scale[r]:02x}{scale[g]:02x}{scale[b]:02x}"
    v = 8 + (n - 232) * 10
    return f"#{v:02x}{v:02x}{v:02x}"


def strip_ansi(text: str) -> str:
    """Drop terminal escape sequences while keeping the terminal text layout."""
    return ANSI_ESCAPE_RE.sub("", ANSI_OSC_RE.sub("", text))


def _span(text: str, style: dict[str, object]) -> str:
    if not text:
        return ""
    text = strip_ansi(text)
    escaped = html.escape(text, quote=False)
    css: list[str] = []
    if style.get("fg"):
        css.append(f"color:{style['fg']}")
    if style.get("bg"):
        css.append(f"background-color:{style['bg']}")
    if style.get("bold"):
        css.append("font-weight:700")
    if style.get("dim"):
        css.append("opacity:.58")
    if style.get("italic"):
        css.append("font-style:italic")
    if style.get("underline"):
        css.append("text-decoration:underline")
    if not css:
        return escaped
    return f'<span style="{";".join(css)}">{escaped}</span>'


def _apply_sgr(style: dict[str, object], raw_params: str) -> None:
    params = [int(p) if p else 0 for p in raw_params.replace(":", ";").split(";")]
    if not params:
        params = [0]
    i = 0
    while i < len(params):
        p = params[i]
        if p == 0:
            style.clear()
        elif p == 1:
            style["bold"] = True
            style.pop("dim", None)
        elif p == 2:
            style["dim"] = True
            style.pop("bold", None)
        elif p == 3:
            style["italic"] = True
        elif p == 4:
            style["underline"] = True
        elif p == 22:
            style.pop("bold", None)
            style.pop("dim", None)
        elif p == 23:
            style.pop("italic", None)
        elif p == 24:
            style.pop("underline", None)
        elif 30 <= p <= 37:
            style["fg"] = xterm_color(p - 30)
        elif 90 <= p <= 97:
            style["fg"] = xterm_color(p - 90 + 8)
        elif p == 39:
            style.pop("fg", None)
        elif 40 <= p <= 47:
            style["bg"] = xterm_color(p - 40)
        elif 100 <= p <= 107:
            style["bg"] = xterm_color(p - 100 + 8)
        elif p == 49:
            style.pop("bg", None)
        elif p in (38, 48) and i + 1 < len(params):
            key = "fg" if p == 38 else "bg"
            mode = params[i + 1]
            if mode == 5 and i + 2 < len(params):
                style[key] = xterm_color(params[i + 2])
                i += 2
            elif mode == 2 and i + 4 < len(params):
                r, g, b = params[i + 2:i + 5]
                style[key] = f"#{max(0, min(255, r)):02x}{max(0, min(255, g)):02x}{max(0, min(255, b)):02x}"
                i += 4
            else:
                i += 1
        i += 1


def ansi_to_html(text: str) -> str:
    """Safely render ANSI SGR-colored terminal text as inline HTML spans."""
    out: list[str] = []
    style: dict[str, object] = {}
    pos = 0
    for m in ANSI_SGR_RE.finditer(text):
        out.append(_span(text[pos:m.start()], style))
        _apply_sgr(style, m.group(1))
        pos = m.end()
    out.append(_span(text[pos:], style))
    return "".join(out)


# Global registry of all active Popen objects. Populated by run_stable so
# that the SIGTERM handler can kill every child SSH process on exit, preventing
# orphaned srun sessions from consuming MaxSessions slots on LUNARC.
_ACTIVE_PROCS: set[subprocess.Popen] = set()
_ACTIVE_PROCS_LOCK = threading.Lock()


def _kill_all_active_procs() -> None:
    with _ACTIVE_PROCS_LOCK:
        procs = list(_ACTIVE_PROCS)
    for p in procs:
        try:
            p.terminate()
        except Exception:
            pass
    for p in procs:
        try:
            p.wait(timeout=2)
        except Exception:
            try:
                p.kill()
            except Exception:
                pass


def run_stable(cmd: list[str], *, timeout: float, retries: int = 1) -> subprocess.CompletedProcess:
    """Run a short-lived command with one retry for transient SSH failures."""
    last: subprocess.CompletedProcess | None = None
    for attempt in range(retries + 1):
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        with _ACTIVE_PROCS_LOCK:
            _ACTIVE_PROCS.add(proc)
        try:
            try:
                stdout, stderr = proc.communicate(timeout=timeout)
            except subprocess.TimeoutExpired:
                proc.kill()
                proc.communicate()
                with _ACTIVE_PROCS_LOCK:
                    _ACTIVE_PROCS.discard(proc)
                if attempt >= retries:
                    raise
                time.sleep(0.15 * (attempt + 1))
                continue
            r = subprocess.CompletedProcess(cmd, proc.returncode, stdout, stderr)
        finally:
            with _ACTIVE_PROCS_LOCK:
                _ACTIVE_PROCS.discard(proc)
        last = r
        # OpenSSH returns 255 for transport/auth/connectivity errors. Retry only
        # that class, not tmux "session not found" or command-level failures.
        if r.returncode != 255 or attempt >= retries:
            return r
        time.sleep(0.15 * (attempt + 1))
    assert last is not None
    return last


def ssh_target_lock_key(ssh_target: str) -> str:
    # Several LUNARC aliases intentionally share one OpenSSH ControlMaster.
    # OpenSSH enforces MaxSessions per master, not per alias, so serialize all
    # lunarc* aliases together to avoid "Session open refused by peer" bursts.
    if ssh_target.startswith("lunarc"):
        return "lunarc"
    return ssh_target


def ssh_command_target(ssh_target: str) -> str:
    # The auto-login helper guarantees only the `lunarc` master socket.  Some
    # inventory aliases (lunarc-babbloo, lunarc-cn018, etc.) point to the same
    # login host but expand to alias-specific ControlPath values on macOS, so
    # BatchMode probes would bypass the live socket and fail.  Execute through
    # the canonical alias while keeping the original target for lock/cache keys.
    if ssh_target.startswith("lunarc"):
        return "lunarc"
    return ssh_target


def ssh_target_lock(ssh_target: str) -> threading.Lock:
    key = ssh_target_lock_key(ssh_target)
    with SSH_TARGET_LOCKS_LOCK:
        lock = SSH_TARGET_LOCKS.get(key)
        if lock is None:
            lock = threading.Lock()
            SSH_TARGET_LOCKS[key] = lock
        return lock


def ssh_target_busy(ssh_target: str) -> bool:
    key = ssh_target_lock_key(ssh_target)
    with SSH_TARGET_LOCKS_LOCK:
        lock = SSH_TARGET_LOCKS.get(key)
    return bool(lock and lock.locked())


def streaming_connection_key(ssh_target: str, job_id: str) -> tuple[str, str]:
    """Normalize aliases that share one LUNARC allocation/ControlMaster.

    The same SLURM job can appear through several configured SSH aliases
    (for example lunarc and lunarc-babbloo).  One streamer per alias doubles
    or triples srun/tmux load and fights the shared SSH lock.  Key by the
    normalized lock target plus job id instead, while keeping separate jobs
    isolated even if their aliases share the same ControlMaster.
    """
    return ssh_target_lock_key(ssh_target), str(job_id)


def run_ssh_stable(ssh_target: str, cmd: list[str], *, timeout: float, retries: int = 1) -> subprocess.CompletedProcess:
    # OpenSSH ControlMaster sockets can refuse concurrent multiplexed session
    # opens. LUNARC is especially sensitive because several host aliases share
    # the same `lunarc` SSH target. Serialize per target so a fast dashboard
    # refresh cannot stampede the control socket.
    return run_ssh_stable_timed(ssh_target, cmd, timeout=timeout, retries=retries)[0]


def run_ssh_stable_timed(ssh_target: str, cmd: list[str], *, timeout: float,
                         retries: int = 1) -> tuple[subprocess.CompletedProcess, int, int]:
    queued_at = time.perf_counter()
    with ssh_target_lock(ssh_target):
        queue_wait_ms = round((time.perf_counter() - queued_at) * 1000)
        started_at = time.perf_counter()
        result = run_stable(cmd, timeout=timeout, retries=retries)
        run_ms = round((time.perf_counter() - started_at) * 1000)
        return result, run_ms, queue_wait_ms


_STREAMER_SCRIPT = r'''
# csup-streamer (delta + adaptive-poll edition)
#
# Behaviour:
#   * First message after CSUP_STREAMER_READY is a full snapshot ("full": true).
#   * Subsequent messages are DELTAS — only panes whose ANSI hash changed since
#     last sent are included. Unchanged panes are simply absent (the dashboard
#     keeps its cached copy).
#   * If no pane changed for HEARTBEAT_SECS, a bare {"hb": ts} is emitted so
#     the dashboard can tell the streamer is alive.
#   * Poll rate is adaptive: tight (POLL_FAST) right after any change, relaxes
#     to POLL_IDLE after IDLE_AFTER_SECS of no changes. Active panes feel
#     instant; idle panes use ~1/15 the load of the previous fixed-rate loop.
#   * Pane removal/addition is detected and signalled via "drop" / inclusion.
import json, subprocess, sys, time, os, hashlib

POLL_FAST = float(os.environ.get("CSUP_STREAMER_POLL_FAST", "0.1"))
POLL_IDLE = float(os.environ.get("CSUP_STREAMER_POLL_IDLE", "1.5"))
IDLE_AFTER_SECS = float(os.environ.get("CSUP_STREAMER_IDLE_AFTER", "3.0"))
HEARTBEAT_SECS = float(os.environ.get("CSUP_STREAMER_HEARTBEAT", "5.0"))
CAP_LINES = int(os.environ.get("CSUP_STREAMER_LINES", "200"))
TARGET_W = int(os.environ.get("CSUP_STREAMER_WIDTH", "160"))
TARGET_H = int(os.environ.get("CSUP_STREAMER_HEIGHT", "50"))

_wide_windows = set()
def ensure_wide(session):
    # List all windows in this session; force TARGET_W on any that are narrow.
    # Sets window-size=manual first so attached clients can't shrink them back.
    r = subprocess.run(
        ["tmux", "list-windows", "-t", session, "-F", "#{window_index}\t#{window_width}"],
        capture_output=True, text=True)
    for line in r.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        widx, ww = parts[0], parts[1]
        key = f"{session}:{widx}"
        w = int(ww) if ww.isdigit() else 0
        if w < TARGET_W and key not in _wide_windows:
            subprocess.run(
                ["tmux", "set-window-option", "-t", f"{session}:{widx}", "window-size", "manual"],
                capture_output=True)
            subprocess.run(
                ["tmux", "resize-window", "-t", f"{session}:{widx}", "-x", str(TARGET_W), "-y", str(TARGET_H)],
                capture_output=True)
            _wide_windows.add(key)

def capture_all():
    r = subprocess.run(["tmux", "ls", "-F", "#{session_name}"], capture_output=True, text=True)
    if r.returncode != 0:
        return []
    out = []
    for session in [s.strip() for s in r.stdout.splitlines() if s.strip()]:
        ensure_wide(session)
        fmt = "#{pane_index}\t#{pane_dead}\t#{pane_current_command}\t#{pane_width}\t#{pane_height}\t#{pane_title}"
        r2 = subprocess.run(["tmux", "list-panes", "-t", session, "-F", fmt], capture_output=True, text=True)
        if r2.returncode != 0:
            continue
        panes = []
        for line in r2.stdout.splitlines():
            parts = line.split("\t")
            if len(parts) < 3:
                continue
            idx = int(parts[0]) if parts[0].isdigit() else 0
            cap = subprocess.run(
                ["tmux", "capture-pane", "-e", "-t", f"{session}:.{idx}", "-p", "-S", f"-{CAP_LINES}"],
                capture_output=True, text=True)
            panes.append({
                "index": idx, "dead": parts[1] == "1", "cmd": parts[2],
                "width": int(parts[3]) if len(parts) > 3 and parts[3].isdigit() else 0,
                "height": int(parts[4]) if len(parts) > 4 and parts[4].isdigit() else 0,
                "title": parts[5] if len(parts) > 5 else "",
                "ansi": cap.stdout if cap.returncode == 0 else "",
            })
        out.append({"session": session, "panes": panes, "ts": time.time()})
    return out

def pane_hash(p):
    h = hashlib.blake2b(digest_size=16)
    h.update(p["ansi"].encode("utf-8", "replace"))
    h.update(b"|")
    h.update(str(p["dead"]).encode())
    h.update(b"|")
    h.update(str(p["cmd"]).encode())
    h.update(b"|")
    h.update(str(p["title"]).encode())
    return h.hexdigest()

def diff(prev_state, fresh):
    """Return (delta_sessions, new_state, any_change_bool).

    delta_sessions: list of {session, panes:[changed_panes], drop:[indices], ts}
    new_state: dict[(session)][idx] = hash
    """
    new_state = {}
    deltas = []
    any_change = False
    for s in fresh:
        sess = s["session"]
        prev_panes = prev_state.get(sess, {})
        fresh_panes = {p["index"]: p for p in s["panes"]}
        new_state[sess] = {}
        changed = []
        for idx, p in fresh_panes.items():
            h = pane_hash(p)
            new_state[sess][idx] = h
            if prev_panes.get(idx) != h:
                changed.append(p)
        dropped = [idx for idx in prev_panes if idx not in fresh_panes]
        if changed or dropped or sess not in prev_state:
            any_change = True
            entry = {"session": sess, "ts": s["ts"]}
            if changed:
                entry["panes"] = changed
            if dropped:
                entry["drop"] = dropped
            deltas.append(entry)
    # Sessions that disappeared entirely
    for sess in prev_state:
        if sess not in new_state:
            any_change = True
            deltas.append({"session": sess, "gone": True, "ts": time.time()})
    return deltas, new_state, any_change

