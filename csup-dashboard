class StreamingConnection:
    """Persistent srun --overlap subprocess that streams all tmux sessions on a SLURM node.

    One instance per (ssh_target, job_id). Eliminates per-refresh srun overhead by
    keeping a single long-lived process that emits newline-delimited JSON every ~0.5s.
    Falls back to the normal srun path automatically until ready.
    """

    RECONNECT_DELAY_MIN = 2.0
    RECONNECT_DELAY_MAX = 60.0
    RECONNECT_GIVEUP_AFTER = 12  # ~10 min of failures = job presumed dead
    STARTUP_TIMEOUT = 30.0

    def __init__(self, ssh_target: str, job_id: str) -> None:
        self.ssh_target = ssh_target
        self.job_id = job_id
        self.cache_key = streaming_connection_key(ssh_target, job_id)
        self._alive = True
        self._ready = False
        self._proc: subprocess.Popen | None = None
        self._last_heartbeat = 0.0
        self._last_error = ""
        self._consecutive_failures = 0
        self._given_up = False
        # _start() acquires the SSH target lock which may be held for many seconds
        # by probe or fetch_remote_lanes calls.  Calling it from __init__ would
        # block the caller (who often holds STREAMING_CONNECTIONS_LOCK) for the
        # same duration.  Defer to a background thread so the lock is released
        # immediately and _start() can wait as long as needed.
        threading.Thread(target=self._start, daemon=True,
                         name=f"csup-stream-init-{ssh_target}").start()

    def _build_cmd(self) -> list[str]:
        inner = (f"srun --jobid={shlex.quote(self.job_id)} --overlap "
                 f"python3 -u -c {shlex.quote(_STREAMER_SCRIPT)}")
        return ["ssh", *SSH_BASE_OPTS, *SSH_CONTROL_OPTS, ssh_command_target(self.ssh_target), inner]

    def _start(self) -> None:
        if not self._alive:
            return
        # Popen is near-instant — it just forks+execs; the SSH slave connects to
        # the ControlMaster asynchronously.  Holding the SSH target lock here
        # caused a deadlock-like starvation: STREAMING_CONNECTIONS_LOCK was held
        # by the caller, blocking all other callers while _start() waited up to
        # 30 s for the lock to free (fetch_remote_lanes calls chain on it).
        # Any "Session open refused" error from srun is caught by _read_loop and
        # triggers a reconnect, so we do not need to serialize Popen.
        try:
            if not self._alive:
                return
            self._proc = subprocess.Popen(
                self._build_cmd(),
                stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                text=True, bufsize=1,
            )
            if self._proc.stderr is not None:
                threading.Thread(target=self._stderr_loop,
                                 args=(self._proc.stderr,),
                                 daemon=True,
                                 name=f"csup-stream-err-{self.ssh_target}").start()
            threading.Thread(target=self._read_loop, daemon=True,
                             name=f"csup-stream-{self.ssh_target}").start()
        except Exception as e:
            print(f"csup-streamer start failed {self.ssh_target}/{self.job_id}: {e}",
                  file=sys.stderr)
            self._schedule_reconnect()

    def _stderr_loop(self, stream) -> None:
        try:
            for raw in stream:
                line = str(raw or "").strip()
                if not line:
                    continue
                self._last_error = line[:240]
        except Exception:
            pass

    def _read_loop(self) -> None:
        proc = self._proc
        if proc is None:
            return
        try:
            for raw in proc.stdout:  # type: ignore[union-attr]
                line = raw.strip()
                if not line:
                    continue
                if line == "CSUP_STREAMER_READY":
                    self._ready = True
                    self._consecutive_failures = 0  # reset backoff on success
                    continue
                try:
                    data = json.loads(line)
                except json.JSONDecodeError:
                    continue
                now = time.time()
                # Heartbeat: streamer is alive but nothing changed.
                if "hb" in data and "sessions" not in data:
                    self._last_heartbeat = float(data.get("hb") or now)
                    continue
                full = bool(data.get("full"))
                broadcast = False
                with STREAMING_CACHE_LOCK:
                    for sess in data.get("sessions", []):
                        sess_name = sess.get("session", "")
                        key = (self.cache_key, sess_name)
                        # Whole-session removal.
                        if sess.get("gone"):
                            STREAMING_CACHE.pop(key, None)
                            broadcast = True
                            continue
                        existing = STREAMING_CACHE.get(key) or {"panes": [], "ts": 0.0}
                        if full:
                            STREAMING_CACHE[key] = {
                                "panes": sess.get("panes", []),
                                "ts": float(sess.get("ts") or now),
                            }
                            broadcast = True
                            continue
                        # Delta path: merge changed panes into existing list,
                        # keyed by pane index. Drop any indices in "drop".
                        cur = {p["index"]: p for p in existing.get("panes", [])}
                        for p in sess.get("panes", []):
                            cur[p["index"]] = p
                            broadcast = True
                        for idx in sess.get("drop", []) or []:
                            cur.pop(idx, None)
                            broadcast = True
                        STREAMING_CACHE[key] = {
                            "panes": sorted(cur.values(), key=lambda x: x.get("index", 0)),
                            "ts": float(sess.get("ts") or now),
                        }
                if broadcast:
                    _sse_broadcast_streaming_update()
        except Exception as e:
            print(f"csup-streamer read error {self.ssh_target}: {e}", file=sys.stderr)
        finally:
            try:
                proc.wait(timeout=1)
            except subprocess.TimeoutExpired:
                try:
                    proc.kill()
                except Exception:
                    pass
                try:
                    proc.wait(timeout=1)
                except Exception:
                    pass
            except Exception:
                pass
        if self._alive:
            self._ready = False
            self._schedule_reconnect()

    def _schedule_reconnect(self) -> None:
        self._consecutive_failures += 1
        if self._consecutive_failures >= self.RECONNECT_GIVEUP_AFTER:
            if not self._given_up:
                print(f"csup-streamer giving up {self.ssh_target}/{self.job_id} "
                      f"after {self._consecutive_failures} failures (job likely gone)",
                      file=sys.stderr)
                self._given_up = True
            self._alive = False
            return
        # Exponential backoff capped at RECONNECT_DELAY_MAX.
        delay = min(self.RECONNECT_DELAY_MIN * (2 ** (self._consecutive_failures - 1)),
                    self.RECONNECT_DELAY_MAX)
        detail = f"; last_error={self._last_error}" if self._last_error else ""
        print(f"csup-streamer reconnecting {self.ssh_target}/{self.job_id} in "
              f"{delay:.0f}s (attempt {self._consecutive_failures}){detail}", file=sys.stderr)
        threading.Timer(delay, self._start).start()

    def is_ready(self) -> bool:
        return self._ready

    def get_session(self, session: str) -> dict | None:
        with STREAMING_CACHE_LOCK:
            return STREAMING_CACHE.get((self.cache_key, session))

    def close(self) -> None:
        self._alive = False
        if self._proc:
            try:
                self._proc.terminate()
            except Exception:
                pass
            try:
                self._proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                try:
                    self._proc.kill()
                except Exception:
                    pass
                try:
                    self._proc.wait(timeout=2)
                except Exception:
                    pass
            except Exception:
                pass


MAX_STREAMING_CONNS_PER_TARGET = 8


def _get_or_create_streaming_conn(ssh_target: str, job_id: str) -> "StreamingConnection | None":
    key = streaming_connection_key(ssh_target, job_id)
    with STREAMING_CONNECTIONS_LOCK:
        conn = STREAMING_CONNECTIONS.get(key)
        if conn is not None and getattr(conn, "_given_up", False):
            del STREAMING_CONNECTIONS[key]
            conn = None
        if conn is None:
            # Cap concurrent streaming connections per target to avoid saturating
            # the SSH ControlMaster's MaxSessions limit.
            target_key = ssh_command_target(ssh_target)
            active = sum(
                1 for k, c in STREAMING_CONNECTIONS.items()
                if k[0] == target_key
                and getattr(c, "_alive", True)
                and not getattr(c, "_given_up", False)
            )
            if active >= MAX_STREAMING_CONNS_PER_TARGET:
                return None
            try:
                conn = StreamingConnection(ssh_target, job_id)
                STREAMING_CONNECTIONS[key] = conn
            except Exception as e:
                print(f"csup-streamer init failed {ssh_target}/{job_id}: {e}", file=sys.stderr)
                return None
    return conn


_sse_last_broadcast: float = 0.0
_SSE_MIN_INTERVAL = 0.05   # max 20 pushes/second to browsers


def _sse_broadcast_streaming_update() -> None:
    """Push a compact 'ping' event to all SSE clients when the streaming cache updates.
    Clients receiving the ping immediately re-fetch /api/state.json for the full payload.
    Rate-limited to _SSE_MIN_INTERVAL so a fast streamer doesn't flood slow browsers.
    """
    global _sse_last_broadcast
    now = time.time()
    if now - _sse_last_broadcast < _SSE_MIN_INTERVAL:
        return
    _sse_last_broadcast = now
    msg = b"event: update\ndata: 1\n\n"
    dead: list = []
    with SSE_CLIENTS_LOCK:
        clients = list(SSE_CLIENTS)
    for wfile in clients:
        try:
            wfile.write(msg)
            wfile.flush()
        except Exception:
            dead.append(wfile)
    if dead:
        with SSE_CLIENTS_LOCK:
            for d in dead:
                try:
                    SSE_CLIENTS.remove(d)
                except ValueError:
                    pass


def list_projects() -> list[dict]:
    out = []
    by_root: dict[str, dict] = {}
    seen = set()
    candidates: list[pathlib.Path] = []
    for base in PROJECT_SEARCH_DIRS:
        if not base.exists():
            continue
        try:
            candidates.extend(base.iterdir())
        except OSError as e:
            print(f"project scan skipped: {base}: {e}", file=sys.stderr)
            continue
    candidates.extend(EXTRA_PROJECT_ROOTS)
    for child in candidates:
        fallback = DIRECT_PROJECT_FALLBACKS.get(str(child), {})
        try:
            child_key = str(child.resolve())
        except OSError:
            child_key = str(child)
        try:
            cfg = child / ".codex-supervisor.toml"
            if not cfg.is_file():
                if not fallback:
                    continue
        except OSError as e:
            if not fallback:
                print(f"project config skipped: {child}: {e}", file=sys.stderr)
                continue
        try:
            cfg_key = str(cfg.resolve()) if cfg.is_file() else f"fallback:{child_key}"
        except OSError:
            cfg_key = str(cfg)
        if cfg_key in seen or child_key in seen:
            continue
        seen.add(cfg_key)
        seen.add(child_key)
        d = toml_read(cfg) or fallback
        name = d.get("project", {}).get("name", child.name)
        out.append({
            "name": name,
            "path": str(child),
            "hosts": d.get("hosts", {}),
            "instances": [],
        })
        by_root[str(child)] = out[-1]
        by_root[child_key] = out[-1]
    for inst in state_instances():
        root = pathlib.Path(inst["project_root"])
        try:
            key = str(root.resolve())
        except OSError:
            key = str(root)
        project = by_root.get(key)
        if project is None:
            project = {
                "name": project_name_for_root(root),
                "path": key,
                "hosts": {},
                "instances": [],
            }
            by_root[key] = project
            out.append(project)
        configured_sessions = {
            (host, (hcfg.get("session") or f"{project['name']}-{host}"))
            for host, hcfg in project.get("hosts", {}).items()
        }
        extra_sessions = {
            (extra.get("host"), extra.get("session"))
            for extra in project.get("instances", [])
        }
        key_tuple = (inst.get("host"), inst.get("session"))
        if key_tuple not in configured_sessions and key_tuple not in extra_sessions:
            project["instances"].append(inst)
    return out


def read_state_file(path: pathlib.Path) -> dict:
    vals: dict[str, str] = {}
    try:
        for raw in path.read_text().splitlines():
            if "=" in raw:
                k, v = raw.split("=", 1)
                vals[k] = v
    except OSError as e:
        print(f"state read skipped: {path}: {e}", file=sys.stderr)
    return vals


def session_from_state_path(path: pathlib.Path) -> str:
    name = path.name
    prefix = ".codex-supervisor-"
    suffix = ".state"
    if name.startswith(prefix) and name.endswith(suffix):
        return name[len(prefix):-len(suffix)]
    return path.stem


def project_name_for_root(root: pathlib.Path) -> str:
    d = toml_read(root / ".codex-supervisor.toml")
    return d.get("project", {}).get("name") or root.name


def prompt_path_for_project(root: pathlib.Path, raw: str) -> str:
    if not raw:
        return ""
    p = pathlib.Path(raw)
    if not p.is_absolute():
        return raw
    try:
        return str(p.relative_to(root))
    except ValueError:
        return str(p)


def state_instances() -> list[dict]:
    hosts = known_hosts()
    me = this_host_name(hosts)
    local_host = me or socket.gethostname()
    instances: list[dict] = []
    for state in STATE_GLOB.parent.glob(STATE_GLOB.name):
        vals = read_state_file(state)
        root_raw = vals.get("PROJECT_ROOT") or ""
        prompts_raw = vals.get("PROMPTS_FILE") or ""
        if not root_raw or not prompts_raw:
            continue
        root = pathlib.Path(root_raw)
        instances.append({
            "host": local_host,
            "session": session_from_state_path(state),
            "prompts": prompt_path_for_project(root, prompts_raw),
            "source": str(state),
            "project_root": str(root),
        })
