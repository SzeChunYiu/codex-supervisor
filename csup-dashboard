function renderTokenBars(events) {
  if (!events.length) {
    const empty = el('div', { cls: 'chart-frame' });
    empty.appendChild(el('div', { cls: 'empty', text: 'No recent token events found yet.' }));
    return empty;
  }
  const stats = tokenEventStats(events);
  const peak = Math.max(1, stats.peak);
  const frame = renderChartGrid(peak);
  const box = frame.chartBox;
  for (const event of events) {
    const value = Number(event.total_tokens || 0);
    const bar = el('span', { cls: 'token-bar', title: formatTokens(value) + ' tokens · ' + formatTime(event.timestamp) });
    bar.style.height = Math.max(4, (value / peak) * 100) + '%';
    box.appendChild(bar);
  }
  return frame;
}

function cumulativeTokenEvents(events) {
  let running = 0;
  return events.map(event => {
    running += Number(event.total_tokens || 0);
    return { ...event, cumulative_tokens: running };
  });
}

function renderCumulativeBars(events) {
  const cumulative = cumulativeTokenEvents(events);
  if (!cumulative.length) {
    const empty = el('div', { cls: 'chart-frame' });
    empty.appendChild(el('div', { cls: 'empty', text: 'No cumulative token events found yet.' }));
    return empty;
  }
  const finalTotal = Math.max(1, Number(cumulative[cumulative.length - 1].cumulative_tokens || 0));
  const frame = renderChartGrid(finalTotal);
  const box = frame.chartBox;
  for (const event of cumulative) {
    const value = Number(event.cumulative_tokens || 0);
    const bar = el('span', { cls: 'cumulative-bar', title: formatTokens(value) + ' cumulative · ' + formatTime(event.timestamp) });
    bar.style.height = Math.max(4, (value / finalTotal) * 100) + '%';
    box.appendChild(bar);
  }
  return frame;
}

function renderMixBars(events) {
  if (!events.length) {
    const empty = el('div', { cls: 'chart-frame' });
    empty.appendChild(el('div', { cls: 'empty', text: 'No token mix events found yet.' }));
    return empty;
  }
  const stats = tokenEventStats(events);
  const peak = Math.max(1, stats.peak);
  const frame = renderChartGrid(peak);
  const box = frame.chartBox;
  for (const event of events) {
    const input = Number(event.input_tokens || 0);
    const output = Number(event.output_tokens || 0);
    const reasoning = Number(event.reasoning_output_tokens || 0);
    const fallback = Number(event.total_tokens || 0);
    const total = Math.max(1, input + output + reasoning || fallback);
    const bar = el('span', { cls: 'mix-bar', title: formatTokens(total) + ' tokens · ' + formatTime(event.timestamp) });
    bar.style.height = Math.max(4, (fallback / peak) * 100) + '%';
    for (const [cls, value] of [['mix-seg-input', input || Math.max(0, fallback - output - reasoning)], ['mix-seg-output', output], ['mix-seg-reasoning', reasoning]]) {
      const seg = el('span', { cls });
      seg.style.height = Math.max(value > 0 ? 2 : 0, (value / total) * 100) + '%';
      bar.appendChild(seg);
    }
    box.appendChild(bar);
  }
  return frame;
}

function renderTokenReadings(state, events) {
