        try:
            remote_payload = json.loads(remote_text)
        except json.JSONDecodeError:
            if REMOTE_CAPTURE_CACHE_SECS > 0:
                with INSTANCE_CAPTURE_CACHE_LOCK:
                    now = time.time()
