    4px 4px 0 rgba(0,0,0,.34);
  color: #fff;
  transform: translate3d(0,0,0);
  animation:
    office-idle 1.15s steps(2, end) infinite,
    office-walk 8s steps(8, end) infinite alternate;
  animation-delay: var(--walk-delay, 0s), var(--walk-delay, 0s);
