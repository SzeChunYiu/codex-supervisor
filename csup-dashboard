def read_text_bounded(path: pathlib.Path, *, max_bytes: int, label: str) -> str | None:
    """Read small control-plane files without letting a corrupt cache dominate startup."""
    try:
        with path.open("rb") as f:
            data = f.read(max_bytes + 1 if max_bytes > 0 else -1)
        if max_bytes > 0 and len(data) > max_bytes:
            print(f"{label} skipped: {path}: file too large", file=sys.stderr)
            return None
        return data.decode("utf-8", "replace")
    except FileNotFoundError:
        return None
    except OSError as e:
        print(f"{label} skipped: {path}: {e}", file=sys.stderr)
        return None


def toml_read(path: pathlib.Path) -> dict:
    """Parse the limited subset csup uses: section.subsection + key='value'."""
    data: dict = {}
    cur = data
    raw_text = read_text_bounded(path, max_bytes=1_000_000, label="toml read")
    if raw_text is None:
        return data
    raw_lines = raw_text.splitlines()
    for raw in raw_lines:
        s = raw.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("[") and s.endswith("]"):
            cur = data
            for part in s[1:-1].split("."):
                cur = cur.setdefault(part.strip('"'), {})
            continue
        m = re.match(r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.+?)(\s*#.*)?$', s)
        if m:
            v = m.group(2).strip()
            if len(v) >= 2 and v[0] == '"' and v[-1] == '"':
                v = v[1:-1]
            cur[m.group(1)] = v
    return data


def toml_read_text(text: str) -> dict:
    """Same parser as toml_read but operating on an in-memory string. Used by
    merge_remote_project_hosts to parse a .codex-supervisor.toml fetched via
    ssh cat without writing it to disk."""
    data: dict = {}
    cur = data
    for raw in (text or "").splitlines():
        s = raw.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("[") and s.endswith("]"):
            cur = data
            for part in s[1:-1].split("."):
                cur = cur.setdefault(part.strip('"'), {})
            continue
        m = re.match(r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.+?)(\s*#.*)?$', s)
        if m:
            v = m.group(2).strip()
            if len(v) >= 2 and v[0] == '"' and v[-1] == '"':
                v = v[1:-1]
            cur[m.group(1)] = v
    return data


# Cache fetched remote project tomls so repeated dashboard refreshes do not
# fire one ssh-cat per refresh. Key: (ssh_target, remote_path). Value:
# {"ts": float, "hosts": dict}.
REMOTE_PROJECT_TOML_CACHE: dict[tuple[str, str], dict] = {}
REMOTE_PROJECT_TOML_CACHE_LOCK = threading.Lock()
REMOTE_PROJECT_TOML_CACHE_SECS = env_float("CSUP_DASHBOARD_REMOTE_TOML_CACHE_SECS", 60.0, min_value=0.0)


def merge_remote_project_hosts(local_hosts: dict) -> dict:
    """Look at each host in local_hosts that references a remote SLURM workdir
    and merge any additional [hosts.*] entries from that remote project's
    .codex-supervisor.toml into the returned dict. Local entries always win.

    This closes the bootstrap-divergence gap: when the CEO running on a SLURM
    compute node appends a new [hosts."ng-newteam-lunarc"] entry to the remote
    project toml, the local Mac copy lags until a human syncs it. Without
    this merge the dashboard hides the new team. With it, the merged hosts
    show up in the next refresh and the dashboard captures their panes.
    """
    merged = dict(local_hosts or {})
    if not merged:
        return merged
    # Collect (ssh_target, remote_project_dir) tuples we should try to fetch.
    sources: set[tuple[str, str]] = set()
    for _hname, hcfg in (local_hosts or {}).items():
        if not isinstance(hcfg, dict):
            continue
        ssh_target = str(hcfg.get("ssh", "") or "").strip()
        # `project_dir` is what csup stores in the per-host config; fall back
        # to `slurm_workdir` for older configs that only have the SLURM path.
        remote_dir = (
            str(hcfg.get("project_dir", "") or "").strip()
            or str(hcfg.get("slurm_workdir", "") or "").strip()
        )
        if not ssh_target or ssh_target in {"local", ""}:
            continue
        if not remote_dir:
            continue
        sources.add((ssh_target, remote_dir.rstrip("/")))
    now = time.time()
    for ssh_target, remote_dir in sources:
        remote_toml = f"{remote_dir}/.codex-supervisor.toml"
        cache_key = (ssh_target, remote_toml)
        cached: dict | None = None
        with REMOTE_PROJECT_TOML_CACHE_LOCK:
            entry = REMOTE_PROJECT_TOML_CACHE.get(cache_key)
            if entry and cache_age(now, entry.get("ts")) < REMOTE_PROJECT_TOML_CACHE_SECS:
                cached = entry
        remote_hosts: dict = {}
        if cached:
            remote_hosts = dict(cached.get("hosts") or {})
        else:
            try:
                r = run_stable(
                    ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target),
                     "cat", shlex.quote(remote_toml)],
                    timeout=8.0, retries=0,
                )
                if r.returncode == 0 and r.stdout:
                    parsed = toml_read_text(r.stdout)
                    remote_hosts = dict(parsed.get("hosts", {}) or {})
            except Exception as e:
                # Cache the failure briefly so we don't hammer SSH on every
                # refresh when the remote is unreachable.
                remote_hosts = {}
                print(f"remote toml fetch skipped {ssh_target}:{remote_toml}: {e}",
                      file=sys.stderr)
            with REMOTE_PROJECT_TOML_CACHE_LOCK:
                REMOTE_PROJECT_TOML_CACHE[cache_key] = {"ts": now, "hosts": remote_hosts}
        # Merge: only add hosts not already in local.
        for host_name, host_cfg in remote_hosts.items():
            if host_name in merged:
                continue
            merged[host_name] = host_cfg
    return merged


ANSI_SGR_RE = re.compile(r"\x1b\[([0-9;:]*)m")
ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-?]*[ -/]*[@-~]")
ANSI_OSC_RE = re.compile(r"\x1b\].*?(?:\x07|\x1b\\)", re.S)

# Codex emits a mix of truecolor and xterm-256 SGR codes. Truecolor is carried
# through exactly; the first 16 xterm entries are tuned to match Codex's dark
# terminal palette better than the very dull historical xterm defaults.
ANSI_16 = {
    0: "#111114", 1: "#ff7b72", 2: "#7ee787", 3: "#e3c16f",
    4: "#79c0ff", 5: "#d2a8ff", 6: "#7dd3fc", 7: "#d8d8d8",
    8: "#6e7681", 9: "#ffa198", 10: "#a7f3b5", 11: "#f6e2b7",
    12: "#a5d6ff", 13: "#e0b3ff", 14: "#b6e3ff", 15: "#ffffff",
}


def xterm_color(n: int) -> str:
    """Return a CSS hex color for an xterm-256 palette index."""
    n = max(0, min(255, n))
    if n < 16:
        return ANSI_16[n]
    if 16 <= n <= 231:
        n -= 16
        r, rem = divmod(n, 36)
        g, b = divmod(rem, 6)
        scale = [0, 95, 135, 175, 215, 255]
        return f"#{scale[r]:02x}{scale[g]:02x}{scale[b]:02x}"
    v = 8 + (n - 232) * 10
    return f"#{v:02x}{v:02x}{v:02x}"


def strip_ansi(text: str) -> str:
    """Drop terminal escape sequences while keeping the terminal text layout."""
    return ANSI_ESCAPE_RE.sub("", ANSI_OSC_RE.sub("", text))


def _span(text: str, style: dict[str, object]) -> str:
    if not text:
        return ""
    text = strip_ansi(text)
    escaped = html.escape(text, quote=False)
    css: list[str] = []
    if style.get("fg"):
        css.append(f"color:{style['fg']}")
    if style.get("bg"):
        css.append(f"background-color:{style['bg']}")
    if style.get("bold"):
        css.append("font-weight:700")
    if style.get("dim"):
        css.append("opacity:.58")
    if style.get("italic"):
        css.append("font-style:italic")
    if style.get("underline"):
        css.append("text-decoration:underline")
    if not css:
        return escaped
    return f'<span style="{";".join(css)}">{escaped}</span>'


def _parse_sgr_params(raw_params: str) -> list[int]:
    params: list[int] = []
    for raw in raw_params.replace(":", ";").split(";"):
        if not raw:
            params.append(0)
            continue
        # SGR values are small control/color codes. A pane can still print an
        # arbitrarily long digit run that matches ANSI_SGR_RE; never let Python
        # bigint parsing limits or CPU-heavy conversion crash the dashboard.
        if len(raw) > 4:
            params.append(-1)
            continue
        try:
            params.append(int(raw))
        except ValueError:
            params.append(-1)
    return params or [0]


def _apply_sgr(style: dict[str, object], raw_params: str) -> None:
    params = _parse_sgr_params(raw_params)
    if not params:
        params = [0]
    i = 0
    while i < len(params):
        p = params[i]
        if p == 0:
            style.clear()
        elif p == 1:
            style["bold"] = True
            style.pop("dim", None)
        elif p == 2:
            style["dim"] = True
            style.pop("bold", None)
        elif p == 3:
            style["italic"] = True
        elif p == 4:
            style["underline"] = True
        elif p == 22:
            style.pop("bold", None)
            style.pop("dim", None)
        elif p == 23:
            style.pop("italic", None)
        elif p == 24:
            style.pop("underline", None)
        elif 30 <= p <= 37:
            style["fg"] = xterm_color(p - 30)
        elif 90 <= p <= 97:
            style["fg"] = xterm_color(p - 90 + 8)
        elif p == 39:
            style.pop("fg", None)
        elif 40 <= p <= 47:
            style["bg"] = xterm_color(p - 40)
        elif 100 <= p <= 107:
            style["bg"] = xterm_color(p - 100 + 8)
        elif p == 49:
            style.pop("bg", None)
        elif p in (38, 48) and i + 1 < len(params):
            key = "fg" if p == 38 else "bg"
            mode = params[i + 1]
            if mode == 5 and i + 2 < len(params):
                if params[i + 2] >= 0:
                    style[key] = xterm_color(params[i + 2])
                i += 2
            elif mode == 2 and i + 4 < len(params):
                r, g, b = params[i + 2:i + 5]
                if r >= 0 and g >= 0 and b >= 0:
                    style[key] = f"#{max(0, min(255, r)):02x}{max(0, min(255, g)):02x}{max(0, min(255, b)):02x}"
                i += 4
            else:
                i += 1
        i += 1


def ansi_to_html(text: str) -> str:
    """Safely render ANSI SGR-colored terminal text as inline HTML spans."""
    out: list[str] = []
    style: dict[str, object] = {}
    pos = 0
    for m in ANSI_SGR_RE.finditer(text):
        out.append(_span(text[pos:m.start()], style))
        _apply_sgr(style, m.group(1))
        pos = m.end()
    out.append(_span(text[pos:], style))
    return "".join(out)


# Global registry of all active Popen objects. Populated by run_stable so
# that the SIGTERM handler can kill every child SSH process on exit, preventing
# orphaned srun sessions from consuming MaxSessions slots on LUNARC.
_ACTIVE_PROCS: set[subprocess.Popen] = set()
_ACTIVE_PROCS_LOCK = threading.Lock()


def _kill_all_active_procs() -> None:
    with _ACTIVE_PROCS_LOCK:
        procs = list(_ACTIVE_PROCS)
    for p in procs:
        try:
            p.terminate()
        except Exception:
            pass
    for p in procs:
        try:
            p.wait(timeout=2)
        except Exception:
            try:
                p.kill()
            except Exception:
                pass


def _read_process_limited(proc: subprocess.Popen, *, timeout: float, max_bytes: int) -> tuple[int, str, str]:
    import select

    assert proc.stdout is not None and proc.stderr is not None
    stdout_chunks: list[bytes] = []
    stderr_chunks: list[bytes] = []
    fds = {proc.stdout.fileno(): ("stdout", stdout_chunks), proc.stderr.fileno(): ("stderr", stderr_chunks)}
    total = 0
    deadline = time.monotonic() + max(0.01, timeout)
    failed_rc: int | None = None
    while fds:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            failed_rc = 124
            break
        readable, _, _ = select.select(list(fds), [], [], min(0.1, remaining))
        if not readable and proc.poll() is not None:
            readable, _, _ = select.select(list(fds), [], [], 0)
            if not readable:
                break
        for fd in readable:
            try:
                chunk = os.read(fd, 65536)
            except OSError:
                chunk = b""
            if not chunk:
                fds.pop(fd, None)
                continue
            total += len(chunk)
            if total > max_bytes:
                failed_rc = 124
                break
            fds[fd][1].append(chunk)
        if failed_rc is not None:
            break
    if failed_rc is not None:
        try:
            proc.kill()
        except Exception:
            pass
        try:
            proc.wait(timeout=1)
        except Exception:
            pass
        return failed_rc, "", "output limit exceeded"
    try:
        proc.wait(timeout=0.2)
    except subprocess.TimeoutExpired:
        try:
            proc.kill()
        except Exception:
            pass
        proc.wait()
        return 124, "", "command timed out"
    stdout = b"".join(stdout_chunks)
    stderr = b"".join(stderr_chunks)
    return proc.returncode, stdout.decode("utf-8", "replace"), stderr.decode("utf-8", "replace")

def run_stable(cmd: list[str], *, timeout: float, retries: int = 1) -> subprocess.CompletedProcess:
    """Run a short-lived command with one retry for transient SSH failures."""
    last: subprocess.CompletedProcess | None = None
    for attempt in range(retries + 1):
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        with _ACTIVE_PROCS_LOCK:
            _ACTIVE_PROCS.add(proc)
        try:
            returncode, stdout, stderr = _read_process_limited(
                proc, timeout=timeout, max_bytes=MAX_RUN_STABLE_OUTPUT_BYTES
            )
            if returncode == 124:
                with _ACTIVE_PROCS_LOCK:
                    _ACTIVE_PROCS.discard(proc)
                if attempt >= retries:
                    if stderr == "command timed out":
                        raise subprocess.TimeoutExpired(cmd, timeout)
                    return subprocess.CompletedProcess(cmd, returncode, stdout, stderr)
                time.sleep(0.15 * (attempt + 1))
                continue
            r = subprocess.CompletedProcess(cmd, returncode, stdout, stderr)
        finally:
            with _ACTIVE_PROCS_LOCK:
                _ACTIVE_PROCS.discard(proc)
        last = r
        # OpenSSH returns 255 for transport/auth/connectivity errors. Retry only
        # that class, not tmux "session not found" or command-level failures.
        if r.returncode != 255 or attempt >= retries:
            return r
        time.sleep(0.15 * (attempt + 1))
    assert last is not None
    return last


def ssh_target_lock_key(ssh_target: str) -> str:
    # Several LUNARC aliases intentionally share one OpenSSH ControlMaster.
    # OpenSSH enforces MaxSessions per master, not per alias, so serialize all
    # lunarc* aliases together to avoid "Session open refused by peer" bursts.
    if ssh_target.startswith("lunarc"):
        return "lunarc"
    return ssh_target


def ssh_command_target(ssh_target: str) -> str:
    # The auto-login helper guarantees only the `lunarc` master socket.  Some
    # inventory aliases (lunarc-babbloo, lunarc-cn018, etc.) point to the same
    # login host but expand to alias-specific ControlPath values on macOS, so
    # BatchMode probes would bypass the live socket and fail.  Execute through
    # the canonical alias while keeping the original target for lock/cache keys.
    if ssh_target.startswith("lunarc"):
        return "lunarc"
    return ssh_target


def ssh_target_lock(ssh_target: str) -> threading.Lock:
    key = ssh_target_lock_key(ssh_target)
    with SSH_TARGET_LOCKS_LOCK:
        lock = SSH_TARGET_LOCKS.get(key)
        if lock is None:
            lock = threading.Lock()
            SSH_TARGET_LOCKS[key] = lock
        return lock


def ssh_target_busy(ssh_target: str) -> bool:
    key = ssh_target_lock_key(ssh_target)
    with SSH_TARGET_LOCKS_LOCK:
        lock = SSH_TARGET_LOCKS.get(key)
    return bool(lock and lock.locked())


def streaming_connection_key(ssh_target: str, job_id: str) -> tuple[str, str]:
    """Normalize aliases that share one LUNARC allocation/ControlMaster.

    The same SLURM job can appear through several configured SSH aliases
    (for example lunarc and lunarc-babbloo).  One streamer per alias doubles
    or triples srun/tmux load and fights the shared SSH lock.  Key by the
    normalized lock target plus job id instead, while keeping separate jobs
    isolated even if their aliases share the same ControlMaster.
    """
    return ssh_target_lock_key(ssh_target), str(job_id)


def run_ssh_stable(ssh_target: str, cmd: list[str], *, timeout: float, retries: int = 1) -> subprocess.CompletedProcess:
    # OpenSSH ControlMaster sockets can refuse concurrent multiplexed session
    # opens. LUNARC is especially sensitive because several host aliases share
    # the same `lunarc` SSH target. Serialize per target so a fast dashboard
    # refresh cannot stampede the control socket.
    return run_ssh_stable_timed(ssh_target, cmd, timeout=timeout, retries=retries)[0]


def run_ssh_stable_timed(ssh_target: str, cmd: list[str], *, timeout: float,
                         retries: int = 1) -> tuple[subprocess.CompletedProcess, int, int]:
    queued_at = time.perf_counter()
    with ssh_target_lock(ssh_target):
        queue_wait_ms = round((time.perf_counter() - queued_at) * 1000)
        started_at = time.perf_counter()
        result = run_stable(cmd, timeout=timeout, retries=retries)
        run_ms = round((time.perf_counter() - started_at) * 1000)
        return result, run_ms, queue_wait_ms


_STREAMER_SCRIPT = r'''
# csup-streamer (delta + adaptive-poll edition)
#
# Behaviour:
#   * First message after CSUP_STREAMER_READY is a full snapshot ("full": true).
#   * Subsequent messages are DELTAS — only panes whose ANSI hash changed since
#     last sent are included. Unchanged panes are simply absent (the dashboard
#     keeps its cached copy).
#   * If no pane changed for HEARTBEAT_SECS, a bare {"hb": ts} is emitted so
#     the dashboard can tell the streamer is alive.
#   * Poll rate is adaptive: tight (POLL_FAST) right after any change, relaxes
#     to POLL_IDLE after IDLE_AFTER_SECS of no changes. Active panes feel
#     instant; idle panes use ~1/15 the load of the previous fixed-rate loop.
#   * Pane removal/addition is detected and signalled via "drop" / inclusion.
import json, math, subprocess, sys, time, os, hashlib

def env_float(name, default, min_value=None):
    try:
        value = float(os.environ.get(name, default))
    except (TypeError, ValueError, OverflowError):
        value = default
    if not math.isfinite(value) or (min_value is not None and value < min_value):
        return default
    return value

def env_int(name, default, min_value=None):
    try:
        value = int(os.environ.get(name, default))
    except (TypeError, ValueError, OverflowError):
        value = default
    if min_value is not None and value < min_value:
        return default
    return value

def safe_int(value, default=0, min_value=0):
    try:
        parsed = int(value)
    except (TypeError, ValueError, OverflowError):
        return default
    return parsed if parsed >= min_value else default

POLL_FAST = env_float("CSUP_STREAMER_POLL_FAST", 0.1, 0.01)
POLL_IDLE = env_float("CSUP_STREAMER_POLL_IDLE", 1.5, 0.01)
IDLE_AFTER_SECS = env_float("CSUP_STREAMER_IDLE_AFTER", 3.0, 0.0)
HEARTBEAT_SECS = env_float("CSUP_STREAMER_HEARTBEAT", 5.0, 0.1)
CAP_LINES = env_int("CSUP_STREAMER_LINES", 200, 1)
TARGET_W = env_int("CSUP_STREAMER_WIDTH", 160, 20)
TARGET_H = env_int("CSUP_STREAMER_HEIGHT", 50, 5)
MAX_TMUX_SOCKET_SCAN = env_int("CSUP_MAX_TMUX_SOCKET_SCAN", 256, 1)
CMD_TIMEOUT_SECS = env_float("CSUP_STREAMER_CMD_TIMEOUT_SECS", 2.0, 0.05)
MAX_CMD_OUTPUT_BYTES = env_int("CSUP_STREAMER_CMD_MAX_OUTPUT_BYTES", 1_000_000, 1024)

def run_capture(cmd, *, timeout=None):
    try:
        r = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=CMD_TIMEOUT_SECS if timeout is None else timeout,
        )
    except subprocess.TimeoutExpired as e:
        return subprocess.CompletedProcess(cmd, 124, e.stdout or "", "command timed out")
    stdout = r.stdout or ""
    stderr = r.stderr or ""
    if len(stdout.encode("utf-8", "replace")) + len(stderr.encode("utf-8", "replace")) > MAX_CMD_OUTPUT_BYTES:
        return subprocess.CompletedProcess(cmd, 124, "", "output limit exceeded")
    return r

_wide_windows = set()
def list_sockets():
    """Enumerate every tmux server socket owned by the current user.

    Per-session sockets mean we can't just call 'tmux ls' once anymore — each
    supervisor session runs its own tmux server. The dashboard's streamer
    must visit each socket and aggregate sessions across them so the whole
    fleet shows up in one capture pass.

    Returns a list of socket names (the -L argument). Empty list means fall
    back to the default socket so single-server / legacy installs still work.
    """
    import glob, os as _os
    sock_dir = _os.environ.get("TMUX_TMPDIR", "/tmp") + f"/tmux-{_os.getuid()}"
    socks = []
    if _os.path.isdir(sock_dir):
        for idx, path in enumerate(glob.iglob(sock_dir + "/*")):
            if idx >= MAX_TMUX_SOCKET_SCAN:
                break
            try:
                if _os.path.isfile(path):
                    continue
                # tmux server sockets are unix sockets; stat to confirm
                import stat
                if stat.S_ISSOCK(_os.stat(path).st_mode):
                    socks.append(_os.path.basename(path))
            except OSError:
                continue
    if not socks:
        # Fall back to default socket name so 'tmux ls' still works.
        socks = ["default"]
    return socks

def tmux_cmd(socket, *args):
    """Build a tmux command targeting a specific socket."""
    if socket and socket != "default":
        return ["tmux", "-L", socket, *args]
    return ["tmux", *args]

def ensure_wide(socket, session):
    # List all windows in this session; force TARGET_W on any that are narrow.
    # Sets window-size=manual first so attached clients can't shrink them back.
    r = run_capture(tmux_cmd(socket, "list-windows", "-t", session, "-F", "#{window_index}\t#{window_width}"))
    for line in r.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        widx, ww = parts[0], parts[1]
        key = f"{socket}:{session}:{widx}"
        w = safe_int(ww, 0, 0)
        if w < TARGET_W and key not in _wide_windows:
            run_capture(tmux_cmd(socket, "set-window-option", "-t", f"{session}:{widx}", "window-size", "manual"))
            run_capture(tmux_cmd(socket, "resize-window", "-t", f"{session}:{widx}", "-x", str(TARGET_W), "-y", str(TARGET_H)))
            _wide_windows.add(key)

def capture_all():
    out = []
    try:
        ps_out = run_capture(["ps", "-axo", "pid=,ppid=,args="]).stdout
    except Exception:
        ps_out = ""

    def monitor_for(session):
        monitor = {"known": True, "running": False, "pids": [], "error": ""}
        candidates = []
        for raw in ps_out.splitlines():
            line = raw.strip()
            if not line or "codex-supervisor.sh" not in line or "--daemon" not in line or "--session" not in line:
                continue
            parts = line.split(None, 2)
            if len(parts) < 3:
                continue
            pid_raw, ppid_raw, args = parts
            if f"--session {session}" not in args and f"--session={session}" not in args:
                continue
            try:
                candidates.append((int(pid_raw), int(ppid_raw)))
            except (ValueError, OverflowError):
                continue
        candidate_pids = {pid for pid, _ in candidates}
        monitor["pids"] = [pid for pid, ppid in candidates if ppid not in candidate_pids]
        monitor["running"] = bool(monitor["pids"])
        return monitor

    for socket in list_sockets():
        r = run_capture(tmux_cmd(socket, "ls", "-F", "#{session_name}"))
        if r.returncode != 0:
            continue
        for session in [s.strip() for s in r.stdout.splitlines() if s.strip()]:
            ensure_wide(socket, session)
            fmt = "#{pane_index}\t#{pane_dead}\t#{pane_current_command}\t#{pane_width}\t#{pane_height}\t#{pane_title}"
            r2 = run_capture(tmux_cmd(socket, "list-panes", "-t", f"={session}", "-F", fmt))
            if r2.returncode != 0:
                continue
            panes = []
            # tmux's pane-base-index is 1 on many LUNARC/cluster installs but 0
            # on Mac. Prompt files always use 0-based "PANE N" ordinals. We
            # emit BOTH the tmux pane_index AND a normalised 0-based ordinal
            # (position within this list) so the dashboard's lane_label_for_capture
            # can resolve MANAGER (prompt 0) regardless of tmux's base-index.
            for ordinal, line in enumerate(r2.stdout.splitlines()):
                parts = line.split("\t")
                if len(parts) < 3:
                    continue
                idx = safe_int(parts[0], -1, 0)
                if idx < 0:
                    continue
                cap = run_capture(tmux_cmd(socket, "capture-pane", "-e", "-t", f"={session}:.{idx}", "-p", "-S", f"-{CAP_LINES}"))
                panes.append({
                    "index": idx, "ordinal": ordinal, "dead": parts[1] == "1", "cmd": parts[2],
                    "width": safe_int(parts[3], 0, 0) if len(parts) > 3 else 0,
                    "height": safe_int(parts[4], 0, 0) if len(parts) > 4 else 0,
                    "title": parts[5] if len(parts) > 5 else "",
                    "ansi": cap.stdout if cap.returncode == 0 else "",
                })
            out.append({"session": session, "panes": panes, "monitor": monitor_for(session), "ts": time.time()})
    return out

def pane_hash(p):
    h = hashlib.blake2b(digest_size=16)
    h.update(p["ansi"].encode("utf-8", "replace"))
    h.update(b"|")
    h.update(str(p["dead"]).encode())
    h.update(b"|")
    h.update(str(p["cmd"]).encode())
    h.update(b"|")
    h.update(str(p["title"]).encode())
    return h.hexdigest()

def diff(prev_state, fresh):
    """Return (delta_sessions, new_state, any_change_bool).

    delta_sessions: list of {session, panes:[changed_panes], drop:[indices], ts}
    new_state: dict[(session)][idx] = hash
    """
    new_state = {}
    deltas = []
    any_change = False
    for s in fresh:
        sess = s["session"]
        prev_panes = prev_state.get(sess, {})
        fresh_panes = {p["index"]: p for p in s["panes"]}
        new_state[sess] = {}
        changed = []
        for idx, p in fresh_panes.items():
            h = pane_hash(p)
            new_state[sess][idx] = h
            if prev_panes.get(idx) != h:
                changed.append(p)
        dropped = [idx for idx in prev_panes if idx not in fresh_panes]
        if changed or dropped or sess not in prev_state:
            any_change = True
            entry = {"session": sess, "ts": s["ts"]}
            if changed:
                entry["panes"] = changed
            if dropped:
                entry["drop"] = dropped
            deltas.append(entry)
    # Sessions that disappeared entirely
    for sess in prev_state:
        if sess not in new_state:
            any_change = True
            deltas.append({"session": sess, "gone": True, "ts": time.time()})
    return deltas, new_state, any_change

# First message: full snapshot.
sys.stdout.write("CSUP_STREAMER_READY\n")
sys.stdout.flush()

prev_state = {}
fresh = capture_all()
_, prev_state, _ = diff({}, fresh)
sys.stdout.write(json.dumps({"full": True, "sessions": fresh}) + "\n")
sys.stdout.flush()

last_change_at = time.monotonic()
last_emit_at = time.monotonic()
poll = POLL_FAST

while True:
    t0 = time.monotonic()
    try:
        fresh = capture_all()
        deltas, prev_state, any_change = diff(prev_state, fresh)
        now = time.monotonic()
        if any_change:
            last_change_at = now
            sys.stdout.write(json.dumps({"sessions": deltas}) + "\n")
            sys.stdout.flush()
            last_emit_at = now
        elif now - last_emit_at >= HEARTBEAT_SECS:
            sys.stdout.write(json.dumps({"hb": time.time()}) + "\n")
            sys.stdout.flush()
            last_emit_at = now
        # Adaptive poll: fast when active, idle when quiet.
        idle_for = now - last_change_at
        poll = POLL_FAST if idle_for < IDLE_AFTER_SECS else POLL_IDLE
    except BrokenPipeError:
        sys.exit(0)
    except Exception as e:
        sys.stderr.write(f"streamer error: {e}\n")
    rem = poll - (time.monotonic() - t0)
    if rem > 0:
        time.sleep(rem)
'''


class StreamingConnection:
    """Persistent srun --overlap subprocess that streams all tmux sessions on a SLURM node.

    One instance per (ssh_target, job_id). Eliminates per-refresh srun overhead by
    keeping a single long-lived process that emits newline-delimited JSON every ~0.5s.
    Falls back to the normal srun path automatically until ready.
    """

    RECONNECT_DELAY_MIN = 2.0
    RECONNECT_DELAY_MAX = 60.0
    RECONNECT_GIVEUP_AFTER = 12  # ~10 min of failures = job presumed dead
    STARTUP_TIMEOUT = 30.0

    def __init__(self, ssh_target: str, job_id: str) -> None:
        self.ssh_target = ssh_target
        self.job_id = job_id
        self.cache_key = streaming_connection_key(ssh_target, job_id)
        self._alive = True
        self._ready = False
        self._proc: subprocess.Popen | None = None
        self._last_heartbeat = 0.0
        self._last_error = ""
        self._consecutive_failures = 0
        self._given_up = False
        # _start() acquires the SSH target lock which may be held for many seconds
        # by probe or fetch_remote_lanes calls.  Calling it from __init__ would
        # block the caller (who often holds STREAMING_CONNECTIONS_LOCK) for the
        # same duration.  Defer to a background thread so the lock is released
        # immediately and _start() can wait as long as needed.
        threading.Thread(target=self._start, daemon=True,
                         name=f"csup-stream-init-{ssh_target}").start()

    def _build_cmd(self) -> list[str]:
        inner = (f"srun --jobid={shlex.quote(self.job_id)} --overlap "
                 f"python3 -u -c {shlex.quote(_STREAMER_SCRIPT)}")
        return ["ssh", *SSH_BASE_OPTS, *SSH_CONTROL_OPTS, ssh_command_target(self.ssh_target), inner]

    def _start(self) -> None:
        if not self._alive:
            return
        # Popen is near-instant — it just forks+execs; the SSH slave connects to
        # the ControlMaster asynchronously.  Holding the SSH target lock here
        # caused a deadlock-like starvation: STREAMING_CONNECTIONS_LOCK was held
        # by the caller, blocking all other callers while _start() waited up to
        # 30 s for the lock to free (fetch_remote_lanes calls chain on it).
        # Any "Session open refused" error from srun is caught by _read_loop and
        # triggers a reconnect, so we do not need to serialize Popen.
        try:
            if not self._alive:
                return
            self._proc = subprocess.Popen(
                self._build_cmd(),
                stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                text=True, bufsize=1,
            )
            if self._proc.stderr is not None:
                threading.Thread(target=self._stderr_loop,
                                 args=(self._proc.stderr,),
                                 daemon=True,
                                 name=f"csup-stream-err-{self.ssh_target}").start()
            threading.Thread(target=self._read_loop, daemon=True,
                             name=f"csup-stream-{self.ssh_target}").start()
        except Exception as e:
            print(f"csup-streamer start failed {self.ssh_target}/{self.job_id}: {e}",
                  file=sys.stderr)
            self._schedule_reconnect()

    def _stderr_loop(self, stream) -> None:
        try:
            for raw in stream:
                line = str(raw or "").strip()
                if not line:
                    continue
                self._last_error = line[:240]
        except Exception:
            pass

    def _read_loop(self) -> None:
        proc = self._proc
        if proc is None:
            return
        try:
            for raw in proc.stdout:  # type: ignore[union-attr]
                line = raw.strip()
                if not line:
                    continue
                if line == "CSUP_STREAMER_READY":
                    self._ready = True
                    self._consecutive_failures = 0  # reset backoff on success
                    continue
                try:
                    data = json.loads(line)
                except json.JSONDecodeError:
                    continue
                now = time.time()
                # Heartbeat: streamer is alive but nothing changed.
                if "hb" in data and "sessions" not in data:
                    self._last_heartbeat = cache_timestamp(data.get("hb"), now)
                    continue
                full = bool(data.get("full"))
                broadcast = False
                with STREAMING_CACHE_LOCK:
                    for sess in data.get("sessions", []) if isinstance(data.get("sessions", []), list) else []:
                        if not isinstance(sess, dict):
                            continue
                        sess_name = sess.get("session", "")
                        key = (self.cache_key, sess_name)
                        # Whole-session removal.
                        if sess.get("gone"):
                            STREAMING_CACHE.pop(key, None)
                            broadcast = True
                            continue
                        existing = STREAMING_CACHE.get(key) or {"panes": [], "ts": 0.0}
                        if full:
                            STREAMING_CACHE[key] = {
                                "panes": sess.get("panes", []) if isinstance(sess.get("panes", []), list) else [],
                                "monitor": sess.get("monitor") or {},
                                "ts": cache_timestamp(sess.get("ts"), now),
                            }
                            broadcast = True
                            continue
                        # Delta path: merge changed panes into existing list,
                        # keyed by pane index. Drop any indices in "drop".
                        cur = {
                            bounded_int(p.get("index"), -1, min_value=0): p
                            for p in existing.get("panes", [])
                            if isinstance(p, dict)
                        }
                        cur.pop(-1, None)
                        for p in sess.get("panes", []) if isinstance(sess.get("panes", []), list) else []:
                            if not isinstance(p, dict):
                                continue
                            idx = bounded_int(p.get("index"), -1, min_value=0)
                            if idx < 0:
                                continue
                            cur[idx] = p
                            broadcast = True
                        for idx in sess.get("drop", []) or []:
                            cur.pop(bounded_int(idx, -1, min_value=0), None)
                            broadcast = True
                        STREAMING_CACHE[key] = {
                            "panes": sorted(cur.values(), key=lambda x: bounded_int(x.get("index"), 0, min_value=0)),
                            "monitor": sess.get("monitor") or existing.get("monitor") or {},
                            "ts": cache_timestamp(sess.get("ts"), now),
                        }
                if broadcast:
                    _sse_broadcast_streaming_update()
        except Exception as e:
            print(f"csup-streamer read error {self.ssh_target}: {e}", file=sys.stderr)
        finally:
            try:
                proc.wait(timeout=1)
            except subprocess.TimeoutExpired:
                try:
                    proc.kill()
                except Exception:
                    pass
                try:
                    proc.wait(timeout=1)
                except Exception:
                    pass
            except Exception:
                pass
        if self._alive:
            self._ready = False
            self._schedule_reconnect()

    def _schedule_reconnect(self) -> None:
        self._consecutive_failures += 1
        if self._consecutive_failures >= self.RECONNECT_GIVEUP_AFTER:
            if not self._given_up:
                print(f"csup-streamer giving up {self.ssh_target}/{self.job_id} "
                      f"after {self._consecutive_failures} failures (job likely gone)",
                      file=sys.stderr)
                self._given_up = True
            self._alive = False
            return
        # Exponential backoff capped at RECONNECT_DELAY_MAX.
        delay = min(self.RECONNECT_DELAY_MIN * (2 ** (self._consecutive_failures - 1)),
                    self.RECONNECT_DELAY_MAX)
        detail = f"; last_error={self._last_error}" if self._last_error else ""
        print(f"csup-streamer reconnecting {self.ssh_target}/{self.job_id} in "
              f"{delay:.0f}s (attempt {self._consecutive_failures}){detail}", file=sys.stderr)
        threading.Timer(delay, self._start).start()

    def is_ready(self) -> bool:
        return self._ready

    def get_session(self, session: str) -> dict | None:
        with STREAMING_CACHE_LOCK:
            return STREAMING_CACHE.get((self.cache_key, session))

    def close(self) -> None:
        self._alive = False
        if self._proc:
            try:
                self._proc.terminate()
            except Exception:
                pass
            try:
                self._proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                try:
                    self._proc.kill()
                except Exception:
                    pass
                try:
                    self._proc.wait(timeout=2)
                except Exception:
                    pass
            except Exception:
                pass


MAX_STREAMING_CONNS_PER_TARGET = 8
TMUX_DISCOVERY_TIMEOUT_SECS = env_float("CSUP_DASHBOARD_TMUX_DISCOVERY_TIMEOUT_SECS", 12.0, min_value=0.1)


def _get_or_create_streaming_conn(ssh_target: str, job_id: str) -> "StreamingConnection | None":
    key = streaming_connection_key(ssh_target, job_id)
    with STREAMING_CONNECTIONS_LOCK:
        conn = STREAMING_CONNECTIONS.get(key)
        if conn is not None and getattr(conn, "_given_up", False):
            del STREAMING_CONNECTIONS[key]
            conn = None
        if conn is None:
            # Cap concurrent streaming connections per target to avoid saturating
            # the SSH ControlMaster's MaxSessions limit.
            target_key = ssh_command_target(ssh_target)
            active = sum(
                1 for k, c in STREAMING_CONNECTIONS.items()
                if k[0] == target_key
                and getattr(c, "_alive", True)
                and not getattr(c, "_given_up", False)
            )
            if active >= MAX_STREAMING_CONNS_PER_TARGET:
                return None
            try:
                conn = StreamingConnection(ssh_target, job_id)
                STREAMING_CONNECTIONS[key] = conn
            except Exception as e:
                print(f"csup-streamer init failed {ssh_target}/{job_id}: {e}", file=sys.stderr)
                return None
    return conn


_sse_last_broadcast: float = 0.0
_SSE_MIN_INTERVAL = 0.05   # max 20 pushes/second to browsers


def _sse_broadcast_streaming_update() -> None:
    """Push a compact 'ping' event to all SSE clients when the streaming cache updates.
    Clients receiving the ping immediately re-fetch /api/state.json for the full payload.
    Rate-limited to _SSE_MIN_INTERVAL so a fast streamer doesn't flood slow browsers.
    """
    global _sse_last_broadcast
    now = time.time()
    if now - _sse_last_broadcast < _SSE_MIN_INTERVAL:
        return
    _sse_last_broadcast = now
    msg = b"event: update\ndata: 1\n\n"
    dead: list = []
    with SSE_CLIENTS_LOCK:
        clients = list(SSE_CLIENTS)
    for wfile in clients:
        try:
            wfile.write(msg)
            wfile.flush()
        except Exception:
            dead.append(wfile)
    if dead:
        with SSE_CLIENTS_LOCK:
            for d in dead:
                try:
                    SSE_CLIENTS.remove(d)
                except ValueError:
                    pass


def list_projects() -> list[dict]:
    out = []
    by_root: dict[str, dict] = {}
    seen = set()
    candidates: list[pathlib.Path] = []
    for base in PROJECT_SEARCH_DIRS:
        if not base.exists():
            continue
        try:
            candidates.extend(base.iterdir())
        except OSError as e:
            print(f"project scan skipped: {base}: {e}", file=sys.stderr)
            continue
    candidates.extend(EXTRA_PROJECT_ROOTS)
    # macOS TCC can deny directory scans of ~/Desktop to dashboard processes
    # launched by tmux/nohup even when direct file access to known project
    # paths still works.  A small root registry outside Desktop lets the
    # dashboard recover the real backstage project list instead of displaying
    # zero projects after a restart.
    roots_text = read_text_bounded(PROJECT_ROOTS_FILE, max_bytes=1_000_000, label="project roots read")
    if roots_text is not None:
        for raw in roots_text.splitlines():
            raw = raw.strip()
            if not raw or raw.startswith("#"):
                continue
            candidates.append(pathlib.Path(raw).expanduser())
    for child in candidates:
        fallback = DIRECT_PROJECT_FALLBACKS.get(str(child), {})
        try:
            child_key = str(child.resolve())
        except OSError:
            child_key = str(child)
        try:
            cfg = child / ".codex-supervisor.toml"
            if not cfg.is_file():
                if not fallback:
                    continue
        except OSError as e:
            if not fallback:
                print(f"project config skipped: {child}: {e}", file=sys.stderr)
                continue
        try:
            cfg_key = str(cfg.resolve()) if cfg.is_file() else f"fallback:{child_key}"
        except OSError:
            cfg_key = str(cfg)
        if cfg_key in seen or child_key in seen:
            continue
        seen.add(cfg_key)
        seen.add(child_key)
        d = toml_read(cfg) or fallback
        name = d.get("project", {}).get("name", child.name)
        local_hosts = dict(d.get("hosts", {}) or {})
        # Cross-machine sync: if any host points at a remote SLURM workdir,
        # also fetch the project's .codex-supervisor.toml from there and merge
        # any hosts that the local copy is missing. This closes the divergence
        # gap where the CEO (running on a compute node) registers a new team
        # session in the remote toml but the local copy never sees it, so the
        # Mac dashboard hides the new session despite live panes existing.
        try:
            merged_remote = merge_remote_project_hosts(local_hosts)
        except Exception as e:
            print(f"remote toml merge skipped for {child}: {e}", file=sys.stderr)
            merged_remote = local_hosts
        out.append({
            "name": name,
            "path": str(child),
            "hosts": merged_remote,
            "instances": [],
        })
        by_root[str(child)] = out[-1]
        by_root[child_key] = out[-1]
    cache_text = read_text_bounded(PROJECT_CACHE_FILE, max_bytes=2_000_000, label="project cache read")
    try:
        cached_projects = json.loads(cache_text or "[]")
    except json.JSONDecodeError:
        cached_projects = []
    if isinstance(cached_projects, list):
        for rec in cached_projects:
            if not isinstance(rec, dict):
                continue
            path_raw = str(rec.get("path") or "")
            cfg = rec.get("config") if isinstance(rec.get("config"), dict) else {}
            if not path_raw or not cfg:
                continue
            root = pathlib.Path(path_raw)
            try:
                root_key = str(root.resolve())
            except OSError:
                root_key = str(root)
            if root_key in by_root or str(root) in by_root:
                continue
            name = cfg.get("project", {}).get("name") or root.name
            local_hosts = dict(cfg.get("hosts", {}) or {})
            try:
                merged_remote = merge_remote_project_hosts(local_hosts)
            except Exception as e:
                print(f"remote toml merge skipped for cached {root}: {e}", file=sys.stderr)
                merged_remote = local_hosts
            project = {
                "name": name,
                "path": str(root),
                "hosts": merged_remote,
                "instances": [],
            }
            by_root[root_key] = project
            by_root[str(root)] = project
            out.append(project)
    for inst in state_instances():
        root = pathlib.Path(inst["project_root"])
        try:
            key = str(root.resolve())
        except OSError:
            key = str(root)
        project = by_root.get(key)
        if project is None:
            project = {
                "name": project_name_for_root(root),
                "path": key,
                "hosts": {},
                "instances": [],
            }
            by_root[key] = project
            out.append(project)
        configured_sessions = {
            (host, (hcfg.get("session") or f"{project['name']}-{host}"))
            for host, hcfg in project.get("hosts", {}).items()
        }
        extra_sessions = {
            (extra.get("host"), extra.get("session"))
            for extra in project.get("instances", [])
        }
        key_tuple = (inst.get("host"), inst.get("session"))
        if key_tuple not in configured_sessions and key_tuple not in extra_sessions:
            project["instances"].append(inst)
    return out


def read_state_file(path: pathlib.Path) -> dict:
    vals: dict[str, str] = {}
    raw_text = read_text_bounded(path, max_bytes=1_000_000, label="state read")
    if raw_text is None:
        return vals
    for raw in raw_text.splitlines():
        if "=" in raw:
            k, v = raw.split("=", 1)
            vals[k] = v
    return vals


def session_from_state_path(path: pathlib.Path) -> str:
    name = path.name
    prefix = ".codex-supervisor-"
    suffix = ".state"
    if name.startswith(prefix) and name.endswith(suffix):
        return name[len(prefix):-len(suffix)]
    return path.stem


def project_name_for_root(root: pathlib.Path) -> str:
    d = toml_read(root / ".codex-supervisor.toml")
    return d.get("project", {}).get("name") or root.name


def prompt_path_for_project(root: pathlib.Path, raw: str) -> str:
    if not raw:
        return ""
    p = pathlib.Path(raw)
    if not p.is_absolute():
        return raw
    try:
        return str(p.relative_to(root))
    except ValueError:
        return str(p)


def state_instances() -> list[dict]:
    """Read local .codex-supervisor-*.state files.

    Skip stale state files whose PROJECT_ROOT no longer exists OR whose
    referenced tmux session is not currently running locally. Without this
    filter, an old state file pointing at a path that has since moved or a
    session that died long ago creates a "phantom" project in the dashboard
    with no panes — exactly the duplicate-tag bug observed in the wild.
    """
    hosts = known_hosts()
    me = this_host_name(hosts)
    local_host = me or socket.gethostname()
    instances: list[dict] = []
    # Cache local tmux session names so we don't run tmux ls per state file.
    # With per-session sockets we enumerate each socket and union their
    # session lists; legacy single-socket installs still resolve through the
    # default socket here.
    local_tmux_sessions: set[str] | None = None
    try:
        import glob as _glob
        sock_dir = f"{os.environ.get('TMUX_TMPDIR', '/tmp')}/tmux-{os.getuid()}"
        sockets: list[str] = []
        if os.path.isdir(sock_dir):
            for idx, p in enumerate(_glob.iglob(sock_dir + "/*")):
                if idx >= MAX_TMUX_SOCKET_SCAN:
                    break
                try:
                    import stat as _stat
                    if _stat.S_ISSOCK(os.stat(p).st_mode):
                        sockets.append(os.path.basename(p))
                except OSError:
                    continue
        if not sockets:
            sockets = ["default"]
        sessions: set[str] = set()
        for sock in sockets:
            cmd = ["tmux"] + (["-L", sock] if sock != "default" else []) + ["ls", "-F", "#{session_name}"]
            r = run_stable(cmd, timeout=2.0, retries=0)
            if r.returncode == 0:
                for line in (r.stdout or "").splitlines():
                    line = line.strip()
                    if line:
                        sessions.add(line)
        local_tmux_sessions = sessions
    except Exception:
        local_tmux_sessions = None
    for idx, state in enumerate(STATE_GLOB.parent.glob(STATE_GLOB.name)):
        if idx >= MAX_STATE_FILES:
            break
        vals = read_state_file(state)
        root_raw = vals.get("PROJECT_ROOT") or ""
        prompts_raw = vals.get("PROMPTS_FILE") or ""
        if not root_raw or not prompts_raw:
            continue
        root = pathlib.Path(root_raw)
        # Drop state files whose project root has vanished — those are leftover
        # from moved/deleted projects and only create phantom entries.
        try:
            if not root.exists():
                continue
        except OSError:
            continue
        session_name = session_from_state_path(state)
        # If we have a tmux session list and this session is not in it, the
        # state file is stale — the supervisor for it died or moved hosts.
        # Drop it so we don't surface a "no panes" phantom.
        if local_tmux_sessions is not None and session_name not in local_tmux_sessions:
            continue
        instances.append({
            "host": local_host,
            "session": session_name,
            "prompts": prompt_path_for_project(root, prompts_raw),
            "source": str(state),
            "project_root": str(root),
        })
    return instances


def project_instances(project: dict) -> list[dict]:
    instances: list[dict] = []
    name = project.get("name", "")
    for host, hcfg in project.get("hosts", {}).items():
        merged_hcfg = dict(hcfg or {})
        merged_hcfg.update({
            "host": host,
            "session": hcfg.get("session") or f"{name}-{host}",
            "prompts": hcfg.get("prompts", ""),
            "role": hcfg.get("role", ""),
            "source": "project-config",
        })
        instances.append(merged_hcfg)
    instances.extend(project.get("instances", []) or [])
    return instances


def _project_host_inventory_base(host: str, hcfg: dict, hosts: dict) -> dict:
    """Return the global inventory profile a project-local host should inherit.

    Project configs intentionally use descriptive host names such as
    ``civic-team-build-lunarc`` while the shared inventory carries the
    connection/scheduler facts under a reusable alias like ``lunarc``.  The
    dashboard must merge those two views before probing, otherwise cached
    project configs become "missing ssh target" cards after macOS TCC blocks
    directory scans and the dashboard falls back to the root/cache registry.
    """
    if host in hosts and isinstance(hosts.get(host), dict):
        return dict(hosts.get(host) or {})
    ssh_target = str((hcfg or {}).get("ssh", "") or "")
    if not ssh_target:
        return {}

    exact_matches: list[dict] = []
    slurm_matches: list[dict] = []
    for _name, info in hosts.items():
        if not isinstance(info, dict):
            continue
        if str(info.get("ssh", "") or "") != ssh_target:
            continue
        info_copy = dict(info)
        exact_matches.append(info_copy)
        if str(info.get("scheduler", "")).lower() == "slurm":
            slurm_matches.append(info_copy)
    if slurm_matches:
        return slurm_matches[0]
    if exact_matches:
        return exact_matches[0]
    return {}


def merge_project_hosts_into_inventory(hosts: dict, projects: list[dict]) -> dict:
    """Overlay project-local host entries onto the shared host inventory.

    ``project_instances()`` returns host names from each project's
    ``.codex-supervisor.toml``.  Those names are not guaranteed to exist in
    ``~/.config/csup/hosts.toml``; they often only provide a session/prompts
    overlay plus ``ssh = "lunarc"``.  Probe/capture code, however, looks up
    scheduler, remote_env, and SSH options by *that exact host name*.  Build a
    refresh-local inventory with inherited connection facts so project and
    backstage/session views stay aligned.
    """
    merged = {
        str(name): dict(info) if isinstance(info, dict) else info
        for name, info in (hosts or {}).items()
    }
    for project in projects:
        for host, raw_hcfg in (project.get("hosts", {}) or {}).items():
            if not isinstance(raw_hcfg, dict):
                continue
            host = str(host)
            if host in merged:
                # A project may intentionally reuse a global host name while
                # overriding session/prompts for that project.  Do not mutate
                # the shared inventory slot here; otherwise one project that
                # says [hosts."lunarc"] ssh="lunarc-babbloo" can poison every
                # other project using the canonical "lunarc" profile.  The
                # per-instance runner below applies project overrides in a
                # temporary one-host inventory.
                continue
            hcfg = dict(raw_hcfg)
            base = _project_host_inventory_base(host, hcfg, merged)
            # Project config owns session/prompt/task metadata; global
            # inventory owns connection/scheduler defaults.  Project values
            # intentionally override inherited defaults when both are present.
            merged[host] = {**base, **hcfg}
    return merged


def effective_hosts_for_instance(hosts: dict, host: str, hcfg: dict) -> dict:
    """Return a temporary host inventory for one project instance."""
    host = str(host)
    hcfg = dict(hcfg or {})
    base = _project_host_inventory_base(host, hcfg, hosts)
    merged_info = {**base, **hcfg}
    return {
        **hosts,
        host: merged_info,
    }


def discover_tmux_sessions(host: str, hosts: dict, me: str | None,
                           connection: dict | None = None) -> list[str]:
    runner = host_runner(host, hosts, me, timeout=TMUX_DISCOVERY_TIMEOUT_SECS, retries=0,
                         slurm_job_id=str((connection or {}).get("job_id", "")))
    if not runner:
        return []
    try:
        r = runner(["tmux", "ls", "-F", "#{session_name}"])
    except Exception:
        return []
    if r.returncode != 0:
        return []
    out: list[str] = []
    for raw in (r.stdout or "").splitlines():
        name = raw.strip()
        if name and re.fullmatch(r"[A-Za-z0-9_.\-]+", name):
            out.append(name)
    return out


def project_instance_lookup_key(project_instances_by_project: dict[str, list[dict]],
                                project: dict) -> str:
    identity = project_identity(project)
    if identity in project_instances_by_project:
        return identity
    # Backward-compatible path for tests/older callers that still pass a
    # name-keyed mapping.
    return str(project.get("name", ""))


def cached_streaming_sessions_for_base(ssh_target: str, job_id: str, base: str) -> list[str]:
    """Return live station sessions already seen by the persistent streamer.

    tmux discovery is best-effort and can be slow on busy SLURM allocations. If
    the streamer has already captured panes for a base/station session, prefer
    that in-memory fact over launching another short srun/tmux-ls probe.
    """
    if not ssh_target or not job_id or not base:
        return []
    stream_key = streaming_connection_key(ssh_target, job_id)
    sessions: list[str] = []
    with STREAMING_CACHE_LOCK:
        for key, sess in STREAMING_CACHE.keys():
            if key == stream_key and (sess == base or str(sess).startswith(f"{base}-station-")):
                sessions.append(str(sess))
    return sorted(set(sessions))


def station_candidate_sessions(base: str) -> list[str]:
    max_station_guess = env_int("CSUP_DASHBOARD_STATION_GUESS_MAX", 4, min_value=1)
    return [base] + [f"{base}-station-{idx}" for idx in range(1, max_station_guess + 1)]


def add_live_station_instances(project_instances_by_name: dict[str, list[dict]],
                               discovered_projects: list[dict],
                               hosts: dict,
                               me: str | None,
                               host_probe_cache: dict[str, dict]) -> None:
    """Add station-generated tmux sessions such as <base>-station-1.

    Project configs intentionally store stable base sessions, while `csup
    station/factory-run` launches numbered sessions to pack multiple batches
    into the same SLURM allocation. The dashboard must show the live tmux
    sessions, not stale base-session captures from earlier allocations.
    """
    tmux_cache: dict[tuple[str, str], list[str]] = {}
    allowed_raw = os.environ.get("CSUP_DASHBOARD_STATION_PROJECTS", "").strip()
    allowed_projects = {part.strip() for part in allowed_raw.split(",") if part.strip()}
    for proj in discovered_projects:
        project_name = proj.get("name", "")
        if allowed_projects and project_name not in allowed_projects:
            continue
        project_key = project_instance_lookup_key(project_instances_by_name, proj)
        existing = {
            (inst.get("host"), inst.get("session"))
            for inst in project_instances_by_name.get(project_key, [])
        }
        additions: list[dict] = []
        for hcfg in project_instances_by_name.get(project_key, []):
            if hcfg.get("source") != "project-config":
                continue
            host = str(hcfg.get("host", "") or "")
            if not host or not host_is_slurm(host, hosts):
                continue
            connection = host_probe_cache.get(host) or {}
            if not connection.get("reachable") or not connection.get("job_id"):
                continue
            info = hosts.get(host, {})
            base = str(hcfg.get("session") or f"{project_name}-{host}")
            ssh_target = str(info.get("ssh", ""))
            job_id = str(connection.get("job_id") or "")
            cached_sessions = cached_streaming_sessions_for_base(ssh_target, job_id, base)
            if cached_sessions:
                sessions_to_check = cached_sessions
            elif os.environ.get("CSUP_DASHBOARD_ASSUME_STATION_1", "").lower() in {"1", "true", "yes", "on"}:
                sessions_to_check = station_candidate_sessions(base)
            elif ssh_target and ssh_target_busy(ssh_target):
                # Do not let tmux discovery contend with active streamers/probes
                # on the shared SSH ControlMaster.  The cheap candidates below
                # are filtered later if no panes are captured.
                sessions_to_check = station_candidate_sessions(base)
            else:
                key = (ssh_target_lock_key(ssh_target), job_id)
                if key not in tmux_cache:
                    tmux_cache[key] = discover_tmux_sessions(host, hosts, me, connection)
                sessions_to_check = tmux_cache[key]
                if not sessions_to_check:
                    # Discovery itself is best-effort: on busy SLURM nodes a
                    # short tmux-ls srun can time out while the dashboard's
                    # persistent streamer/direct capture can still read a
                    # concrete session moments later.  Always include the
                    # configured base and the common station session as cheap
                    # candidates; build_instance hides candidates that capture
                    # no panes, so this restores live station visibility
                    # without showing stale configured sessions.
                    sessions_to_check = station_candidate_sessions(base)
            for session in sessions_to_check:
                if session != base and not session.startswith(f"{base}-station-"):
                    continue
                inst_key = (host, session)
                if inst_key in existing:
                    continue
                clone = dict(hcfg)
                clone["session"] = session
                clone["source"] = "live-station"
                additions.append(clone)
                existing.add(inst_key)
        project_instances_by_name.setdefault(project_key, []).extend(additions)


def parse_lanes_from_lines(raw_lines: list[str]) -> dict[int, str]:
    """Parse prompt lines: each /goal line maps a pane ordinal to a lane."""
    lanes: dict[int, str] = {}
    idx = 0
    for raw in raw_lines:
        s = raw.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("/goal"):
            # Match: "PANE <n>, lane <name>"
            m = re.search(r"PANE\s+(\d+),\s*lane\s+([A-Za-z0-9_-]+)", s)
            if m:
                pane_idx = bounded_int(m.group(1), idx, min_value=0, max_value=9999)
                lanes[pane_idx] = m.group(2)
            else:
                lanes[idx] = f"pane{idx}"
            idx += 1
    return lanes


def parse_lanes(prompts_path: pathlib.Path) -> dict[int, str]:
    """Parse a prompts file: each /goal line maps a pane ordinal to a lane."""
    raw_text = read_text_bounded(prompts_path, max_bytes=1_000_000, label="prompts read")
    if raw_text is None:
        return {}
    return parse_lanes_from_lines(raw_text.splitlines())


def fetch_remote_lanes(host: str, hosts: dict, me: str | None, prompts_path: str,
                       connection: dict | None = None) -> dict[int, str]:
    runner = host_runner(host, hosts, me, timeout=5, retries=0,
                         slurm_job_id=str((connection or {}).get("job_id", "")))
    if not runner:
        return {}
    script = """
import pathlib
import sys
p = pathlib.Path(sys.argv[1])
try:
    with p.open("rb") as f:
        data = f.read(100001)
    if len(data) > 100000:
        sys.exit(2)
    sys.stdout.write(data.decode("utf-8", "replace"))
except OSError:
    sys.exit(1)
"""
    try:
        r = runner(["python3", "-c", script, prompts_path])
        if r.returncode == 0:
            return parse_lanes_from_lines((r.stdout or "").splitlines())
    except Exception:
        return {}
    return {}


def start_remote_lanes_refresh(key: tuple, host: str, hosts: dict, me: str | None,
                               prompts_path: str, connection: dict | None = None) -> None:
    with PROMPT_LANE_CACHE_LOCK:
        if key in PROMPT_LANE_IN_FLIGHT:
            return
        PROMPT_LANE_IN_FLIGHT.add(key)

    def worker() -> None:
        lanes = fetch_remote_lanes(host, hosts, me, prompts_path, connection)
        with PROMPT_LANE_CACHE_LOCK:
            PROMPT_LANE_CACHE[key] = {"updated_at": time.time(), "value": dict(lanes)}
            PROMPT_LANE_IN_FLIGHT.discard(key)

    threading.Thread(target=worker, daemon=True).start()


def parse_remote_lanes_cached(host: str, hosts: dict, me: str | None, prompts_path: str,
                              connection: dict | None = None, *, async_ok: bool = False) -> dict[int, str]:
    """Fetch and parse an absolute remote prompts file without blocking pane refresh."""
    if not prompts_path:
        return {}
    now = time.time()
    key = (host, prompts_path, str((connection or {}).get("job_id", "")))
    with PROMPT_LANE_CACHE_LOCK:
        cached = PROMPT_LANE_CACHE.get(key)
        cached_value = dict((cached or {}).get("value") or {}) if cached else {}
        fresh = bool(cached) and cache_age(now, cached.get("updated_at")) < PROMPT_LANE_CACHE_SECS
    if fresh:
        return cached_value
    if async_ok:
        start_remote_lanes_refresh(key, host, hosts, me, prompts_path, connection)
        return cached_value
    lanes = fetch_remote_lanes(host, hosts, me, prompts_path, connection)
    with PROMPT_LANE_CACHE_LOCK:
        PROMPT_LANE_CACHE[key] = {"updated_at": now, "value": dict(lanes)}
    return lanes


