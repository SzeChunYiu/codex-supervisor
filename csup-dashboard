def refresh_remote_capture_cache(host: str, hosts: dict, me: str | None, session: str,
                                 lines: int, lane_map: dict[int, str] | None = None,
                                 connection: dict | None = None) -> None:
    cache_key = capture_cache_key(host, session, max(1, int(lines or DEFAULT_TAIL)), lane_map)
    try:
        capture_session(host, hosts, me, session, lines, lane_map, connection, _bypass_cache=True)
    except Exception as e:
        print(f"background capture skipped: {host}/{session}: {e}", file=sys.stderr)
    finally:
        with INSTANCE_CAPTURE_CACHE_LOCK:
            cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
            if cached:
                cached["refreshing"] = False



def pct(numer: float, denom: float) -> float | None:
    try:
        if denom <= 0:
            return None
        return round((numer / denom) * 100, 1)
    except Exception:
        return None


def collect_cpu_health() -> dict:
    cores = os.cpu_count() or 1
    try:
        load1, load5, load15 = os.getloadavg()
    except (AttributeError, OSError):
        load1 = load5 = load15 = 0.0
    return {
        "cores": cores,
        "load_1m": round(load1, 2),
        "load_5m": round(load5, 2),
        "load_15m": round(load15, 2),
        "load_percent": pct(load1, cores),
    }


def collect_memory_health() -> dict:
    # macOS path: total from sysctl, availability from vm_stat pages.
    try:
        total_r = run_stable(["sysctl", "-n", "hw.memsize"], timeout=2, retries=0)
        vm_r = run_stable(["vm_stat"], timeout=2, retries=0)
        if total_r.returncode == 0 and vm_r.returncode == 0:
            total = safe_int((total_r.stdout or "").strip())
            page_size = 4096
            m = re.search(r"page size of (\d+) bytes", vm_r.stdout or "")
            if m:
                page_size = safe_int(m.group(1)) or page_size
            pages: dict[str, int] = {}
            for line in (vm_r.stdout or "").splitlines():
                if ":" not in line:
                    continue
                key, raw = line.split(":", 1)
                pages[key.strip().lower()] = safe_int(raw.strip().strip("."))
            available_pages = (
                pages.get("pages free", 0) +
                pages.get("pages inactive", 0) +
                pages.get("pages speculative", 0)
            )
            free = max(0, min(total, available_pages * page_size)) if total else 0
            used = max(0, total - free) if total else 0
            return {
                "total_bytes": total,
                "used_bytes": used,
                "free_bytes": free,
                "used_percent": pct(used, total),
                "source": "vm_stat",
            }
    except Exception as e:
        print(f"memory health macOS path skipped: {e}", file=sys.stderr)

    # Linux fallback.
    try:
        meminfo = pathlib.Path("/proc/meminfo")
        if meminfo.exists():
            vals = {}
            for line in meminfo.read_text().splitlines():
                parts = line.split()
                if len(parts) >= 2:
                    vals[parts[0].rstrip(":")] = safe_int(parts[1]) * 1024
            total = vals.get("MemTotal", 0)
            free = vals.get("MemAvailable", vals.get("MemFree", 0))
            used = max(0, total - free) if total else 0
            return {
                "total_bytes": total,
                "used_bytes": used,
                "free_bytes": free,
                "used_percent": pct(used, total),
                "source": "proc_meminfo",
            }
    except Exception as e:
        print(f"memory health linux path skipped: {e}", file=sys.stderr)

    return {"total_bytes": 0, "used_bytes": 0, "free_bytes": 0, "used_percent": None, "source": "unavailable"}


def collect_disk_health(path: str | pathlib.Path | None = None) -> dict:
    path = str(pathlib.Path(path).expanduser()) if path else str(pathlib.Path.home())
    try:
        usage = shutil.disk_usage(path)
        filesystem = ""
        try:
            df = run_stable(["df", "-kP", path], timeout=2, retries=0)
            if df.returncode == 0:
                lines = (df.stdout or "").splitlines()
                if len(lines) >= 2:
                    filesystem = lines[1].split()[0]
        except Exception:
            filesystem = ""
        return {
            "path": path,
            "filesystem": filesystem,
            "total_bytes": usage.total,
            "used_bytes": usage.used,
            "free_bytes": usage.free,
            "used_percent": pct(usage.used, usage.total),
            "error": "",
        }
    except Exception as e:
        print(f"disk health skipped: {e}", file=sys.stderr)
        return {"path": path, "filesystem": "", "total_bytes": 0, "used_bytes": 0, "free_bytes": 0, "used_percent": None, "error": str(e)[:160]}


REMOTE_DISK_SCRIPT = r'''
import json, os, pathlib, shutil, subprocess, sys

def filesystem_for(path):
    try:
        r = subprocess.run(["df", "-kP", path], capture_output=True, text=True, timeout=2)
        if r.returncode == 0:
            lines = (r.stdout or "").splitlines()
            if len(lines) >= 2:
                return lines[1].split()[0]
    except Exception:
        return ""
    return ""

def emit(path, total=0, used=0, free=0, error="", filesystem=""):
    pct = round((used / total) * 100, 1) if total else None
    print(json.dumps({
        "path": path,
        "filesystem": filesystem,
        "total_bytes": int(total or 0),
        "used_bytes": int(used or 0),
        "free_bytes": int(free or 0),
        "used_percent": pct,
        "error": str(error or "")[:160],
    }))

candidates = [arg for arg in sys.argv[1:] if arg]
if not candidates:
    candidates = ["~"]
last_error = ""
for raw in candidates:
    path = os.path.expanduser(os.path.expandvars(raw))
    if not path:
        continue
    try:
        p = pathlib.Path(path)
        if not p.exists():
            last_error = f"{path} does not exist"
            continue
        usage = shutil.disk_usage(str(p))
        emit(str(p), usage.total, usage.used, usage.free, filesystem=filesystem_for(str(p)))
        raise SystemExit(0)
    except Exception as e:
        last_error = str(e)
emit(os.path.expanduser(os.path.expandvars(candidates[0] if candidates else "~")), error=last_error or "no usable disk path")
'''


def storage_paths_for_host(host: str, hosts: dict) -> list[str]:
    info = hosts.get(host, {})
    paths: list[str] = []
    configured = str(info.get("storage_path", "") or "").strip()
    if configured:
        paths.append(configured)
    if host_is_slurm(host, hosts):
        workdir = str(info.get("slurm_workdir", "") or "").strip()
        if workdir:
            paths.append(workdir)
        paths.extend(["$CODEX_SUPERVISOR_RUN_DIR", "$HOME"])
    else:
        paths.append("$HOME")
    out: list[str] = []
    seen = set()
    for path in paths:
        if path and path not in seen:
            seen.add(path)
            out.append(path)
    return out or ["$HOME"]


def collect_remote_disk_health(host: str, hosts: dict, me: str | None,
                               connection: dict | None = None) -> dict | None:
    runner = host_runner(
        host, hosts, me, timeout=REMOTE_DISK_TIMEOUT, retries=0,
        slurm_job_id=str((connection or {}).get("job_id") or ""),
    )
    if runner is None:
        return None
    cmd = ["python3", "-c", REMOTE_DISK_SCRIPT, *storage_paths_for_host(host, hosts)]
    try:
        r = runner(cmd)
    except subprocess.TimeoutExpired:
        return {
            "host": host, "aliases": [host], "role": "slurm" if host_is_slurm(host, hosts) else "ssh",
            "path": "", "total_bytes": 0, "used_bytes": 0, "free_bytes": 0,
            "used_percent": None, "reachable": False, "error": "disk probe timeout",
        }
    if r.returncode != 0:
        msg = (r.stderr or r.stdout or f"disk probe exited {r.returncode}").strip()
        return {
            "host": host, "aliases": [host], "role": "slurm" if host_is_slurm(host, hosts) else "ssh",
            "path": "", "total_bytes": 0, "used_bytes": 0, "free_bytes": 0,
            "used_percent": None, "reachable": False, "error": msg[:160],
        }
    try:
        disk = json.loads(r.stdout or "{}")
    except json.JSONDecodeError:
        return {
            "host": host, "aliases": [host], "role": "slurm" if host_is_slurm(host, hosts) else "ssh",
            "path": "", "total_bytes": 0, "used_bytes": 0, "free_bytes": 0,
            "used_percent": None, "reachable": False, "error": "disk probe returned invalid JSON",
        }
    disk.update({
        "host": host,
        "aliases": [host],
        "role": "slurm" if host_is_slurm(host, hosts) else "ssh",
        "reachable": not bool(disk.get("error")),
        "latency_ms": (connection or {}).get("latency_ms"),
        "job_id": (connection or {}).get("job_id", ""),
        "node": (connection or {}).get("node", ""),
    })
    return disk


def collect_storage_health(hosts: dict | None = None, me: str | None = None,
                           host_probe_cache: dict[str, dict] | None = None) -> dict:
    hosts = hosts or known_hosts()
    me = me or this_host_name(hosts)
    local_name = me or socket.gethostname()
    local_disk = collect_disk_health()
    local_device = {
        **local_disk,
        "host": local_name,
        "aliases": [local_name],
        "role": "local",
        "reachable": not bool(local_disk.get("error")),
        "latency_ms": 0,
    }
    devices: list[dict] = [local_device]
    seen_remote_keys: dict[tuple, dict] = {}

    for host, connection in sorted((host_probe_cache or {}).items()):
        if not host or host == me or not bool((connection or {}).get("reachable")):
            continue
        info = hosts.get(host, {})
        ssh_key = ssh_target_lock_key(str(info.get("ssh", "")))
        key = (
            ssh_key,
            str(info.get("scheduler", "")),
            str((connection or {}).get("job_id", "")),
            str((connection or {}).get("node", "")),
        )
        if key in seen_remote_keys:
            aliases = seen_remote_keys[key].setdefault("aliases", [])
            if host not in aliases:
                aliases.append(host)
            continue
        disk = collect_remote_disk_health(host, hosts, me, connection)
        if not disk:
            continue
        seen_remote_keys[key] = disk
        devices.append(disk)

    usable = [d for d in devices if d.get("reachable", True) and not d.get("error") and int(d.get("total_bytes") or 0) > 0]
    # Multiple connected sessions can point at the same mounted filesystem
    # (for example two LUNARC allocations under /projects). Keep every device
    # row visible, but do not double-count identical volume readings in the
    # headline aggregate.
    unique_volumes: dict[tuple, dict] = {}
    for d in usable:
        filesystem = str(d.get("filesystem") or "").strip()
        total_bytes = int(d.get("total_bytes") or 0)
        key = (filesystem, total_bytes) if filesystem else ("path", str(d.get("path") or ""), total_bytes)
        unique_volumes.setdefault(key, d)
    volume_values = list(unique_volumes.values())
    total = sum(int(d.get("total_bytes") or 0) for d in volume_values)
    free = sum(int(d.get("free_bytes") or 0) for d in volume_values)
    used = sum(int(d.get("used_bytes") or 0) for d in volume_values)
    return {
        "devices": devices,
        "connected_count": len(usable),
        "remote_count": max(0, len(usable) - 1),
        "volume_count": len(volume_values),
        "total_bytes": total,
        "used_bytes": used,
        "free_bytes": free,
        "used_percent": pct(used, total),
        "updated_at": time.time(),
    }


def compact_command(command: str, limit: int = 120) -> str:
    command = re.sub(r"\s+", " ", command or "").strip()
    if len(command) <= limit:
        return command
    return command[:max(0, limit - 1)] + "…"


def collect_process_health(limit: int | None = None) -> dict:
    limit = max(1, limit or PROCESS_TOP_LIMIT)
    try:
        r = run_stable(["ps", "-axo", "pid=,pcpu=,pmem=,rss=,command="], timeout=3, retries=0)
    except Exception as e:
        print(f"process health skipped: {e}", file=sys.stderr)
        return {"top_cpu_processes": [], "top_memory_processes": [], "error": str(e)[:160]}
    if r.returncode != 0:
        msg = (r.stderr or r.stdout or "").strip()
        return {"top_cpu_processes": [], "top_memory_processes": [], "error": msg[:160]}

    processes: list[dict] = []
    for raw in (r.stdout or "").splitlines():
        parts = raw.strip().split(None, 4)
        if len(parts) < 5:
            continue
        pid_raw, cpu_raw, mem_raw, rss_raw, command = parts
        pid = safe_int(pid_raw)
        if pid <= 0:
            continue
        cpu = safe_float(cpu_raw) or 0.0
        mem = safe_float(mem_raw) or 0.0
        rss_kb = safe_int(rss_raw)
        rss_bytes = max(0, rss_kb) * 1024
        proc = {
            "pid": pid,
            "cpu_percent": round(cpu, 1),
            "memory_percent": round(mem, 1),
            "rss_bytes": rss_bytes,
            "command": compact_command(command),
            "name": pathlib.Path((command.split() or [""])[0]).name if command else "",
        }
        processes.append(proc)

    return {
        "top_cpu_processes": sorted(
            processes, key=lambda p: (float(p.get("cpu_percent") or 0), int(p.get("rss_bytes") or 0)), reverse=True
        )[:limit],
        "top_memory_processes": sorted(
            processes, key=lambda p: (int(p.get("rss_bytes") or 0), float(p.get("cpu_percent") or 0)), reverse=True
        )[:limit],
        "error": "",
    }


def collect_system_health(hosts: dict | None = None, me: str | None = None,
                          host_probe_cache: dict[str, dict] | None = None) -> dict:
    cpu = collect_cpu_health()
    memory = collect_memory_health()
    storage = collect_storage_health(hosts, me, host_probe_cache)
    disk = (storage.get("devices") or [{}])[0] if isinstance(storage.get("devices"), list) else collect_disk_health()
    processes = collect_process_health()
    cpu_pct = cpu.get("load_percent")
    mem_pct = memory.get("used_percent")
    disk_pct = storage.get("used_percent", disk.get("used_percent"))
    warn = any(v is not None and v >= limit for v, limit in [
        (cpu_pct, 90), (mem_pct, 90), (disk_pct, 90),
    ])
    return {
        "status": "warn" if warn else "ok",
        "updated_at": time.time(),
        "cpu": cpu,
        "memory": memory,
        "disk": disk,
        "storage": storage,
        "top_cpu_processes": processes.get("top_cpu_processes", []),
        "top_memory_processes": processes.get("top_memory_processes", []),
        "process_error": processes.get("error", ""),
    }


def system_health_cache_key(hosts: dict | None = None, me: str | None = None,
                            host_probe_cache: dict[str, dict] | None = None) -> str:
    stable_probes = {
        host: {
            "reachable": bool((probe or {}).get("reachable")),
            "job_id": str((probe or {}).get("job_id", "")),
            "node": str((probe or {}).get("node", "")),
        }
        for host, probe in (host_probe_cache or {}).items()
    }
    try:
        key = json.dumps({
            "me": me or "",
            "hosts": hosts or {},
            "probes": stable_probes,
        }, sort_keys=True, default=str)
    except Exception:
        key = str((me, sorted((host_probe_cache or {}).keys())))
    return key


def collect_system_health_cached(hosts: dict | None = None, me: str | None = None,
                                 host_probe_cache: dict[str, dict] | None = None,
                                 now: float | None = None) -> dict:
    """Cache slow CPU/RAM/disk/process telemetry so pane captures stay live."""
    now = time.time() if now is None else now
    key = system_health_cache_key(hosts, me, host_probe_cache)
    with SYSTEM_HEALTH_CACHE_LOCK:
        cached = SYSTEM_HEALTH_CACHE.get("value")
        if (SYSTEM_HEALTH_CACHE_SECS > 0 and cached is not None and
                SYSTEM_HEALTH_CACHE.get("key") == key and
                now - float(SYSTEM_HEALTH_CACHE.get("updated_at") or 0) < SYSTEM_HEALTH_CACHE_SECS):
            return json.loads(json.dumps(cached))
    value = collect_system_health(hosts, me, host_probe_cache)
    with SYSTEM_HEALTH_CACHE_LOCK:
        SYSTEM_HEALTH_CACHE["key"] = key
        SYSTEM_HEALTH_CACHE["updated_at"] = now
        SYSTEM_HEALTH_CACHE["value"] = json.loads(json.dumps(value))
    return value


def collect_system_health_snapshot(hosts: dict | None = None, me: str | None = None,
                                   host_probe_cache: dict[str, dict] | None = None,
                                   now: float | None = None) -> dict:
    """Return cached system telemetry immediately and refresh it in background."""
    now = time.time() if now is None else now
    key = system_health_cache_key(hosts, me, host_probe_cache)
    with SYSTEM_HEALTH_CACHE_LOCK:
        cached = SYSTEM_HEALTH_CACHE.get("value")
        same_key = cached is not None and SYSTEM_HEALTH_CACHE.get("key") == key
        age = now - float(SYSTEM_HEALTH_CACHE.get("updated_at") or 0)
    if same_key:
        if SYSTEM_HEALTH_CACHE_SECS <= 0 or age >= SYSTEM_HEALTH_CACHE_SECS:
            start_async_metric_refresh(
                "system_health",
                lambda: collect_system_health_cached(hosts, me, host_probe_cache, time.time()),
            )
        return json.loads(json.dumps(cached))

    start_async_metric_refresh(
        "system_health",
        lambda: collect_system_health_cached(hosts, me, host_probe_cache, time.time()),
    )
    return {
        "status": "warming",
        "error": "",
        "refreshing": True,
        "cpu": {},
        "memory": {},
        "disk": {},
        "storage": {"devices": []},
        "top_cpu_processes": [],
        "top_memory_processes": [],
    }


def system_history_sample(health: dict, timestamp: float) -> dict:
    cpu = health.get("cpu") if isinstance(health.get("cpu"), dict) else {}
    memory = health.get("memory") if isinstance(health.get("memory"), dict) else {}
    storage = health.get("storage") if isinstance(health.get("storage"), dict) else {}
    return {
        "timestamp": timestamp,
        "cpu_load_percent": cpu.get("load_percent"),
        "cpu_load_1m": cpu.get("load_1m"),
        "memory_used_percent": memory.get("used_percent"),
        "memory_used_bytes": memory.get("used_bytes"),
        "memory_free_bytes": memory.get("free_bytes"),
        "storage_used_percent": storage.get("used_percent"),
        "storage_free_bytes": storage.get("free_bytes"),
    }


def refresh(lines: int):
    started_at = time.time()
    hosts = known_hosts()
    me = this_host_name(hosts)
    discovered_projects = list_projects()
    project_instances_by_name: dict[str, list[dict]] = {
        proj["name"]: project_instances(proj) for proj in discovered_projects
    }
    host_names = sorted({
        str(hcfg.get("host", ""))
        for instances in project_instances_by_name.values()
        for hcfg in instances
        if hcfg.get("host", "")
    })
    host_probe_cache: dict[str, dict] = {}
    if host_names:
        with cf.ThreadPoolExecutor(max_workers=min(8, len(host_names))) as ex:
            futures = {
                ex.submit(cached_probe_host, host, hosts, me, started_at): host
                for host in host_names
            }
            for fut in cf.as_completed(futures):
                host = futures[fut]
                try:
                    host_probe_cache[host] = fut.result()
                except Exception as e:
                    host_probe_cache[host] = {"reachable": False, "latency_ms": None, "error": str(e)[:160]}

    def build_instance(proj: dict, hcfg: dict) -> tuple[str, dict | None]:
        host = hcfg.get("host", "")
        session = hcfg.get("session") or f"{proj['name']}-{host}"
        prompts_rel = hcfg.get("prompts", "")
        role = str(hcfg.get("role", "") or "")
        monitor_expected = role.lower() not in MONITORLESS_ROLES
        if not prompts_rel and hcfg.get("source") == "project-config" and not INCLUDE_PROMPTLESS_INSTANCES:
            return proj["name"], None
        prompts_path = pathlib.Path(prompts_rel)
        if prompts_rel and not prompts_path.is_absolute():
            prompts_path = pathlib.Path(proj["path"]) / prompts_rel
        lane_map = parse_lanes(prompts_path) if prompts_rel else {}
        connection = host_probe_cache.get(host) or {"reachable": False, "latency_ms": None, "error": "host not probed"}
        reachable = bool(connection["reachable"])
        if prompts_rel and not lane_map and reachable and prompts_path.is_absolute() and host != me:
            lane_map = parse_remote_lanes_cached(host, hosts, me, str(prompts_path), connection, async_ok=True)
        instance = {
            "host": host, "session": session, "prompts": prompts_rel,
            "role": role,
            "monitor_expected": monitor_expected,
            "reachable": reachable, "connection": connection,
            "panes": [], "error": "",
            "monitor": empty_monitor_status(),
        }
        if reachable:
            try:
                panes = capture_session(host, hosts, me, session, lines, lane_map, connection)
                if panes is None:
                    instance["error"] = "session not running"
                    if host != me:
                        problem = capture_cache_problem(host, session, lines, lane_map)
                        if problem.get("error"):
                            instance["error"] = problem["error"]
                            instance["capture_problem"] = problem
                else:
                    instance["panes"] = panes
                    if monitor_expected:
                        instance["monitor"] = get_monitor_status(host, session)
            except subprocess.TimeoutExpired:
                instance["error"] = "timeout"
            except Exception as e:
                instance["error"] = str(e)[:120]
        else:
            instance["error"] = "host unreachable"
            if host != me:
                probe_deferred = bool(connection.get("probe_stale") and connection.get("probe_deferred"))
                if probe_deferred:
                    cached_panes = capture_cached_panes(host, session, lines, lane_map)
                else:
                    cached_panes = capture_cached_panes_with_error(
                        host,
                        session,
                        lines,
                        lane_map,
                        connection.get("error") or "host unreachable",
                    )
                if cached_panes:
                    instance["panes"] = cached_panes
                    if probe_deferred:
                        # A fresh pane stream/cache is stronger evidence than
                        # a stale deferred probe failure. Keep the probe flags
                        # visible for diagnostics, but do not mark the live
                        # pane card or health as unreachable/capture-stale.
                        instance["error"] = ""
                        instance["reachable"] = True
                    if monitor_expected:
                        instance["monitor"] = get_monitor_status(host, session)
        if monitor_expected and instance["panes"] and not instance.get("monitor", {}).get("known"):
            instance["monitor"] = get_monitor_status(host, session)
        # Hide stale supervisor targets that produced no tmux panes.
        # The dashboard is for live captured panes; configured/state-file
        # sessions that are not running just create noisy "No panes captured"
        # cards.
        if instance["panes"]:
            return proj["name"], instance
        return proj["name"], None

    built_instances: dict[str, list[dict]] = {proj["name"]: [] for proj in discovered_projects}
    jobs: list[tuple[dict, dict]] = [
        (proj, hcfg)
        for proj in discovered_projects
        for hcfg in project_instances_by_name.get(proj["name"], [])
    ]
    if jobs:
        ex = cf.ThreadPoolExecutor(max_workers=min(12, len(jobs)))
        futures = {ex.submit(build_instance, proj, hcfg): proj["name"] for proj, hcfg in jobs}
        try:
            for fut in cf.as_completed(futures, timeout=max(0.05, REFRESH_INSTANCE_TIMEOUT_SECS)):
                try:
                    project_name, instance = fut.result()
                except Exception:
                    continue
                if instance:
                    built_instances.setdefault(project_name, []).append(instance)
        except cf.TimeoutError:
            # Never let a slow remote capture/probe freeze the whole dashboard.
            # Unfinished jobs keep running in their worker threads; they update
            # the per-instance caches when they complete, and the next refresh
            # can pick up stale/partial data instead of letting CACHE go stale.
            pass
        finally:
            for fut in futures:
                if not fut.done():
                    fut.cancel()
            ex.shutdown(wait=False, cancel_futures=True)

    out_projects = []
    for proj in discovered_projects:
        instances = built_instances.get(proj["name"], [])
        if instances:
            instances.sort(key=lambda inst: (str(inst.get("host", "")), str(inst.get("session", ""))))
            out_projects.append({"name": proj["name"], "path": proj["path"], "instances": instances})
    finished_at = time.time()
    try:
        token_usage = collect_token_usage_snapshot(now=finished_at)
    except Exception as e:
        token_usage = empty_token_usage(error=str(e)[:160])
    try:
        tool_call_usage = collect_tool_call_usage_snapshot(now=finished_at)
    except Exception as e:
        tool_call_usage = empty_tool_call_usage(error=str(e)[:160])
    try:
        system_health = collect_system_health_snapshot(hosts, me, host_probe_cache, finished_at)
    except Exception as e:
        system_health = {"status": "unknown", "error": str(e)[:160], "cpu": {}, "memory": {}, "disk": {}, "storage": {"devices": []}}
    with CACHE_LOCK:
        history = list(CACHE.get("system_history") or [])
        history.append(system_history_sample(system_health, finished_at))
        if SYSTEM_HISTORY_MAX_POINTS > 0:
            history = history[-SYSTEM_HISTORY_MAX_POINTS:]
        CACHE["refresh_started_at"] = started_at
        CACHE["updated_at"] = finished_at
        CACHE["last_refresh_duration_ms"] = round((finished_at - started_at) * 1000)
        CACHE["last_refresh_error"] = ""
        CACHE["refresh_count"] = int(CACHE.get("refresh_count") or 0) + 1
        CACHE["projects"] = out_projects
        CACHE["token_usage"] = token_usage
        CACHE["tool_call_usage"] = tool_call_usage
        CACHE["system_health"] = system_health
        CACHE["system_history"] = history


def refresh_loop(refresh_secs: int, lines: int):
    while True:
        started = time.time()
        try:
            refresh_once(lines)
        except Exception as e:
            with CACHE_LOCK:
                CACHE["last_refresh_error"] = str(e)[:200]
            print(f"refresh error: {e}", file=sys.stderr)
        elapsed = time.time() - started
        sleep_for = max(0.05, refresh_secs - elapsed)
        time.sleep(sleep_for)


def refresh_once(lines: int | None = None):
    with REFRESH_LOCK:
        refresh(REFRESH_LINES if lines is None else lines)



def empty_token_usage(session_files_scanned: int = 0, error: str = "") -> dict:
    return {
        "session_files_scanned": session_files_scanned,
        "sessions_with_usage": 0,
        "latest_event_at": "",
        "latest_plan_type": "",
        "latest_primary_used_percent": None,
        "latest_secondary_used_percent": None,
        "error": error,
        "total_token_usage": {key: 0 for key in TOKEN_USAGE_KEYS},
        "recent_token_events": [],
    }


def safe_int(value: object) -> int:
    try:
        if value is None or value == "":
            return 0
        return int(value)
    except (TypeError, ValueError):
        return 0


def safe_float(value: object):
    try:
        if value is None or value == "":
            return None
        return float(value)
    except (TypeError, ValueError):
        return None


def normalize_token_usage(raw: object) -> dict:
    raw = raw if isinstance(raw, dict) else {}
    return {key: safe_int(raw.get(key)) for key in TOKEN_USAGE_KEYS}


def codex_session_dirs() -> list[pathlib.Path]:
    dirs: list[pathlib.Path] = []
    seen: set[str] = set()

    def add(path: pathlib.Path):
        try:
            resolved = str(path.expanduser())
        except Exception:
            resolved = str(path)
        if resolved in seen or not path.exists():
            return
        seen.add(resolved)
        dirs.append(path)

    add(CODEX_SESSIONS_DIR)
    # Tests and explicit one-off dashboard invocations can pin a single
    # transcript root with CSUP_DASHBOARD_CODEX_SESSIONS_DIR. In the normal
    # default mode, include supervisor worker CODEX_HOME transcript roots too;
    # otherwise pane-generated tool calls would be invisible.
    if CODEX_SESSIONS_DIR != DEFAULT_CODEX_SESSIONS_DIR:
        return dirs

    for raw in EXTRA_CODEX_SESSIONS_DIRS.split(os.pathsep):
        if raw.strip():
            add(pathlib.Path(raw.strip()).expanduser())
    for root in SUPERVISOR_CODEX_HOME_ROOTS:
        if not root.exists():
            continue
        try:
            candidates = sorted(root.glob("*/sessions"))
        except OSError:
            continue
        for path in candidates:
            add(path)
    return dirs


def recent_codex_session_files(now: float) -> list[pathlib.Path]:
    cutoff = now - (max(0, TOKEN_SCAN_MTIME_DAYS) * 86400)
    files: list[tuple[float, pathlib.Path]] = []
    for session_dir in codex_session_dirs():
        try:
            iterator = session_dir.rglob("*.jsonl")
            for path in iterator:
                try:
                    st = path.stat()
                except OSError:
                    continue
                if TOKEN_SCAN_MTIME_DAYS > 0 and st.st_mtime < cutoff:
                    continue
                files.append((st.st_mtime, path))
        except OSError as e:
            print(f"token scan skipped: {session_dir}: {e}", file=sys.stderr)
            continue
    files.sort(key=lambda item: item[0], reverse=True)
    return [path for _, path in files[:max(0, TOKEN_SCAN_MAX_FILES)]]


def read_tail_lines(path: pathlib.Path, max_bytes: int) -> list[str]:
    try:
        size = path.stat().st_size
        with path.open("rb") as f:
            if max_bytes > 0 and size > max_bytes:
                f.seek(-max_bytes, 2)
                data = f.read(max_bytes)
                # Drop the first fragment when we start in the middle of a JSONL
                # record. Token-count events are frequent enough that the tail is
                # still enough for dashboard telemetry.
                if b"\n" in data:
                    data = data.split(b"\n", 1)[1]
            else:
                data = f.read()
    except OSError as e:
        print(f"token usage read skipped: {path}: {e}", file=sys.stderr)
        return []
    return data.decode("utf-8", "replace").splitlines()


def parse_token_count_record(obj: object, path: pathlib.Path) -> dict | None:
    payload = obj.get("payload") if isinstance(obj, dict) else None
    if not isinstance(payload, dict) or payload.get("type") != "token_count":
        return None
    info = payload.get("info") if isinstance(payload.get("info"), dict) else {}
    rate_limits = payload.get("rate_limits") if isinstance(payload.get("rate_limits"), dict) else {}
    primary = rate_limits.get("primary") if isinstance(rate_limits.get("primary"), dict) else {}
    secondary = rate_limits.get("secondary") if isinstance(rate_limits.get("secondary"), dict) else {}
    return {
        "path": str(path),
        "timestamp": obj.get("timestamp") or "",
        "total_token_usage": normalize_token_usage(info.get("total_token_usage")),
        "last_token_usage": normalize_token_usage(info.get("last_token_usage")),
        "model_context_window": safe_int(info.get("model_context_window")),
        "plan_type": rate_limits.get("plan_type") or "",
        "primary_used_percent": safe_float(primary.get("used_percent")),
        "secondary_used_percent": safe_float(secondary.get("used_percent")),
    }


def token_count_events_for_file(path: pathlib.Path, max_events: int | None = None) -> list[dict]:
    events: list[dict] = []
    for raw in reversed(read_tail_lines(path, TOKEN_SCAN_MAX_BYTES)):
        if "token_count" not in raw:
            continue
        try:
            obj = json.loads(raw)
        except json.JSONDecodeError:
            continue
        record = parse_token_count_record(obj, path)
        if not record:
            continue
        events.append(record)
        if max_events is not None and len(events) >= max_events:
            break
    return events


def latest_token_count_for_file(path: pathlib.Path) -> dict | None:
    events = token_count_events_for_file(path, 1)
    return events[0] if events else None


def token_usage_cache_key() -> tuple:
    return (tuple(str(path) for path in codex_session_dirs()), TOKEN_SCAN_MAX_FILES,
            TOKEN_SCAN_MTIME_DAYS, TOKEN_SCAN_MAX_BYTES)


def collect_token_usage(now: float | None = None, *, force: bool = False) -> dict:
    """Aggregate the latest Codex token_count event from recent session files.

    Each JSONL file can contain many token_count events. Counting every event
    would inflate totals on every turn, so the dashboard sums only the latest
    event per session file and exposes the latest observed rate-limit snapshot.
    """
    now = time.time() if now is None else now
    cache_key = token_usage_cache_key()
    with TOKEN_USAGE_CACHE_LOCK:
        cached = TOKEN_USAGE_CACHE.get("value")
        if (not force and cached is not None and TOKEN_USAGE_CACHE.get("key") == cache_key and
                now - float(TOKEN_USAGE_CACHE.get("updated_at") or 0) < TOKEN_SCAN_CACHE_SECS):
            return json.loads(json.dumps(cached))

    files = recent_codex_session_files(now)
    usage = empty_token_usage(session_files_scanned=len(files))
    latest_record: dict | None = None
    recent_events: list[dict] = []
    per_file_history = max(1, TOKEN_HISTORY_EVENTS_PER_FILE)
    for path in files:
        events = token_count_events_for_file(path, per_file_history)
        if not events:
            continue
        record = events[0]
        usage["sessions_with_usage"] += 1
        for key in TOKEN_USAGE_KEYS:
            usage["total_token_usage"][key] += safe_int(record["total_token_usage"].get(key))
        if latest_record is None or str(record.get("timestamp") or "") > str(latest_record.get("timestamp") or ""):
            latest_record = record
        for event in events:
            last = event.get("last_token_usage") or {}
            total = safe_int(last.get("total_tokens"))
            if total <= 0:
                total = safe_int((event.get("total_token_usage") or {}).get("total_tokens"))
            recent_events.append({
                "timestamp": event.get("timestamp") or "",
                "total_tokens": total,
                "input_tokens": safe_int(last.get("input_tokens")),
                "cached_input_tokens": safe_int(last.get("cached_input_tokens")),
                "output_tokens": safe_int(last.get("output_tokens")),
                "reasoning_output_tokens": safe_int(last.get("reasoning_output_tokens")),
                "session": pathlib.Path(event.get("path") or "").name,
            })

    recent_events.sort(key=lambda item: str(item.get("timestamp") or ""))
    usage["recent_token_events"] = recent_events[-max(0, TOKEN_HISTORY_MAX_EVENTS):]

    if latest_record:
        usage["latest_event_at"] = latest_record.get("timestamp") or ""
        usage["latest_plan_type"] = latest_record.get("plan_type") or ""
        usage["latest_primary_used_percent"] = latest_record.get("primary_used_percent")
        usage["latest_secondary_used_percent"] = latest_record.get("secondary_used_percent")
        usage["latest_model_context_window"] = latest_record.get("model_context_window")

    with TOKEN_USAGE_CACHE_LOCK:
        TOKEN_USAGE_CACHE["key"] = cache_key
        TOKEN_USAGE_CACHE["updated_at"] = now
        TOKEN_USAGE_CACHE["value"] = json.loads(json.dumps(usage))
    return usage


def collect_token_usage_snapshot(now: float | None = None) -> dict:
    """Return cached token telemetry immediately and refresh it in background."""
    now = time.time() if now is None else now
    with TOKEN_USAGE_CACHE_LOCK:
        cached = TOKEN_USAGE_CACHE.get("value")
        age = now - float(TOKEN_USAGE_CACHE.get("updated_at") or 0)
        cached_key = TOKEN_USAGE_CACHE.get("key")
    if cached is None:
        start_async_metric_refresh("token_usage", lambda: collect_token_usage(now=time.time(), force=True))
        usage = empty_token_usage()
        usage["refreshing"] = True
        return usage

    cache_key = token_usage_cache_key()
    same_key = cached_key == cache_key
    if same_key:
        if age >= TOKEN_SCAN_CACHE_SECS:
            start_async_metric_refresh("token_usage", lambda: collect_token_usage(now=time.time(), force=True))
        return json.loads(json.dumps(cached))

    start_async_metric_refresh("token_usage", lambda: collect_token_usage(now=time.time(), force=True))
    usage = empty_token_usage()
    usage["refreshing"] = True
    return usage


def empty_tool_call_usage(session_files_scanned: int = 0, error: str = "") -> dict:
    return {
        "session_files_scanned": session_files_scanned,
        "sessions_with_tool_calls": 0,
        "total_tool_calls": 0,
        "tool_counts": {},
        "latest_event_at": "",
        "latest_tool": "",
        "streaming_arg_delta_events": 0,
        "recent_tool_call_events": [],
        "error": error,
    }


def parse_tool_call_record(obj: object, path: pathlib.Path) -> tuple[str, dict] | None:
    if not isinstance(obj, dict):
        return None
    payload = obj.get("payload") if isinstance(obj.get("payload"), dict) else {}
    event_type = str(obj.get("type") or "")
    payload_type = str(payload.get("type") or "")
    type_candidates = {event_type, payload_type}
    timestamp = str(obj.get("timestamp") or payload.get("timestamp") or "")

    if "response.function_call_arguments.delta" in type_candidates:
        return "delta", {"path": str(path), "timestamp": timestamp}

    if event_type == "response_item" and payload_type in {"function_call", "custom_tool_call"}:
        tool = str(
            payload.get("name")
            or payload.get("tool_name")
            or payload.get("call_type")
            or payload_type
        )
        return "call", {
            "path": str(path),
            "timestamp": timestamp,
            "tool": tool,
            "call_id": str(payload.get("call_id") or payload.get("id") or ""),
        }
    return None


def tool_call_events_for_file(path: pathlib.Path, max_events: int | None = None) -> tuple[list[dict], int]:
    events: list[dict] = []
    delta_count = 0
    seen: set[str] = set()
    for raw in reversed(read_tail_lines(path, TOKEN_SCAN_MAX_BYTES)):
        if "function_call" not in raw and "tool_call" not in raw:
            continue
        try:
            obj = json.loads(raw)
        except json.JSONDecodeError:
            continue
        parsed = parse_tool_call_record(obj, path)
        if not parsed:
            continue
        kind, record = parsed
        if kind == "delta":
            delta_count += 1
            continue
        if max_events is not None and len(events) >= max_events:
            continue
        key = record.get("call_id") or f"{record.get('timestamp')}:{record.get('tool')}:{len(events)}"
        if key in seen:
            continue
        seen.add(key)
        events.append(record)
    return events, delta_count


def tool_call_usage_cache_key() -> tuple:
    return (tuple(str(path) for path in codex_session_dirs()), TOKEN_SCAN_MAX_FILES, TOKEN_SCAN_MTIME_DAYS,
            TOKEN_SCAN_MAX_BYTES, TOOL_HISTORY_MAX_EVENTS, TOOL_HISTORY_EVENTS_PER_FILE)


def collect_tool_call_usage(now: float | None = None, *, force: bool = False) -> dict:
    """Aggregate Codex function_call response items from recent session files."""
    now = time.time() if now is None else now
    cache_key = tool_call_usage_cache_key()
    with TOOL_CALL_USAGE_CACHE_LOCK:
        cached = TOOL_CALL_USAGE_CACHE.get("value")
        if (not force and cached is not None and TOOL_CALL_USAGE_CACHE.get("key") == cache_key and
                now - float(TOOL_CALL_USAGE_CACHE.get("updated_at") or 0) < TOKEN_SCAN_CACHE_SECS):
            return json.loads(json.dumps(cached))

    files = recent_codex_session_files(now)
    usage = empty_tool_call_usage(session_files_scanned=len(files))
    recent_events: list[dict] = []
    per_file_history = max(1, TOOL_HISTORY_EVENTS_PER_FILE)
    latest_record: dict | None = None
    for path in files:
        events, delta_count = tool_call_events_for_file(path, per_file_history)
        usage["streaming_arg_delta_events"] += delta_count
        if not events:
            continue
        usage["sessions_with_tool_calls"] += 1
        usage["total_tool_calls"] += len(events)
        for event in events:
            tool = event.get("tool") or "unknown"
            usage["tool_counts"][tool] = int(usage["tool_counts"].get(tool, 0)) + 1
            recent_events.append({
                "timestamp": event.get("timestamp") or "",
                "tool": tool,
                "session": pathlib.Path(event.get("path") or "").name,
                "call_id": event.get("call_id") or "",
            })
            if latest_record is None or str(event.get("timestamp") or "") > str(latest_record.get("timestamp") or ""):
                latest_record = event

    recent_events.sort(key=lambda item: str(item.get("timestamp") or ""))
    usage["recent_tool_call_events"] = recent_events[-max(0, TOOL_HISTORY_MAX_EVENTS):]
    if latest_record:
        usage["latest_event_at"] = latest_record.get("timestamp") or ""
        usage["latest_tool"] = latest_record.get("tool") or ""

    with TOOL_CALL_USAGE_CACHE_LOCK:
        TOOL_CALL_USAGE_CACHE["key"] = cache_key
        TOOL_CALL_USAGE_CACHE["updated_at"] = now
        TOOL_CALL_USAGE_CACHE["value"] = json.loads(json.dumps(usage))
    return usage


def collect_tool_call_usage_snapshot(now: float | None = None) -> dict:
    """Return cached tool-call telemetry immediately and refresh it in background."""
    now = time.time() if now is None else now
    with TOOL_CALL_USAGE_CACHE_LOCK:
        cached = TOOL_CALL_USAGE_CACHE.get("value")
        age = now - float(TOOL_CALL_USAGE_CACHE.get("updated_at") or 0)
        cached_key = TOOL_CALL_USAGE_CACHE.get("key")
    if cached is None:
        start_async_metric_refresh("tool_call_usage", lambda: collect_tool_call_usage(now=time.time(), force=True))
        usage = empty_tool_call_usage()
        usage["refreshing"] = True
        return usage

    cache_key = tool_call_usage_cache_key()
    same_key = cached_key == cache_key
    if same_key:
        if age >= TOKEN_SCAN_CACHE_SECS:
            start_async_metric_refresh("tool_call_usage", lambda: collect_tool_call_usage(now=time.time(), force=True))
        return json.loads(json.dumps(cached))

    start_async_metric_refresh("tool_call_usage", lambda: collect_tool_call_usage(now=time.time(), force=True))
    usage = empty_tool_call_usage()
    usage["refreshing"] = True
    return usage


def health_payload() -> dict:
    with CACHE_LOCK:
        snapshot = json.loads(json.dumps(CACHE))
    now = time.time()
    age_secs = now - float(snapshot.get("updated_at") or 0)
    try:
        interval = max(0.05, float(snapshot.get("refresh_interval_secs") or DEFAULT_REFRESH))
    except (TypeError, ValueError):
        interval = DEFAULT_REFRESH
    stale_after = max(30, interval * 4)
    instance_errors = []
    unreachable_hosts = set()
    state_counts: dict[str, int] = {}
    pane_issues: list[dict] = []
    panes = 0
    instances = 0
    for project in snapshot.get("projects", []):
        for inst in project.get("instances", []):
            instances += 1
            panes += len(inst.get("panes", []) or [])
            monitor = inst.get("monitor") if isinstance(inst.get("monitor"), dict) else {}
            monitor_expected = bool(inst.get("monitor_expected", True))
            monitor_running = (not monitor_expected) or bool(monitor.get("running"))
            for pane in inst.get("panes", []) or []:
                pane_state = str(pane.get("state") or "?")
                state_counts[pane_state] = int(state_counts.get(pane_state, 0)) + 1
                reasons: list[str] = []
                if monitor_expected and (
                    pane_state in {"idle", "ready", "?", "dead"}
                    or (pane_state == "goal-done" and not monitor_running)
                ):
                    reasons.append(f"pane-{pane_state}")
                if pane_state == "rate-limited" and not monitor_running:
                    reasons.append("rate-limited")
                if pane.get("capture_stale"):
                    reasons.append("capture-stale")
                if reasons and len(pane_issues) < 80:
                    last_tail = ""
                    for line in reversed(pane.get("tail") or []):
                        if str(line).strip():
                            last_tail = str(line).strip()
                            break
                    pane_issues.append({
                        "project": project.get("name"),
                        "host": inst.get("host"),
                        "session": inst.get("session"),
                        "index": pane.get("index"),
                        "state": pane_state,
                        "lane": pane.get("lane", ""),
                        "reasons": reasons,
                        "capture_age_secs": pane.get("capture_age_secs"),
                        "capture_error": pane.get("capture_error", ""),
                        "last": last_tail[:160],
                    })
            if inst.get("error"):
                instance_errors.append({
                    "project": project.get("name"),
                    "host": inst.get("host"),
                    "session": inst.get("session"),
                    "error": inst.get("error"),
                })
            if monitor_expected and monitor.get("known") and not monitor.get("running"):
                instance_errors.append({
                    "project": project.get("name"),
                    "host": inst.get("host"),
                    "session": inst.get("session"),
                    "error": monitor.get("error") or "supervisor monitor daemon missing",
                    "kind": "monitor",
                })
            if not inst.get("reachable", False):
                unreachable_hosts.add(inst.get("host", ""))
    stale = not snapshot.get("updated_at") or age_secs > stale_after
    ok = (not stale and not snapshot.get("last_refresh_error") and
          not instance_errors and not pane_issues and panes > 0)
    status = "ok" if ok else "degraded"
    return {
        "status": status,
        "ok": ok,
        "now": now,
        "updated_at": snapshot.get("updated_at", 0),
        "age_secs": round(age_secs, 3) if snapshot.get("updated_at") else None,
        "stale_after_secs": stale_after,
        "refresh_count": snapshot.get("refresh_count", 0),
        "last_refresh_duration_ms": snapshot.get("last_refresh_duration_ms", 0),
        "last_refresh_error": snapshot.get("last_refresh_error", ""),
        "refresh_interval_secs": snapshot.get("refresh_interval_secs", DEFAULT_REFRESH),
        "projects": len(snapshot.get("projects", [])),
        "instances": instances,
        "panes": panes,
        "state_counts": dict(sorted(state_counts.items())),
        "pane_issue_count": len(pane_issues),
        "pane_issues": pane_issues,
        "instance_errors": instance_errors,
        "unreachable_hosts": sorted(h for h in unreachable_hosts if h),
        "source": SOURCE_INFO,
        "metrics_refreshing": async_metric_names(),
    }


