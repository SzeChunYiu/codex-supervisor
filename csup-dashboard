  mixCard.appendChild(renderToolMixBars(events));
  mixCard.appendChild(readingRow([
    { label: 'Sessions', value: formatNumber(toolUsage.sessions_with_tool_calls || 0), note: formatNumber(toolUsage.session_files_scanned || 0) + ' files scanned' },
    { label: 'Top tool', value: stats.topTool || 'n/a', note: stats.topCount ? formatNumber(stats.topCount) + ' calls' : 'n/a' },
  ]));
  wrap.appendChild(mixCard);
  return wrap;
}

function systemHistory(state) {
  return (((state || {}).system_history || [])).filter(sample => sample);
}

function renderHealthHistoryBars(samples, key, clsName, formatter) {
  if (!samples.length) {
    const empty = el('div', { cls: 'chart-frame' });
    empty.appendChild(el('div', { cls: 'empty', text: 'No system history captured yet.' }));
    return empty;
  }
  const values = samples.map(sample => Number(sample[key])).filter(value => Number.isFinite(value));
  const peak = Math.max(1, ...values);
  const frame = renderChartGrid(Math.max(100, peak), formatter || formatPercent);
  const box = frame.chartBox;
  for (const sample of samples) {
    const value = Number(sample[key]);
    const safe = Number.isFinite(value) ? value : 0;
    const bar = el('span', { cls: 'health-bar ' + clsName, title: (formatter || formatPercent)(safe) + ' · ' + formatTime(sample.timestamp ? sample.timestamp * 1000 : '') });
    bar.style.height = Math.max(4, (safe / Math.max(100, peak)) * 100) + '%';
    box.appendChild(bar);
  }
  return frame;
}

function renderProcessList(processes, mode) {
