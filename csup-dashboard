        # variable spacing; collapse runs of whitespace before matching.
        m = re.search(r"(gpt-[\d.]+\s+[a-z]+(?:\s+[a-z]+)?)",
                      re.sub(r"\s+", " ", full_text.lower()))
        idx_val = bounded_int(item.get("index"), 0, min_value=0)
        return {
            "index": idx_val,
            "dead": bool(item.get("dead")),
            "state": state,
            "model": m.group(1) if m else "",
            "lane": lane_label_for_capture(item, lane_map),
            "width": bounded_int(item.get("width"), 0, min_value=0),
            "height": bounded_int(item.get("height"), 0, min_value=0),
