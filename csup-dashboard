def render_captured_item_simple(item: dict, tail_lines: int = DEFAULT_TAIL,
                                lane_map: dict[int, str] | None = None) -> dict:
    """Standalone version of the render_captured_item closure inside capture_session."""
    tail_lines = bounded_int(tail_lines, DEFAULT_TAIL, min_value=1, max_value=200)
    ansi_text = item.get("ansi", "")
    ansi_lines = ansi_text.splitlines()
    tail_ansi = ansi_lines[-tail_lines:] if ansi_lines else []
    full_text = strip_ansi(ansi_text)
    tail_text = strip_ansi("\n".join(tail_ansi))
    tail = tail_text.splitlines()
    joined = re.sub(r"\s+", " ", full_text.lower())
    pane_title = item.get("title") or ""
    if item.get("dead"):
        state = "dead"
    elif "you've hit your usage limit" in joined:
        state = "rate-limited"
    elif "goal achieved" in joined:
        state = "goal-done"
    elif "pursuing goal" in joined or "working" in joined:
        state = "working"
    elif "listening for jobs" in joined or "running job:" in joined:
        state = "working"
    elif pane_title_indicates_activity(pane_title):
        state = "working"
    elif joined.strip():
        state = "idle"
    else:
        state = "idle"
    m = re.search(r"(gpt-[\d.]+\s+[a-z]+(?:\s+[a-z]+)?)", re.sub(r"\s+", " ", full_text.lower()))
    idx_val = bounded_int(item.get("index"), 0, min_value=0)
    return {
        "index": idx_val,
        "dead": bool(item.get("dead")),
        "state": state,
        "model": m.group(1) if m else "",
        "lane": lane_label_for_capture(item, lane_map),
        "width": bounded_int(item.get("width"), 0, min_value=0),
        "height": bounded_int(item.get("height"), 0, min_value=0),
        "tail": tail,
        "tail_html": ansi_to_html("\n".join(tail_ansi)),
        "tail_line_count": len(tail),
    }


def capture_session(host: str, hosts: dict, me: str | None, session: str,
                    lines: int, lane_map: dict[int, str] | None = None,
                    connection: dict | None = None,
                    _bypass_cache: bool = False) -> list[dict] | None:
    runner = host_runner(host, hosts, me, timeout=SSH_TIMEOUT, retries=1,
                         slurm_job_id=str((connection or {}).get("job_id") or ""))
    if runner is None:
        return None
    tail_lines = bounded_int(lines, DEFAULT_TAIL, min_value=1, max_value=200)
    cache_key = capture_cache_key(host, session, tail_lines, lane_map)

    # ── Streaming fast path ──────────────────────────────────────────────────
    # For SLURM hosts, try the persistent streaming connection first.  The
    # streamer runs inside the allocation and emits JSON every ~0.5s, so we
    # just read from the in-memory cache — no srun step per refresh.  While the
    # streamer is warming, do not fall through to per-session fallback captures:
    # those slow sruns hold the same LUNARC ControlMaster lock and can starve
    # streamer startup, creating a self-sustaining timeout storm.
    if CSUP_STREAMING and host != me and host_is_slurm(host, hosts):
        conn_info = connection or {}
        job_id = str(conn_info.get("job_id") or "")
        info = hosts.get(host, {})
        ssh_target = info.get("ssh", "")
        if ssh_target and job_id:
            stream = _get_or_create_streaming_conn(ssh_target, job_id)
            if stream and stream.is_ready():
                cached = stream.get_session(session)
                if cached:
                    set_monitor_status(host, session, cached.get("monitor") or empty_monitor_status())
                    panes = [
                        render_captured_item_simple(item, tail_lines=tail_lines, lane_map=lane_map)
                        for item in cached["panes"]
                    ]
                    if REMOTE_CAPTURE_CACHE_SECS > 0:
                        cache_key_s = capture_cache_key(host, session, tail_lines, lane_map)
                        cached_ts = cache_timestamp(cached.get("ts"), time.time())
                        with INSTANCE_CAPTURE_CACHE_LOCK:
                            INSTANCE_CAPTURE_CACHE[cache_key_s] = {
                                "updated_at": cached_ts,
                                "last_attempt_at": cached_ts,
                                "last_error": "",
                                "value": clone_jsonable(panes),
                                "monitor": cached.get("monitor") or {},
                                "refreshing": False,
                            }
                    return panes
                if REMOTE_CAPTURE_CACHE_SECS > 0:
                    with INSTANCE_CAPTURE_CACHE_LOCK:
                        INSTANCE_CAPTURE_CACHE.pop(cache_key, None)
                return None
            stream_error = str(getattr(stream, "_last_error", "") or "").lower() if stream else ""
            stream_open_failed = (
                "permission denied" in stream_error or
                "session open refused" in stream_error or
                "mux_client_request_session" in stream_error
            )
            if REMOTE_CAPTURE_CACHE_SECS > 0:
                with INSTANCE_CAPTURE_CACHE_LOCK:
                    cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
                    if cached:
                        return capture_cache_value_with_status(cached, time.time())
            if not stream_open_failed:
                return None
            # The persistent streamer is best-effort.  If SSH refuses another
            # streaming session, fall through to the bounded one-shot capture
            # path below so live panes are not hidden indefinitely.
    # ── End streaming fast path ──────────────────────────────────────────────
    if host != me and REMOTE_CAPTURE_CACHE_SECS > 0 and not _bypass_cache:
        now = time.time()
        with INSTANCE_CAPTURE_CACHE_LOCK:
            cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
            if cached:
                value = capture_cache_value_with_status(cached, now)
                if cache_age(now, cached.get("updated_at")) < REMOTE_CAPTURE_CACHE_SECS:
                    return value
                retry_secs = REMOTE_CAPTURE_CACHE_SECS
                if cached.get("last_error"):
                    last_attempt = cache_timestamp(cached.get("last_attempt_at") or cached.get("updated_at"))
                    retry_secs = max(REMOTE_CAPTURE_CACHE_SECS, REMOTE_CAPTURE_ERROR_RETRY_SECS)
                else:
                    last_attempt = cache_timestamp(cached.get("updated_at"))
                if not cached.get("refreshing") and now - last_attempt >= retry_secs:
                    cached["refreshing"] = True
                    cached["last_attempt_at"] = now
                    threading.Thread(
                        target=refresh_remote_capture_cache,
                        args=(host, hosts, me, session, lines, lane_map, connection),
                        daemon=True,
                    ).start()
                return value
            if REMOTE_INITIAL_CAPTURE_ASYNC:
                INSTANCE_CAPTURE_CACHE[cache_key] = {
                    "updated_at": now,
                    "last_attempt_at": now,
                    "last_error": "",
                    "value": None,
                    "refreshing": True,
                }
                threading.Thread(
                    target=refresh_remote_capture_cache,
                    args=(host, hosts, me, session, lines, lane_map, connection),
                    daemon=True,
                ).start()
                return None

    def render_captured_item(item):
        ansi_text = item.get("ansi", "")
        ansi_lines = ansi_text.splitlines()
        tail_ansi = ansi_lines[-tail_lines:] if ansi_lines else []
        full_text = strip_ansi(ansi_text)
        tail_text = strip_ansi("\n".join(tail_ansi))
        tail = tail_text.splitlines()
