}
.office-person.office-agent.submitting-route {
  animation: worker-submit-route 6.2s steps(31, end) 1 both;
  animation-delay: 0s;
}
.office-person.office-agent .pixel-avatar.sprite-avatar {
  position: relative;
  z-index: 4;
  width: 32px;
  height: 64px;
  margin: 10px 0 0 8px;
  transform: scaleX(var(--face-x, 1));
  transform-origin: 50% 70%;
  animation: sprite-walk-down .42s steps(3, end) infinite;
  animation-delay: var(--walk-delay, 0s);
  image-rendering: pixelated;
}
.office-person.office-agent.face-up .pixel-avatar.sprite-avatar {
  background-position: 0 -64px;
  animation-name: sprite-walk-up;
}
.office-person.office-agent.face-right .pixel-avatar.sprite-avatar,
.office-person.office-agent.face-left .pixel-avatar.sprite-avatar {
  animation-name: sprite-walk-right;
}
.office-person.office-agent.at-seat .pixel-avatar.sprite-avatar,
.office-person.office-agent.dead .pixel-avatar.sprite-avatar {
