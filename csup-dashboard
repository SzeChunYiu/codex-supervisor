function officeEmote(person) {
  const state = person.state || '';
  if (state === 'dead') return '💀';
  if (state === 'rate-limited') return '⏳';
  if (state === 'goal-done') return '✅';
  if (state === 'working') {
    if (person.role === 'gm') return '♛';
    if (person.role === 'manager') return '📋';
    if (person.role === 'planner') return '🗺';
    return '⌨';
  }
  if (person.role === 'gm') return '♛';
  if (person.role === 'manager') return '☰';
  if (person.role === 'planner') return '◇';
  return '…';
}

function officeThought(person, handoffActive) {
  const state = person.state || 'idle';
  const seed = officeHash((person.key || person.name || '') + state);
  if (state === 'dead') return 'offline — reconnecting';
  if (state === 'rate-limited') return 'waiting for API quota…';
  if (state === 'goal-done') {
    if (person.role === 'worker') return handoffActive ? 'submitting to section manager…' : 'submitted · seated';
    if (person.role === 'manager') return 'review done ✓';
    if (person.role === 'planner') return 'plan ready ✓';
    return 'goal reached ✓';
  }
  if (person.role === 'gm') {
    const t = ['steering direction', 'reviewing strategy', 'scanning progress', 'prioritizing work', 'aligning team'];
    return t[seed % t.length];
  }
  if (person.role === 'manager') {
    const t = ['reviewing output', 'unblocking team', 'routing next task', 'quality check', 'clearing blockers'];
    return t[seed % t.length];
  }
  if (person.role === 'planner') {
    const t = ['drafting next steps', 'writing plan cells', 'mapping dependencies', 'outlining approach', 'scheduling tasks'];
    return t[seed % t.length];
  }
  if (state === 'working') {
    const t = ['running tests…', 'writing code…', 'debugging issue…', 'building feature…', 'editing files…', 'reading context…', 'applying changes…'];
    return t[seed % t.length];
  }
  return 'standing by';
}

function officeAgentGridPosition(index, role, zoneKind) {
  if (zoneKind === 'team') {
    const col = index % 8;
    const row = Math.floor(index / 8);
    const face = row % 2 ? 'face-up' : 'face-down';
    return {
      x: 5 + col * 4,
      y: 3 + row * 5,
      handoffX: 2,
      handoffY: 6 + row * 5,
      face,
      seat: (role === 'manager' || role === 'planner') ? 'team-manager-seat shima-seat section-team-seat' : 'team-long-desk-chair shima-seat section-team-seat',
    };
  }
  if (zoneKind === 'executive') return { x: 4 + (index % 2) * 4, y: 6, handoffX: 8, handoffY: 7, seat: 'executive-desk' };
  if (zoneKind === 'ops') {
    const managerSeats = [{ x: 8, y: 5 }, { x: 12, y: 5 }, { x: 16, y: 5 }, { x: 10, y: 9 }, { x: 14, y: 9 }];
    const plannerSeats = [{ x: 3, y: 7 }, { x: 6, y: 7 }, { x: 3, y: 10 }, { x: 6, y: 10 }];
    const seats = role === 'planner' ? plannerSeats : managerSeats;
    const seat = seats[index % seats.length];
    return { x: seat.x, y: seat.y, handoffX: 9, handoffY: 7, seat: role === 'planner' ? 'planning-bank' : 'manager-review-desk' };
  }
  const longDeskSeats = [
    { x: 5, y: 3, face: 'face-down' }, { x: 9, y: 3, face: 'face-down' }, { x: 13, y: 3, face: 'face-down' }, { x: 17, y: 3, face: 'face-down' }, { x: 21, y: 3, face: 'face-down' },
    { x: 5, y: 8, face: 'face-up' }, { x: 9, y: 8, face: 'face-up' }, { x: 13, y: 8, face: 'face-up' }, { x: 17, y: 8, face: 'face-up' }, { x: 21, y: 8, face: 'face-up' },
  ];
  const seat = longDeskSeats[index % longDeskSeats.length];
  return { x: seat.x, y: seat.y, handoffX: 1, handoffY: 7, face: seat.face, seat: 'team-long-desk-chair shima-seat section-team-seat' };
}

function companyPersonCard(person, index, zoneKind) {
  const state = person.state || 'idle';
  const submitting = officeShouldRunHandoff(person);
  const moving = submitting || (person.role !== 'worker' && state === 'rate-limited');
  const seed = officeHash(person.name + person.meta + person.role);
  const pos = officeAgentGridPosition(index, person.role, zoneKind);
  const direction = submitting ? 'face-left' : (person.role === 'worker' ? (pos.face || 'face-down') : ((seed % 3) === 0 ? 'face-down' : ((seed % 2) ? 'face-right' : 'face-left')));
  const seated = !moving && (person.role === 'worker' || person.role === 'planner' || person.role === 'manager');
  const card = el('article', { cls: 'office-person office-agent ' + direction + ' ' + person.role + ' ' + state + ' ' + pos.seat + (seated ? ' seated-at-desk' : '') + (moving ? ' moving submitting-route to-section-manager' : ' at-seat') + (submitting ? ' talking' : ''), title: (person.title || person.name) + (submitting ? ' · submitting to section manager' : (person.role === 'worker' && state === 'goal-done' ? ' · submitted · seated' : '')) });
  card.style.setProperty('--agent-x', pos.x);
  card.style.setProperty('--agent-y', pos.y);
  card.style.setProperty('--agent-submit-x', pos.handoffX);
  card.style.setProperty('--agent-submit-y', pos.handoffY);
  // Moving (handoff) characters keep exact grid-based walk distances; idle characters get varied paths
  if (moving) {
    card.style.setProperty('--walk-x', ((pos.handoffX - pos.x) * 16) + 'px');
    card.style.setProperty('--walk-y', ((pos.handoffY - pos.y) * 16) + 'px');
  } else {
    const wx = (6 + ((seed * 7 + index * 3) % 140) / 10).toFixed(1);
    const wy = (3 + ((seed * 3 + index * 5) % 60) / 10).toFixed(1);
    card.style.setProperty('--walk-x', wx + 'px');
    card.style.setProperty('--walk-y', wy + 'px');
  }
  card.style.setProperty('--face-x', direction === 'face-left' ? '-1' : '1');
  card.style.setProperty('--walk-delay', '-' + ((seed % 7000) / 1000).toFixed(2) + 's');
  card.style.setProperty('--sprite-url', 'url("' + AGENT_OFFICE_CHARACTER_SPRITES[seed % AGENT_OFFICE_CHARACTER_SPRITES.length] + '")');
  card.dataset.emote = officeEmote(person);
  // Build rich thought bubble content
  let thoughtText;
  if (state === 'working' && person.activity) {
    const act = String(person.activity);
    thoughtText = act.length > 18 ? act.slice(0, 18) + '…' : act;
  } else if (state === 'idle' || state === 'ready') {
    const idleEmotes = ['💤', '☕', '🤔'];
    thoughtText = idleEmotes[seed % idleEmotes.length];
  } else if (state === 'goal-done') {
    const doneEmotes = ['✅', '🎉'];
    thoughtText = doneEmotes[seed % doneEmotes.length];
  } else {
    thoughtText = officeThought(person, submitting);
  }
  card.dataset.thought = thoughtText;
  card.dataset.seat = pos.seat;
  card.appendChild(el('span', { cls: 'status-light ' + (person.state || 'idle'), title: person.state || 'idle' }));
  card.appendChild(el('div', { cls: 'agent-thought', text: officeThought(person, submitting) }));
  const chatLines = ['nice', 'agreed', 'on it', 'makes sense', 'got it', 'exactly', 'one sec', 'done ✓', 'hm…', 'lgtm', 'check this', 'hmm good point', 'yep', 'almost'];
  card.appendChild(el('div', { cls: 'agent-chat', text: chatLines[seed % chatLines.length] }));
  card.appendChild(el('div', { cls: 'pixel-avatar sprite-avatar', title: companyRoleLabel(person.role) + ' — agent-office sprite' }));
  const label = el('div', { cls: 'agent-nameplate' });
  label.appendChild(el('span', { cls: 'person-name', text: person.name }));
  label.appendChild(el('span', { cls: 'person-role', text: companyRoleLabel(person.role) }));
  card.appendChild(label);
  card.appendChild(el('div', { cls: 'person-meta', text: person.meta, title: person.meta }));
  // Portrait desk surface (visible only inside .project-office-panel via CSS)
  const deskSurface = el('div', { cls: 'office-desk-surface' });
  const deskItems = person.role === 'gm' ? ['🖥', '📋', '☕'] :
                    person.role === 'manager' ? ['🖥', '📋'] :
                    ['🖥', '⌨'];
  deskItems.forEach(item => {
    const span = document.createElement('span');
    span.textContent = item;
    deskSurface.appendChild(span);
  });
  card.appendChild(deskSurface);
  return card;
}

function companyOfficeModel(project) {
  const people = { gm: [], manager: [], planner: [], worker: [] };
  for (const inst of capturedInstances(project)) {
    for (const pane of inst.panes || []) {
      const lane = pane.lane || ('pane' + pane.index);
      const role = companyRoleForLane(lane, inst.session, inst.host);
      people[role].push({
        role,
        key: [project.name, inst.host, inst.session, pane.index, lane].join('|'),
        name: lane,
        state: pane.dead ? 'dead' : (pane.state || 'idle'),
        meta: inst.host + ' · pane #' + pane.index + (pane.model ? ' · ' + pane.model : ''),
        title: project.name + ' · ' + inst.session + ' · ' + lane,
      });
    }
  }
  return people;
}

function paneOfficePerson(project, inst, pane, originalOrder) {
  const lane = pane.lane || ('pane' + pane.index);
  const role = companyRoleForLane(lane, inst.session, inst.host);
  return {
    role,
    pane,
    originalOrder,
    key: [project.name, inst.host, inst.session, pane.index, lane].join('|'),
    name: lane,
    state: pane.dead ? 'dead' : (pane.state || 'idle'),
    meta: inst.host + ' · pane #' + pane.index + (pane.model ? ' · ' + pane.model : ''),
    title: project.name + ' · ' + inst.session + ' · ' + lane,
  };
}

function teamSortedOfficeModel(project) {
  const teams = [];
  for (const inst of capturedInstances(project)) {
    const people = (inst.panes || []).map((pane, originalOrder) => paneOfficePerson(project, inst, pane, originalOrder));
    if (!people.length) continue;
    teams.push({
      key: instanceKey(project, inst),
      label: 'Team ' + inst.host + ' · ' + inst.session,
      people,
      detail: people.length + ' panes · same order as TUI panes below · same order as terminal cards below',
    });
