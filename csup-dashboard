/* AgentOffice v2: 16px-grid top-down pixel coworking map. React renders HUD/DOM overlays;
   the office world stays as explicit pixel primitives and sprite containers. */
.company-office {
  --cell: 16px;
  --floor-a: #24283d;
  --floor-b: #30314b;
  --wall: #121426;
  --desk: #765438;
  --desk-hi: #9a6d45;
  --outline: rgba(3,4,9,.72);
  background:
    linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px) 0 0 / 32px 32px,
    radial-gradient(circle at 8% 4%, rgba(153,102,255,.12), transparent 20rem),
    radial-gradient(circle at 90% 10%, rgba(74,222,255,.09), transparent 22rem),
    linear-gradient(180deg, #111326, #090b15 82%);
}
.office-grid {
  grid-template-columns: minmax(304px, .78fr) minmax(384px, .95fr) minmax(600px, 1.55fr);
  gap: 0;
  min-height: 368px;
  image-rendering: pixelated;
}
.office-grid.team-sorted-office {
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 680px), 1fr));
}
.office-grid.team-sorted-office .office-zone {
