function recentTokenEvents(state) {
  return (((state || {}).token_usage || {}).recent_token_events || [])
    .filter(e => e && Number(e.total_tokens || 0) > 0);
}

function tokenEventStats(events) {
  const values = events.map(e => Number(e.total_tokens || 0)).filter(n => Number.isFinite(n) && n > 0);
  const sum = values.reduce((a, b) => a + b, 0);
  const peak = values.length ? Math.max(...values) : 0;
  const min = values.length ? Math.min(...values) : 0;
  const avg = values.length ? sum / values.length : 0;
  const latest = values.length ? values[values.length - 1] : 0;
  return { values, sum, peak, min, avg, latest };
}

function tokenUsageTotals(state) {
  return (((state || {}).token_usage || {}).total_token_usage || {});
}

function ratio(numer, denom) {
  const n = Number(numer || 0);
  const d = Number(denom || 0);
  return d > 0 ? n / d : 0;
}

