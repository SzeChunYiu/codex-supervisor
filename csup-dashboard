}
/* Sprite avatar: fully visible inside project-office-panel (undo seated-at-desk clip) */
.project-office-panel .pixel-avatar.sprite-avatar {
  position: relative !important;
  width: 32px !important;
  height: 64px !important;  /* full frame height — character fully visible */
  margin: 4px 0 0 0 !important;
  clip-path: none !important;
  transform: scaleX(var(--face-x, 1)) !important;
  transform-origin: 50% 50% !important;
  animation: sprite-idle-breathe 3.8s ease-in-out infinite !important;
  animation-delay: var(--walk-delay, 0s) !important;
  image-rendering: pixelated;
  background-position: 0 0 !important;
  z-index: 4;
}
/* Working agents: rhythmic desk-lean card + faster typing sprite */
.project-office-panel .office-person.working {
  animation:
    desk-lean 0.42s ease-in-out infinite,
    office-idle 2s steps(2, end) infinite !important;
  animation-delay: var(--walk-delay, 0s), var(--walk-delay, 0s) !important;
}
.project-office-panel .office-person.working .pixel-avatar.sprite-avatar {
  animation: office-typing 0.55s ease-in-out infinite !important;
  animation-delay: var(--walk-delay, 0s) !important;
}
/* Idle / ready: occasional look-around */
.project-office-panel .office-person.idle .pixel-avatar.sprite-avatar,
.project-office-panel .office-person.ready .pixel-avatar.sprite-avatar {
