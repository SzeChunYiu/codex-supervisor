  overflow: hidden;
}
.office-decor {
  z-index: 1;
  pointer-events: none;
}
.office-people {
  z-index: 3;
  display: block;
  top: 34px;
  min-height: 320px;
}
.office-prop {
  position: absolute;
  left: calc(var(--x) * var(--cell));
  top: calc(var(--y) * var(--cell));
  width: calc(var(--w) * var(--cell));
  height: calc(var(--h) * var(--cell));
  box-sizing: border-box;
  border: 2px solid var(--outline);
  border-radius: 2px;
  color: rgba(255,255,255,.72);
