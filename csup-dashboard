      if (companyRoleForLane(lane, inst.session, inst.host) === 'gm') {
        gms.push({ inst, pane, lane });
      }
    }
  }
  return gms;
}

function projectGmState(project) {
  const gms = projectGmPanes(project);
  if (!gms.length) return 'dead';
  if (gms.some(({ pane }) => pane.state === 'working' || pane.state === 'rate-limited')) return 'working';
  if (gms.every(({ pane }) => pane.state === 'goal-done')) return 'goal-done';
