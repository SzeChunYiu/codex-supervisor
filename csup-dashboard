}

function updateMonitorElement(node, inst) {
  if (!node) return;
  const monitor = inst.monitor || {};
  if (!monitor.known) {
    node.hidden = true;
    setText(node, '');
    node.title = '';
    return;
  }
  const text = monitor.running
    ? 'monitor pid ' + (monitor.pids || []).join(',')
    : 'monitor missing';
  node.className = 'conn ' + (monitor.running ? 'conn-ok' : 'conn-bad');
  node.title = monitor.error || text;
  node.hidden = false;
  setText(node, text);
}

function updateInstanceErrorElement(node, inst) {
  if (!node) return;
  if (!inst.error) {
    node.hidden = true;
    setText(node, '');
    return;
