    panes_meta = []
    for line in r.stdout.strip().splitlines():
        parts = line.split("|")
        if len(parts) >= 3:
            idx = bounded_int(parts[0], -1, min_value=0)
            if idx < 0:
                continue
            panes_meta.append({
                "index": idx,
                "ordinal": len(panes_meta),
                "dead": parts[1] == "1",
                "cmd": parts[2],
                "width": bounded_int(parts[3], 0, min_value=0) if len(parts) > 3 else 0,
                "height": bounded_int(parts[4], 0, min_value=0) if len(parts) > 4 else 0,
                "title": parts[5] if len(parts) > 5 else "",
            })

    def grab(p):
        cap_lines = max(tail_lines, STATE_CAPTURE_MIN_LINES)
        c = runner(["tmux", "capture-pane", "-e", "-t", f"{session}:.{p['index']}",
                    "-p", "-S", f"-{cap_lines}"])
        item = dict(p)
        item["ansi"] = c.stdout if c.returncode == 0 else ""
        return render_captured_item(item)

    if not panes_meta:
        set_monitor_status(host, session, capture_monitor_status_with_runner(runner, session))
        return []
    with cf.ThreadPoolExecutor(max_workers=min(8, len(panes_meta))) as ex:
        panes = list(ex.map(grab, panes_meta))
    set_monitor_status(host, session, capture_monitor_status_with_runner(runner, session))
    return panes


def refresh_remote_capture_cache(host: str, hosts: dict, me: str | None, session: str,
                                 lines: int, lane_map: dict[int, str] | None = None,
                                 connection: dict | None = None) -> None:
    cache_lines = bounded_int(lines, DEFAULT_TAIL, min_value=1, max_value=200)
    cache_key = capture_cache_key(host, session, cache_lines, lane_map)
    try:
        capture_session(host, hosts, me, session, lines, lane_map, connection, _bypass_cache=True)
    except Exception as e:
        print(f"background capture skipped: {host}/{session}: {e}", file=sys.stderr)
    finally:
        with INSTANCE_CAPTURE_CACHE_LOCK:
            cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
            if cached:
                cached["refreshing"] = False



def pct(numer: float, denom: float) -> float | None:
    try:
        if denom <= 0:
            return None
        return round((numer / denom) * 100, 1)
    except Exception:
        return None


def collect_cpu_health() -> dict:
    cores = os.cpu_count() or 1
    try:
