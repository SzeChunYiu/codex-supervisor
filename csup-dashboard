.office-zone {
  min-height: 368px;
  padding: 16px;
  background:
    linear-gradient(180deg, rgba(14,15,28,.92) 0 16px, transparent 16px 100%),
    linear-gradient(90deg, rgba(255,255,255,.055) 1px, transparent 1px) 0 0 / var(--cell) var(--cell),
    linear-gradient(0deg, rgba(255,255,255,.045) 1px, transparent 1px) 0 0 / var(--cell) var(--cell),
    linear-gradient(45deg, rgba(255,255,255,.030) 25%, transparent 25%, transparent 75%, rgba(0,0,0,.060) 75%) 0 0 / 32px 32px,
    linear-gradient(180deg, var(--floor-b), var(--floor-a));
  box-shadow:
    inset 0 14px 0 rgba(7,8,16,.55),
    inset 0 0 0 4px rgba(0,0,0,.22),
    inset 0 -12px 0 rgba(0,0,0,.10);
}
.office-zone::before {
  display: none;
}
.office-zone.executive {
  background-color: #292134;
}
.office-zone.ops {
  background-color: #232b3f;
}
.office-zone.workers {
  background-color: #222d36;
}
.office-zone.workers::after {
  content: "SECTION TEAM SHIMA";
  position: absolute;
  right: 16px;
  bottom: 12px;
  z-index: 2;
  color: rgba(255,255,255,.12);
  font-size: 9px;
  font-weight: 950;
  letter-spacing: .18em;
}
.floor-label {
  position: relative;
  z-index: 4;
  border-radius: 3px;
  background: rgba(11,13,24,.72);
  box-shadow: 2px 2px 0 rgba(0,0,0,.28);
}
.floor-subtitle {
