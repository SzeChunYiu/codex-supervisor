  text-overflow: ellipsis;
  overflow: hidden;
  color: #fff;
}
.office-person.office-agent .person-role {
  font-size: 7px;
  line-height: 1;
  color: rgba(255,255,255,.52);
  letter-spacing: .04em;
}
.office-person.office-agent .person-meta {
  display: none;
}
.agent-thought {
  position: absolute;
  z-index: 7;
  left: -10px;
  top: -22px;
  width: 102px;
  max-height: 36px;
  overflow: hidden;
  padding: 4px 7px 5px;
  border: 1px solid rgba(255,255,255,.22);
  border-radius: 6px 6px 6px 2px;
  background: rgba(248,248,255,.96);
  color: #1a1a2e;
  font-size: 8px;
  font-weight: 600;
  line-height: 1.25;
  text-align: center;
  box-shadow: 2px 3px 0 rgba(0,0,0,.32), 0 0 0 1px rgba(0,0,0,.10);
  opacity: 0;
  display: block;
  pointer-events: none;
  transition: opacity .3s ease;
}
/* Bubble tail */
.agent-thought::after {
  content: "";
  position: absolute;
  left: 12px;
  bottom: -6px;
  width: 0;
  height: 0;
  border-left: 5px solid transparent;
  border-right: 3px solid transparent;
  border-top: 6px solid rgba(248,248,255,.96);
  filter: drop-shadow(1px 2px 0 rgba(0,0,0,.20));
}
/* Show thought for active agents */
.office-person.office-agent.working .agent-thought,
.office-person.office-agent.goal-done .agent-thought,
.office-person.office-agent.rate-limited .agent-thought,
.office-person.office-agent.submitting-route .agent-thought,
.office-person.office-agent:hover .agent-thought,
.office-person.office-agent:focus-within .agent-thought {
  opacity: 1;
}
.office-person.office-agent.idle .agent-thought,
.office-person.office-agent.ready .agent-thought {
  opacity: 0;
}
/* Hover shows even idle thoughts */
.office-person.office-agent:hover .agent-thought,
.office-person.office-agent:focus-within .agent-thought {
  opacity: 1;
}
.office-person.office-agent .status-light {
  z-index: 8;
  top: 42px;
  right: 2px;
}
.office-person.office-agent.gm .pixel-avatar.sprite-avatar {
  filter: drop-shadow(0 0 7px rgba(255,209,102,.55)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
}
.office-person.office-agent.manager .pixel-avatar.sprite-avatar {
  filter: drop-shadow(0 0 7px rgba(125,211,252,.45)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
}
.office-person.office-agent.planner .pixel-avatar.sprite-avatar {
  filter: drop-shadow(0 0 7px rgba(200,169,238,.45)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
}
.office-person.office-agent.worker .pixel-avatar.sprite-avatar {
  filter: drop-shadow(0 0 7px rgba(171,223,167,.38)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
}
@keyframes office-desk-breathe {
  0%, 100% { transform: translate3d(0,0,0); }
  30% { transform: translate3d(0,-0.5px,0); }
  65% { transform: translate3d(0,0.8px,0); }
}
@keyframes office-desk-work {
  0%, 100% { transform: translate3d(0,0,0); }
  25% { transform: translate3d(0.8px,-0.5px,0); }
  75% { transform: translate3d(-0.5px,0.5px,0); }
}
@keyframes office-typing {
  0%, 100% {
    transform: translateY(0) scaleX(var(--face-x, 1));
    filter: drop-shadow(0 0 5px rgba(171,223,167,.50)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
  }
  35% {
    transform: translateY(-1px) scaleX(var(--face-x, 1));
    filter: drop-shadow(0 0 11px rgba(171,223,167,.80)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
  }
  70% {
    transform: translateY(0.5px) scaleX(var(--face-x, 1));
    filter: drop-shadow(0 0 6px rgba(171,223,167,.55)) drop-shadow(3px 4px 0 rgba(0,0,0,.45));
  }
}
@keyframes sprite-idle-breathe {
  0%, 100% { transform: scaleX(var(--face-x,1)) translateY(0); }
  40% { transform: scaleX(var(--face-x,1)) translateY(-0.5px); }
  80% { transform: scaleX(var(--face-x,1)) translateY(0.5px); }
}
@keyframes sprite-seated-breathe {
  0%, 100% { transform: scaleX(var(--face-x,1)) translateY(0); filter: none; }
  50% { transform: scaleX(var(--face-x,1)) translateY(-0.5px); }
}
/* Occasional look-around for idle seated workers */
@keyframes sprite-idle-look {
  0%, 100% { transform: scaleX(var(--face-x,1)) translateY(0); }
  12%       { transform: scaleX(var(--face-x,1)) translateY(-1px) rotate(-1.5deg); }
  28%       { transform: scaleX(var(--face-x,1)) translateY(-0.5px) rotate(1deg); }
  45%, 90%  { transform: scaleX(var(--face-x,1)) translateY(0); }
  70%       { transform: scaleX(var(--face-x,1)) translateY(-0.5px); }
}
/* Stretch + lean-back for idle agents */
@keyframes sprite-idle-stretch {
  0%, 100% { transform: scaleX(var(--face-x,1)) translateY(0) scaleY(1); }
  20%       { transform: scaleX(var(--face-x,1)) translateY(-2px) scaleY(1.04); }
  40%       { transform: scaleX(var(--face-x,1)) translateY(0) scaleY(1); }
  60%       { transform: scaleX(var(--face-x,1)) translateY(-1px) scaleY(1.02); }
  80%       { transform: scaleX(var(--face-x,1)) translateY(0); }
}
/* Agents that are idle/ready at desk occasionally look around */
.office-person.office-agent.idle.seated-at-desk .pixel-avatar.sprite-avatar,
.office-person.office-agent.ready.seated-at-desk .pixel-avatar.sprite-avatar {
  animation: sprite-idle-look 8.4s ease-in-out infinite;
  animation-delay: var(--walk-delay, 0s);
}
/* Goal-done agents lean back visibly */
.office-person.office-agent.goal-done.seated-at-desk .pixel-avatar.sprite-avatar {
  animation: sprite-idle-stretch 6.8s ease-in-out infinite;
  animation-delay: var(--walk-delay, 0s);
}
@keyframes sprite-walk-up {
  from { background-position: 0 -64px; }
  to { background-position: -96px -64px; }
}
@keyframes worker-submit-route {
  0%, 12%, 100% {
    left: calc(var(--agent-x) * var(--cell));
    top: calc(var(--agent-y) * var(--cell));
    transform: translate3d(0,0,0);
  }
  24% {
    left: calc(var(--agent-x) * var(--cell));
    top: calc(var(--agent-submit-y) * var(--cell));
    transform: translate3d(0,0,0);
  }
  44%, 58% {
    left: calc(var(--agent-submit-x) * var(--cell));
    top: calc(var(--agent-submit-y) * var(--cell));
    transform: translate3d(0,0,0);
  }
  82% {
    left: calc(var(--agent-x) * var(--cell));
    top: calc(var(--agent-submit-y) * var(--cell));
    transform: translate3d(0,0,0);
  }
}
@keyframes sprite-walk-right {
  from { background-position: 0 -128px; }
  to { background-position: -96px -128px; }
}
/* Peer chat bubble — shown by JS on social-active agents */
