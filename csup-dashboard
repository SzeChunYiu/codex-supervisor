  const nextPaneCache = new Map();
  for (const inst of capturedInstances(project)) {
    const ikey = instanceKey(project, inst);
    updateInstanceHeader(currentInstanceElementCache.get(ikey), inst);
    for (const pane of inst.panes || []) {
      const key = paneKey(project, inst, pane);
      nextPaneCache.set(key, { project: project.name, host: inst.host, session: inst.session, pane });
      const entry = currentPaneElementCache.get(key);
      if (entry) {
        updateVisiblePane(entry, pane, pane.lane || ('pane' + pane.index), key, false);
