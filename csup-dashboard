    list.appendChild(el('div', { cls: 'empty', text: 'No process samples captured.' }));
    return list;
  }
  const peak = Math.max(1, ...processes.map(p => mode === 'cpu' ? Number(p.cpu_percent || 0) : Number(p.rss_bytes || 0)));
  for (const proc of processes) {
    const metric = mode === 'cpu' ? Number(proc.cpu_percent || 0) : Number(proc.rss_bytes || 0);
    const row = el('div', { cls: 'process-row' });
    const body = el('div');
    const name = (proc.name || proc.command || 'pid ' + proc.pid);
    body.appendChild(el('div', { cls: 'process-name', text: name, title: proc.command || name }));
    body.appendChild(el('div', { cls: 'process-meta', text: 'pid ' + proc.pid + ' · RSS ' + formatBytes(proc.rss_bytes) + ' · RAM ' + formatPercent(proc.memory_percent) }));
    row.appendChild(body);
    row.appendChild(el('div', { cls: 'process-value', text: mode === 'cpu' ? formatPercent(proc.cpu_percent) : formatBytes(proc.rss_bytes) }));
    const meter = el('div', { cls: 'process-meter' });
    const fill = el('span');
    fill.style.width = Math.max(3, (metric / peak) * 100) + '%';
    meter.appendChild(fill);
    row.appendChild(meter);
    list.appendChild(row);
  }
  return list;
}

function renderSystemDiagnostics(state) {
