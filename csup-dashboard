def host_is_slurm(host: str, hosts: dict) -> bool:
    return str(hosts.get(host, {}).get("scheduler", "")).lower() == "slurm"


def slurm_job_name(host: str, hosts: dict) -> str:
    return hosts.get(host, {}).get("slurm_job_name") or f"csup-{host}"


def host_remote_env(host: str, hosts: dict) -> str:
    env_cmd = hosts.get(host, {}).get("remote_env", "")
    if not env_cmd and host_is_slurm(host, hosts):
        env_cmd = "source /projects/hep/fs10/shared/codex-tooling/env-shared.sh"
    return env_cmd


def ssh_opts_for_host(host: str, hosts: dict) -> list[str]:
    if host_is_slurm(host, hosts):
        # LUNARC uses its own pre-authenticated control socket. Do not override
        # the configured ControlPath, or BatchMode probes bypass the live socket.
        return SSH_BASE_OPTS
    return [*SSH_BASE_OPTS, *SSH_CONTROL_OPTS]


def slurm_active_job_cmd(host: str, hosts: dict) -> str:
    name = slurm_job_name(host, hosts)
    return f"squeue -h -u $(whoami) -n {shlex.quote(name)} -t RUNNING -o '%i|%N' 2>/dev/null | head -1"


def parse_slurm_job_info(stdout: str) -> tuple[str, str]:
    line = (stdout or "").strip().splitlines()[0] if (stdout or "").strip() else ""
    if not line:
        return "", ""
    if "|" in line:
        jobid, node = line.split("|", 1)
        return jobid.strip(), node.strip()
    return line.strip(), ""


def slurm_active_job_id(host: str, hosts: dict) -> str:
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if not ssh_target or ssh_target == "local":
        return ""
    try:
        r = run_ssh_stable(ssh_target, ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), slurm_active_job_cmd(host, hosts)],
                           timeout=HOST_PROBE_TIMEOUT, retries=1)
    except subprocess.TimeoutExpired:
        return ""
    if r.returncode != 0:
        return ""
    return parse_slurm_job_info(r.stdout)[0]


def host_runner(host: str, hosts: dict, me: str | None, *,
                timeout: float = SSH_TIMEOUT, retries: int = 1,
                slurm_job_id: str = ""):
    """Return a command runner for local, plain-SSH, or SSH+SLURM hosts."""
    if host == me:
        return lambda cmd: run_stable(cmd, timeout=timeout, retries=0)
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if not ssh_target or ssh_target == "local":
        return None
    if host_is_slurm(host, hosts):
        jobid = slurm_job_id or slurm_active_job_id(host, hosts)
        if not jobid:
            return None
        env_cmd = host_remote_env(host, hosts)

        def runner(cmd):
            inner = " ".join(shlex.quote(str(c)) for c in cmd)
            if env_cmd:
                inner = f"{env_cmd}; {inner}"
            srun_timeout = int(env_float("CSUP_DASHBOARD_SRUN_TIMEOUT_SECS", float(timeout), min_value=1.0))
            remote_cmd = f"timeout {srun_timeout}s srun --jobid={shlex.quote(jobid)} --overlap bash -lc {shlex.quote(inner)}"
            return run_ssh_stable(ssh_target, ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), remote_cmd],
                                  timeout=max(timeout, srun_timeout + 2), retries=retries)
        return runner

    def runner(cmd):
        remote_cmd = " ".join(shlex.quote(str(c)) for c in cmd)
        return run_ssh_stable(ssh_target, ["ssh", *ssh_opts_for_host(host, hosts), ssh_target, remote_cmd],
                              timeout=timeout, retries=retries)
    return runner


def probe_host(host: str, hosts: dict, me: str | None) -> dict:
    if host == me:
        return {"reachable": True, "latency_ms": 0, "error": ""}
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if ssh_target == "local":
        return {"reachable": False, "latency_ms": None,
                "error": "ssh target is local but this is not the current host"}
    if not ssh_target:
        return {"reachable": False, "latency_ms": None, "error": "missing ssh target"}
    if host_is_slurm(host, hosts):
        try:
            r, latency_ms, queue_wait_ms = run_ssh_stable_timed(
                ssh_target,
                ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), slurm_active_job_cmd(host, hosts)],
                timeout=HOST_PROBE_TIMEOUT,
                retries=1,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or f"ssh exited {r.returncode}").strip()
                return {
                    "reachable": False,
                    "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": err[:160],
                }
            jobid, node = parse_slurm_job_info(r.stdout)
            if jobid:
                return {
                    "reachable": True,
                    "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": "",
                    "job_id": jobid,
                    "node": node,
                }
            return {"reachable": False, "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": f"no RUNNING SLURM allocation for {slurm_job_name(host, hosts)}"}
        except subprocess.TimeoutExpired:
            return {"reachable": False, "latency_ms": None, "error": "ssh probe timeout"}
        except Exception as e:
            return {"reachable": False, "latency_ms": None, "error": str(e)[:160]}
    try:
        r, latency_ms, queue_wait_ms = run_ssh_stable_timed(
            ssh_target,
            ["ssh", *ssh_opts_for_host(host, hosts), ssh_target, "true"],
            timeout=HOST_PROBE_TIMEOUT,
            retries=1,
        )
        if r.returncode == 0:
            return {
                "reachable": True,
                "latency_ms": latency_ms,
                "queue_wait_ms": queue_wait_ms,
                "error": "",
            }
        err = (r.stderr or r.stdout or f"ssh exited {r.returncode}").strip()
        return {
            "reachable": False,
            "latency_ms": latency_ms,
            "queue_wait_ms": queue_wait_ms,
            "error": err[:160],
        }
    except subprocess.TimeoutExpired:
        return {"reachable": False, "latency_ms": None, "error": "ssh probe timeout"}
    except Exception as e:
        return {"reachable": False, "latency_ms": None, "error": str(e)[:160]}


def cached_probe_host(host: str, hosts: dict, me: str | None, now: float | None = None) -> dict:
    now = time.time() if now is None else now
    info = hosts.get(host, {})
    # For SLURM hosts that share the same job (e.g. lunarc, lunarc-b, lunarc-c
    # all pointing at slurm_job_name=mcaccel-sup), dedupe the probe so we don't
    # hammer the SSH multiplex with N identical srun calls.
    sched = info.get("scheduler", "")
    job_name = info.get("slurm_job_name", "")
    if sched == "slurm" and job_name:
        key = ("slurm-job", ssh_target_lock_key(str(info.get("ssh", ""))), job_name, me or "")
    else:
        key = (
            host,
            me or "",
            info.get("ssh", ""),
            sched,
            job_name,
        )
    if host == me or not HOST_PROBE_ASYNC or HOST_PROBE_CACHE_SECS <= 0:
        value = probe_host(host, hosts, me)
        if HOST_PROBE_CACHE_SECS > 0:
            with HOST_PROBE_CACHE_LOCK:
                HOST_PROBE_CACHE[key] = {"updated_at": now, "value": dict(value), "refreshing": False}
        return value
    if HOST_PROBE_CACHE_SECS > 0:
        with HOST_PROBE_CACHE_LOCK:
            cached = HOST_PROBE_CACHE.get(key)
            if cached:
                value = dict(cached.get("value") or {})
                if cache_age(now, cached.get("updated_at")) < HOST_PROBE_CACHE_SECS:
                    return value
                if not cached.get("refreshing"):
                    ssh_target = str(info.get("ssh", ""))
                    cache_age_secs = cache_age(now, cached.get("updated_at"))
                    if (
                        ssh_target and
                        ssh_target_busy(ssh_target) and
                        value and
                        cache_age_secs < HOST_PROBE_DEFER_MAX_STALE_SECS
                    ):
                        value["probe_stale"] = True
                        value["probe_deferred"] = True
                        return value
                    cached["refreshing"] = True
                    cached["last_attempt_at"] = now
                    threading.Thread(
                        target=refresh_host_probe_cache,
                        args=(key, host, hosts, me),
                        daemon=True,
                    ).start()
                if value:
                    value["probe_stale"] = True
                    return value
            HOST_PROBE_CACHE[key] = {
                "updated_at": 0,
                "last_attempt_at": now,
                "value": {"reachable": False, "latency_ms": None, "error": "probe warming", "probe_warming": True},
                "refreshing": True,
            }
            threading.Thread(
                target=refresh_host_probe_cache,
                args=(key, host, hosts, me),
                daemon=True,
            ).start()
    return {"reachable": False, "latency_ms": None, "error": "probe warming", "probe_warming": True}


def probe_error_is_transient(error: str) -> bool:
    lowered = (error or "").lower()
    transient_markers = (
        "mux_client_request_session",
        "session open refused",
        "ssh probe timeout",
        "connection reset",
        "connection closed",
        "broken pipe",
    )
    return any(marker in lowered for marker in transient_markers)


def refresh_host_probe_cache(key: tuple, host: str, hosts: dict, me: str | None) -> None:
    try:
        value = probe_host(host, hosts, me)
    except Exception as e:
        value = {"reachable": False, "latency_ms": None, "error": str(e)[:160]}
    with HOST_PROBE_CACHE_LOCK:
        previous = dict((HOST_PROBE_CACHE.get(key) or {}).get("value") or {})
    error = str(value.get("error") or "")
    if previous.get("reachable") and not value.get("reachable") and probe_error_is_transient(error):
        preserved = dict(previous)
        preserved["probe_stale"] = True
        preserved["probe_deferred"] = True
        preserved["last_probe_error"] = error[:160]
        value = preserved
    with HOST_PROBE_CACHE_LOCK:
        HOST_PROBE_CACHE[key] = {"updated_at": time.time(), "value": dict(value), "refreshing": False}


def host_reachable(host: str, hosts: dict, me: str | None) -> bool:
    return bool(cached_probe_host(host, hosts, me)["reachable"])


