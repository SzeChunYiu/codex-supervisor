def ssh_opts_for_host(host: str, hosts: dict) -> list[str]:
    if host_is_slurm(host, hosts):
        # LUNARC uses its own pre-authenticated control socket. Do not override
        # the configured ControlPath, or BatchMode probes bypass the live socket.
        return SSH_BASE_OPTS
    return [*SSH_BASE_OPTS, *SSH_CONTROL_OPTS]


def slurm_active_job_cmd(host: str, hosts: dict) -> str:
    name = slurm_job_name(host, hosts)
    return f"squeue -h -u $(whoami) -n {shlex.quote(name)} -t RUNNING -o '%i|%N' 2>/dev/null | head -1"


def parse_slurm_job_info(stdout: str) -> tuple[str, str]:
    line = (stdout or "").strip().splitlines()[0] if (stdout or "").strip() else ""
    if not line:
        return "", ""
    if "|" in line:
        jobid, node = line.split("|", 1)
        return jobid.strip(), node.strip()
    return line.strip(), ""


def slurm_active_job_id(host: str, hosts: dict) -> str:
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if not ssh_target or ssh_target == "local":
        return ""
    try:
        r = run_ssh_stable(ssh_target, ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), slurm_active_job_cmd(host, hosts)],
                           timeout=HOST_PROBE_TIMEOUT, retries=1)
    except subprocess.TimeoutExpired:
        return ""
    if r.returncode != 0:
        return ""
    return parse_slurm_job_info(r.stdout)[0]


def host_runner(host: str, hosts: dict, me: str | None, *,
                timeout: float = SSH_TIMEOUT, retries: int = 1,
                slurm_job_id: str = ""):
    """Return a command runner for local, plain-SSH, or SSH+SLURM hosts."""
    if host == me:
        return lambda cmd: run_stable(cmd, timeout=timeout, retries=0)
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if not ssh_target or ssh_target == "local":
        return None
    if host_is_slurm(host, hosts):
        jobid = slurm_job_id or slurm_active_job_id(host, hosts)
        if not jobid:
            return None
        env_cmd = host_remote_env(host, hosts)

        def runner(cmd):
            inner = " ".join(shlex.quote(str(c)) for c in cmd)
            if env_cmd:
                inner = f"{env_cmd}; {inner}"
            remote_cmd = f"srun --jobid={shlex.quote(jobid)} --overlap bash -lc {shlex.quote(inner)}"
            return run_ssh_stable(ssh_target, ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), remote_cmd],
                                  timeout=timeout, retries=retries)
        return runner

    def runner(cmd):
        remote_cmd = " ".join(shlex.quote(str(c)) for c in cmd)
        return run_ssh_stable(ssh_target, ["ssh", *ssh_opts_for_host(host, hosts), ssh_target, remote_cmd],
                              timeout=timeout, retries=retries)
    return runner


def probe_host(host: str, hosts: dict, me: str | None) -> dict:
    if host == me:
        return {"reachable": True, "latency_ms": 0, "error": ""}
    info = hosts.get(host, {})
    ssh_target = info.get("ssh", "")
    if ssh_target == "local":
        return {"reachable": False, "latency_ms": None,
                "error": "ssh target is local but this is not the current host"}
    if not ssh_target:
        return {"reachable": False, "latency_ms": None, "error": "missing ssh target"}
    if host_is_slurm(host, hosts):
        try:
            r, latency_ms, queue_wait_ms = run_ssh_stable_timed(
                ssh_target,
                ["ssh", *SSH_BASE_OPTS, ssh_command_target(ssh_target), slurm_active_job_cmd(host, hosts)],
                timeout=HOST_PROBE_TIMEOUT,
                retries=1,
            )
            if r.returncode != 0:
                err = (r.stderr or r.stdout or f"ssh exited {r.returncode}").strip()
                return {
                    "reachable": False,
                    "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": err[:160],
                }
            jobid, node = parse_slurm_job_info(r.stdout)
            if jobid:
                return {
                    "reachable": True,
                    "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": "",
                    "job_id": jobid,
                    "node": node,
                }
            return {"reachable": False, "latency_ms": latency_ms,
                    "queue_wait_ms": queue_wait_ms,
                    "error": f"no RUNNING SLURM allocation for {slurm_job_name(host, hosts)}"}
        except subprocess.TimeoutExpired:
            return {"reachable": False, "latency_ms": None, "error": "ssh probe timeout"}
        except Exception as e:
            return {"reachable": False, "latency_ms": None, "error": str(e)[:160]}
    try:
        r, latency_ms, queue_wait_ms = run_ssh_stable_timed(
            ssh_target,
            ["ssh", *ssh_opts_for_host(host, hosts), ssh_target, "true"],
            timeout=HOST_PROBE_TIMEOUT,
            retries=1,
        )
        if r.returncode == 0:
            return {
                "reachable": True,
                "latency_ms": latency_ms,
                "queue_wait_ms": queue_wait_ms,
                "error": "",
            }
        err = (r.stderr or r.stdout or f"ssh exited {r.returncode}").strip()
        return {
            "reachable": False,
            "latency_ms": latency_ms,
            "queue_wait_ms": queue_wait_ms,
            "error": err[:160],
        }
    except subprocess.TimeoutExpired:
        return {"reachable": False, "latency_ms": None, "error": "ssh probe timeout"}
    except Exception as e:
        return {"reachable": False, "latency_ms": None, "error": str(e)[:160]}


def cached_probe_host(host: str, hosts: dict, me: str | None, now: float | None = None) -> dict:
    now = time.time() if now is None else now
    info = hosts.get(host, {})
    # For SLURM hosts that share the same job (e.g. lunarc, lunarc-b, lunarc-c
    # all pointing at slurm_job_name=mcaccel-sup), dedupe the probe so we don't
    # hammer the SSH multiplex with N identical srun calls.
    sched = info.get("scheduler", "")
    job_name = info.get("slurm_job_name", "")
    if sched == "slurm" and job_name:
        key = ("slurm-job", ssh_target_lock_key(str(info.get("ssh", ""))), job_name, me or "")
    else:
        key = (
            host,
            me or "",
            info.get("ssh", ""),
            sched,
            job_name,
        )
    if host == me or not HOST_PROBE_ASYNC or HOST_PROBE_CACHE_SECS <= 0:
        value = probe_host(host, hosts, me)
        if HOST_PROBE_CACHE_SECS > 0:
            with HOST_PROBE_CACHE_LOCK:
                HOST_PROBE_CACHE[key] = {"updated_at": now, "value": dict(value), "refreshing": False}
        return value
    if HOST_PROBE_CACHE_SECS > 0:
        with HOST_PROBE_CACHE_LOCK:
            cached = HOST_PROBE_CACHE.get(key)
            if cached:
                value = dict(cached.get("value") or {})
                if now - float(cached.get("updated_at", 0)) < HOST_PROBE_CACHE_SECS:
                    return value
                if not cached.get("refreshing"):
                    ssh_target = str(info.get("ssh", ""))
                    if ssh_target and ssh_target_busy(ssh_target) and value:
                        value["probe_stale"] = True
                        value["probe_deferred"] = True
                        return value
                    cached["refreshing"] = True
                    cached["last_attempt_at"] = now
                    threading.Thread(
                        target=refresh_host_probe_cache,
                        args=(key, host, hosts, me),
                        daemon=True,
                    ).start()
                if value:
                    value["probe_stale"] = True
                    return value
            HOST_PROBE_CACHE[key] = {
                "updated_at": 0,
                "last_attempt_at": now,
                "value": {"reachable": False, "latency_ms": None, "error": "probe warming", "probe_warming": True},
                "refreshing": True,
            }
            threading.Thread(
                target=refresh_host_probe_cache,
                args=(key, host, hosts, me),
                daemon=True,
            ).start()
    return {"reachable": False, "latency_ms": None, "error": "probe warming", "probe_warming": True}


def probe_error_is_transient(error: str) -> bool:
    lowered = (error or "").lower()
    transient_markers = (
        "mux_client_request_session",
        "session open refused",
        "ssh probe timeout",
        "connection reset",
        "connection closed",
        "broken pipe",
    )
    return any(marker in lowered for marker in transient_markers)


def refresh_host_probe_cache(key: tuple, host: str, hosts: dict, me: str | None) -> None:
    try:
        value = probe_host(host, hosts, me)
    except Exception as e:
        value = {"reachable": False, "latency_ms": None, "error": str(e)[:160]}
    with HOST_PROBE_CACHE_LOCK:
        previous = dict((HOST_PROBE_CACHE.get(key) or {}).get("value") or {})
    error = str(value.get("error") or "")
    if previous.get("reachable") and not value.get("reachable") and probe_error_is_transient(error):
        preserved = dict(previous)
        preserved["probe_stale"] = True
        preserved["probe_deferred"] = True
        preserved["last_probe_error"] = error[:160]
        value = preserved
    with HOST_PROBE_CACHE_LOCK:
        HOST_PROBE_CACHE[key] = {"updated_at": time.time(), "value": dict(value), "refreshing": False}


def host_reachable(host: str, hosts: dict, me: str | None) -> bool:
    return bool(cached_probe_host(host, hosts, me)["reachable"])


def capture_cache_key(host: str, session: str, lines: int,
                      lane_map: dict[int, str] | None) -> tuple:
    lanes = tuple(sorted((int(k), str(v)) for k, v in (lane_map or {}).items()))
    return host, session, int(lines), lanes


def monitor_cache_key(host: str, session: str) -> tuple:
    return host, session


def pane_title_indicates_activity(title: str | None) -> bool:
    stripped = str(title or "").strip()
    return bool(stripped) and stripped[0] in BRAILLE_SPINNER_CHARS


def lane_label_for_capture(item: dict, lane_map: dict[int, str] | None = None) -> str:
    known_lanes = set((lane_map or {}).values())
    pane_title = item.get("title") or ""
    if pane_title and pane_title != (item.get("cmd") or ""):
        if (not pane_title_indicates_activity(pane_title)) and (not known_lanes or pane_title in known_lanes):
            return str(pane_title)
    idx_val = int(item.get("index") if item.get("index") is not None else 0)
    ordinal_val = int(item.get("ordinal") if item.get("ordinal") is not None else -1)
    # Prompt files use "PANE N" ordinals, while tmux pane indexes may start
    # at 1 on clusters. Prefer ordinal labels to avoid off-by-one lane names
    # on base-index=1 tmux servers.
    return str((lane_map or {}).get(ordinal_val, "") or (lane_map or {}).get(idx_val, ""))


def clone_jsonable(value):
    return json.loads(json.dumps(value))


def project_slug(name: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", str(name or "project").lower()).strip("-")
    return slug or "project"


def count_project_payload(project: dict) -> dict:
    hosts = 0
    panes = 0
    errors = 0
    for inst in project.get("instances", []) or []:
        inst_panes = inst.get("panes", []) or []
        if not inst_panes:
            continue
        hosts += 1
        panes += len(inst_panes)
        if inst.get("error"):
            errors += 1
    return {"hosts": hosts, "panes": panes, "errors": errors}


def compact_state_panes(snapshot: dict, tail_lines: int) -> None:
    keep = max(1, min(50, int(tail_lines or 6)))
    for project in snapshot.get("projects", []) or []:
        for inst in project.get("instances", []) or []:
            for pane in inst.get("panes", []) or []:
                tail = [str(line) for line in (pane.get("tail") or [])]
                if len(tail) > keep:
                    pane["tail"] = tail[-keep:]
                else:
                    pane["tail"] = tail
                pane["tail_line_count"] = len(pane["tail"])
                # Compact live cards prefer low payload + cheap text escaping.
                # The click-through pane endpoint still serves rich ANSI HTML.
                pane.pop("tail_html", None)


def state_payload(project_filter: str = "", *, compact: bool = False,
                  tail_lines: int = 6) -> dict:
    with CACHE_LOCK:
        snapshot = clone_jsonable(CACHE)
    projects = snapshot.get("projects", []) or []
    snapshot["project_index"] = [
        {
            "name": project.get("name", ""),
            "slug": project_slug(project.get("name", "")),
            **count_project_payload(project),
        }
        for project in projects
    ]
    if project_filter:
        snapshot["projects"] = [
            project for project in projects
            if project_slug(project.get("name", "")) == project_filter
        ]
    if compact:
        compact_state_panes(snapshot, tail_lines)
    return snapshot


def empty_monitor_status() -> dict:
    return {"known": False, "running": False, "pids": [], "updated_at": 0, "error": ""}


def set_monitor_status(host: str, session: str, status: dict) -> None:
    value = dict(status or {})
    value.setdefault("known", True)
    value.setdefault("running", bool(value.get("pids")))
    value.setdefault("pids", [])
    value.setdefault("error", "")
    value["updated_at"] = time.time()
    with INSTANCE_MONITOR_CACHE_LOCK:
        INSTANCE_MONITOR_CACHE[monitor_cache_key(host, session)] = value


def get_monitor_status(host: str, session: str) -> dict:
    with INSTANCE_MONITOR_CACHE_LOCK:
        value = INSTANCE_MONITOR_CACHE.get(monitor_cache_key(host, session))
    return clone_jsonable(value) if value else empty_monitor_status()


def parse_monitor_status_from_ps(output: str, session: str) -> dict:
    candidates: list[tuple[int, int]] = []
    daemon_seen = False
    for raw in (output or "").splitlines():
        line = raw.strip()
        if not line or "codex-supervisor.sh" not in line:
            continue
        parts = line.split(None, 2)
        if len(parts) < 2:
            continue
        pid_raw = parts[0]
        ppid_raw = "0"
        if len(parts) >= 3 and parts[1].isdigit():
            ppid_raw = parts[1]
            args = parts[2]
        else:
            args = line.split(None, 1)[1]
        if "--daemon" not in args or "--session" not in args:
            continue
        daemon_seen = True
        try:
            argv = shlex.split(args)
        except ValueError:
            argv = args.split()
        for i, arg in enumerate(argv[:-1]):
            if arg == "--session" and argv[i + 1] == session:
                try:
                    candidates.append((int(pid_raw), int(ppid_raw)))
                except ValueError:
                    pass
                break
    candidate_pids = {pid for pid, _ in candidates}
    # Bash background prompt-sender subshells inherit the parent script's
    # command line, so they look like `start --daemon --session ...` in ps.
    # They are children of the actual monitor daemon; keep only root candidates.
    pids = [pid for pid, ppid in candidates if ppid not in candidate_pids]
    return {"known": True, "running": bool(pids), "pids": pids, "daemon_seen": daemon_seen, "error": ""}


def capture_monitor_status_with_runner(runner, session: str) -> dict:
    try:
        r = runner(["ps", "-axo", "pid=,ppid=,args="])
    except Exception as e:
        return {"known": True, "running": False, "pids": [], "error": str(e)[:160]}
    if r.returncode != 0:
        return {
            "known": True,
            "running": False,
            "pids": [],
            "error": (r.stderr or r.stdout or f"ps exited {r.returncode}").strip()[:160],
        }
    return parse_monitor_status_from_ps(r.stdout or "", session)


def capture_cache_value_with_status(cached: dict, now: float) -> list[dict] | None:
    value = cached.get("value")
    if value is None:
        return None
    cloned = clone_jsonable(value)
    last_error = str(cached.get("last_error") or "")
    if last_error:
        age = max(0.0, now - float(cached.get("updated_at") or 0))
        for pane in cloned:
            pane["capture_stale"] = True
            pane["capture_age_secs"] = round(age, 1)
            pane["capture_error"] = last_error[:160]
    return cloned


def capture_cache_problem(host: str, session: str, lines: int,
                          lane_map: dict[int, str] | None = None) -> dict:
    cache_key = capture_cache_key(host, session, max(1, int(lines or DEFAULT_TAIL)), lane_map)
    with INSTANCE_CAPTURE_CACHE_LOCK:
        cached = clone_jsonable(INSTANCE_CAPTURE_CACHE.get(cache_key) or {})
    if not cached:
        return {}
    if cached.get("value") is None and cached.get("last_error"):
        return {
            "error": str(cached.get("last_error") or "")[:160],
            "refreshing": bool(cached.get("refreshing")),
            "last_attempt_age_secs": round(max(0.0, time.time() - float(cached.get("last_attempt_at") or 0)), 1),
        }
    return {}


def capture_cached_panes_with_error(host: str, session: str, lines: int,
                                    lane_map: dict[int, str] | None,
                                    error: str) -> list[dict] | None:
    cache_key = capture_cache_key(host, session, max(1, int(lines or DEFAULT_TAIL)), lane_map)
    now = time.time()
    with INSTANCE_CAPTURE_CACHE_LOCK:
        cached = clone_jsonable(INSTANCE_CAPTURE_CACHE.get(cache_key) or {})
    if not cached or cached.get("value") is None:
        return None
    cached["last_error"] = error or cached.get("last_error") or "capture unavailable"
    return capture_cache_value_with_status(cached, now)


def capture_cached_panes(host: str, session: str, lines: int,
                         lane_map: dict[int, str] | None) -> list[dict] | None:
    cache_key = capture_cache_key(host, session, max(1, int(lines or DEFAULT_TAIL)), lane_map)
    now = time.time()
    with INSTANCE_CAPTURE_CACHE_LOCK:
        cached = clone_jsonable(INSTANCE_CAPTURE_CACHE.get(cache_key) or {})
    if not cached or cached.get("value") is None:
        return None
    return capture_cache_value_with_status(cached, now)


def render_captured_item_simple(item: dict, tail_lines: int = DEFAULT_TAIL,
                                lane_map: dict[int, str] | None = None) -> dict:
    """Standalone version of the render_captured_item closure inside capture_session."""
    ansi_text = item.get("ansi", "")
    ansi_lines = ansi_text.splitlines()
    tail_ansi = ansi_lines[-tail_lines:] if ansi_lines else []
    full_text = strip_ansi(ansi_text)
    tail_text = strip_ansi("\n".join(tail_ansi))
    tail = tail_text.splitlines()
    joined = re.sub(r"\s+", " ", full_text.lower())
    pane_title = item.get("title") or ""
    if item.get("dead"):
        state = "dead"
    elif "you've hit your usage limit" in joined:
        state = "rate-limited"
    elif "goal achieved" in joined:
        state = "goal-done"
    elif "pursuing goal" in joined or "working" in joined:
        state = "working"
    elif "listening for jobs" in joined or "running job:" in joined:
        state = "working"
    elif pane_title_indicates_activity(pane_title):
        state = "working"
    elif joined.strip():
        state = "idle"
    else:
        state = "idle"
    m = re.search(r"(gpt-[\d.]+\s+[a-z]+(?:\s+[a-z]+)?)", re.sub(r"\s+", " ", full_text.lower()))
    idx_val = int(item.get("index") if item.get("index") is not None else 0)
    return {
        "index": idx_val,
        "dead": bool(item.get("dead")),
        "state": state,
        "model": m.group(1) if m else "",
        "lane": lane_label_for_capture(item, lane_map),
        "width": int(item.get("width") or 0),
        "height": int(item.get("height") or 0),
        "tail": tail,
        "tail_html": ansi_to_html("\n".join(tail_ansi)),
        "tail_line_count": len(tail),
    }


def capture_session(host: str, hosts: dict, me: str | None, session: str,
                    lines: int, lane_map: dict[int, str] | None = None,
                    connection: dict | None = None,
                    _bypass_cache: bool = False) -> list[dict] | None:
    runner = host_runner(host, hosts, me, timeout=SSH_TIMEOUT, retries=1,
                         slurm_job_id=str((connection or {}).get("job_id") or ""))
    if runner is None:
        return None
    tail_lines = max(1, int(lines or DEFAULT_TAIL))
    cache_key = capture_cache_key(host, session, tail_lines, lane_map)

    # ── Streaming fast path ──────────────────────────────────────────────────
    # For SLURM hosts, try the persistent streaming connection first.  The
    # streamer runs inside the allocation and emits JSON every ~0.5s, so we
    # just read from the in-memory cache — no srun step per refresh.  While the
    # streamer is warming, do not fall through to per-session fallback captures:
    # those slow sruns hold the same LUNARC ControlMaster lock and can starve
    # streamer startup, creating a self-sustaining timeout storm.
    if CSUP_STREAMING and host != me and host_is_slurm(host, hosts):
        conn_info = connection or {}
        job_id = str(conn_info.get("job_id") or "")
        info = hosts.get(host, {})
        ssh_target = info.get("ssh", "")
        if ssh_target and job_id:
            stream = _get_or_create_streaming_conn(ssh_target, job_id)
            if stream and stream.is_ready():
                cached = stream.get_session(session)
                if cached:
                    panes = [render_captured_item_simple(item) for item in cached["panes"]]
                    if REMOTE_CAPTURE_CACHE_SECS > 0:
                        cache_key_s = capture_cache_key(host, session, tail_lines, lane_map)
                        with INSTANCE_CAPTURE_CACHE_LOCK:
                            INSTANCE_CAPTURE_CACHE[cache_key_s] = {
                                "updated_at": cached["ts"],
                                "last_attempt_at": cached["ts"],
                                "last_error": "",
                                "value": clone_jsonable(panes),
                                "refreshing": False,
                            }
                    return panes
            if REMOTE_CAPTURE_CACHE_SECS > 0:
                with INSTANCE_CAPTURE_CACHE_LOCK:
                    cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
                    if cached:
                        return capture_cache_value_with_status(cached, time.time())
            return None
    # ── End streaming fast path ──────────────────────────────────────────────
    if host != me and REMOTE_CAPTURE_CACHE_SECS > 0 and not _bypass_cache:
        now = time.time()
        with INSTANCE_CAPTURE_CACHE_LOCK:
            cached = INSTANCE_CAPTURE_CACHE.get(cache_key)
            if cached:
                value = capture_cache_value_with_status(cached, now)
                if now - float(cached.get("updated_at", 0)) < REMOTE_CAPTURE_CACHE_SECS:
                    return value
                retry_secs = REMOTE_CAPTURE_CACHE_SECS
                if cached.get("last_error"):
                    last_attempt = float(cached.get("last_attempt_at") or cached.get("updated_at") or 0)
                    retry_secs = max(REMOTE_CAPTURE_CACHE_SECS, REMOTE_CAPTURE_ERROR_RETRY_SECS)
                else:
                    last_attempt = float(cached.get("updated_at") or 0)
                if not cached.get("refreshing") and now - last_attempt >= retry_secs:
                    cached["refreshing"] = True
                    cached["last_attempt_at"] = now
                    threading.Thread(
                        target=refresh_remote_capture_cache,
                        args=(host, hosts, me, session, lines, lane_map, connection),
                        daemon=True,
                    ).start()
                return value
            if REMOTE_INITIAL_CAPTURE_ASYNC:
                INSTANCE_CAPTURE_CACHE[cache_key] = {
                    "updated_at": now,
                    "last_attempt_at": now,
                    "last_error": "",
                    "value": None,
                    "refreshing": True,
                }
                threading.Thread(
                    target=refresh_remote_capture_cache,
                    args=(host, hosts, me, session, lines, lane_map, connection),
                    daemon=True,
                ).start()
                return None

    def render_captured_item(item):
        ansi_text = item.get("ansi", "")
        ansi_lines = ansi_text.splitlines()
        tail_ansi = ansi_lines[-tail_lines:] if ansi_lines else []
        full_text = strip_ansi(ansi_text)
        tail_text = strip_ansi("\n".join(tail_ansi))
        tail = tail_text.splitlines()
        joined = re.sub(r"\s+", " ", full_text.lower())
        pane_title = item.get("title") or ""
        if item.get("dead"):
            state = "dead"
        elif "you've hit your usage limit" in joined:
            state = "rate-limited"
        elif "goal achieved" in joined:
            state = "goal-done"
        elif "pursuing goal" in joined or "working" in joined:
            state = "working"
        elif "listening for jobs" in joined or "running job:" in joined:
            # Self-hosted CI runner panes are intentionally idle-looking while
            # waiting for work. Treat the heartbeat as a live service state,
            # not as a stuck Codex pane.
            state = "working"
        elif pane_title_indicates_activity(pane_title):
            # Codex often updates only the tmux title with a Braille spinner
            # while the visible tail is blank during startup/submit. Treat that
            # as live work instead of a false idle/empty-pane alert.
            state = "working"
        elif "ready" in joined or "tip:" in joined:
            state = "ready"
        else:
            state = "idle"
        # Model badge — codex displays as "gpt-X.Y reasoning service" with
        # variable spacing; collapse runs of whitespace before matching.
        m = re.search(r"(gpt-[\d.]+\s+[a-z]+(?:\s+[a-z]+)?)",
                      re.sub(r"\s+", " ", full_text.lower()))
        idx_val = int(item.get("index") if item.get("index") is not None else 0)
        return {
            "index": idx_val,
            "dead": bool(item.get("dead")),
            "state": state,
            "model": m.group(1) if m else "",
            "lane": lane_label_for_capture(item, lane_map),
            "width": int(item.get("width") or 0),
            "height": int(item.get("height") or 0),
            "tail": tail,
