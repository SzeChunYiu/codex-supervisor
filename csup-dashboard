.grid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(min(100%, 54ch), 1fr)); align-items: start; contain: layout style; }
.pane {
  --pane-lines: 28;
  background: var(--codex-bg);
  border: 1px solid var(--codex-border);
  border-radius: 9px;
  overflow: hidden;
  cursor: pointer;
  min-height: 190px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.035), 0 8px 20px rgba(0,0,0,.24);
  contain: layout paint style;
  transform: translateZ(0);
  backface-visibility: hidden;
  transition: border-color .12s ease, transform .12s ease, box-shadow .12s ease;
}
.pane:hover { border-color: #44444d; transform: translate3d(0,-1px,0); box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 12px 28px rgba(0,0,0,.30); will-change: transform, box-shadow; }
.pane-head {
  min-height: 34px;
  display: flex; align-items: center; gap: 7px;
  padding: 7px 9px;
  border-bottom: 1px solid var(--codex-border-soft);
  background: linear-gradient(180deg, #151519, #101013);
  color: var(--codex-dim);
  font-size: 10px;
}
.lane-tag { color: #fff; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; }
.pane-idx, .pane-dims { color: var(--codex-muted); }
.state-badge {
  padding: 1px 7px; border-radius: 999px; border: 1px solid transparent;
  font-size: 9px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase;
}
.state-badge.working { color: var(--codex-green); background: rgba(171,223,167,.12); border-color: rgba(171,223,167,.22); }
.state-badge.goal-done { color: var(--codex-blue); background: rgba(125,211,252,.11); border-color: rgba(125,211,252,.20); }
.state-badge.ready { color: var(--codex-purple); background: rgba(200,169,238,.11); border-color: rgba(200,169,238,.20); }
.state-badge.idle { color: var(--codex-dim); background: rgba(255,255,255,.035); border-color: rgba(255,255,255,.055); }
.state-badge.dead { color: var(--codex-red); background: rgba(255,138,128,.10); border-color: rgba(255,138,128,.22); }
.state-badge.rate-limited { color: var(--codex-orange); background: rgba(255,191,122,.10); border-color: rgba(255,191,122,.22); }
.model-badge { margin-left: auto; color: var(--codex-yellow); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 28ch; }
.pane-terminal { padding: 9px 10px 11px; max-height: min(64vh, calc((var(--pane-lines, 28) * 1.36em) + 24px)); overflow: auto; overscroll-behavior: contain; scrollbar-gutter: stable both-edges; }
.terminal-pre {
  margin: 0;
  white-space: pre-wrap;
  overflow-wrap: anywhere;
  tab-size: 2;
  color: var(--codex-fg);
  font: 12px/1.36 var(--mono);
  letter-spacing: 0;
  contain: content;
}
body.wrap .terminal-pre { white-space: pre-wrap; overflow-wrap: anywhere; }
body.wrap .pane-terminal { overflow-x: hidden; }
.pane.s-dead { opacity: .72; }
.empty {
  color: var(--codex-muted); padding: 16px; border: 1px dashed var(--codex-border);
  border-radius: 9px; background: rgba(255,255,255,.018);
}

.modal { position: fixed; inset: 0; background: rgba(0,0,0,.88); display: none; align-items: center; justify-content: center; z-index: 100; padding: 18px; }
.modal.open { display: flex; }
.modal-body { width: min(1120px, 94vw); max-height: 92vh; overflow: hidden; background: var(--codex-bg); border: 1px solid var(--codex-border); border-radius: 10px; box-shadow: 0 20px 70px rgba(0,0,0,.55); }
.modal-title { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-bottom: 1px solid var(--codex-border-soft); background: #141418; color: #fff; font-weight: 700; font-size: 12px; }
.modal-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.modal-title button { margin-left: auto; }
.modal-scroll { max-height: calc(92vh - 48px); overflow: auto; padding: 12px; overscroll-behavior: contain; scrollbar-gutter: stable both-edges; }
.project, .metric-card, .chart-card, .activity-panel, .project-card-link { contain: layout paint style; }
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
  .pane:hover { transform: none; will-change: auto; }
}
@media (max-width: 720px) {
  body { padding: 10px; }
  .shellbar { grid-template-columns: 1fr; }
  .actions { justify-content: flex-start; }
  .project-head { grid-template-columns: 1fr; gap: 3px; }
  .metric-card { min-height: 82px; }
  .token-graphs { grid-template-columns: 1fr; }
  .activity-head { align-items: flex-start; flex-direction: column; }
  .activity-text { white-space: normal; }
  .prompts { display: none; }
}
</style>
</head>
<body>
<header class="shellbar">
  <div>
    <div class="brand">
      <h1>csup dashboard</h1>
      <span class="subtle">Codex-terminal accurate panes</span>
      <span class="subtle" id="upd"></span>
    </div>
    <div class="summary" id="summary"></div>
  </div>
  <div class="actions">
    <button class="action" id="refresh-now" type="button">refresh</button>
    <a class="action" href="/api/health.json" target="_blank" rel="noreferrer">health</a>
    <label class="toggle"><input id="wrap-toggle" type="checkbox"> wrap output</label>
    <label class="toggle"><input id="compact-toggle" type="checkbox"> compact cards</label>
  </div>
</header>
<nav class="project-nav" id="project-nav" aria-label="Projects"></nav>
<main id="root"></main>
<div class="modal" id="modal" role="dialog" aria-modal="true" aria-labelledby="modal-heading">
  <div class="modal-body">
    <div class="modal-title"><span id="modal-heading"></span><button class="action" id="copy-modal" type="button">copy</button></div>
    <div class="modal-scroll"><pre class="terminal-pre" id="modal-pre"></pre></div>
  </div>
</div>
<script>
const root = document.getElementById('root');
const projectNav = document.getElementById('project-nav');
const upd = document.getElementById('upd');
const summary = document.getElementById('summary');
const modal = document.getElementById('modal');
const modalScroll = modal.querySelector('.modal-scroll');
const modalPre = document.getElementById('modal-pre');
const modalTitle = document.getElementById('modal-heading');
const wrapToggle = document.getElementById('wrap-toggle');
const compactToggle = document.getElementById('compact-toggle');
const refreshNow = document.getElementById('refresh-now');
const copyModal = document.getElementById('copy-modal');
const UI_REFRESH_MS = 200;
const FETCH_TIMEOUT_MS = 2000;
const FORCE_FETCH_TIMEOUT_MS = 12000;
const POLL_STALE_WARN_MS = 10000;
const numberFormatter = new Intl.NumberFormat();
let latestState = null;
let pendingState = null;
let renderFrame = 0;
let tickInFlight = null;
let stateFetchController = null;
let stateFetchSeq = 0;
let consecutiveRefreshFailures = 0;
let lastSuccessfulFetchAt = 0;
let lastSummarySignature = '';
let lastNavSignature = '';
let lastRootSignature = '';
let lastSelectedProjectStructureSignature = '';
let lastOverviewLayoutSignature = '';
let overviewSectionSignatures = new Map();
let currentPaneCache = new Map();
let currentPaneElementCache = new Map();
let currentInstanceElementCache = new Map();
let bottomScrollFrame = 0;
const bottomScrollQueue = new Set();
let paneVisibilityObserver = null;
const visiblePaneKeys = new Set();
compactToggle.checked = localStorage.getItem('csupCompactCards') === '1';

modal.addEventListener('click', () => modal.classList.remove('open'));
modal.querySelector('.modal-body').addEventListener('click', e => e.stopPropagation());
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    modal.classList.remove('open');
    return;
  }
  if ((e.key === 'Enter' || e.key === ' ') && e.target.closest) {
    const paneEl = e.target.closest('.pane[data-pane-key]');
    if (paneEl) {
      const item = currentPaneCache.get(paneEl.dataset.paneKey);
      if (item) {
        e.preventDefault();
        showFull(item.project, item.host, item.session, item.pane);
      }
    }
  }
});
wrapToggle.addEventListener('change', () => {
  document.body.classList.toggle('wrap', wrapToggle.checked);
  scrollAllPanesToBottom();
});
compactToggle.addEventListener('change', () => {
  localStorage.setItem('csupCompactCards', compactToggle.checked ? '1' : '0');
  tick(true);
});
refreshNow.addEventListener('click', () => tick(true));
copyModal.addEventListener('click', async () => {
  const text = modalPre.dataset.text || modalPre.textContent || '';
  try { await navigator.clipboard.writeText(text); copyModal.textContent = 'copied'; }
  catch (e) { copyModal.textContent = 'copy failed'; }
  setTimeout(() => copyModal.textContent = 'copy', 1200);
});
document.addEventListener('click', e => {
  const paneEl = e.target.closest && e.target.closest('.pane[data-pane-key]');
  if (paneEl) {
    const item = currentPaneCache.get(paneEl.dataset.paneKey);
    if (item) {
      e.preventDefault();
      showFull(item.project, item.host, item.session, item.pane);
    }
    return;
  }
  const a = e.target.closest && e.target.closest('a[data-route="1"]');
  if (!a) return;
  e.preventDefault();
  if (a.pathname !== window.location.pathname) {
    window.history.pushState({}, '', a.pathname);
    lastRootSignature = '';
    lastNavSignature = '';
  }
  if (latestState) render(latestState);
});
window.addEventListener('popstate', () => {
  lastRootSignature = '';
  lastNavSignature = '';
  if (latestState) render(latestState);
});
document.addEventListener('visibilitychange', () => {
  if (!document.hidden) tick(false);
});

function el(tag, opts) {
  const e = document.createElement(tag);
  if (opts) {
    if (opts.cls) e.className = opts.cls;
    if (opts.text != null) e.textContent = opts.text;
    if (opts.title) e.title = opts.title;
  }
  return e;
}

function escapeHtml(text) {
  return String(text || '').replace(/[&<>]/g, ch => ({'&': '&amp;', '<': '&lt;', '>': '&gt;'}[ch]));
}

function stableStringify(value) {
  try { return JSON.stringify(value); }
  catch (e) { return String(Date.now()); }
}

function setText(node, text) {
  const next = String(text == null ? '' : text);
  if (node.textContent !== next) node.textContent = next;
}

function scheduleBottomScroll(scroller) {
  if (!scroller) return;
  bottomScrollQueue.add(scroller);
  if (bottomScrollFrame) return;
  bottomScrollFrame = requestAnimationFrame(flushBottomScrollQueue);
}

function flushBottomScrollQueue() {
  bottomScrollFrame = 0;
  for (const terminal of bottomScrollQueue) {
    terminal.scrollTop = terminal.scrollHeight;
  }
  bottomScrollQueue.clear();
}

function scrollPaneToBottom(terminal) {
  if (!terminal) return;
  scheduleBottomScroll(terminal);
}

function scrollAllPanesToBottom() {
  for (const terminal of document.querySelectorAll('.pane-terminal')) {
    scheduleBottomScroll(terminal);
  }
  if (modal.classList.contains('open')) {
    scheduleBottomScroll(modalScroll);
  }
}

function stopPaneVisibilityTracking() {
  if (paneVisibilityObserver) paneVisibilityObserver.disconnect();
  paneVisibilityObserver = null;
  visiblePaneKeys.clear();
}

function resetPaneVisibilityTracking() {
  stopPaneVisibilityTracking();
  if (!('IntersectionObserver' in window)) return;
  paneVisibilityObserver = new IntersectionObserver(entries => {
    for (const entry of entries) {
      const key = entry.target && entry.target.dataset ? entry.target.dataset.paneKey : '';
      if (!key) continue;
      if (entry.isIntersecting) {
        visiblePaneKeys.add(key);
        const item = currentPaneCache.get(key);
        const paneEntry = currentPaneElementCache.get(key);
        if (item && paneEntry) {
          updateVisiblePane(paneEntry, item.pane, item.pane.lane || ('pane' + item.pane.index), key, true);
        }
      } else {
        visiblePaneKeys.delete(key);
      }
    }
  }, { root: null, rootMargin: '240px 0px', threshold: 0 });
}

function observePaneCard(card) {
  const key = card && card.dataset ? card.dataset.paneKey : '';
  if (!key) return;
  if (paneVisibilityObserver) {
    paneVisibilityObserver.observe(card);
  } else {
    visiblePaneKeys.add(key);
  }
}

function shouldRenderPaneTerminal(key) {
  return !paneVisibilityObserver || visiblePaneKeys.has(key);
}

function pill(label, value, cls) {
  const p = el('span', { cls: 'pill' + (cls ? ' ' + cls : '') });
  p.append(label + ' ');
  p.appendChild(el('strong', { text: value }));
  return p;
}

function formatNumber(value) {
  const n = Number(value || 0);
  if (!Number.isFinite(n)) return '0';
  return numberFormatter.format(Math.round(n));
}

function formatTokens(value) {
  const n = Number(value || 0);
  if (!Number.isFinite(n) || n <= 0) return '0';
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(2).replace(/\.00$/, '') + 'B';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(2).replace(/\.00$/, '') + 'M';
  if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, '') + 'K';
  return formatNumber(n);
}

function formatBytes(value) {
  const n = Number(value || 0);
  if (!Number.isFinite(n) || n <= 0) return '0 B';
  const units = ['B', 'KB', 'MB', 'GB', 'TB'];
  let v = n;
  let i = 0;
  while (v >= 1024 && i < units.length - 1) { v /= 1024; i += 1; }
  return v.toFixed(v >= 10 || i === 0 ? 0 : 1) + ' ' + units[i];
}

function formatPercent(value) {
  const n = Number(value);
  return Number.isFinite(n) ? n.toFixed(n % 1 ? 1 : 0) + '%' : 'n/a';
}

function formatTime(value) {
  if (!value) return 'no token events yet';
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return value;
  return d.toLocaleTimeString();
}

function metricCard(label, value, note, cls) {
  const card = el('article', { cls: 'metric-card' + (cls ? ' ' + cls : '') });
  card.appendChild(el('div', { cls: 'metric-title', text: label }));
  card.appendChild(el('div', { cls: 'metric-value', text: value }));
  if (note) card.appendChild(el('div', { cls: 'metric-note', text: note }));
  return card;
}

function miniReading(label, value, note) {
  const item = el('div', { cls: 'metric-reading-mini' });
  item.appendChild(el('div', { cls: 'mini-label', text: label }));
  item.appendChild(el('div', { cls: 'mini-value', text: value }));
  if (note) item.appendChild(el('div', { cls: 'mini-note', text: note, title: note }));
  return item;
}

function systemHealthCard(health) {
  const cpu = (health || {}).cpu || {};
  const memory = (health || {}).memory || {};
  const storage = (health || {}).storage || {};
  const localDisk = (health || {}).disk || ((storage.devices || [])[0] || {});
  const status = ((health || {}).status || 'unknown').toUpperCase();
  const card = metricCard(
    'Computer health',
    status,
    'CPU · RAM · local disk grouped together',
    'wide system-health-card' + ((health || {}).status === 'warn' ? ' warn' : '')
  );
  const readings = el('div', { cls: 'metric-reading-grid' });
  readings.appendChild(miniReading('CPU load', formatPercent(cpu.load_percent), '1m ' + (cpu.load_1m ?? 'n/a') + ' · ' + formatNumber(cpu.cores || 0) + ' cores'));
  readings.appendChild(miniReading('RAM used', formatPercent(memory.used_percent), formatBytes(memory.used_bytes) + ' / ' + formatBytes(memory.total_bytes)));
  readings.appendChild(miniReading('Disk free', formatBytes(localDisk.free_bytes), (localDisk.host || 'local') + ' · ' + (localDisk.path || '~')));
  card.appendChild(readings);
  return card;
}

function storageDeviceLabel(device) {
  const aliases = (device.aliases || []).filter(Boolean);
  if (aliases.length > 1) return aliases[0] + ' +' + formatNumber(aliases.length - 1);
  return device.host || aliases[0] || 'host';
}

function storageDeviceTitle(device) {
  const aliases = (device.aliases || []).filter(Boolean);
  const hostText = aliases.length ? aliases.join(', ') : (device.host || 'host');
  const bits = [hostText];
  if (device.node) bits.push('node ' + device.node);
  if (device.job_id) bits.push('job ' + device.job_id);
  if (device.error) bits.push(device.error);
  return bits.join(' · ');
}

function storageHeadroomCard(storage) {
  const devices = ((storage || {}).devices || []).filter(Boolean);
  const connected = devices.filter(d => d.reachable !== false && !d.error && Number(d.total_bytes || 0) > 0);
  const totalFree = Number((storage || {}).free_bytes || connected.reduce((acc, d) => acc + Number(d.free_bytes || 0), 0));
  const usedPct = (storage || {}).used_percent;
  const volumeCount = Number((storage || {}).volume_count || connected.length);
  const volumeNote = volumeCount && volumeCount !== connected.length ? ' · ' + formatNumber(volumeCount) + ' unique volumes' : '';
  const card = metricCard(
    'Storage headroom',
    formatBytes(totalFree),
    formatNumber(connected.length) + ' connected device' + (connected.length === 1 ? '' : 's') + volumeNote + ' · ' + formatPercent(usedPct) + ' used overall',
    'wide storage-card emphasis'
  );
  const list = el('div', { cls: 'storage-device-list' });
  if (!devices.length) {
    list.appendChild(el('div', { cls: 'empty', text: 'No storage devices reported yet.' }));
  }
  for (const device of devices) {
    const row = el('div', { cls: 'storage-device-row', title: storageDeviceTitle(device) });
    const body = el('div');
    const label = storageDeviceLabel(device);
    const role = device.role ? String(device.role).toUpperCase() : 'HOST';
    body.appendChild(el('div', { cls: 'storage-host', text: label + ' · ' + role }));
    body.appendChild(el('div', { cls: 'storage-path', text: device.path || device.error || 'path unavailable' }));
    row.appendChild(body);
    row.appendChild(el('div', { cls: 'storage-free', text: formatBytes(device.free_bytes) + ' free' }));
    const meter = el('div', { cls: 'storage-meter' });
    const fill = el('span');
    const freePct = Number.isFinite(Number(device.used_percent)) ? Math.max(3, 100 - Number(device.used_percent)) : 0;
    fill.style.width = freePct + '%';
    meter.appendChild(fill);
    row.appendChild(meter);
    list.appendChild(row);
  }
  card.appendChild(list);
  return card;
}

function projectSlug(name) {
  return String(name || 'project')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'project';
}

function projectUrl(project) {
  return '/project/' + encodeURIComponent(projectSlug(project.name));
}

function currentProjectSlug() {
  const m = window.location.pathname.match(/^\/project\/([^/]+)\/?$/);
  return m ? decodeURIComponent(m[1]) : '';
}

function capturedInstances(project) {
  return (project.instances || []).filter(inst => inst.panes && inst.panes.length);
}

function countProject(project) {
  const counts = { hosts: 0, panes: 0, errors: 0 };
  for (const inst of capturedInstances(project)) {
    counts.hosts += 1;
    if (inst.error) counts.errors += 1;
    counts.panes += (inst.panes || []).length;
  }
  return counts;
}

function findProject(projects, slug) {
  return (projects || []).find(p => projectSlug(p.name) === slug) || null;
}

function summarize(state) {
  const counts = { projects: 0, hosts: 0, panes: 0, errors: 0, states: {} };
  counts.projects = (state.projects || []).length;
  for (const project of state.projects || []) {
    for (const inst of capturedInstances(project)) {
      counts.hosts += 1;
      if (inst.error) counts.errors += 1;
      for (const pane of inst.panes || []) {
        counts.panes += 1;
        counts.states[pane.state] = (counts.states[pane.state] || 0) + 1;
      }
    }
  }
  return counts;
}

function renderSummary(state) {
  const s = summarize(state);
  const tokenUsage = state.token_usage || {};
  const toolUsage = state.tool_call_usage || {};
  const totals = tokenUsage.total_token_usage || {};
  const signature = stableStringify({ s, totalTokens: totals.total_tokens || 0, toolCalls: toolUsage.total_tool_calls || 0 });
  if (signature === lastSummarySignature) return;
  lastSummarySignature = signature;
  summary.replaceChildren(
    pill('projects', s.projects),
    pill('hosts', s.hosts),
    pill('panes', s.panes),
    pill('issues', s.errors),
    pill('tokens', formatTokens(totals.total_tokens || 0)),
    pill('tools', formatNumber(toolUsage.total_tool_calls || 0))
  );
  for (const [stateName, count] of Object.entries(s.states).sort()) {
    summary.appendChild(pill(stateName, count));
  }
}

function renderProjectNav(state, selectedSlug) {
  const navProjects = state.project_index || (state.projects || []).map(p => ({ name: p.name, slug: projectSlug(p.name), panes: countProject(p).panes }));
  const navModel = navProjects.map(p => ({ name: p.name, slug: p.slug || projectSlug(p.name), panes: p.panes || 0 }));
  const signature = stableStringify({ selectedSlug, navModel });
  if (signature === lastNavSignature) return;
  lastNavSignature = signature;
  const frag = document.createDocumentFragment();
  const overview = el('a', { cls: 'project-tab' + (!selectedSlug ? ' active' : ''), text: 'projects' });
  overview.href = '/';
  overview.dataset.route = '1';
  frag.appendChild(overview);
  for (const p of navProjects) {
    const slug = p.slug || projectSlug(p.name);
    const tab = el('a', { cls: 'project-tab' + (slug === selectedSlug ? ' active' : '') });
    tab.href = projectUrl(p);
    tab.dataset.route = '1';
    tab.appendChild(el('span', { text: p.name }));
    tab.appendChild(el('span', { cls: 'count', text: (p.panes || 0) + ' panes' }));
    frag.appendChild(tab);
  }
  projectNav.replaceChildren(frag);
}

function renderProjectChooser(projects) {
  const wrap = el('div', { cls: 'chooser-grid' });
  for (const p of projects || []) {
    const counts = countProject(p);
    const card = el('a', { cls: 'project-card-link', title: 'Open ' + p.name });
    card.href = projectUrl(p);
    card.dataset.route = '1';
    card.appendChild(el('div', { cls: 'project-card-title', text: p.name }));
    card.appendChild(el('div', { cls: 'project-card-path', text: p.path, title: p.path }));
    const meta = el('div', { cls: 'summary' });
    meta.appendChild(pill('hosts', counts.hosts));
    meta.appendChild(pill('panes', counts.panes));
    meta.appendChild(pill('issues', counts.errors));
    card.appendChild(meta);
    wrap.appendChild(card);
  }
  return wrap;
}

function renderEmptyOverview(projects) {
  if (projects && projects.length) return renderProjectChooser(projects);
  return el('div', { cls: 'empty', text: 'No active supervisor tmux panes were captured.' });
}

function overviewProjectModel(state) {
  return (state.projects || []).map(project => ({
    name: project.name,
    path: project.path,
    slug: projectSlug(project.name),
    counts: countProject(project),
  }));
}

function overviewLayoutSignature(state) {
  return stableStringify({
    mode: 'overview',
    projects: overviewProjectModel(state),
    hasProjects: Boolean((state.projects || []).length),
  });
}

function ensureOverviewSlots(state) {
  const signature = overviewLayoutSignature(state);
  if (root.dataset.viewMode === 'overview' && signature === lastOverviewLayoutSignature) return;
  const frag = document.createDocumentFragment();
  for (const name of ['metrics', 'activities', 'tools', 'diagnostics', 'tokens', 'chooser']) {
    const slot = el('div', { cls: 'overview-slot' });
    slot.dataset.overviewSlot = name;
    frag.appendChild(slot);
  }
  root.replaceChildren(frag);
  root.dataset.viewMode = 'overview';
  lastOverviewLayoutSignature = signature;
  lastRootSignature = '';
  lastSelectedProjectStructureSignature = '';
  currentPaneCache = new Map();
  currentPaneElementCache = new Map();
  currentInstanceElementCache = new Map();
  stopPaneVisibilityTracking();
  overviewSectionSignatures = new Map();
}

function overviewSlot(name) {
  return root.querySelector('[data-overview-slot="' + name + '"]');
}

function updateOverviewSlot(name, signature, renderFn) {
  const slot = overviewSlot(name);
  if (!slot) return;
  if (overviewSectionSignatures.get(name) === signature) return;
  overviewSectionSignatures.set(name, signature);
  slot.replaceChildren(renderFn());
}

function renderOverview(state) {
  ensureOverviewSlots(state);
  updateOverviewSlot('metrics', stableStringify({
    counts: summarize(state),
    token_usage: state.token_usage,
    tool_call_usage: state.tool_call_usage,
    system_health: state.system_health,
    latency_ms: state.last_refresh_duration_ms,
    refresh: state.refresh_count,
  }), () => renderOverviewDashboard(state));
  updateOverviewSlot('activities', stableStringify(recentActivities(state)), () => renderRecentActivities(state));
  updateOverviewSlot('tools', stableStringify(state.tool_call_usage || {}), () => renderToolCallGraphs(state));
  updateOverviewSlot('diagnostics', stableStringify({
    health: state.system_health,
    history: state.system_history,
  }), () => renderSystemDiagnostics(state));
  updateOverviewSlot('tokens', stableStringify(state.token_usage || {}), () => renderTokenGraphs(state));
