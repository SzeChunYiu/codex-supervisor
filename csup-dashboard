    for (const inst of capturedInstances(project)) {
      for (const pane of inst.panes || []) {
        const lane = pane.lane || ('pane' + pane.index);
        const text = lastMeaningfulPaneLine(pane);
        activities.push({
          project: project.name,
          path: project.path,
          host: inst.host,
          session: inst.session,
          lane,
          pane: pane.index,
          state: pane.state || 'idle',
          model: pane.model || '',
          text,
          context: 'tmux ' + inst.session + ' · pane #' + pane.index + ' · ' + inst.host,
        });
      }
    }
  }
  const score = { working: 0, 'goal-done': 1, ready: 2, idle: 3, 'rate-limited': 4, dead: 5 };
  activities.sort((a, b) => (score[a.state] ?? 9) - (score[b.state] ?? 9) || a.project.localeCompare(b.project) || a.pane - b.pane);
  return activities.slice(0, 18);
}

function renderRecentActivities(state) {
  const activities = recentActivities(state);
  const panel = el('section', { cls: 'activity-panel', title: 'Recent activities across panes and projects' });
  const head = el('div', { cls: 'activity-head' });
  const titleWrap = el('div');
  titleWrap.appendChild(el('div', { cls: 'activity-title', text: 'Recent activities' }));
  titleWrap.appendChild(el('div', { cls: 'activity-subtitle', text: 'last meaningful pane output across projects and panes' }));
  head.appendChild(titleWrap);
  head.appendChild(pill('items', activities.length));
  panel.appendChild(head);

  const list = el('div', { cls: 'activity-list' });
  if (!activities.length) {
    list.appendChild(el('div', { cls: 'empty', text: 'No active pane activity captured yet.' }));
  }
  for (const activity of activities) {
    const row = el('article', { cls: 'activity-row' });
    row.appendChild(el('span', { cls: 'activity-rail ' + activity.state }));
    const body = el('div');
    const meta = el('div', { cls: 'activity-meta' });
    meta.appendChild(el('span', { cls: 'activity-project', text: activity.project }));
    meta.appendChild(el('span', { cls: 'activity-lane', text: activity.lane }));
    meta.appendChild(el('span', { cls: 'activity-state', text: activity.state }));
    if (activity.model) meta.appendChild(el('span', { text: activity.model }));
    body.appendChild(meta);
    body.appendChild(el('div', { cls: 'activity-text', text: activity.text, title: activity.text }));
    body.appendChild(el('div', { cls: 'activity-context', text: activity.context, title: activity.path || activity.context }));
    row.appendChild(body);
    list.appendChild(row);
  }
  panel.appendChild(list);
  return panel;
}

function paneKey(project, inst, pane) {
  return [project.name, inst.host, inst.session, pane.index].map(part => encodeURIComponent(String(part == null ? '' : part))).join('|');
}

function instanceKey(project, inst) {
  return [project.name, inst.host, inst.session].map(part => encodeURIComponent(String(part == null ? '' : part))).join('|');
}

function paneTailHtml(pane) {
  return pane.tail_html || escapeHtml((pane.tail || []).join('\n'));
}

function paneContentSignature(pane) {
  return pane.tail_html || (pane.tail || []).join('\n');
}

function paneSelector(key) {
  return '.pane[data-pane-key="' + String(key).replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"]';
}

function selectedProjectStructure(project) {
  return {
    name: project.name,
    path: project.path,
    instances: capturedInstances(project).map(inst => ({
      host: inst.host,
      session: inst.session,
      prompts: inst.prompts,
      panes: (inst.panes || []).map(pane => ({
        index: pane.index,
        width: pane.width,
        height: pane.height,
      })),
    })),
  };
}

function connectionDisplay(inst) {
  const conn = inst.connection || { reachable: inst.reachable };
  let text = conn.reachable ? 'online' : 'offline';
  if (conn.reachable && conn.node) text += ' node ' + conn.node;
  else if (conn.reachable && conn.job_id) text += ' job ' + conn.job_id;
  if (conn.reachable && conn.latency_ms != null) text += ' ' + conn.latency_ms + 'ms';
  const queueWait = Number(conn.queue_wait_ms || 0);
  const title = (conn.error || text) + (queueWait > 0 ? ' · ssh queue wait ' + queueWait + 'ms' : '');
  return { text, title, cls: 'conn ' + (conn.reachable ? 'conn-ok' : 'conn-bad') };
}

function updateConnectionElement(node, inst) {
  if (!node) return;
  const next = connectionDisplay(inst);
  node.className = next.cls;
  node.title = next.title;
  node.hidden = false;
  setText(node, next.text);
}

function updateMonitorElement(node, inst) {
  if (!node) return;
  const monitor = inst.monitor || {};
  if (!monitor.known) {
    node.hidden = true;
    setText(node, '');
    node.title = '';
    return;
  }
  const text = monitor.running
    ? 'monitor pid ' + (monitor.pids || []).join(',')
    : 'monitor missing';
  node.className = 'conn ' + (monitor.running ? 'conn-ok' : 'conn-bad');
  node.title = monitor.error || text;
  node.hidden = false;
  setText(node, text);
}

function updateInstanceErrorElement(node, inst) {
  if (!node) return;
  if (!inst.error) {
    node.hidden = true;
    setText(node, '');
    return;
  }
  node.hidden = false;
  setText(node, '⚠ ' + inst.error);
}

function updateInstanceHeader(entry, inst) {
  if (!entry) return;
  updateConnectionElement(entry.connEl, inst);
  updateMonitorElement(entry.monitorEl, inst);
  updateInstanceErrorElement(entry.errEl, inst);
}

function updatePaneChrome(entry, pane, lane) {
  if (!entry || !entry.card) return;
  const state = pane.state || 'idle';
  if (entry.card.__paneState !== state) {
    entry.card.className = 'pane s-' + state;
    entry.card.__paneState = state;
  }
  const title = 'Open latest tail for ' + lane;
  if (entry.card.title !== title) entry.card.title = title;
  entry.card.setAttribute('aria-label', title);
  if (entry.laneEl) setText(entry.laneEl, lane);
  if (entry.stateEl) {
    entry.stateEl.className = 'state-badge ' + state;
    setText(entry.stateEl, state);
  }
  if (entry.dimsEl) {
    const dims = pane.width && pane.height ? pane.width + '×' + pane.height : '';
    entry.dimsEl.hidden = !dims;
    setText(entry.dimsEl, dims);
  }
  if (entry.modelEl) {
    const model = pane.model || '';
    entry.modelEl.hidden = !model;
    entry.modelEl.title = model;
    setText(entry.modelEl, model);
  }
}

function updateVisiblePane(entry, pane, lane, key, forceTerminal) {
  updatePaneChrome(entry, pane, lane);
  if (!forceTerminal && key && !shouldRenderPaneTerminal(key)) {
    entry.pendingPane = pane;
    return;
  }
  const terminal = entry && entry.terminal;
  const pre = entry && entry.pre;
  if (!terminal || !pre) return;
  const tailSig = paneContentSignature(pane);
  if (pre.__tailSignature === tailSig) return;
  const wasNearBottom = terminal.scrollHeight - terminal.scrollTop - terminal.clientHeight < 28;
  pre.innerHTML = paneTailHtml(pane);
  pre.__tailSignature = tailSig;
  if (wasNearBottom) scrollPaneToBottom(terminal);
}

function renderSelectedProject(project) {
  const structureSignature = stableStringify(selectedProjectStructure(project));
  if (structureSignature !== lastSelectedProjectStructureSignature || root.dataset.viewMode !== 'project') {
    resetPaneVisibilityTracking();
    const nextPaneCache = new Map();
    const nextPaneElementCache = new Map();
    const nextInstanceElementCache = new Map();
    root.replaceChildren(renderProject(project, nextPaneCache, nextPaneElementCache, nextInstanceElementCache));
    root.dataset.viewMode = 'project';
    currentPaneCache = nextPaneCache;
    currentPaneElementCache = nextPaneElementCache;
    currentInstanceElementCache = nextInstanceElementCache;
    lastSelectedProjectStructureSignature = structureSignature;
    return;
  }
  const nextPaneCache = new Map();
  for (const inst of capturedInstances(project)) {
    const ikey = instanceKey(project, inst);
    updateInstanceHeader(currentInstanceElementCache.get(ikey), inst);
    for (const pane of inst.panes || []) {
      const key = paneKey(project, inst, pane);
      nextPaneCache.set(key, { project: project.name, host: inst.host, session: inst.session, pane });
      const entry = currentPaneElementCache.get(key);
      if (entry) {
        updateVisiblePane(entry, pane, pane.lane || ('pane' + pane.index), key, false);
      }
    }
  }
  currentPaneCache = nextPaneCache;
}

function renderProject(p, paneCache, paneElementCache, instanceElementCache) {
  const proj = el('section', { cls: 'project' });
  const head = el('div', { cls: 'project-head' });
  head.appendChild(el('span', { cls: 'name', text: p.name }));
  head.appendChild(el('span', { cls: 'path', text: p.path, title: p.path }));
  proj.appendChild(head);
  proj.appendChild(renderCompanyOffice(p));

  const instances = capturedInstances(p);
  if (!instances.length) {
    proj.appendChild(el('div', { cls: 'empty', text: 'No active supervisor tmux panes were captured for this project.' }));
    return proj;
  }

  // Shared helper: build a pane card, register in caches, return the element
  function buildPaneCard(inst, pane) {
    const lane = pane.lane || ('pane' + pane.index);
    const role = companyRoleForLane(lane, inst.session, inst.host);
    const dims = pane.width && pane.height ? pane.width + '\xd7' + pane.height : '';
    const key = paneKey(p, inst, pane);
    paneCache.set(key, { project: p.name, host: inst.host, session: inst.session, pane });
    const card = el('article', { cls: 'pane s-' + pane.state + ' role-' + role, title: 'Open latest tail for ' + lane });
    card.dataset.paneKey = key;
    card.tabIndex = 0;
    card.setAttribute('role', 'button');
    card.setAttribute('aria-label', 'Open latest tail for ' + lane);
    observePaneCard(card);
    const displayLines = pane.tail_line_count || (pane.tail || []).length || pane.height || 28;
    card.style.setProperty('--pane-lines', Math.max(8, Math.min(32, displayLines)));
    const ph = el('div', { cls: 'pane-head' });
    const laneEl = el('span', { cls: 'lane-tag', text: lane });
    ph.appendChild(laneEl);
    ph.appendChild(el('span', { cls: 'pane-idx', text: '#' + pane.index }));
    const stateEl = el('span', { cls: 'state-badge ' + pane.state, text: pane.state });
    ph.appendChild(stateEl);
    const dimsEl = el('span', { cls: 'pane-dims', text: dims });
    dimsEl.hidden = !dims;
    ph.appendChild(dimsEl);
    let roleBadge = null;
    if (role !== 'worker') {
      roleBadge = el('span', { cls: 'pane-role-badge role-' + role, text: companyRoleLabel(role) });
      ph.appendChild(roleBadge);
    }
    const modelEl = el('span', { cls: 'model-badge', text: pane.model || '', title: pane.model || '' });
    modelEl.hidden = !pane.model;
    ph.appendChild(modelEl);
    card.appendChild(ph);
    const terminal = el('div', { cls: 'pane-terminal' });
    const pre = el('pre', { cls: 'terminal-pre' });
    pre.innerHTML = paneTailHtml(pane);
    pre.__tailSignature = paneContentSignature(pane);
    card.__paneState = pane.state || 'idle';
    terminal.appendChild(pre);
    scrollPaneToBottom(terminal);
    card.appendChild(terminal);
    if (paneElementCache) {
      paneElementCache.set(key, { card, terminal, pre, laneEl, stateEl, dimsEl, modelEl, roleBadge });
    }
    return card;
  }

  // ── CEO section ─────────────────────────────────────────────────────────
  // Collect all gm/CEO panes across ALL instances and render at the top.
  const ceoPaneItems = [];
  for (const inst of instances) {
    for (const pane of (inst.panes || [])) {
      const lane = pane.lane || ('pane' + pane.index);
      if (companyRoleForLane(lane, inst.session, inst.host) === 'gm') {
        ceoPaneItems.push({ inst, pane });
      }
    }
  }
  if (ceoPaneItems.length) {
    const ceoSection = el('div', { cls: 'ceo-section' });
    ceoSection.appendChild(el('div', { cls: 'ceo-section-head', text: '♛ Executive' }));
    const ceoGrid = el('div', { cls: 'grid' });
    ceoPaneItems.forEach(({ inst, pane }) => ceoGrid.appendChild(buildPaneCard(inst, pane)));
    ceoSection.appendChild(ceoGrid);
    proj.appendChild(ceoSection);
  }

  // ── Team sections ────────────────────────────────────────────────────────
  // Render each instance, skipping gm panes (already shown above),
  // with manager panes sorted first within each team.
  for (const inst of instances) {
    const teamPanes = [...(inst.panes || [])].filter(pane => {
      const lane = pane.lane || ('pane' + pane.index);
      return companyRoleForLane(lane, inst.session, inst.host) !== 'gm';
    }).sort((a, b) => {
      const ra = teamPaneRoleRank(companyRoleForLane(a.lane || ('pane' + a.index), inst.session, inst.host));
      const rb = teamPaneRoleRank(companyRoleForLane(b.lane || ('pane' + b.index), inst.session, inst.host));
      return ra - rb || (a.index - b.index);
    });
    if (!teamPanes.length) continue;

    const instDiv = el('div', { cls: 'instance' });
    const ihead = el('div', { cls: 'instance-head' });
    ihead.appendChild(el('span', { cls: 'host-badge ' + inst.host, text: inst.host }));
    ihead.appendChild(el('span', { cls: 'session', text: 'tmux: ' + inst.session }));
    const connEl = el('span');
    updateConnectionElement(connEl, inst);
    ihead.appendChild(connEl);
    const monitorEl = el('span');
    updateMonitorElement(monitorEl, inst);
    ihead.appendChild(monitorEl);
    if (inst.prompts) ihead.appendChild(el('span', { cls: 'prompts', text: 'prompts: ' + inst.prompts, title: inst.prompts }));
    const errEl = el('span', { cls: 'err' });
    updateInstanceErrorElement(errEl, inst);
    ihead.appendChild(errEl);
    if (instanceElementCache) {
      instanceElementCache.set(instanceKey(p, inst), { connEl, monitorEl, errEl });
    }
    instDiv.appendChild(ihead);

    const grid = el('div', { cls: 'grid' });
    teamPanes.forEach(pane => grid.appendChild(buildPaneCard(inst, pane)));
    instDiv.appendChild(grid);
    proj.appendChild(instDiv);
  }
  return proj;
}

function rootSignature(state, selectedSlug, selectedProject) {
  if (!state.projects || !state.projects.length) return 'empty';
  if (!selectedSlug) return 'overview';
  if (!selectedProject) {
    return stableStringify({ mode: 'missing', selectedSlug, projects: (state.projects || []).map(p => p.name) });
  }
  return stableStringify({ mode: 'project', selectedSlug, project: selectedProject });
}

function render(state) {
  latestState = state;
  pendingState = state;
  if (!renderFrame) {
    renderFrame = requestAnimationFrame(flushRender);
  }
}

function renderTransportStatus(state, message) {
  if (message) {
    upd.className = 'subtle status-bad';
    setText(upd, message);
    return;
  }
  const updatedMs = Number((state || {}).updated_at || 0) * 1000;
  const refreshText = updatedMs ? new Date(updatedMs).toLocaleTimeString() : 'never';
  const ageMs = updatedMs ? Math.max(0, Date.now() - updatedMs) : 0;
  const failureText = consecutiveRefreshFailures ? ' · failures ' + consecutiveRefreshFailures : '';
  upd.className = 'subtle' + (ageMs > POLL_STALE_WARN_MS || consecutiveRefreshFailures ? ' status-warn' : '');
  setText(upd, 'last refresh ' + refreshText + failureText);
}

function flushRender() {
  renderFrame = 0;
  const state = pendingState;
  pendingState = null;
  if (!state) return;
  const selectedSlug = currentProjectSlug();
  const selectedProject = selectedSlug ? findProject(state.projects, selectedSlug) : null;
  const scopedState = selectedProject ? { projects: [selectedProject] } : state;
  renderTransportStatus(state);
  renderSummary(scopedState);
  renderProjectNav(state, selectedSlug);

  if (!selectedSlug) {
    renderOverview(state);
    return;
  }

  if (selectedProject) {
    renderSelectedProject(selectedProject);
    return;
  }
  lastSelectedProjectStructureSignature = '';
  lastOverviewLayoutSignature = '';

  const signature = rootSignature(state, selectedSlug, selectedProject);
  if (signature === lastRootSignature) return;
  lastRootSignature = signature;
  root.dataset.viewMode = 'missing';

  const oldScrollY = window.scrollY;
  const frag = document.createDocumentFragment();
  frag.appendChild(el('div', { cls: 'empty', text: 'Project not found. Pick a project above.' }));
  currentPaneCache = new Map();
  currentPaneElementCache = new Map();
  currentInstanceElementCache = new Map();
  stopPaneVisibilityTracking();
  root.replaceChildren(frag);
  if (oldScrollY > 0) {
    requestAnimationFrame(() => window.scrollTo(0, Math.min(oldScrollY, document.documentElement.scrollHeight)));
  }
}

async function showFull(project, host, session, pane) {
  const lane = pane.lane || ('pane' + pane.index);
  modalTitle.textContent = project + ' · ' + host + ' · ' + lane + ' (#' + pane.index + ', ' + pane.state + ')';
  modalPre.textContent = 'loading…';
  modalPre.dataset.text = '';
  modal.classList.add('open');
  try {
    const r = await fetch('/api/pane?format=json&host=' + encodeURIComponent(host) +
      '&session=' + encodeURIComponent(session) + '&index=' + pane.index);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const data = await r.json();
    modalPre.innerHTML = data.html || escapeHtml(data.text || '');
    modalPre.dataset.text = data.text || modalPre.textContent || '';
    requestAnimationFrame(() => {
      modalScroll.scrollTop = modalScroll.scrollHeight;
    });
  } catch (e) {
    modalPre.textContent = 'error: ' + e.message;
    modalPre.dataset.text = modalPre.textContent;
    requestAnimationFrame(() => {
      modalScroll.scrollTop = modalScroll.scrollHeight;
    });
  }
}

async function fetchStateJson(url, timeoutMs) {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
  stateFetchController = controller;
  try {
    const r = await fetch(url, { cache: 'no-store', signal: controller.signal });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return await r.json();
  } finally {
    clearTimeout(timeoutId);
    if (stateFetchController === controller) stateFetchController = null;
  }
}

async function tick(force) {
  if (tickInFlight) {
    if (!force) return tickInFlight;
    stateFetchSeq += 1;
    if (stateFetchController) stateFetchController.abort();
    tickInFlight = null;
  }
  const seq = ++stateFetchSeq;
  if (force) refreshNow.disabled = true;
  tickInFlight = (async () => {
    try {
      const selectedSlug = currentProjectSlug();
      const params = new URLSearchParams();
      if (force) params.set('refresh', '1');
      if (selectedSlug) params.set('project', selectedSlug);
      if (compactToggle.checked) {
        params.set('compact', '1');
        params.set('tail', '6');
      }
      const query = params.toString();
      const url = '/api/state.json' + (query ? '?' + query : '');
      const data = await fetchStateJson(url, force ? FORCE_FETCH_TIMEOUT_MS : FETCH_TIMEOUT_MS);
      if (seq !== stateFetchSeq) return;
      consecutiveRefreshFailures = 0;
      lastSuccessfulFetchAt = Date.now();
      render(data);
    } catch (e) {
      if (seq !== stateFetchSeq) return;
      consecutiveRefreshFailures += 1;
      const reason = e && e.name === 'AbortError' ? 'timeout' : (e && e.message ? e.message : String(e));
      renderTransportStatus(latestState, 'refresh failed: ' + reason + ' · retrying');
    } finally {
      if (seq === stateFetchSeq) {
        if (force) refreshNow.disabled = false;
        tickInFlight = null;
      }
    }
  })();
  return tickInFlight;
}
tick();
// SSE push: re-fetch immediately when the server signals new streaming data.
// Falls back to polling if SSE is unavailable.
(function initSSE() {
  if (typeof EventSource === 'undefined') {
    setInterval(() => { if (!document.hidden) tick(false); }, UI_REFRESH_MS);
    return;
  }
  let sseConnected = false;
  function connectSSE() {
    const es = new EventSource('/api/events');
    es.addEventListener('connected', () => { sseConnected = true; });
    es.addEventListener('update', () => { if (!document.hidden) tick(false); });
    es.onerror = () => {
      sseConnected = false;
      es.close();
      setTimeout(connectSSE, 2000);
    };
  }
  connectSSE();
  // Fallback polling at reduced rate (catches non-streaming updates e.g. local panes)
  setInterval(() => { if (!document.hidden) tick(false); }, 1000);
  setInterval(() => {
    if (!latestState || !lastSuccessfulFetchAt || document.hidden) return;
    if (Date.now() - lastSuccessfulFetchAt > POLL_STALE_WARN_MS) {
      renderTransportStatus(latestState, 'refresh stale · retrying');
      tick(false);
    }
  }, Math.max(1000, Math.floor(POLL_STALE_WARN_MS / 2)));
})();
// MIT-licensed character sprites adapted from harishkotra/agent-office.
const AGENT_OFFICE_CHARACTER_SPRITES = ["data:image/png;base64,", "data:image/png;base64,", "data:image/png;base64,", "data:image/png;base64,", "data:image/png;base64,", "data:image/png;base64,"];

const OFFICE_HANDOFF_MS = 6200;
const OFFICE_HANDOFF_SEEN = new Set();
const OFFICE_HANDOFF_ACTIVE_UNTIL = new Map();

function officeHandoffKey(person) {
  return person.key || [person.name, person.meta, person.role].join('|');
}

function officeShouldRunHandoff(person) {
  const key = officeHandoffKey(person);
  const isFinishedWorker = person.role === 'worker' && (person.state || 'idle') === 'goal-done';
  if (!isFinishedWorker) {
    OFFICE_HANDOFF_SEEN.delete(key);
    OFFICE_HANDOFF_ACTIVE_UNTIL.delete(key);
    return false;
  }
  const now = Date.now();
  const activeUntil = OFFICE_HANDOFF_ACTIVE_UNTIL.get(key) || 0;
  if (activeUntil > now) return true;
  if (!OFFICE_HANDOFF_SEEN.has(key)) {
    OFFICE_HANDOFF_SEEN.add(key);
    OFFICE_HANDOFF_ACTIVE_UNTIL.set(key, now + OFFICE_HANDOFF_MS);
    return true;
  }
  return false;
}

function companyRoleForLane(lane, session, host) {
  const raw = String(lane || session || host || '').toLowerCase();
  if (raw.includes('gm') || raw.includes('general-manager') || raw.includes('general_manager') || raw.includes('general manager') || raw.includes('ceo') || raw.includes('chief')) return 'gm';
  if (raw.includes('validator') || raw.includes('debug') || raw.includes('manager') || raw.includes('meta')) return 'manager';
  if (raw.includes('planner') || raw.includes('plan-') || raw.startsWith('plan')) return 'planner';
  return 'worker';
}

function companyRoleLabel(role) {
  return role === 'gm' ? 'Executive'
    : role === 'manager' ? 'Manager'
    : role === 'planner' ? 'Planner'
    : 'Worker';
}

function teamPaneRoleRank(role) {
  return role === 'gm' ? 0
    : role === 'manager' ? 1
    : role === 'planner' ? 2
    : 3;
}

function teamPaneSortKey(item, fallbackIndex) {
  const role = item.role || 'worker';
  const pane = item.pane || {};
  const idx = Number.isFinite(Number(pane.index)) ? Number(pane.index) : fallbackIndex;
  return [teamPaneRoleRank(role), idx];
}

function sortTeamPaneItems(items) {
  return [...items].sort((a, b) => {
    const ak = teamPaneSortKey(a, a.originalOrder || 0);
    const bk = teamPaneSortKey(b, b.originalOrder || 0);
    return (ak[0] - bk[0]) || (ak[1] - bk[1]) || ((a.originalOrder || 0) - (b.originalOrder || 0));
  });
}

function officeHash(text) {
  let hash = 0;
  const value = String(text || '');
  for (let i = 0; i < value.length; i++) hash = ((hash << 5) - hash + value.charCodeAt(i)) | 0;
  return Math.abs(hash);
}

function officeApplyTimeOfDay() {
  const h = new Date().getHours();
  let sky;
  if (h >= 6 && h < 9) {
    sky = 'linear-gradient(180deg, rgba(255,180,80,.45), rgba(255,140,60,.30), rgba(100,160,220,.40))';
  } else if (h >= 9 && h < 18) {
    sky = 'linear-gradient(180deg, rgba(80,160,255,.55), rgba(140,200,255,.35), rgba(200,230,255,.25))';
  } else if (h >= 18 && h < 21) {
