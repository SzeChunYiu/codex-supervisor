  animation-delay: var(--walk-delay, 0s);
}
.office-person.office-agent.seated-at-desk.face-down .pixel-avatar.sprite-avatar {
  margin-top: 8px;
}
.office-person.office-agent.seated-at-desk.face-up .pixel-avatar.sprite-avatar {
  margin-top: 16px;
}
/* Chair back visible behind seated agent */
.office-person.office-agent.seated-at-desk::before {
  bottom: 22px;
  height: 14px;
  width: 28px;
  left: 10px;
  border-radius: 3px;
  background:
    linear-gradient(rgba(255,255,255,.12) 0 0) 0 0 / 28px 3px no-repeat,
    linear-gradient(#4b5567 0 0) 0 0 / 28px 8px no-repeat,
    linear-gradient(#232838 0 0) 3px 8px / 22px 6px no-repeat;
  opacity: 1;
  box-shadow: 2px 2px 0 rgba(0,0,0,.36);
}
/* Working = typing animation + green glow pulse */
.office-person.office-agent.worker.working .pixel-avatar.sprite-avatar,
.office-person.office-agent.planner.working .pixel-avatar.sprite-avatar,
.office-person.office-agent.manager.working .pixel-avatar.sprite-avatar {
  animation: office-typing .72s ease-in-out infinite;
}
.office-person.office-agent.worker.working::after {
  content: "⌨";
}
.office-person.office-agent.planner.working::after,
.office-person.office-agent.manager.working::after {
  content: "📋";
}
.office-person.office-agent.submitting-route .pixel-avatar.sprite-avatar {
  animation: sprite-walk-right .42s steps(3, end) infinite;
  animation-delay: 0s;
  height: 64px;
  margin-top: 14px;
  clip-path: none;
}
.office-person.office-agent.submitting-route::after {
  content: "📄";
}
.office-person.office-agent:hover .pixel-avatar.sprite-avatar,
.office-person.office-agent:focus-within .pixel-avatar.sprite-avatar {
  outline: 2px solid rgba(255,209,102,.9);
