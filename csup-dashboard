        if match and match in me:
            return name
    return None


def host_is_slurm(host: str, hosts: dict) -> bool:
    return str(hosts.get(host, {}).get("scheduler", "")).lower() == "slurm"


def slurm_job_name(host: str, hosts: dict) -> str:
