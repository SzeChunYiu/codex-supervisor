.office-person.office-agent::after {
  top: 0;
  left: 36px;
  z-index: 6;
}
.office-person.office-agent.at-seat {
  left: calc(var(--agent-x) * var(--cell));
  top: calc(var(--agent-y) * var(--cell));
}
.office-person.office-agent.worker.working,
.office-person.office-agent.planner.working,
.office-person.office-agent.manager.working {
