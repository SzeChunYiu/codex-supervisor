function toolEventStats(events) {
  const counts = {};
  for (const event of events) counts[event.tool || 'unknown'] = (counts[event.tool || 'unknown'] || 0) + 1;
  const top = Object.entries(counts).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
  return {
    total: events.length,
    counts,
    topTool: top.length ? top[0][0] : '',
    topCount: top.length ? top[0][1] : 0,
    latest: events.length ? events[events.length - 1] : null,
  };
}

function bucketToolCalls(events, maxBuckets) {
  const dated = events
    .map(event => ({ ...event, ms: Date.parse(event.timestamp || '') }))
    .filter(event => Number.isFinite(event.ms))
    .sort((a, b) => a.ms - b.ms);
  if (!dated.length) return [];
  const first = dated[0].ms;
  const last = dated[dated.length - 1].ms;
  const span = Math.max(60_000, last - first);
  const bucketMs = Math.max(60_000, Math.ceil(span / Math.max(1, maxBuckets) / 60_000) * 60_000);
  const buckets = new Map();
  for (const event of dated) {
    const start = Math.floor(event.ms / bucketMs) * bucketMs;
    if (!buckets.has(start)) buckets.set(start, { timestamp: new Date(start).toISOString(), count: 0, tools: {} });
    const bucket = buckets.get(start);
    bucket.count += 1;
    bucket.tools[event.tool] = (bucket.tools[event.tool] || 0) + 1;
  }
  return Array.from(buckets.values()).slice(-maxBuckets);
}

function renderToolCallBars(buckets) {
  if (!buckets.length) {
    const empty = el('div', { cls: 'chart-frame' });
    empty.appendChild(el('div', { cls: 'empty', text: 'No recent tool calls found yet.' }));
    return empty;
  }
  const peak = Math.max(1, ...buckets.map(bucket => Number(bucket.count || 0)));
  const frame = renderChartGrid(peak, formatNumber);
  const box = frame.chartBox;
  for (const bucket of buckets) {
    const count = Number(bucket.count || 0);
    const topTools = Object.entries(bucket.tools || {}).sort((a, b) => b[1] - a[1]).slice(0, 3)
      .map(([name, value]) => name + '×' + value).join(' · ');
    const bar = el('span', { cls: 'tool-bar', title: formatNumber(count) + ' tool calls · ' + formatTime(bucket.timestamp) + (topTools ? ' · ' + topTools : '') });
    bar.style.height = Math.max(4, (count / peak) * 100) + '%';
    box.appendChild(bar);
  }
  return frame;
}

