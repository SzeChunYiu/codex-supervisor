    office-celebrate 1.4s steps(4, end) 3,
    office-idle 3s steps(2, end) infinite 4.2s !important;
  animation-delay: var(--walk-delay, 0s) !important;
}
.project-office-panel .office-person.goal-done .pixel-avatar.sprite-avatar {
  animation: sprite-idle-stretch 5s ease-in-out infinite !important;
  animation-delay: var(--walk-delay, 0s) !important;
}
/* Desk surface: screen glow when working */
.project-office-panel .office-person.working .office-desk-surface {
  box-shadow: 0 -2px 8px rgba(171,223,167,.25);
}
.project-office-panel .office-person.gm.working .office-desk-surface {
  box-shadow: 0 -2px 8px rgba(255,209,102,.30);
}
/* New keyframes for project office panel */
@keyframes desk-sway {
  0%, 100% { transform: translate3d(0, 0, 0); }
  33% { transform: translate3d(1.5px, -0.5px, 0); }
  66% { transform: translate3d(-1px, 0.5px, 0); }
}
@keyframes desk-lean {
  0%, 100% { transform: translate3d(0, 0, 0); }
  20% { transform: translate3d(1px, -0.5px, 0); }
  50% { transform: translate3d(-0.5px, 0.5px, 0); }
  80% { transform: translate3d(0.5px, 0, 0); }
}

@keyframes office-walk {
  0%   { transform: translate3d(calc(var(--walk-x, 8px)*-1), 0, 0); }
  12%  { transform: translate3d(calc(var(--walk-x, 8px)*-.7), calc(var(--walk-y, 5px)*-.5), 0); }
  25%  { transform: translate3d(calc(var(--walk-x, 8px)*-.2), calc(var(--walk-y, 5px)*1), 0); }
  37%  { transform: translate3d(calc(var(--walk-x, 8px)*.3), calc(var(--walk-y, 5px)*.3), 0); }
  50%  { transform: translate3d(calc(var(--walk-x, 8px)*.6), calc(var(--walk-y, 5px)*-1), 0); }
  62%  { transform: translate3d(calc(var(--walk-x, 8px)*.85), calc(var(--walk-y, 5px)*.6), 0); }
  80%  { transform: translate3d(calc(var(--walk-x, 8px)*.4), calc(var(--walk-y, 5px)*-.3), 0); }
  100% { transform: translate3d(var(--walk-x, 8px), 0, 0); }
}
.office-person.working {
