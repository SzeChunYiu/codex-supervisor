                    now = time.time()
                    cached = INSTANCE_CAPTURE_CACHE.get(cache_key) or {}
                    if cached.get("value") is None:
                        cached["updated_at"] = now
                        cached["value"] = None
                    cached["last_attempt_at"] = now
                    cached["last_error"] = "remote capture JSON too large"
                    cached["refreshing"] = False
