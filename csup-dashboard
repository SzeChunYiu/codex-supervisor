def pane_title_indicates_activity(title: str | None) -> bool:
    stripped = str(title or "").strip()
    return bool(stripped) and stripped[0] in BRAILLE_SPINNER_CHARS


def lane_label_for_capture(item: dict, lane_map: dict[int, str] | None = None) -> str:
    known_lanes = set((lane_map or {}).values())
    pane_title = item.get("title") or ""
    idx_val = bounded_int(item.get("index"), 0, min_value=0)
    ordinal_val = bounded_int(item.get("ordinal"), -1, min_value=0)
    if pane_title and pane_title != (item.get("cmd") or ""):
        if str(pane_title).strip().upper() in {"CEO", "MANAGER"}:
            return str(pane_title).strip().upper()
        if (not pane_title_indicates_activity(pane_title)) and (not known_lanes or pane_title in known_lanes):
            return str(pane_title)
    mapped = (lane_map or {}).get(ordinal_val, "") or (lane_map or {}).get(idx_val, "")
    if not mapped:
        ansi_text = str(item.get("ansi") or item.get("tail") or "")
        if re.search(r"\blane\s+CEO\b", ansi_text, re.IGNORECASE):
            return "CEO"
        if re.search(r"\blane\s+MANAGER\b", ansi_text, re.IGNORECASE):
            return "MANAGER"
    # Prompt files use "PANE N" ordinals, while tmux pane indexes may start
    # at 1 on clusters. Prefer ordinal labels to avoid off-by-one lane names
    # on base-index=1 tmux servers.
    return str(mapped)


def clone_jsonable(value):
    """Return a JSON-safe copy without non-finite floats or exotic keys."""
    if isinstance(value, dict):
        return {str(k): clone_jsonable(v) for k, v in value.items()}
    if isinstance(value, (list, tuple)):
        return [clone_jsonable(v) for v in value]
    if isinstance(value, float):
        return value if math.isfinite(value) else None
    if value is None or isinstance(value, (str, int, bool)):
        return value
    return str(value)


def json_api_bytes(value) -> bytes:
    return json.dumps(clone_jsonable(value), allow_nan=False).encode()


def project_slug(name: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", str(name or "project").lower()).strip("-")
    return slug or "project"


def project_identity(project: dict) -> str:
    """Stable internal project key.

    Project names are display labels, not identifiers: users can run multiple
    worktrees with the same configured project.name.  Keying dashboard capture
    state by name makes those worktrees share the same instance list, which
    double-counts panes and makes one route shadow the other.
    """
    path = str(project.get("path", "") or "")
    if path:
        return path
    return str(project.get("name", "") or "project")


def unique_project_slug(project: dict, duplicate_names: set[str]) -> str:
    base = project_slug(project.get("name", ""))
    if base not in duplicate_names:
        return base
    digest = hashlib.sha1(project_identity(project).encode("utf-8")).hexdigest()[:8]
    return f"{base}-{digest}"


def assign_project_slugs(projects: list[dict]) -> None:
    counts: dict[str, int] = {}
    for project in projects:
        base = project_slug(project.get("name", ""))
        counts[base] = counts.get(base, 0) + 1
    duplicate_names = {slug for slug, count in counts.items() if count > 1}
    used: set[str] = set()
    for project in projects:
        slug = unique_project_slug(project, duplicate_names)
        if slug in used:
            digest = hashlib.sha1((project_identity(project) + "\0" + slug).encode("utf-8")).hexdigest()[:8]
            slug = f"{slug}-{digest}"
        project["slug"] = slug
        used.add(slug)


def count_project_payload(project: dict) -> dict:
    hosts = 0
    panes = 0
    errors = 0
    pane_issues = 0
    for inst in project.get("instances", []) or []:
        inst_panes = inst.get("panes", []) or []
        if not inst_panes:
            continue
        hosts += 1
        panes += len(inst_panes)
        if inst.get("error"):
            errors += 1
        for pane in inst_panes:
            if pane_issue_reasons(inst, pane):
                pane_issues += 1
    return {
        "hosts": hosts,
        "panes": panes,
        "errors": errors + pane_issues,
        "issue_count": errors + pane_issues,
        "instance_error_count": errors,
        "pane_issue_count": pane_issues,
    }


def pane_issue_reasons(inst: dict, pane: dict) -> list[str]:
    """Return dashboard-visible pane health reasons.

    Keep this in sync with `health_payload()` and the frontend issue badges:
    the header/project "issues" counts must describe the same backstage state
    that `/api/health.json` reports.  Previously the visible dashboard counted
    only instance errors, so idle/dead/stale panes showed health=degraded while
    the header still displayed `issues 0`.
    """
    monitor = inst.get("monitor") if isinstance(inst.get("monitor"), dict) else {}
    monitor_expected = bool(inst.get("monitor_expected", True))
    monitor_running = (not monitor_expected) or bool(monitor.get("running"))
    pane_state = str(pane.get("state") or "?")
    reasons: list[str] = []
    if monitor_expected and (
        pane_state in {"idle", "ready", "?", "dead"}
        or (pane_state == "goal-done" and not monitor_running)
    ):
        reasons.append(f"pane-{pane_state}")
    if pane_state == "rate-limited" and not monitor_running:
        reasons.append("rate-limited")
    if pane.get("capture_stale"):
        reasons.append("capture-stale")
    return reasons


def compact_state_panes(snapshot: dict, tail_lines: int) -> None:
    keep = bounded_int(tail_lines, 6, min_value=1, max_value=50)
    for project in snapshot.get("projects", []) or []:
        for inst in project.get("instances", []) or []:
            for pane in inst.get("panes", []) or []:
                tail = [str(line) for line in (pane.get("tail") or [])]
                if len(tail) > keep:
                    pane["tail"] = tail[-keep:]
                else:
                    pane["tail"] = tail
                pane["tail_line_count"] = len(pane["tail"])
                # Compact live cards prefer low payload + cheap text escaping.
                # The click-through pane endpoint still serves rich ANSI HTML.
                pane.pop("tail_html", None)


def apply_streaming_cache_overlay(snapshot: dict, tail_lines: int) -> None:
    """Overlay latest streamer panes onto the cached refresh snapshot.

    The dashboard refresh loop discovers projects/instances, but the persistent
    streamers update pane text much more frequently.  SSE clients re-fetch
    /api/state.json on every stream update; without this overlay they would get
    the last refresh-loop snapshot and appear frozen until the next full poll.
    """
    try:
        hosts = known_hosts()
    except Exception:
        hosts = {}
    keep_lines = bounded_int(tail_lines, DEFAULT_TAIL, min_value=1, max_value=200)
    for project in snapshot.get("projects", []) or []:
        for inst in project.get("instances", []) or []:
            host = str(inst.get("host", "") or "")
            session = str(inst.get("session", "") or "")
            connection = inst.get("connection") if isinstance(inst.get("connection"), dict) else {}
            job_id = str(connection.get("job_id") or "")
            if not host or not session or not job_id:
                continue
            info = hosts.get(host, {})
            ssh_target = str(info.get("ssh", "") or "")
            if not ssh_target:
                continue
            stream_key = streaming_connection_key(ssh_target, job_id)
            with STREAMING_CACHE_LOCK:
                cached = clone_jsonable(STREAMING_CACHE.get((stream_key, session)) or {})
            raw_panes = cached.get("panes") or []
            if not raw_panes:
                continue
            existing_lanes = {}
            for pane in (inst.get("panes") or []):
                if pane.get("index") is None:
                    continue
                idx = bounded_int(pane.get("index"), -1, min_value=0)
                if idx >= 0:
                    existing_lanes[idx] = str(pane.get("lane") or "")
            panes = [
                render_captured_item_simple(item, tail_lines=keep_lines)
                for item in raw_panes
            ]
            for pane in panes:
                idx = bounded_int(pane.get("index"), -1, min_value=0)
                if idx < 0:
                    continue
                if existing_lanes.get(idx):
                    pane["lane"] = existing_lanes[idx]
            inst["panes"] = panes
            if cached.get("monitor"):
                inst["monitor"] = cached.get("monitor")
                set_monitor_status(host, session, cached.get("monitor") or empty_monitor_status())
            inst["stream_updated_at"] = bounded_float(cached.get("ts"), 0.0, min_value=0.0)


def state_payload(project_filter: str = "", *, compact: bool = False,
                  tail_lines: int = 6) -> dict:
    with CACHE_LOCK:
        snapshot = clone_jsonable(CACHE)
    projects = snapshot.get("projects", []) or []
    apply_streaming_cache_overlay(snapshot, tail_lines)
    assign_project_slugs(projects)
    for project in projects:
        project.update(count_project_payload(project))
    snapshot["project_index"] = [
        {
            "name": project.get("name", ""),
            "slug": project.get("slug") or project_slug(project.get("name", "")),
            **count_project_payload(project),
        }
        for project in projects
    ]
    if project_filter:
        snapshot["projects"] = [
            project for project in projects
            if (project.get("slug") or project_slug(project.get("name", ""))) == project_filter
        ]
    if compact:
        compact_state_panes(snapshot, tail_lines)
    return snapshot


def empty_monitor_status() -> dict:
    return {"known": False, "running": False, "pids": [], "updated_at": 0, "error": ""}


def set_monitor_status(host: str, session: str, status: dict) -> None:
    value = dict(status or {})
    value.setdefault("known", True)
    value.setdefault("running", bool(value.get("pids")))
    value.setdefault("pids", [])
    value.setdefault("error", "")
    value["updated_at"] = time.time()
    with INSTANCE_MONITOR_CACHE_LOCK:
        INSTANCE_MONITOR_CACHE[monitor_cache_key(host, session)] = value


def get_monitor_status(host: str, session: str) -> dict:
    with INSTANCE_MONITOR_CACHE_LOCK:
        value = INSTANCE_MONITOR_CACHE.get(monitor_cache_key(host, session))
    return clone_jsonable(value) if value else empty_monitor_status()


def parse_monitor_status_from_ps(output: str, session: str) -> dict:
    candidates: list[tuple[int, int]] = []
    daemon_seen = False
    for raw in (output or "").splitlines():
        line = raw.strip()
        if not line or "codex-supervisor.sh" not in line:
            continue
        parts = line.split(None, 2)
        if len(parts) < 2:
            continue
        pid_raw = parts[0]
        ppid_raw = "0"
        if len(parts) >= 3 and parts[1].isdigit():
            ppid_raw = parts[1]
            args = parts[2]
        else:
            args = line.split(None, 1)[1]
        if "--daemon" not in args or "--session" not in args:
            continue
        daemon_seen = True
        try:
            argv = shlex.split(args)
        except ValueError:
            argv = args.split()
        for i, arg in enumerate(argv[:-1]):
            if arg == "--session" and argv[i + 1] == session:
                try:
                    candidates.append((int(pid_raw), int(ppid_raw)))
                except (ValueError, OverflowError):
                    pass
                break
    candidate_pids = {pid for pid, _ in candidates}
    # Bash background prompt-sender subshells inherit the parent script's
    # command line, so they look like `start --daemon --session ...` in ps.
    # They are children of the actual monitor daemon; keep only root candidates.
    pids = [pid for pid, ppid in candidates if ppid not in candidate_pids]
    return {"known": True, "running": bool(pids), "pids": pids, "daemon_seen": daemon_seen, "error": ""}


def capture_monitor_status_with_runner(runner, session: str) -> dict:
    try:
        r = runner(["ps", "-axo", "pid=,ppid=,args="])
    except Exception as e:
        return {"known": True, "running": False, "pids": [], "error": str(e)[:160]}
    if r.returncode != 0:
        return {
            "known": True,
            "running": False,
            "pids": [],
            "error": (r.stderr or r.stdout or f"ps exited {r.returncode}").strip()[:160],
        }
    return parse_monitor_status_from_ps(r.stdout or "", session)


def capture_cache_value_with_status(cached: dict, now: float) -> list[dict] | None:
    value = cached.get("value")
    if value is None:
        return None
    cloned = clone_jsonable(value)
    last_error = str(cached.get("last_error") or "")
    if last_error:
        age = cache_age(now, cached.get("updated_at"))
        for pane in cloned:
            pane["capture_stale"] = True
            pane["capture_age_secs"] = round(age, 1)
            pane["capture_error"] = last_error[:160]
    return cloned


def capture_cache_problem(host: str, session: str, lines: int,
                          lane_map: dict[int, str] | None = None) -> dict:
    cache_lines = bounded_int(lines, DEFAULT_TAIL, min_value=1, max_value=200)
    cache_key = capture_cache_key(host, session, cache_lines, lane_map)
    with INSTANCE_CAPTURE_CACHE_LOCK:
        cached = clone_jsonable(INSTANCE_CAPTURE_CACHE.get(cache_key) or {})
    if not cached:
        return {}
    if cached.get("value") is None and cached.get("last_error"):
        return {
            "error": str(cached.get("last_error") or "")[:160],
            "refreshing": bool(cached.get("refreshing")),
            "last_attempt_age_secs": round(cache_age(time.time(), cached.get("last_attempt_at")), 1),
        }
    return {}


def capture_cached_panes_with_error(host: str, session: str, lines: int,
                                    lane_map: dict[int, str] | None,
                                    error: str) -> list[dict] | None:
    cache_lines = bounded_int(lines, DEFAULT_TAIL, min_value=1, max_value=200)
