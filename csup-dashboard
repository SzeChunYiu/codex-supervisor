def dashboard_source_info() -> dict:
    path = pathlib.Path(__file__).resolve()
    try:
        data = path.read_bytes()
        stat = path.stat()
        return {
            "path": str(path),
            "mtime": stat.st_mtime,
            "size_bytes": stat.st_size,
            "sha256": hashlib.sha256(data).hexdigest()[:16],
        }
    except OSError as e:
        return {"path": str(path), "mtime": 0, "size_bytes": 0, "sha256": "", "error": str(e)[:160]}


