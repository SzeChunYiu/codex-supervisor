#!/bin/bash
# csup — codex-supervisor launcher (cross-host)
#
# Reads a project's .codex-supervisor.toml + ~/.config/csup/hosts.toml and
# starts/stops/inspects supervisor sessions across known hosts.
#
# Subcommands:
#   csup start <project> [--host=<name>] [--fallback]
#   csup submit <project> <lane> <goal text...>
#   csup capacity [--json]
#   csup govern [--dry-run|--apply] [--json] [--max-panes=N] [--project=<name>] [--host=<name>]
#   csup factory-audit [--project=<name>|<project>]
#   csup factory-run <project> [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply]
#   csup staff <project> [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply] [--allow-stop]
#   csup steward [--project=<name>|<project>] [--sample-secs=N]
#   csup station <project> --sessions=N --workers=N [--host=<name>] [--dry-run|--apply]
#   csup stop  <project> [--host=<name>]
#   csup status [<project>]
#   csup ls
#   csup hosts
#
# Project lookup order (matches a project name to a directory):
#   1) cwd if .codex-supervisor.toml present in cwd
#   2) ~/Desktop/projects/<name>/.codex-supervisor.toml
#   3) ~/<name>/.codex-supervisor.toml
#
# Host detection (which host am I on right now):
#   uname -n is matched against hosts[*].hostname_match.
#
# Fallback semantics:
#   --fallback (or env CSUP_FALLBACK=1): if the requested host is unreachable,
#   run the lanes locally instead. Prints a clear warning. Without --fallback,
#   prints the warning and exits non-zero.
#
# This script is idempotent: re-running `start` on an active session re-attaches
# rather than failing.

set -u
HOSTS_FILE="${CSUP_HOSTS_FILE:-$HOME/.config/csup/hosts.toml}"
PROJECT_ROOTS_FILE="${CSUP_PROJECT_ROOTS_FILE:-$HOME/.config/csup/project-roots.txt}"
SUPERVISOR="${CSUP_SUPERVISOR:-$HOME/codex-supervisor.sh}"
DEFAULT_RUNTIME_ROOT="$HOME/.codex-supervisor"
[[ -d "/Volumes/MyDrive" ]] && DEFAULT_RUNTIME_ROOT="/Volumes/MyDrive/codex-supervisor"
RUNTIME_ROOT="${CSUP_RUNTIME_ROOT:-${CODEX_SUPERVISOR_ROOT:-$DEFAULT_RUNTIME_ROOT}}"

err() { printf 'csup: error: %s\n' "$*" >&2; }
warn() { printf 'csup: warn: %s\n' "$*" >&2; }
info() { printf 'csup: %s\n' "$*"; }

ensure_tmpdir_headroom() {
  [[ "${CSUP_DISABLE_TMPDIR_FALLBACK:-0}" == "1" ]] && return 0
  local min_kb cur="${TMPDIR:-/tmp}" avail candidate
  min_kb="${CSUP_MIN_TMP_KB:-262144}"
  [[ "$min_kb" =~ ^[0-9]+$ && "$min_kb" -gt 0 ]] || min_kb=262144
  mkdir -p "$cur" 2>/dev/null || true
  avail=$(df -k "$cur" 2>/dev/null | awk 'NR==2 {print $4+0}')
  [[ "$avail" =~ ^[0-9]+$ ]] || avail=0
  (( avail >= min_kb )) && return 0
  for candidate in \
    "${CSUP_TMPDIR_FALLBACK:-}" \
    "/Volumes/MyDrive/codex-supervisor/tmp" \
    "/private/tmp"; do
    [[ -n "$candidate" ]] || continue
    mkdir -p "$candidate" 2>/dev/null || continue
    avail=$(df -k "$candidate" 2>/dev/null | awk 'NR==2 {print $4+0}')
    [[ "$avail" =~ ^[0-9]+$ ]] || avail=0
    if (( avail >= min_kb )); then
      export TMPDIR="$candidate"
      [[ "${CSUP_DEBUG_TMPDIR:-0}" == "1" ]] && warn "using TMPDIR=$TMPDIR because ${cur:-/tmp} has low headroom"
      return 0
    fi
  done
  warn "temporary filesystem has low headroom (${avail}KB available); Python-backed config parsing may fail"
}

ensure_tmpdir_headroom

ssh_timeout_secs() {
  local value="${CSUP_SSH_TIMEOUT_SECS:-8}"
  [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]] || value=8
  printf '%s' "$value"
}

shell_run_timeout() {
  local timeout="$1" cmd="$2"
  python3 - "$timeout" "$cmd" <<'PY'
import math, os, signal, subprocess, sys
try:
    timeout = float(sys.argv[1])
    if not math.isfinite(timeout) or timeout <= 0:
        timeout = 8.0
except (TypeError, ValueError):
    timeout = 8.0
cmd = sys.argv[2]
try:
    p = subprocess.Popen(
        cmd,
        shell=True,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    try:
        p.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(p.pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            p.wait(timeout=1)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(p.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            p.wait()
except Exception:
    sys.exit(124)
sys.exit(p.returncode)
PY
}

shell_capture_timeout() {
  local timeout="$1" cmd="$2"
  python3 - "$timeout" "$cmd" <<'PY'
import math, os, signal, subprocess, sys
try:
    timeout = float(sys.argv[1])
    if not math.isfinite(timeout) or timeout <= 0:
        timeout = 8.0
except (TypeError, ValueError):
    timeout = 8.0
cmd = sys.argv[2]
try:
    p = subprocess.Popen(
        cmd,
        shell=True,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        start_new_session=True,
    )
    try:
        stdout, _ = p.communicate(timeout=timeout)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(p.pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        try:
            stdout, _ = p.communicate(timeout=1)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(p.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            stdout, _ = p.communicate()
        sys.exit(124)
except Exception:
    sys.exit(124)
sys.stdout.write(stdout)
sys.exit(p.returncode)
PY
}

join_csv() {
  local IFS=,
  printf '%s' "$*"
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

ssh_command_target() {
  local target="$1"
  case "$target" in
    lunarc*) printf 'lunarc' ;;
    *) printf '%s' "$target" ;;
  esac
}

ssh_cmd_prefix() {
  local target="$1" actual
  actual=$(ssh_command_target "$target")
  printf 'ssh -o ConnectTimeout=3 -o BatchMode=yes -o ServerAliveInterval=10 -o ServerAliveCountMax=1 -o ControlMaster=auto -o ControlPath=%s %s' \
    "$(shell_quote "$HOME/.ssh/sockets/%r@%h-%p")" \
    "$(shell_quote "$actual")"
}

ssh_exec() {
  local target="$1" remote_cmd="$2"
  # Never let ssh consume a caller's stdin. Many csup commands iterate over
  # process-substitution streams of hosts; an ssh command that inherits stdin
  # can drain the remaining host list and make status/start/stop silently skip
  # configured projects.
  eval "$(ssh_cmd_prefix "$target") $(shell_quote "$remote_cmd")" </dev/null
}

ssh_capture_timeout() {
  local target="$1" remote_cmd="$2"
  shell_capture_timeout "$(ssh_timeout_secs)" "$(ssh_cmd_prefix "$target") $(shell_quote "$remote_cmd")"
}

# ---------------------------------------------------------------------------
# Tiny TOML reader (Python-backed for portability across macOS / Linux awks).
# Handles the subset we use:
#   key = "value"
#   key = value          (no quotes — int / bool / bare word)
#   [section.subsection]
# Comments (#) and blank lines are skipped. Multiline arrays not supported.
# Usage: toml_get <file> <section> <key>  -> prints value (no quotes)
# ---------------------------------------------------------------------------
toml_get() {
  local file="$1" section="$2" key="$3"
  python3 - "$file" "$section" "$key" <<'PY'
import re, sys
path, want_sec, want_key = sys.argv[1], sys.argv[2], sys.argv[3]
cur = ""
try:
    with open(path) as f:
        for line in f:
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            if s.startswith("["):
                cur = s.strip("[]").replace('"', '')
                continue
            if cur != want_sec:
                continue
            m = re.match(r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*?)(?:\s*#.*)?$', s)
            if m and m.group(1) == want_key:
                v = m.group(2).strip()
                if len(v) >= 2 and v[0] == '"' and v[-1] == '"':
                    v = v[1:-1]
                print(v)
                sys.exit(0)
except FileNotFoundError:
    pass
PY
}

toml_sections() {
  local file="$1" prefix="$2"
  python3 - "$file" "$prefix" <<'PY'
import sys
path, prefix = sys.argv[1], sys.argv[2]
try:
    with open(path) as f:
        for line in f:
            s = line.strip()
            if s.startswith("[") and s.endswith("]"):
                name = s.strip("[]").replace('"', '')
                if name.startswith(prefix):
                    print(name[len(prefix):])
except FileNotFoundError:
    pass
PY
}

# ---------------------------------------------------------------------------
# Project discovery
# ---------------------------------------------------------------------------
project_candidates() {
  local d extra_roots
  for d in \
    "$HOME/Desktop/projects"/* \
    "/home/billy/Desktop/projects"/*; do
    [[ -d "$d" && -f "$d/.codex-supervisor.toml" ]] || continue
    ( cd "$d" && pwd )
  done

  extra_roots="${CSUP_EXTRA_PROJECT_ROOTS:-}"
  if [[ -z "$extra_roots" && "$HOME" == "/Users/billy" ]]; then
    extra_roots="/Volumes/MyDrive/nnbar/nnbar/simulation"
  fi
  local IFS=:
  for d in $extra_roots; do
    [[ -d "$d" && -f "$d/.codex-supervisor.toml" ]] || continue
    ( cd "$d" && pwd )
  done
}

remember_project_root() {
  local root="$1" real dir tmp
  [[ -n "$root" && -d "$root" ]] || return 0
  real=$(cd "$root" && pwd -P 2>/dev/null) || return 0
  dir=$(dirname "$PROJECT_ROOTS_FILE")
  mkdir -p "$dir" 2>/dev/null || return 0
  tmp="${PROJECT_ROOTS_FILE}.$$"
  {
    [[ -f "$PROJECT_ROOTS_FILE" ]] && cat "$PROJECT_ROOTS_FILE"
    printf '%s\n' "$real"
  } | awk 'NF && !seen[$0]++' > "$tmp" 2>/dev/null && mv "$tmp" "$PROJECT_ROOTS_FILE" 2>/dev/null || rm -f "$tmp"
}

find_project_config() {
  local name="$1"
  if [[ -z "$name" && -f "./.codex-supervisor.toml" ]]; then
    local here; here=$(pwd -P)
    remember_project_root "$here"
    printf '%s\n' "$here"; return 0
  fi
  # Accept absolute path directly (used when cmd_staff passes resolved project_dir)
  if [[ "$name" == /* && -d "$name" && -f "$name/.codex-supervisor.toml" ]]; then
    local abs; abs=$(cd "$name" && pwd -P)
    remember_project_root "$abs"
    printf '%s\n' "$abs"; return 0
  fi
  for d in \
    "./$name" \
    "$HOME/Desktop/projects/$name" \
    "$HOME/$name" \
    "/home/billy/Desktop/projects/$name"; do
    if [[ -f "$d/.codex-supervisor.toml" ]]; then
      local found; found=$(cd "$d" && pwd -P)
      remember_project_root "$found"
      printf '%s\n' "$found"; return 0
    fi
  done
  while read -r d; do
    [[ -n "$d" ]] || continue
    local cfg_name; cfg_name=$(toml_get "$d/.codex-supervisor.toml" "project" "name")
    if [[ "$cfg_name" == "$name" ]]; then
      remember_project_root "$d"
      printf '%s\n' "$d"; return 0
    fi
  done < <(project_candidates)
  return 1
}

list_projects() {
  while read -r d; do
    [[ -n "$d" ]] || continue
    local name; name=$(toml_get "$d/.codex-supervisor.toml" "project" "name")
    [[ -z "$name" ]] && name=$(basename "$d")
    remember_project_root "$d"
    printf '  %-20s  %s\n' "$name" "$d"
  done < <(project_candidates)
}

# ---------------------------------------------------------------------------
# Host discovery & reachability
# ---------------------------------------------------------------------------
host_field() {
  toml_get "$HOSTS_FILE" "hosts.$1" "$2"
}

host_scheduler() {
  host_field "$1" "scheduler"
}

host_ssh_target() {
  host_field "$1" "ssh"
}

host_is_lunarc() {
  local host="$1" ssh_target
  ssh_target=$(host_ssh_target "$host")
  [[ "$host" == *lunarc* || "$ssh_target" == lunarc* ]]
}

# Returns 0 if we are currently running inside a LUNARC SLURM compute node.
# Compute nodes can run sbatch/squeue directly — no SSH to login node needed.
on_lunarc_compute_node() {
  [[ -n "${SLURM_JOB_ID:-}" ]] || return 1
  local h; h=$(hostname -s 2>/dev/null || hostname)
  case "$h" in cn*|cx*|cg*) return 0 ;; esac
  return 1
}

slurm_compute_guard_snippet() {
  # This snippet runs inside the `srun` payload, not on the SSH login shell.
  # It is intentionally fail-closed: if SLURM did not place us inside an
  # allocation, do not start tmux/Codex on the login node.
  printf '%s' 'if [[ -z "${SLURM_JOB_ID:-}" ]]; then echo "csup: refusing to start supervisor outside a SLURM allocation (login node forbidden)" >&2; exit 97; fi; _csup_node=$(hostname -s 2>/dev/null || hostname); case "$_csup_node" in login*|ln*) echo "csup: refusing to start supervisor on login node ${_csup_node}" >&2; exit 97 ;; esac'
}

host_remote_env() {
  local env_cmd; env_cmd=$(host_field "$1" "remote_env")
  if [[ -z "$env_cmd" && "$(host_scheduler "$1")" == "slurm" ]]; then
    env_cmd="source /projects/hep/fs10/shared/codex-tooling/env-shared.sh"
  fi
  printf '%s' "$env_cmd"
}

host_supervisor() {
  local supervisor; supervisor=$(host_field "$1" "supervisor")
  if [[ -z "$supervisor" && "$(host_scheduler "$1")" == "slurm" ]]; then
    supervisor="/projects/hep/fs10/shared/codex-tooling/supervisor/codex-supervisor.sh"
  fi
  [[ -z "$supervisor" ]] && supervisor="~/codex-supervisor.sh"
  printf '%s' "$supervisor"
}

ssh_login_reachable() {
  local host="$1" ssh_target probe
  ssh_target=$(host_ssh_target "$host")
  [[ "$ssh_target" == "local" ]] && return 1
  probe=$(host_field "$host" "reachable")
  if [[ -z "$probe" ]]; then
    probe="$(ssh_cmd_prefix "$ssh_target") true"
  elif [[ "$ssh_target" == lunarc* ]]; then
    # LUNARC aliases must use the pre-authenticated canonical master socket.
    # Host configs may contain older reachability probes without ControlPath;
    # ignoring them here prevents false "login_unreachable" failures.
    probe="$(ssh_cmd_prefix "$ssh_target") true"
  fi
  shell_run_timeout "$(ssh_timeout_secs)" "$probe"
}

slurm_job_name() {
  local name; name=$(host_field "$1" "slurm_job_name")
  [[ -z "$name" ]] && name="csup-$1"
  printf '%s' "$name"
}

slurm_job_name_for_slot() {
  local host="$1" slot="${2:-1}" base
  base=$(slurm_job_name "$host")
  if [[ "$slot" == "1" ]]; then
    printf '%s' "$base"
  else
    printf '%s-%s' "$base" "$slot"
  fi
}

slurm_active_job_id() {
  local info
  info=$(slurm_active_job_info "$1" || true)
  [[ -n "$info" ]] || return 1
  printf '%s\n' "${info%%|*}"
}

slurm_active_job_node() {
  local info node
  info=$(slurm_active_job_info "$1" || true)
  [[ -n "$info" && "$info" == *"|"* ]] || return 1
  node="${info#*|}"
  [[ -n "$node" && "$node" != "$info" ]] || return 1
  printf '%s\n' "$node"
}

slurm_active_job_info() {
  local host="$1" name
  name=$(slurm_job_name "$host")
  slurm_active_job_info_named "$host" "$name"
}

slurm_active_job_info_named() {
  local host="$1" name="$2" ssh_target
  ssh_target=$(host_ssh_target "$host")
  # On a LUNARC compute node squeue is available directly — no SSH needed.
  if on_lunarc_compute_node && host_is_lunarc "$host"; then
    squeue -h -u "$(whoami)" -n "$name" -t RUNNING -o '%i|%N' 2>/dev/null | head -1
    return 0
  fi
  [[ -n "$ssh_target" && "$ssh_target" != "local" ]] || return 1
  shell_capture_timeout "$(ssh_timeout_secs)" "$(ssh_cmd_prefix "$ssh_target") \"squeue -h -u \\\$(whoami) -n $(shell_quote "$name") -t RUNNING -o '%i|%N' 2>/dev/null | head -1\"" 2>/dev/null
}

slurm_submit_holder() {
  local host="$1" name
  name=$(slurm_job_name "$host")
  slurm_submit_holder_named "$host" "$name"
}

slurm_submit_holder_named() {
  local host="$1" name="$2" ssh_target partition account time nodes cpus mem workdir output wrap
  ssh_target=$(host_ssh_target "$host")
  partition=$(host_field "$host" "slurm_partition"); [[ -z "$partition" ]] && partition="hep"
  account=$(host_field "$host" "slurm_account"); [[ -z "$account" ]] && account="hep2023-1-3"
  time=$(host_field "$host" "slurm_time"); [[ -z "$time" ]] && time="5-00:00:00"
  nodes=$(host_field "$host" "slurm_nodes"); [[ -z "$nodes" ]] && nodes="1"
  cpus=$(host_field "$host" "slurm_cpus"); [[ -z "$cpus" ]] && cpus="40"
  mem=$(host_field "$host" "slurm_mem"); [[ -z "$mem" ]] && mem="200G"
  workdir=$(host_field "$host" "slurm_workdir"); [[ -z "$workdir" ]] && workdir="/projects/hep/fs10/shared/nnbar/billy/csup-allocations/$name"
  output=$(host_field "$host" "slurm_output"); [[ -z "$output" ]] && output="$workdir/holder.%j.log"
  wrap='echo "===NODE: $(hostname)==="; echo "===START: $(date)==="; echo "===CPUS: $SLURM_CPUS_ON_NODE==="; echo "===MEM_MB: $SLURM_MEM_PER_NODE==="; echo "===JOBID: $SLURM_JOB_ID==="; sleep 432000'
  local sbatch_cmd="mkdir -p $(shell_quote "$workdir") && sbatch --parsable --job-name=$(shell_quote "$name") --partition=$(shell_quote "$partition") --time=$(shell_quote "$time") --nodes=$(shell_quote "$nodes") --ntasks=1 --cpus-per-task=$(shell_quote "$cpus") --mem=$(shell_quote "$mem") --account=$(shell_quote "$account") --chdir=$(shell_quote "$workdir") --output=$(shell_quote "$output") --wrap=$(shell_quote "$wrap")"
  # On a LUNARC compute node, sbatch is available directly — no SSH needed.
  if on_lunarc_compute_node && host_is_lunarc "$host"; then
    eval "$sbatch_cmd"
  else
    ssh_exec "$ssh_target" "$sbatch_cmd"
  fi
}

slurm_ensure_allocation() {
  local host="$1" job wait_secs waited auto
  job=$(slurm_active_job_id "$host" || true)
  if [[ -n "$job" ]]; then
    printf '%s\n' "$job"
    return 0
  fi
  auto=$(host_field "$host" "slurm_auto_allocate")
  case "$auto" in 0|false|FALSE|no|NO|off|OFF)
    err "host '$host' has no running allocation for job $(slurm_job_name "$host")"
    return 1
  esac
  { info "no active SLURM allocation for '$host'; submitting holder job $(slurm_job_name "$host")"; } >&2
  slurm_submit_holder "$host" >/dev/null || return 1
  wait_secs=$(nonnegative_int_or_default "${CSUP_SLURM_WAIT_SECS:-}" 120)
  waited=0
  while (( waited < wait_secs )); do
    sleep 5
    waited=$((waited + 5))
    job=$(slurm_active_job_id "$host" || true)
    if [[ -n "$job" ]]; then
      printf '%s\n' "$job"
      return 0
    fi
  done
  err "submitted allocation for '$host' but it is not RUNNING after ${wait_secs}s"
  return 1
}

remote_run_existing() {
  local host="$1" payload="$2" ssh_target env_cmd scheduler job
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  scheduler=$(host_scheduler "$host")
  [[ -n "$ssh_target" && "$ssh_target" != "local" ]] || return 1
  if [[ "$scheduler" == "slurm" ]]; then
    job=$(slurm_active_job_id "$host" || true)
    [[ -n "$job" ]] || { err "host '$host' has no running SLURM allocation for job $(slurm_job_name "$host")"; return 1; }
    ssh_exec "$ssh_target" "env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$env_cmd; $payload")"
  else
    if host_is_lunarc "$host"; then
      err "refusing to run remote command on LUNARC login node for host '$host'; configure scheduler=\"slurm\" and use csup station/start through srun"
      return 1
    fi
    ssh_exec "$ssh_target" "$payload"
  fi
}

remote_run_start() {
  local host="$1" payload="$2" ssh_target env_cmd scheduler job
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  scheduler=$(host_scheduler "$host")
  [[ -n "$ssh_target" && "$ssh_target" != "local" ]] || return 1
  if [[ "$scheduler" == "slurm" ]]; then
    job=$(slurm_ensure_allocation "$host") || return 1
    ssh_exec "$ssh_target" "env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$env_cmd; $payload")"
  else
    if host_is_lunarc "$host"; then
      err "refusing to start supervisor on LUNARC login node for host '$host'; configure scheduler=\"slurm\" and use csup station/start through srun"
      return 1
    fi
    ssh_exec "$ssh_target" "$payload"
  fi
}

remote_slurm_keepalive_start() {
  local host="$1" session="$2" payload="$3" ssh_target env_cmd job workdir log inner launch
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  job=$(slurm_ensure_allocation "$host") || return 1
  workdir=$(host_field "$host" "slurm_workdir")
  [[ -z "$workdir" ]] && workdir="/projects/hep/fs10/shared/nnbar/billy/csup-allocations/$(slurm_job_name "$host")"
  log="$workdir/csup-${session}.log"
  # SLURM kills child processes from a short-lived srun step when that step
  # exits. Keep the step alive for as long as the tmux session exists so the
  # supervisor's tmux server and worker panes survive after `csup start`
  # returns to the local operator.
  # Keepalive must check the SAME per-session socket the supervisor.sh wrapper
  # uses (TMUX_SOCKET defaults to the session name → tmux -L <session>).
  # Without -L this checks the default socket, finds no session, exits in 15s,
  # SLURM SIGKILLs the entire srun step → daemon + per-session tmux server
  # killed silently. Bug observed 2026-05-15: sessions died ~15-45s after start.
  inner="$env_cmd; $(slurm_compute_guard_snippet); export CODEX_SUPERVISOR_MAX_LOAD_PER_CPU=\${CODEX_SUPERVISOR_MAX_LOAD_PER_CPU:-0}; $payload; sleep 15; while tmux -L $(shell_quote "$session") has-session -t $(shell_quote "$session") 2>/dev/null; do sleep 30; done"
  launch="nohup setsid env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$inner") > $(shell_quote "$log") 2>&1 < /dev/null & disown; echo started slurm_job=$job session=$(shell_quote "$session") log=$(shell_quote "$log")"
  local run_cmd="mkdir -p $(shell_quote "$workdir") && bash -lc $(shell_quote "$launch")"
  if on_lunarc_compute_node && host_is_lunarc "$host"; then
    eval "$run_cmd"
  else
    ssh_exec "$ssh_target" "$run_cmd"
  fi
}

remote_slurm_keepalive_start_job() {
  local host="$1" job="$2" session="$3" payload="$4" ssh_target env_cmd workdir log inner launch
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  workdir=$(host_field "$host" "slurm_workdir")
  [[ -z "$workdir" ]] && workdir="/projects/hep/fs10/shared/nnbar/billy/csup-allocations/$(slurm_job_name "$host")"
  log="$workdir/csup-${session}.log"
  inner="$env_cmd; $(slurm_compute_guard_snippet); export CODEX_SUPERVISOR_MAX_LOAD_PER_CPU=\${CODEX_SUPERVISOR_MAX_LOAD_PER_CPU:-0}; $payload; sleep 15; while tmux -L $(shell_quote "$session") has-session -t $(shell_quote "$session") 2>/dev/null; do sleep 30; done"
  launch="nohup setsid env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$inner") > $(shell_quote "$log") 2>&1 < /dev/null & disown; echo started slurm_job=$job session=$(shell_quote "$session") log=$(shell_quote "$log")"
  local run_cmd="mkdir -p $(shell_quote "$workdir") && bash -lc $(shell_quote "$launch")"
  if on_lunarc_compute_node && host_is_lunarc "$host"; then
    eval "$run_cmd"
  else
    ssh_exec "$ssh_target" "$run_cmd"
  fi
}

remote_slurm_keepalive_start_batch_job() {
  local host="$1" job="$2" count="$3" ssh_target env_cmd workdir first_session log inner launch i session payload sessions_csv stagger
  shift 3
  local sessions=() payloads=()
  for ((i=0; i<count; i++)); do
    sessions+=("$1")
    shift
  done
  for ((i=0; i<count; i++)); do
    payloads+=("$1")
    shift
  done
  (( count > 0 )) || return 0
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  workdir=$(host_field "$host" "slurm_workdir")
  [[ -z "$workdir" ]] && workdir="/projects/hep/fs10/shared/nnbar/billy/csup-allocations/$(slurm_job_name "$host")"
  first_session="${sessions[0]}"
  log="$workdir/csup-batch-${first_session}.log"
  sessions_csv=$(join_csv "${sessions[@]}")
  stagger=$(slurm_start_stagger_secs "$host")

  inner="$env_cmd; $(slurm_compute_guard_snippet); export CODEX_SUPERVISOR_MAX_LOAD_PER_CPU=\${CODEX_SUPERVISOR_MAX_LOAD_PER_CPU:-0}; _csup_rc=0; "
  for ((i=0; i<count; i++)); do
    payload="${payloads[$i]}"
    inner="$inner ( $payload ) || _csup_rc=1; "
    if (( i + 1 < count && stagger > 0 )); then
      inner="$inner sleep $(shell_quote "$stagger"); "
    fi
  done
  inner="${inner} (( _csup_rc == 0 )) || exit \"\$_csup_rc\"; "
  inner="${inner} while true; do _csup_any=0; "
  for ((i=0; i<count; i++)); do
    session="${sessions[$i]}"
    inner="${inner} tmux -L $(shell_quote "$session") has-session -t $(shell_quote "$session") 2>/dev/null && _csup_any=1; "
  done
  inner="${inner} (( _csup_any )) || break; sleep 30; done"

  launch="nohup setsid env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$inner") > $(shell_quote "$log") 2>&1 < /dev/null & disown; echo started slurm_job=$job sessions=$(shell_quote "$sessions_csv") log=$(shell_quote "$log")"
  local run_cmd="mkdir -p $(shell_quote "$workdir") && bash -lc $(shell_quote "$launch")"
  if on_lunarc_compute_node && host_is_lunarc "$host"; then
    eval "$run_cmd"
  else
    ssh_exec "$ssh_target" "$run_cmd"
  fi
}

project_dir_for_host() {
  local cfg="$1" host="$2" local_dir="$3" remote_dir
  remote_dir=$(toml_get "$cfg" "hosts.$host" "project_dir")
  [[ -z "$remote_dir" ]] && remote_dir="$local_dir"
  printf '%s' "$remote_dir"
}

path_under_project_if_relative() {
  local project_dir="$1" path="$2"
  [[ -n "$path" ]] || return 0
  case "$path" in
    /*|~|~/*) printf '%s' "$path" ;;
    *) printf '%s/%s' "$project_dir" "$path" ;;
  esac
}

this_host() {
  local h me; me=$(uname -n)
  while read -r h; do
    [[ -z "$h" ]] && continue
    local match; match=$(toml_get "$HOSTS_FILE" "hosts.$h" "hostname_match")
    if [[ -n "$match" && "$me" == *"$match"* ]]; then
      echo "$h"; return 0
    fi
  done < <(toml_sections "$HOSTS_FILE" "hosts.")
  echo "unknown"
}

# Returns true when $host is the same physical machine we are running on,
# even when it has a different logical host name (e.g. laptop-b alongside laptop).
# Matches by hostname_match: if the current uname contains the host's
# hostname_match string, it is the same box.
is_same_machine() {
  local host="$1"
  [[ "$(this_host)" == "$host" ]] && return 0
  local me_hostname; me_hostname=$(uname -n)
  local host_match; host_match=$(toml_get "$HOSTS_FILE" "hosts.$host" "hostname_match")
  [[ -n "$host_match" && "$me_hostname" == *"$host_match"* ]]
}

host_reachable() {
  local host="$1"
  # If we ARE this host (or same physical machine), we're trivially reachable.
  is_same_machine "$host" && return 0
  local ssh_target; ssh_target=$(host_ssh_target "$host")
  if [[ "$ssh_target" == "local" ]]; then
    # ssh="local" but we're not on this host -> can't reach it
    return 1
  fi
  if [[ "$(host_scheduler "$host")" == "slurm" ]]; then
    ssh_login_reachable "$host" && [[ -n "$(slurm_active_job_id "$host" || true)" ]]
    return
  fi
  ssh_login_reachable "$host"
}

list_hosts() {
  local me; me=$(this_host)
  printf '  %-12s  %-30s  %-28s  %s\n' HOST SSH STATUS NOTES
  while read -r h; do
    [[ -z "$h" ]] && continue
    local s; s=$(host_ssh_target "$h")
    local d; d=$(host_field "$h" "description")
    local status
    if [[ "$(host_scheduler "$h")" == "slurm" && "$h" != "$me" ]]; then
      if ssh_login_reachable "$h"; then
        local info job node; info=$(slurm_active_job_info "$h" || true)
        job="${info%%|*}"
        node=""
        [[ "$info" == *"|"* ]] && node="${info#*|}"
        if [[ -n "$job" ]]; then
          status="up job=$job"
          [[ -n "$node" && "$node" != "$info" ]] && status="$status node=$node"
        else
          status="login-up/noalloc"
        fi
      else
        status=down
      fi
    elif host_reachable "$h"; then status=up; else status=down; fi
    [[ "$h" == "$me" ]] && status="$status (this)"
    printf '  %-12s  %-30s  %-28s  %s\n' "$h" "$s" "$status" "$d"
  done < <(toml_sections "$HOSTS_FILE" "hosts.")
}

free_ram_mb() {
  if [[ -n "${CSUP_GOVERNOR_FREE_RAM_MB:-}" ]]; then echo "$CSUP_GOVERNOR_FREE_RAM_MB"; return; fi
  if command -v free >/dev/null 2>&1; then
    free -m 2>/dev/null | awk '/^Mem:/ { if ($7 ~ /^[0-9]+$/) print $7; else print $4; found=1 } END { if (!found) print 0 }'
    return
  fi
  local pgsz; pgsz=$(vm_stat 2>/dev/null | awk '/page size of/{print $8}')
  [[ -z "$pgsz" ]] && pgsz=16384
  vm_stat 2>/dev/null | awk -v pg="$pgsz" '
    /Pages free/     { f=$3+0 }
    /Pages inactive/ { i=$3+0 }
    END { printf "%d\n", (f+i)*pg/1024/1024 }
  '
}

free_disk_gb() {
  if [[ -n "${CSUP_GOVERNOR_FREE_DISK_GB:-}" ]]; then echo "$CSUP_GOVERNOR_FREE_DISK_GB"; return; fi
  mkdir -p "$RUNTIME_ROOT" 2>/dev/null || true
  df -k "$RUNTIME_ROOT" 2>/dev/null | awk 'NR==2 { printf "%d\n", $4/1024/1024; found=1 } END { if (!found) print 0 }'
}

load1() {
  if [[ -n "${CSUP_GOVERNOR_LOAD1:-}" ]]; then echo "$CSUP_GOVERNOR_LOAD1"; return; fi
  uptime | sed -E 's/.*load averages?: ([0-9.]+).*/\1/'
}

cpu_count() {
  if [[ -n "${CSUP_GOVERNOR_CPU_COUNT:-}" ]]; then echo "$CSUP_GOVERNOR_CPU_COUNT"; return; fi
  sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 1
}

running_local_panes() {
  if [[ -n "${CSUP_GOVERNOR_RUNNING_PANES:-}" ]]; then echo "$CSUP_GOVERNOR_RUNNING_PANES"; return; fi
  tmux list-panes -a 2>/dev/null | wc -l | tr -d ' '
}

capacity_fields() {
  local free_ram free_disk cpus load running max_total ram_per disk_per reserve_ram reserve_disk load_room ram_room disk_room
  free_ram=$(free_ram_mb)
  free_disk=$(free_disk_gb)
  cpus=$(cpu_count)
  load=$(load1)
  running=$(running_local_panes)
  free_ram=$(nonnegative_int_or_default "$free_ram" 0)
  free_disk=$(nonnegative_int_or_default "$free_disk" 0)
  cpus=$(positive_int_or_default "$cpus" 1)
  load=$(nonnegative_decimal_or_default "$load" 0)
  running=$(nonnegative_int_or_default "$running" 0)
  max_total=$(positive_int_or_default "${CSUP_GOVERNOR_MAX_TOTAL_PANES:-}" 8)
  ram_per=$(positive_int_or_default "${CSUP_GOVERNOR_RAM_MB_PER_PANE:-}" 700)
  disk_per=$(positive_int_or_default "${CSUP_GOVERNOR_DISK_MB_PER_PANE:-}" 1024)
  reserve_ram=$(nonnegative_int_or_default "${CSUP_GOVERNOR_MIN_FREE_RAM_MB:-}" 2048)
  reserve_disk=$(nonnegative_int_or_default "${CSUP_GOVERNOR_MIN_FREE_DISK_GB:-}" 10)

  ram_room=$(( (free_ram - reserve_ram) / ram_per ))
  (( ram_room < 0 )) && ram_room=0
  disk_room=$(( (free_disk - reserve_disk) * 1024 / disk_per ))
  (( disk_room < 0 )) && disk_room=0
  local load_limit
  load_limit=$(nonnegative_decimal_or_default "${CSUP_GOVERNOR_MAX_LOAD_PER_CPU:-}" 1.25)
  load_room=$(python3 - "$cpus" "$load" "$load_limit" <<'PY'
import math, sys
try:
    cpus_raw = float(sys.argv[1])
    load_raw = float(sys.argv[2])
    limit = float(sys.argv[3])
    if not all(math.isfinite(v) for v in (cpus_raw, load_raw, limit)) or limit < 0:
        raise ValueError("non-finite capacity input")
    cpus = max(1, int(cpus_raw))
    load = max(0.0, load_raw)
except Exception:
    print(0)
    raise SystemExit(0)
if limit <= 0:
    print(999999)
else:
    print(max(0, int(math.floor(cpus * limit - load))))
PY
)
  local total_room=$(( max_total - running ))
  (( total_room < 0 )) && total_room=0

  local available="$total_room" bottleneck="session_cap" v label
  for label in ram disk load; do
    case "$label" in
      ram) v="$ram_room" ;;
      disk) v="$disk_room" ;;
      load) v="$load_room" ;;
    esac
    if (( v < available )); then
      available="$v"
      bottleneck="$label"
    fi
  done

  printf 'available=%s\n' "$available"
  printf 'bottleneck=%s\n' "$bottleneck"
  printf 'total_room=%s\n' "$total_room"
  printf 'ram_room=%s\n' "$ram_room"
  printf 'disk_room=%s\n' "$disk_room"
  printf 'load_room=%s\n' "$load_room"
  printf 'max_total=%s\n' "$max_total"
  printf 'running=%s\n' "$running"
  printf 'free_ram_mb=%s\n' "$free_ram"
  printf 'reserve_ram_mb=%s\n' "$reserve_ram"
  printf 'ram_mb_per_pane=%s\n' "$ram_per"
  printf 'free_disk_gb=%s\n' "$free_disk"
  printf 'reserve_disk_gb=%s\n' "$reserve_disk"
  printf 'disk_mb_per_pane=%s\n' "$disk_per"
  printf 'cpus=%s\n' "$cpus"
  printf 'load1=%s\n' "$load"
  printf 'max_load_per_cpu=%s\n' "$load_limit"
}

capacity_panes() {
  local k v
  while IFS='=' read -r k v; do
    if [[ "$k" == "available" ]]; then
      echo "$v"
      return
    fi
  done < <(capacity_fields)
  echo 0
}

positive_int_or_default() {
  local value="$1" default="$2"
  if [[ "$value" =~ ^[0-9]+$ && "$value" -gt 0 ]]; then
    printf '%s' "$value"
  else
    printf '%s' "$default"
  fi
}

nonnegative_int_or_default() {
  local value="$1" default="$2"
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    printf '%s' "$value"
  else
    printf '%s' "$default"
  fi
}

nonnegative_decimal_or_default() {
  local value="$1" default="$2"
  if [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    printf '%s' "$value"
  else
    printf '%s' "$default"
  fi
}

slurm_slot_capacity_panes() {
  local host="$1" max cpus
  max=$(host_field "$host" "slurm_max_panes")
  if [[ "$max" =~ ^[0-9]+$ && "$max" -gt 0 ]]; then
    printf '%s' "$max"
    return
  fi
  cpus=$(host_field "$host" "slurm_cpus")
  cpus=$(positive_int_or_default "$cpus" 8)
  # Keep one CPU's worth of headroom and cap by the historical stable
  # supervisor density unless host config explicitly overrides it.
  (( cpus > 1 )) && cpus=$((cpus - 1))
  (( cpus > 24 )) && cpus=24
  (( cpus < 1 )) && cpus=1
  printf '%s' "$cpus"
}

project_node_cap() {
  local host="$1" cap
  cap="${CSUP_PROJECT_MAX_NODES:-}"
  [[ -z "$cap" ]] && cap=$(host_field "$host" "project_max_nodes")
  cap=$(positive_int_or_default "$cap" 2)
  # Hard project policy: at most two computer nodes. The env/config knob can
  # lower the cap for smaller projects, but cannot raise it above two.
  (( cap > 2 )) && cap=2
  printf '%s' "$cap"
}

slurm_slots_for_host() {
  local host="$1" slots cap
  slots=$(host_field "$host" "slurm_slots")
  slots=$(positive_int_or_default "$slots" 1)
  cap=$(project_node_cap "$host")
  # Global policy: a single project may use at most two computer nodes.
  # slurm_slots is capacity discovery, not permission to exceed the
  # project node budget. Operators can still maximize panes by raising
  # slurm_max_panes/load headroom inside those nodes.
  (( slots > cap )) && slots="$cap"
  printf '%s' "$slots"
}

slurm_start_batch_size() {
  local host="$1" batch
  batch="${CSUP_STATION_START_BATCH_SIZE:-}"
  [[ -z "$batch" ]] && batch=$(host_field "$host" "slurm_start_batch_size")
  positive_int_or_default "$batch" 32
}

slurm_start_stagger_secs() {
  local host="$1" stagger
  stagger="${CSUP_STATION_START_STAGGER_SECS:-}"
  [[ -z "$stagger" ]] && stagger=$(host_field "$host" "slurm_start_stagger_secs")
  nonnegative_int_or_default "$stagger" 2
}

slurm_remote_pane_count() {
  local host="$1" job="$2" ssh_target env_cmd count pane_count_cmd
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  # Supervisor sessions use isolated tmux servers (`tmux -L <session>`), so the
  # default tmux socket can report zero panes while many station sessions are
  # alive. Count panes across all user tmux sockets on the compute node so
  # station capacity decisions do not overpack and churn sessions.
  pane_count_cmd='__count=0; __dir="${TMUX_TMPDIR:-/tmp}/tmux-$(id -u)"; if [ -d "$__dir" ]; then for __sock in "$__dir"/*; do [ -S "$__sock" ] || continue; __n=$(tmux -S "$__sock" list-panes -a 2>/dev/null | wc -l | tr -d " "); case "$__n" in ""|*[!0-9]*) __n=0;; esac; __count=$((__count + __n)); done; printf "%s\n" "$__count"; else tmux list-panes -a 2>/dev/null | wc -l | tr -d " "; fi'
  count=$(ssh_capture_timeout "$ssh_target" "env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$env_cmd; $pane_count_cmd")" 2>/dev/null || true)
  [[ "$count" =~ ^[0-9]+$ ]] || count=0
  printf '%s' "$count"
}

slurm_remote_session_running() {
  local host="$1" job="$2" session="$3" ssh_target env_cmd out
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  # Match the per-session socket used by codex-supervisor.sh. Checking the
  # default socket makes station think a live session is gone, causing duplicate
  # starts and panes that appear/disappear without making progress.
  out=$(ssh_capture_timeout "$ssh_target" "env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$env_cmd; if tmux -L $(shell_quote "$session") has-session -t $(shell_quote "$session") 2>/dev/null; then echo yes; else echo no; fi")" 2>/dev/null | tail -1 || true)
  [[ "$out" == "yes" ]]
}

slurm_remote_load_room() {
  local host="$1" job="$2" ssh_target env_cmd out
  ssh_target=$(host_ssh_target "$host")
  env_cmd=$(host_remote_env "$host")
  out=$(ssh_capture_timeout "$ssh_target" "env -u LD_LIBRARY_PATH srun --jobid=$(shell_quote "$job") --overlap bash -lc $(shell_quote "$env_cmd; python3 - <<'PY'
import math, os
raw_limit = os.environ.get('CODEX_SUPERVISOR_MAX_LOAD_PER_CPU')
try:
    limit = float(raw_limit) if raw_limit not in (None, '') else 0.0
    if not math.isfinite(limit) or limit < 0:
        limit = 1.25
except (TypeError, ValueError):
    limit = 1.25
if limit <= 0:
    print(9999)
else:
    try:
        load = max(0.0, os.getloadavg()[0])
    except (AttributeError, OSError):
        load = 0.0
    cpus = max(1, os.cpu_count() or 1)
    print(max(0, int(math.floor(cpus * limit - load))))
PY")" 2>/dev/null | tail -1 || true)
  [[ "$out" =~ ^[0-9]+$ ]] || out=9999
  printf '%s' "$out"
}

session_running_local() {
  tmux has-session -t "=$1" 2>/dev/null
}

queue_lanes_for_tasks_dir() {
  local tasks_dir="$1"
  [[ -n "$tasks_dir" && -d "$tasks_dir" ]] || return 0
  local f lane count
  for f in "$tasks_dir"/*.txt; do
    [[ -e "$f" ]] || continue
    lane="${f##*/}"; lane="${lane%.txt}"
    is_dynamic_queue_lane "$lane" && continue
    count=$(grep -cE '^/goal' "$f" 2>/dev/null || true)
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    (( count > 0 )) && printf '%06d %s\n' "$count" "$lane"
  done | sort -rn
}

is_dynamic_queue_lane() {
  local lane="$1" token
  for token in ${CSUP_DYNAMIC_QUEUE_LANES:-blockers blocker open worker workers dynamic}; do
    [[ "$lane" == "$token" ]] && return 0
  done
  return 1
}

dynamic_queue_goal_count() {
  local tasks_dir="$1" token file count total=0
  [[ -n "$tasks_dir" && -d "$tasks_dir" ]] || { echo 0; return; }
  for token in ${CSUP_DYNAMIC_QUEUE_LANES:-blockers blocker open worker workers dynamic}; do
    file="$tasks_dir/$token.txt"
    [[ -f "$file" ]] || continue
    count=$(grep -cE '^/goal' "$file" 2>/dev/null || true)
    [[ "$count" =~ ^[0-9]+$ ]] || count=0
    total=$((total + count))
  done
  echo "$total"
}

goal_count_file() {
  local file="$1" count
  [[ -f "$file" ]] || { echo 0; return; }
  count=$(grep -cE '^/goal' "$file" 2>/dev/null || true)
  [[ "$count" =~ ^[0-9]+$ ]] || count=0
  echo "$count"
}

factory_blocker_goal_count() {
  local tasks_dir="$1" total=0 count
  [[ -n "$tasks_dir" && -d "$tasks_dir" ]] || { echo 0; return; }
  for f in "$tasks_dir/blockers.txt" "$tasks_dir/blocker.txt"; do
    count=$(goal_count_file "$f")
    total=$((total + count))
  done
  echo "$total"
}

factory_open_goal_count() {
  local tasks_dir="$1" total=0 token count
  [[ -n "$tasks_dir" && -d "$tasks_dir" ]] || { echo 0; return; }
  for token in open worker workers dynamic; do
    count=$(goal_count_file "$tasks_dir/$token.txt")
    total=$((total + count))
  done
  echo "$total"
}

factory_lane_goal_count() {
  local tasks_dir="$1" total=0 f lane count
  [[ -n "$tasks_dir" && -d "$tasks_dir" ]] || { echo 0; return; }
  for f in "$tasks_dir"/*.txt; do
    [[ -e "$f" ]] || continue
    lane="${f##*/}"; lane="${lane%.txt}"
    is_dynamic_queue_lane "$lane" && continue
    count=$(goal_count_file "$f")
    total=$((total + count))
  done
  echo "$total"
}

factory_prompt_goal_count() {
  local file="$1" count
  [[ -n "$file" && -f "$file" ]] || { echo 0; return; }
  count=$(grep -cE '^/goal([[:space:]]|$)' "$file" 2>/dev/null || true)
  [[ "$count" =~ ^[0-9]+$ ]] || count=0
  echo "$count"
}

goal_count_dir() {
  local dir="$1" count
  [[ -n "$dir" && -d "$dir" ]] || { echo 0; return; }
  count=$(find "$dir" -maxdepth 2 -type f -name '*.txt' -exec grep -hE '^/goal([[:space:]]|$)' {} + 2>/dev/null | wc -l | tr -d ' ')
  [[ "$count" =~ ^[0-9]+$ ]] || count=0
  echo "$count"
}

factory_blocker_queue_status() {
  local dir="$1"
  [[ -n "$dir" ]] || { printf 'none'; return; }
  [[ -d "$dir" ]] || { printf 'missing'; return; }
  if [[ -f "$dir/blockers.txt" || -f "$dir/blocker.txt" ]]; then
    printf 'ok'
  else
    printf 'missing'
  fi
}

factory_docs_status() {
  local project_dir="$1" missing="" shared ai team version_board blocker_schema
  shared="$project_dir/docs/parallel-sessions.md"
  ai="$project_dir/docs/parallel-sessions/AI_FACTORY.md"
  team="$project_dir/docs/parallel-sessions/TEAM_PLAN.md"
  version_board="$project_dir/docs/parallel-sessions/VERSION_BOARD.md"
  blocker_schema="$project_dir/docs/blocker-schema.md"
  if [[ ! -f "$shared" ]]; then
    missing="${missing:+$missing,}shared"
  elif ! grep -qE 'AI factory override|AI_FACTORY\.md' "$shared" 2>/dev/null; then
    missing="${missing:+$missing,}shared_override"
  fi
  [[ -f "$ai" ]] || missing="${missing:+$missing,}ai_factory"
  if [[ ! -f "$team" ]]; then
    missing="${missing:+$missing,}team_plan"
  elif ! grep -qE 'AI Factory acceptance board|Batch outcome|Acceptance checklist' "$team" 2>/dev/null; then
    missing="${missing:+$missing,}team_plan_board"
  fi
  if [[ ! -f "$version_board" ]]; then
    missing="${missing:+$missing,}version_board"
  elif ! grep -qE 'Batch Version|PR Train|batch/<date>-<slug>|worker branch intake' "$version_board" 2>/dev/null; then
    missing="${missing:+$missing,}version_board_policy"
  fi
  if [[ ! -f "$blocker_schema" ]]; then
    missing="${missing:+$missing,}blocker_schema"
  elif ! grep -qE 'type=code\|data\|approval\|infra\|empirical\|external' "$blocker_schema" 2>/dev/null; then
    missing="${missing:+$missing,}blocker_schema_types"
  fi
  if [[ -n "$missing" ]]; then
    printf 'missing:%s' "$missing"
  else
    printf 'ok'
  fi
}

factory_audit_project_host() {
  local project="$1" project_dir="$2" cfg="$3" host="$4"
  local h_project_dir prompts tasks_dir prompts_abs tasks_abs docs blockers blocker_queue open lane prompts_count status action docs_missing
  h_project_dir=$(project_dir_for_host "$cfg" "$host" "$project_dir")
  # If a remote project_dir is configured and not locally visible, audit the
  # canonical local checkout. Running this command on the remote host audits the
  # remote tree directly.
  [[ -d "$h_project_dir" ]] || h_project_dir="$project_dir"
  prompts=$(toml_get "$cfg" "hosts.$host" "prompts")
  tasks_dir=$(toml_get "$cfg" "hosts.$host" "tasks_dir")
  prompts_abs=$(path_under_project_if_relative "$h_project_dir" "$prompts")
  tasks_abs=$(path_under_project_if_relative "$h_project_dir" "$tasks_dir")

  docs=$(factory_docs_status "$h_project_dir")
  blockers=$(factory_blocker_goal_count "$tasks_abs")
  blocker_queue=$(factory_blocker_queue_status "$tasks_abs")
  open=$(factory_open_goal_count "$tasks_abs")
  lane=$(factory_lane_goal_count "$tasks_abs")
  prompts_count=$(factory_prompt_goal_count "$prompts_abs")

  status="GREEN"
  [[ "$docs" != "ok" || "$blocker_queue" == "missing" || "$blockers" -gt 0 ]] && status="RED"
  [[ "$status" == "GREEN" && $((open + lane)) -gt 0 ]] && status="YELLOW"

  printf 'FACTORY %s/%s status=%s blockers=%s open=%s lane=%s prompts=%s docs=%s blocker_queue=%s tasks=%s\n' \
    "$project" "$host" "$status" "$blockers" "$open" "$lane" "$prompts_count" "$docs" "$blocker_queue" "${tasks_abs:-none}"

  if (( blockers > 0 )); then
    printf 'ACTION %s/%s: resolve shared blockers before lane-local work\n' "$project" "$host"
  elif [[ "$docs" != "ok" ]]; then
    docs_missing="${docs#missing:}"
    printf 'ACTION %s/%s: install/fix factory docs (%s)\n' "$project" "$host" "$docs_missing"
  elif [[ "$blocker_queue" == "missing" ]]; then
    printf 'ACTION %s/%s: install codex-tasks/blockers.txt before lane-local work\n' "$project" "$host"
  elif (( open + lane > 0 )); then
    printf 'ACTION %s/%s: work queued acceptance gaps; keep blocker queue empty or explicit\n' "$project" "$host"
  else
    printf 'ACTION %s/%s: no queued work; validator should confirm batch accepted or add next acceptance gap\n' "$project" "$host"
  fi
}

run_local_start() {
  local project_dir="$1" session="$2" prompts="$3" tasks_dir="$4" lanes="${5:-}" max_panes="${6:-}" dynamic_workers="${7:-0}" generated_only="${8:-0}" role="${9:-ceo}"
  local prompts_abs tasks_abs
  local ceo_enabled=1 manager_enabled=0 reviewer_enabled=0
  if [[ "$role" == "team" || "$role" == "worker" || "$role" == "remote-executor" || "$role" == "manager" ]]; then
    ceo_enabled=0
  fi
  if [[ "$role" == "manager" ]]; then
    manager_enabled=1
  fi
  if [[ ( "$generated_only" == "1" || -n "$max_panes" ) && ( "$role" == "team" || "$role" == "worker" || "$role" == "remote-executor" || "$role" == "manager" ) ]]; then
    manager_enabled=1
    reviewer_enabled=1
  fi
  prompts_abs=$(path_under_project_if_relative "$project_dir" "$prompts")
  tasks_abs=$(path_under_project_if_relative "$project_dir" "$tasks_dir")
  if [[ -n "$tasks_dir" ]]; then
    ( cd "$project_dir" && \
      CODEX_SUPERVISOR_ROOT="$RUNTIME_ROOT" \
      CODEX_SUPERVISOR_SESSION="$session" \
      CODEX_SUPERVISOR_PROMPTS="$prompts_abs" \
      CODEX_SUPERVISOR_TASKS_DIR="$tasks_abs" \
      CODEX_SUPERVISOR_LANES="$lanes" \
      CODEX_SUPERVISOR_CEO="$ceo_enabled" \
      CODEX_SUPERVISOR_MANAGER="$manager_enabled" \
      CODEX_SUPERVISOR_REVIEWER="$reviewer_enabled" \
      CODEX_SUPERVISOR_DEBUGGER=0 \
      CODEX_SUPERVISOR_VALIDATOR=0 \
      CODEX_SUPERVISOR_DYNAMIC_WORKERS="$dynamic_workers" \
      CODEX_SUPERVISOR_GENERATED_ONLY="$generated_only" \
      CODEX_SUPERVISOR_MAX_PANES="$max_panes" \
      "$SUPERVISOR" start --no-attach ) | tail -5
  else
    ( cd "$project_dir" && \
      CODEX_SUPERVISOR_ROOT="$RUNTIME_ROOT" \
      CODEX_SUPERVISOR_SESSION="$session" \
      CODEX_SUPERVISOR_PROMPTS="$prompts_abs" \
      CODEX_SUPERVISOR_LANES="$lanes" \
      CODEX_SUPERVISOR_CEO="$ceo_enabled" \
      CODEX_SUPERVISOR_MANAGER="$manager_enabled" \
      CODEX_SUPERVISOR_REVIEWER="$reviewer_enabled" \
      CODEX_SUPERVISOR_DEBUGGER=0 \
      CODEX_SUPERVISOR_VALIDATOR=0 \
      CODEX_SUPERVISOR_DYNAMIC_WORKERS="$dynamic_workers" \
      CODEX_SUPERVISOR_GENERATED_ONLY="$generated_only" \
      CODEX_SUPERVISOR_MAX_PANES="$max_panes" \
      "$SUPERVISOR" start --no-attach ) | tail -5
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: start
# ---------------------------------------------------------------------------
cmd_start() {
  local project="" target_host="" fallback=0 _slurm_started=0
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --fallback) fallback=1 ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done

  [[ -z "$project" ]] && { err "usage: csup start <project> [--host=<name>] [--fallback]"; return 2; }

  local project_dir; project_dir=$(find_project_config "$project")
  [[ -z "$project_dir" ]] && { err "no .codex-supervisor.toml found for project '$project'"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"

  # If no --host specified, start every host's lanes (each on its own machine)
  local hosts_to_start=()
  if [[ -n "$target_host" ]]; then
    hosts_to_start=("$target_host")
  else
    while read -r h; do
      [[ -n "$h" ]] && hosts_to_start+=("$h")
    done < <(toml_sections "$cfg" "hosts.")
  fi

  local me; me=$(this_host)
  for h in "${hosts_to_start[@]}"; do
    local prompts; prompts=$(toml_get "$cfg" "hosts.$h" "prompts")
    local tasks_dir; tasks_dir=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
    local session; session=$(toml_get "$cfg" "hosts.$h" "session")
    local remote_dir; remote_dir=$(project_dir_for_host "$cfg" "$h" "$project_dir")
    local supervisor; supervisor=$(host_supervisor "$h")
    local host_role; host_role=$(toml_get "$cfg" "hosts.$h" "role")
    [[ -z "$session" ]] && session="${project}-${h}"
    if [[ -z "$prompts" ]]; then
      warn "host '$h' missing prompts in $cfg — skipping"
      continue
    fi
    if host_is_lunarc "$h" && [[ "$(host_scheduler "$h")" != "slurm" ]]; then
      warn "host '$h' targets LUNARC but is not scheduler=\"slurm\" — refusing to start on the login node"
      warn "  configure the host as LUNARC and use csup station/start so workers run inside srun"
      continue
    fi

    # Derive CEO/manager env flags from role field in .codex-supervisor.toml
    local ceo_env="" manager_env=""
    case "${host_role:-}" in
      team|worker|remote-executor) ceo_env=" CODEX_SUPERVISOR_CEO=0"; manager_env=" CODEX_SUPERVISOR_MANAGER=0" ;;
      manager) ceo_env=" CODEX_SUPERVISOR_CEO=0"; manager_env=" CODEX_SUPERVISOR_MANAGER=1" ;;
    esac

    if is_same_machine "$h" && [[ "$(host_scheduler "$h")" != "slurm" ]]; then
      info "starting '$session' locally on $h"
      run_local_start "$project_dir" "$session" "$prompts" "$tasks_dir" "" "" "0" "0" "${host_role:-ceo}"
    else
      if [[ "$(host_scheduler "$h")" == "slurm" ]] || host_reachable "$h"; then
        local ssh_target; ssh_target=$(host_ssh_target "$h")
        local task_env="" lane_env="" max_env="" prompts_abs tasks_abs
        prompts_abs=$(path_under_project_if_relative "$remote_dir" "$prompts")
        tasks_abs=$(path_under_project_if_relative "$remote_dir" "$tasks_dir")
        [[ -n "$tasks_dir" ]] && task_env=" CODEX_SUPERVISOR_TASKS_DIR=$(shell_quote "$tasks_abs")"
        info "starting '$session' on $h via $ssh_target"
        if [[ "$(host_scheduler "$h")" == "slurm" ]]; then
          remote_slurm_keepalive_start "$h" "$session" "cd $(shell_quote "$remote_dir") || exit 1; CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$task_env$lane_env$max_env$ceo_env$manager_env $(shell_quote "$supervisor") start --no-attach" 2>&1 | tail -5
          _slurm_started=1
        else
          remote_run_start "$h" "cd $(shell_quote "$remote_dir") || exit 1; CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$task_env$lane_env$max_env$ceo_env$manager_env $(shell_quote "$supervisor") start --no-attach" 2>&1 | tail -5
        fi
      else
        warn "host '$h' unreachable"
        if (( fallback )); then
          warn "  --fallback: starting '$session' locally on $me instead"
          run_local_start "$project_dir" "$session" "$prompts" "$tasks_dir" "" "" "0" "0" "${host_role:-ceo}"
        else
          warn "  skipping (re-run with --fallback to run on $me)"
        fi
      fi
    fi
  done

  # Auto-refresh tunnels after any SLURM session was started
  if (( _slurm_started )); then
    info "refreshing dashboard tunnels..."
    cmd_tunnel --auto &
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: submit
# ---------------------------------------------------------------------------
cmd_submit() {
  local project="" lane="" target_host=""
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}"; shift ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *)
        project="$1"; shift
        lane="${1:-}"; [[ $# -gt 0 ]] && shift
        break
        ;;
    esac
  done
  [[ -n "$project" && -n "$lane" && $# -gt 0 ]] || { err "usage: csup submit <project> <lane> <goal text...>"; return 2; }
  local project_dir; project_dir=$(find_project_config "$project")
  [[ -z "$project_dir" ]] && { err "no .codex-supervisor.toml found for project '$project'"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"
  local h tasks_dir=""
  if [[ -n "$target_host" ]]; then
    tasks_dir=$(toml_get "$cfg" "hosts.$target_host" "tasks_dir")
  else
    while read -r h; do
      [[ -n "$h" ]] || continue
      tasks_dir=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
      [[ -n "$tasks_dir" ]] && break
    done < <(toml_sections "$cfg" "hosts.")
  fi
  [[ -n "$tasks_dir" ]] || { err "project '$project' has no tasks_dir configured"; return 1; }
  mkdir -p "$project_dir/$tasks_dir"
  local text="$*"
  [[ "$text" == /goal* ]] || text="/goal $text"
  printf '%s\n' "$text" >> "$project_dir/$tasks_dir/$lane.txt"
  printf 'queued %s/%s: %s\n' "$project" "$lane" "$text"
}

# ---------------------------------------------------------------------------
# Subcommand: capacity
# ---------------------------------------------------------------------------
cmd_capacity() {
  local json=0 help=0
  while (( $# > 0 )); do
    case "$1" in
      --json) json=1 ;;
      -h|--help) help=1 ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) err "capacity takes no positional arguments"; return 2 ;;
    esac
    shift
  done
  if (( help )); then
    cat <<'USAGE'
csup capacity [--json]

Reports the current local safe pane headroom and the limiting resource.
Use before large `csup govern --apply` runs to scale up to the largest safe
parallel session count without guessing.

  --json  emit one machine-readable JSON object instead of human text
USAGE
    return 0
  fi

  local available bottleneck total_room ram_room disk_room load_room max_total running
  local free_ram_mb reserve_ram_mb ram_mb_per_pane free_disk_gb reserve_disk_gb disk_mb_per_pane cpus load max_load_per_cpu
  local k v
  while IFS='=' read -r k v; do
    case "$k" in
      available) available="$v" ;;
      bottleneck) bottleneck="$v" ;;
      total_room) total_room="$v" ;;
      ram_room) ram_room="$v" ;;
      disk_room) disk_room="$v" ;;
      load_room) load_room="$v" ;;
      max_total) max_total="$v" ;;
      running) running="$v" ;;
      free_ram_mb) free_ram_mb="$v" ;;
      reserve_ram_mb) reserve_ram_mb="$v" ;;
      ram_mb_per_pane) ram_mb_per_pane="$v" ;;
      free_disk_gb) free_disk_gb="$v" ;;
      reserve_disk_gb) reserve_disk_gb="$v" ;;
      disk_mb_per_pane) disk_mb_per_pane="$v" ;;
      cpus) cpus="$v" ;;
      load1) load="$v" ;;
      max_load_per_cpu) max_load_per_cpu="$v" ;;
    esac
  done < <(capacity_fields)

  local host; host=$(this_host)
  if (( json )); then
    python3 - "$host" "$RUNTIME_ROOT" "$available" "$bottleneck" "$total_room" \
      "$ram_room" "$disk_room" "$load_room" "$max_total" "$running" \
      "$free_ram_mb" "$reserve_ram_mb" "$ram_mb_per_pane" "$free_disk_gb" \
      "$reserve_disk_gb" "$disk_mb_per_pane" "$cpus" "$load" "$max_load_per_cpu" <<'PY'
import json
import math
import sys

keys = [
    "host", "runtime", "available", "bottleneck", "total_room",
    "ram_room", "disk_room", "load_room", "max_total", "running",
    "free_ram_mb", "reserve_ram_mb", "ram_mb_per_pane", "free_disk_gb",
    "reserve_disk_gb", "disk_mb_per_pane", "cpus", "load1",
    "max_load_per_cpu",
]
int_keys = {
    "available", "total_room", "ram_room", "disk_room", "load_room",
    "max_total", "running", "free_ram_mb", "reserve_ram_mb",
    "ram_mb_per_pane", "free_disk_gb", "reserve_disk_gb",
    "disk_mb_per_pane", "cpus",
}
float_keys = {"load1", "max_load_per_cpu"}
obj = {}
for key, raw in zip(keys, sys.argv[1:]):
    if key in int_keys:
        try:
            obj[key] = int(raw)
        except (TypeError, ValueError):
            obj[key] = raw
    elif key in float_keys:
        try:
            value = float(raw)
            obj[key] = value if math.isfinite(value) else raw
        except (TypeError, ValueError):
            obj[key] = raw
    else:
        obj[key] = raw
print(json.dumps(obj, sort_keys=True, separators=(",", ":"), allow_nan=False))
PY
    return 0
  fi

  printf 'csup: capacity host=%s runtime=%s available=%s bottleneck=%s\n' "$host" "$RUNTIME_ROOT" "$available" "$bottleneck"
  printf 'limits total_room=%s ram_room=%s disk_room=%s load_room=%s max_total=%s running=%s\n' "$total_room" "$ram_room" "$disk_room" "$load_room" "$max_total" "$running"
  printf 'inputs free_ram_mb=%s reserve_ram_mb=%s ram_mb_per_pane=%s free_disk_gb=%s reserve_disk_gb=%s disk_mb_per_pane=%s cpus=%s load1=%s max_load_per_cpu=%s\n' \
    "$free_ram_mb" "$reserve_ram_mb" "$ram_mb_per_pane" "$free_disk_gb" "$reserve_disk_gb" "$disk_mb_per_pane" "$cpus" "$load" "$max_load_per_cpu"
}

json_emit() {
  python3 - "$@" <<'PY'
import json
import sys

int_keys = {
    "capacity", "capacity_raw", "max_panes_override",
    "total_room", "ram_room", "disk_room", "load_room",
    "dynamic_workers", "generated_only", "panes", "queued",
}
obj = {}
for item in sys.argv[1:]:
    key, _, raw = item.partition("=")
    if key in int_keys:
        try:
            obj[key] = int(raw)
        except ValueError:
            obj[key] = raw
    else:
        obj[key] = raw
print(json.dumps(obj, sort_keys=True, separators=(",", ":"), allow_nan=False))
PY
}

# ---------------------------------------------------------------------------
# Subcommand: govern
# ---------------------------------------------------------------------------
cmd_govern() {
  local mode="dry-run" target_project="" target_host="" json=0 max_panes_override=""
  while (( $# > 0 )); do
    case "$1" in
      --dry-run) mode="dry-run" ;;
      --apply) mode="apply" ;;
      --json) json=1 ;;
      --max-panes=*) max_panes_override="${1#--max-panes=}" ;;
      --project=*) target_project="${1#--project=}" ;;
      --host=*) target_host="${1#--host=}" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) target_project="$1" ;;
    esac
    shift
  done
  if [[ -n "$max_panes_override" && ! "$max_panes_override" =~ ^[0-9]+$ ]]; then
    err "govern --max-panes must be a positive integer"
    return 2
  fi
  if [[ -n "$max_panes_override" && "$max_panes_override" -le 0 ]]; then
    err "govern --max-panes must be a positive integer"
    return 2
  fi
  if (( json )) && [[ "$mode" == "apply" ]]; then
    err "govern --json is only supported with --dry-run"
    return 2
  fi

  local me; me=$(this_host)
  local capacity=0 capacity_raw=0 bottleneck="unknown" total_room=0 ram_room=0 disk_room=0 load_room=0 cap_k cap_v
  while IFS='=' read -r cap_k cap_v; do
    case "$cap_k" in
      available) capacity="$cap_v" ;;
      bottleneck) bottleneck="$cap_v" ;;
      total_room) total_room="$cap_v" ;;
      ram_room) ram_room="$cap_v" ;;
      disk_room) disk_room="$cap_v" ;;
      load_room) load_room="$cap_v" ;;
    esac
  done < <(capacity_fields)
  capacity_raw="$capacity"
  if [[ -n "$max_panes_override" && "$max_panes_override" -lt "$capacity" ]]; then
    capacity="$max_panes_override"
    bottleneck="operator_cap"
  fi
  local remaining="$capacity"
  if (( json )); then
    if [[ -n "$max_panes_override" ]]; then
      json_emit event=summary mode="$mode" host="$me" runtime="$RUNTIME_ROOT" capacity="$capacity" capacity_raw="$capacity_raw" max_panes_override="$max_panes_override" bottleneck="$bottleneck" total_room="$total_room" ram_room="$ram_room" disk_room="$disk_room" load_room="$load_room"
    else
      json_emit event=summary mode="$mode" host="$me" runtime="$RUNTIME_ROOT" capacity="$capacity" bottleneck="$bottleneck" total_room="$total_room" ram_room="$ram_room" disk_room="$disk_room" load_room="$load_room"
    fi
  else
    if [[ -n "$max_panes_override" ]]; then
      printf 'csup: govern mode=%s host=%s runtime=%s capacity=%s pane(s) bottleneck=%s max_panes=%s raw_capacity=%s\n' "$mode" "$me" "$RUNTIME_ROOT" "$capacity" "$bottleneck" "$max_panes_override" "$capacity_raw"
    else
      printf 'csup: govern mode=%s host=%s runtime=%s capacity=%s pane(s) bottleneck=%s\n' "$mode" "$me" "$RUNTIME_ROOT" "$capacity" "$bottleneck"
    fi
  fi
  if (( remaining <= 0 )); then
    if (( json )); then
      json_emit event=skip scope=all reason=no_local_capacity bottleneck="$bottleneck" total_room="$total_room" ram_room="$ram_room" disk_room="$disk_room" load_room="$load_room"
    else
      printf 'SKIP all: no local capacity (bottleneck=%s total_room=%s ram_room=%s disk_room=%s load_room=%s)\n' "$bottleneck" "$total_room" "$ram_room" "$disk_room" "$load_room"
    fi
    return 0
  fi

  local projects=()
  if [[ -n "$target_project" ]]; then
    projects=("$target_project")
  else
    while read -r line; do
      local name; name=$(echo "$line" | awk '{print $1}')
      [[ -n "$name" ]] && projects+=("$name")
    done < <(list_projects)
  fi

  local p project_dir cfg h prompts tasks_dir session queue_abs qline count lane selected_lanes=() queued_total lane_budget lanes_csv max_panes fixed_panes dynamic_total dynamic_workers generated_only
  for p in "${projects[@]}"; do
    project_dir=$(find_project_config "$p") || continue
    [[ -n "$project_dir" ]] || continue
    cfg="$project_dir/.codex-supervisor.toml"
    while read -r h; do
      [[ -n "$h" ]] || continue
      [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
      if [[ "$h" != "$me" ]]; then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" reason=non_local_host
        else
          printf 'SKIP %s/%s: non-local host for this governor pass\n' "$p" "$h"
        fi
        continue
      fi

      prompts=$(toml_get "$cfg" "hosts.$h" "prompts")
      tasks_dir=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
      session=$(toml_get "$cfg" "hosts.$h" "session")
      [[ -z "$session" ]] && session="${p}-${h}"
      if [[ -z "$prompts" ]]; then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" session="$session" reason=missing_prompts_config
        else
          printf 'SKIP %s/%s: missing prompts config\n' "$p" "$h"
        fi
        continue
      fi
      if session_running_local "$session"; then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" session="$session" reason=already_running
        else
          printf 'SKIP %s/%s session=%s: already running\n' "$p" "$h" "$session"
        fi
        continue
      fi
      if [[ -z "$tasks_dir" ]]; then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" session="$session" reason=no_tasks_dir
        else
          printf 'SKIP %s/%s session=%s: no tasks_dir configured\n' "$p" "$h" "$session"
        fi
        continue
      fi
      queue_abs="$project_dir/$tasks_dir"
      queue_abs=$(path_under_project_if_relative "$project_dir" "$tasks_dir")
      selected_lanes=()
      queued_total=0
      dynamic_total=$(dynamic_queue_goal_count "$queue_abs")
      queued_total="$dynamic_total"
      fixed_panes=$(positive_int_or_default "${CSUP_GOVERNOR_FIXED_PANES:-}" 2) # generated MANAGER + REVIEWER; CEO runs as its own session.
      lane_budget=$(( remaining - fixed_panes ))
      if (( lane_budget < 1 )); then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" session="$session" reason=fixed_roles_reserved
        else
          printf 'SKIP %s/%s session=%s: capacity reserved for fixed roles only\n' "$p" "$h" "$session"
        fi
        continue
      fi
      while read -r qline; do
        [[ -n "$qline" ]] || continue
        count="${qline%% *}"
        lane="${qline#* }"
        selected_lanes+=("$lane")
        queued_total=$((queued_total + 10#$count))
        (( ${#selected_lanes[@]} >= lane_budget )) && break
      done < <(queue_lanes_for_tasks_dir "$queue_abs")

      dynamic_workers=0
      if (( dynamic_total > 0 && ${#selected_lanes[@]} < lane_budget )); then
        dynamic_workers=$(( lane_budget - ${#selected_lanes[@]} ))
        (( dynamic_workers > dynamic_total )) && dynamic_workers="$dynamic_total"
      fi

      if (( ${#selected_lanes[@]} == 0 && dynamic_workers == 0 )); then
        if (( json )); then
          json_emit event=skip project="$p" host="$h" session="$session" reason=no_queued_goal_tasks
        else
          printf 'SKIP %s/%s session=%s: no queued /goal tasks\n' "$p" "$h" "$session"
        fi
        continue
      fi

      lanes_csv=""
      (( ${#selected_lanes[@]} > 0 )) && lanes_csv=$(join_csv "${selected_lanes[@]}")
      generated_only=0
      [[ -z "$lanes_csv" ]] && generated_only=1
      max_panes=$(( ${#selected_lanes[@]} + dynamic_workers + fixed_panes ))
      if (( json )); then
        json_emit event=start project="$p" host="$h" session="$session" lanes="${lanes_csv:-generated-only}" dynamic_workers="$dynamic_workers" panes="$max_panes" queued="$queued_total" generated_only="$generated_only"
      else
        printf 'START %s/%s session=%s lanes=%s dynamic_workers=%s panes=%s queued=%s\n' "$p" "$h" "$session" "${lanes_csv:-generated-only}" "$dynamic_workers" "$max_panes" "$queued_total"
      fi
      if [[ "$mode" == "apply" ]]; then
        run_local_start "$project_dir" "$session" "$prompts" "$tasks_dir" "$lanes_csv" "$max_panes" "$dynamic_workers" "$generated_only" "team"
      fi
      remaining=$(( remaining - max_panes ))
      (( remaining <= 0 )) && return 0
    done < <(toml_sections "$cfg" "hosts.")
  done
  return 0
}

# ---------------------------------------------------------------------------
# Subcommand: factory-audit
# ---------------------------------------------------------------------------
cmd_factory_audit() {
  local target_project=""
  while (( $# > 0 )); do
    case "$1" in
      --project=*) target_project="${1#--project=}" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) target_project="$1" ;;
    esac
    shift
  done

  local projects=()
  if [[ -n "$target_project" ]]; then
    projects=("$target_project")
  else
    while read -r line; do
      local name; name=$(echo "$line" | awk '{print $1}')
      [[ -n "$name" ]] && projects+=("$name")
    done < <(list_projects)
  fi

  local p project_dir cfg h project_name
  for p in "${projects[@]}"; do
    project_dir=$(find_project_config "$p") || {
      printf 'FACTORY %s status=RED docs=missing:project_config\n' "$p"
      printf 'ACTION %s: add .codex-supervisor.toml before factory launch\n' "$p"
      continue
    }
    [[ -n "$project_dir" ]] || continue
    cfg="$project_dir/.codex-supervisor.toml"
    project_name=$(toml_get "$cfg" "project" "name")
    [[ -n "$project_name" ]] || project_name="$p"
    while read -r h; do
      [[ -n "$h" ]] || continue
      factory_audit_project_host "$project_name" "$project_dir" "$cfg" "$h"
    done < <(toml_sections "$cfg" "hosts.")
  done
}

# ---------------------------------------------------------------------------
# Subcommand: factory-run
# ---------------------------------------------------------------------------
factory_run_scenario_defaults() {
  local scenario="$1"
  case "$scenario" in
    resume)   printf '1|5' ;;
    balanced) printf '2|6' ;;
    full)     printf '99|10' ;;
    blockers) printf '1|4' ;;
    *) return 1 ;;
  esac
}

factory_run_remote_counts() {
  local host="$1" tasks_abs="$2" prompts_abs="$3" ssh_target cmd out
  ssh_target=$(host_ssh_target "$host")
  [[ -n "$ssh_target" && "$ssh_target" != "local" ]] || { printf '0|0|0\n'; return; }
  cmd="tasks=$(shell_quote "$tasks_abs"); prompts=$(shell_quote "$prompts_abs"); work=0; blockers=0; prompt_count=0; if [ -d \"\$tasks\" ]; then work=\$(find \"\$tasks\" -maxdepth 2 -type f -name '*.txt' -exec grep -hE '^/goal([[:space:]]|$)' {} + 2>/dev/null | wc -l | tr -d ' '); for f in \"\$tasks/blockers.txt\" \"\$tasks/blocker.txt\"; do [ -f \"\$f\" ] && blockers=\$((blockers + \$(grep -cE '^/goal([[:space:]]|$)' \"\$f\" 2>/dev/null || true))); done; fi; [ -f \"\$prompts\" ] && prompt_count=\$(grep -cE '^/goal([[:space:]]|$)' \"\$prompts\" 2>/dev/null || true); printf '%s|%s|%s\n' \"\${work:-0}\" \"\${blockers:-0}\" \"\${prompt_count:-0}\""
  out=$(ssh_capture_timeout "$ssh_target" "$cmd" 2>/dev/null | tail -1 || true)
  if [[ "$out" =~ ^[0-9]+\|[0-9]+\|[0-9]+$ ]]; then
    printf '%s\n' "$out"
  else
    printf '0|0|0\n'
  fi
}

factory_run_host_counts() {
  local project_dir="$1" cfg="$2" host="$3" tasks_dir prompts remote_dir tasks_abs prompts_abs local_tasks local_prompts
  tasks_dir=$(toml_get "$cfg" "hosts.$host" "tasks_dir")
  prompts=$(toml_get "$cfg" "hosts.$host" "prompts")
  remote_dir=$(project_dir_for_host "$cfg" "$host" "$project_dir")
  tasks_abs=$(path_under_project_if_relative "$remote_dir" "$tasks_dir")
  prompts_abs=$(path_under_project_if_relative "$remote_dir" "$prompts")
  local_tasks=$(path_under_project_if_relative "$project_dir" "$tasks_dir")
  local_prompts=$(path_under_project_if_relative "$project_dir" "$prompts")

  if [[ -n "$tasks_dir" && -d "$local_tasks" ]]; then
    printf '%s|%s|%s\n' "$(goal_count_dir "$local_tasks")" "$(factory_blocker_goal_count "$local_tasks")" "$(factory_prompt_goal_count "$local_prompts")"
  else
    factory_run_remote_counts "$host" "$tasks_abs" "$prompts_abs"
  fi
}

cmd_factory_run() {
  local project="" target_host="" mode="dry-run" scenario="resume" sessions_override="" workers_override="" max_workers_override="" max_panes_override="" allow_static=0
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --scenario=*) scenario="${1#--scenario=}" ;;
      --sessions=*) sessions_override="${1#--sessions=}" ;;
      --workers=*) workers_override="${1#--workers=}" ;;
      --max-workers=*) max_workers_override="${1#--max-workers=}" ;;
      --max-panes=*) max_panes_override="${1#--max-panes=}" ;;
      --allow-static-prompts) allow_static=1 ;;
      --dry-run) mode="dry-run" ;;
      --apply) mode="apply" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done
  [[ -n "$project" ]] || { err "usage: csup factory-run <project> [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply]"; return 2; }

  local defaults default_sessions default_workers
  defaults=$(factory_run_scenario_defaults "$scenario") || { err "unknown factory-run scenario '$scenario'"; return 2; }
  default_sessions="${defaults%%|*}"
  default_workers="${defaults#*|}"
  [[ "$sessions_override" =~ ^[0-9]+$ && "$sessions_override" -gt 0 ]] || sessions_override=""
  [[ "$workers_override" =~ ^[0-9]+$ && "$workers_override" -gt 0 ]] || workers_override=""
  [[ "$max_workers_override" =~ ^[0-9]+$ && "$max_workers_override" -gt 0 ]] || max_workers_override=""
  [[ "$max_panes_override" =~ ^[0-9]+$ && "$max_panes_override" -gt 0 ]] || max_panes_override=""

  local project_dir; project_dir=$(find_project_config "$project")
  [[ -n "$project_dir" ]] || { err "no .codex-supervisor.toml found for project '$project'"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"
  local project_name; project_name=$(toml_get "$cfg" "project" "name")
  [[ -n "$project_name" ]] || project_name="$project"

  local me; me=$(this_host)
  local any=0 h counts work blockers prompts effective_work fixed cap safe_workers max_workers workers sessions panes scheduler
  while read -r h; do
    [[ -n "$h" ]] || continue
    [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
    any=1
    counts=$(factory_run_host_counts "$project_dir" "$cfg" "$h")
    work="${counts%%|*}"
    blockers="${counts#*|}"; blockers="${blockers%%|*}"
    prompts="${counts##*|}"
    [[ "$work" =~ ^[0-9]+$ ]] || work=0
    [[ "$blockers" =~ ^[0-9]+$ ]] || blockers=0
    [[ "$prompts" =~ ^[0-9]+$ ]] || prompts=0
    effective_work="$work"
    [[ "$scenario" == "blockers" ]] && effective_work="$blockers"

    if (( effective_work <= 0 )); then
      if (( allow_static && prompts > 0 )); then
        effective_work="$prompts"
      else
        printf 'HOLD %s/%s reason=no_queued_work work=%s blockers=%s prompts=%s scenario=%s\n' "$project_name" "$h" "$work" "$blockers" "$prompts" "$scenario"
        continue
      fi
    fi

    scheduler=$(host_scheduler "$h")
    if [[ "$scheduler" == "slurm" ]]; then
      fixed="${CSUP_STATION_FIXED_PANES:-1}"
      [[ "$fixed" =~ ^[0-9]+$ ]] || fixed=1
      cap=$(slurm_slot_capacity_panes "$h")
      safe_workers=$((cap - fixed))
      (( safe_workers < 1 )) && { printf 'HOLD %s/%s reason=no_safe_worker_capacity cap=%s fixed=%s\n' "$project_name" "$h" "$cap" "$fixed"; continue; }
      max_workers="${max_workers_override:-$default_workers}"
      (( max_workers > safe_workers )) && max_workers="$safe_workers"
      if [[ -n "$max_panes_override" ]]; then
        local pane_workers=$((max_panes_override - fixed))
        (( pane_workers < 1 )) && pane_workers=1
        (( max_workers > pane_workers )) && max_workers="$pane_workers"
      fi
      workers="${workers_override:-}"
      [[ -z "$workers" ]] && workers="$effective_work"
      (( workers > max_workers )) && workers="$max_workers"
      (( workers < 1 )) && workers=1
      sessions=$(( (effective_work + workers - 1) / workers ))
      [[ -n "$sessions_override" ]] && sessions="$sessions_override"
      (( sessions > default_sessions )) && sessions="$default_sessions"
      (( sessions < 1 )) && sessions=1
      panes=$((workers + fixed))
      printf 'FACTORY-RUN %s/%s scenario=%s work=%s blockers=%s sessions=%s workers=%s panes=%s mode=%s\n' "$project_name" "$h" "$scenario" "$work" "$blockers" "$sessions" "$workers" "$panes" "$mode"
      if [[ "$mode" == "apply" ]]; then
        cmd_station "$project" --host="$h" --sessions="$sessions" --workers="$workers" --apply
      else
        cmd_station "$project" --host="$h" --sessions="$sessions" --workers="$workers" --dry-run
      fi
    elif [[ "$h" == "$me" ]]; then
      printf 'FACTORY-RUN %s/%s scenario=%s work=%s blockers=%s mode=%s delegate=govern\n' "$project_name" "$h" "$scenario" "$work" "$blockers" "$mode"
      if [[ "$mode" == "apply" ]]; then
        if [[ -n "$max_panes_override" ]]; then
          cmd_govern --project="$project" --host="$h" --apply --max-panes="$max_panes_override"
        else
          cmd_govern --project="$project" --host="$h" --apply
        fi
      else
        if [[ -n "$max_panes_override" ]]; then
          cmd_govern --project="$project" --host="$h" --dry-run --max-panes="$max_panes_override"
        else
          cmd_govern --project="$project" --host="$h" --dry-run
        fi
      fi
    elif host_is_lunarc "$h"; then
      printf 'HOLD %s/%s reason=lunarc_requires_slurm_station\n' "$project_name" "$h"
    else
      printf 'HOLD %s/%s reason=remote_non_slurm_use_csup_start_or_configure_scheduler\n' "$project_name" "$h"
    fi
  done < <(toml_sections "$cfg" "hosts.")

  (( any )) || { err "project '$project' has no matching host stanza"; return 1; }
}


# ---------------------------------------------------------------------------
# Subcommand: gm-start / general-manager-start
# ---------------------------------------------------------------------------
cmd_gm_start() {
  local project="" target_host="" mode="dry-run"
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --dry-run) mode="dry-run" ;;
      --apply) mode="apply" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done
  [[ -n "$project" ]] || { err "usage: csup gm-start <project> [--host=<name>] [--dry-run|--apply]"; return 2; }

  local project_dir; project_dir=$(find_project_config "$project")
  [[ -n "$project_dir" ]] || { err "no .codex-supervisor.toml found for project '$project'"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"
  local project_name; project_name=$(toml_get "$cfg" "project" "name")
  [[ -n "$project_name" ]] || project_name="$project"
  local me; me=$(this_host)
  local any=0 h
  while read -r h; do
    [[ -n "$h" ]] || continue
    [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
    any=1
    local prompts tasks_dir session scheduler remote_dir supervisor prompts_abs tasks_abs task_env
    prompts=$(toml_get "$cfg" "hosts.$h" "prompts")
    tasks_dir=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
    session=$(toml_get "$cfg" "hosts.$h" "session")
    [[ -z "$session" ]] && session="${project_name}-${h}"
    scheduler=$(host_scheduler "$h")
    printf 'CEO-BOOT %s/%s session=%s action=start_real_ceo_first panes=1 mode=%s\n' "$project_name" "$h" "$session" "$mode"
    if [[ "$mode" != "apply" ]]; then
      printf 'CEO-NEXT %s/%s: after CEO reviews plans/work/resources, run csup staff to open/reduce/redeploy teams.\n' "$project_name" "$h"
      continue
    fi
    if [[ "$scheduler" == "slurm" ]]; then
      local station_out
      station_out=$(CSUP_STATION_FIXED_PANES=1 CSUP_STATION_PAYLOAD_ROLE=ceo cmd_station "$project" --host="$h" --sessions=1 --workers=0 --apply 2>&1)
      printf '%s\n' "$station_out"
      # When the CEO station was already running it prints SKIP reason=session_running.
      # Unblock a goal-done CEO by appending a re-run task to codex-tasks/ceo.txt so
      # the supervisor restarts the executive review on the next poll cycle.
      if echo "$station_out" | grep -q 'reason=session_running'; then
        local tasks_dir_h; tasks_dir_h=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
        local remote_dir_h; remote_dir_h=$(project_dir_for_host "$cfg" "$h" "$project_dir")
        if [[ -n "$tasks_dir_h" ]]; then
          local tasks_abs_h; tasks_abs_h=$(path_under_project_if_relative "$remote_dir_h" "$tasks_dir_h")
          local ssh_host_h; ssh_host_h=$(toml_get "$cfg" "hosts.$h" "ssh")
          if [[ -n "$ssh_host_h" ]]; then
            ssh "$ssh_host_h" "mkdir -p $(shell_quote "$tasks_abs_h") && printf '/goal Re-run executive review: read docs/ceo-staffing.md and manage staffing.\n' >> $(shell_quote "$tasks_abs_h/ceo.txt")" 2>/dev/null \
              && printf 'CEO-WAKE %s/%s: queued re-run task in ceo.txt so supervisor restarts CEO on next poll.\n' "$project_name" "$h" \
              || printf 'CEO-WAKE-FAIL %s/%s: could not queue re-run task (remote write failed).\n' "$project_name" "$h"
          fi
        fi
      fi
    elif [[ "$h" == "$me" ]]; then
      if session_running_local "$session"; then
        printf 'SKIP %s/%s session=%s reason=session_running\n' "$project_name" "$h" "$session"
        # Unblock a goal-done CEO by submitting to its task queue
        local tasks_dir_local; tasks_dir_local=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
        if [[ -n "$tasks_dir_local" ]]; then
          local tasks_abs_local; tasks_abs_local=$(path_under_project_if_relative "$project_dir" "$tasks_dir_local")
          mkdir -p "$tasks_abs_local"
          printf '/goal Re-run executive review: read docs/ceo-staffing.md and manage staffing.\n' >> "$tasks_abs_local/ceo.txt"
          printf 'CEO-WAKE %s/%s: queued re-run task in ceo.txt.\n' "$project_name" "$h"
        fi
      else
        run_local_start "$project_dir" "$session" "$prompts" "$tasks_dir" "" "1" "0" "1" "ceo"
      fi
    elif host_reachable "$h"; then
      remote_dir=$(project_dir_for_host "$cfg" "$h" "$project_dir")
      supervisor=$(host_supervisor "$h")
      prompts_abs=$(path_under_project_if_relative "$remote_dir" "$prompts")
      tasks_abs=$(path_under_project_if_relative "$remote_dir" "$tasks_dir")
      task_env=""
      [[ -n "$tasks_dir" ]] && task_env=" CODEX_SUPERVISOR_TASKS_DIR=$(shell_quote "$tasks_abs")"
      remote_run_start "$h" "cd $(shell_quote "$remote_dir") || exit 1; CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$task_env CODEX_SUPERVISOR_GENERATED_ONLY=1 CODEX_SUPERVISOR_CEO=1 CODEX_SUPERVISOR_MANAGER=0 CODEX_SUPERVISOR_DEBUGGER=0 CODEX_SUPERVISOR_VALIDATOR=0 CODEX_SUPERVISOR_DYNAMIC_WORKERS=0 CODEX_SUPERVISOR_MAX_PANES=1 $(shell_quote "$supervisor") start --no-attach" 2>&1 | tail -5
    else
      printf 'HOLD %s/%s reason=host_unreachable\n' "$project_name" "$h"
    fi
  done < <(toml_sections "$cfg" "hosts.")
  (( any )) || { err "project '$project' has no matching host stanza"; return 1; }
}

# ---------------------------------------------------------------------------
# Subcommand: staff / gm-staff
# ---------------------------------------------------------------------------
cmd_staff() {
  local project="" target_host="" mode="dry-run" scenario="resume" allow_stop=0 max_workers_override="" workers_override="" sessions_override="" max_panes_override=""
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --scenario=*) scenario="${1#--scenario=}" ;;
      --sessions=*) sessions_override="${1#--sessions=}" ;;
      --workers=*) workers_override="${1#--workers=}" ;;
      --max-workers=*) max_workers_override="${1#--max-workers=}" ;;
      --max-panes=*) max_panes_override="${1#--max-panes=}" ;;
      --allow-stop) allow_stop=1 ;;
      --dry-run) mode="dry-run" ;;
      --apply) mode="apply" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done
  factory_run_scenario_defaults "$scenario" >/dev/null || { err "unknown staffing scenario '$scenario'"; return 2; }

  local project_dir; project_dir=$(find_project_config "$project")
  if [[ -z "$project_dir" ]]; then
    if [[ -z "$project" ]]; then
      err "usage: csup staff [<project>] [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply] [--allow-stop]"
      err "  Run from the project directory (where .codex-supervisor.toml lives) to omit the project argument."
    else
      err "no .codex-supervisor.toml found for project '$project'"
    fi
    return 1
  fi
  local cfg="$project_dir/.codex-supervisor.toml"
  local project_name; project_name=$(toml_get "$cfg" "project" "name")
  [[ -n "$project_name" ]] || project_name="$project"
  # Use absolute path so cmd_factory_run can resolve on any host layout
  [[ -z "$project" ]] && project="$project_dir"

  local me; me=$(this_host)
  local any=0 h counts work blockers prompts effective_work session scheduler
  while read -r h; do
    [[ -n "$h" ]] || continue
    [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
    any=1
    counts=$(factory_run_host_counts "$project_dir" "$cfg" "$h")
    work="${counts%%|*}"
    blockers="${counts#*|}"; blockers="${blockers%%|*}"
    prompts="${counts##*|}"
    [[ "$work" =~ ^[0-9]+$ ]] || work=0
    [[ "$blockers" =~ ^[0-9]+$ ]] || blockers=0
    [[ "$prompts" =~ ^[0-9]+$ ]] || prompts=0
    effective_work="$work"
    [[ "$scenario" == "blockers" ]] && effective_work="$blockers"
    session=$(toml_get "$cfg" "hosts.$h" "session")
    [[ -z "$session" ]] && session="${project_name}-${h}"
    scheduler=$(host_scheduler "$h")

    # Team invariant check: warn if TEAM_PLAN.md has teams missing manager or workers
    local team_plan_h
    team_plan_h=$(path_under_project_if_relative "$(project_dir_for_host "$cfg" "$h" "$project_dir")" "docs/parallel-sessions/TEAM_PLAN.md")
    if [[ "$h" == "$me" && -f "$team_plan_h" ]]; then
      local tp_team tp_workers tp_manager
      while IFS='|' read -r tp_team tp_workers tp_manager _rest; do
        tp_team=$(printf '%s' "$tp_team" | tr -d '[:space:]')
        tp_workers=$(printf '%s' "$tp_workers" | tr -d '[:space:]')
        tp_manager=$(printf '%s' "$tp_manager" | tr -d '[:space:]')
        [[ -z "$tp_team" || "$tp_team" == Team* || "$tp_team" == --- || "$tp_team" == "#"* ]] && continue
        # Skip rows where the workers column is not a plain integer — these are
        # acceptance-board, artifact-ledger, or other prose table rows, not team rows.
        [[ ! "$tp_workers" =~ ^[0-9]+$ ]] && continue
        [[ "$tp_workers" == "0" || -z "$tp_workers" ]] && \
          printf 'WARN %s/%s team=%s has_workers=0: every active team requires at least 1 worker. Add workers or close the team.\n' "$project_name" "$h" "$tp_team"
        [[ -z "$tp_manager" ]] && \
          printf 'WARN %s/%s team=%s manager=missing: every active team requires a manager lane. Add a manager or close the team.\n' "$project_name" "$h" "$tp_team"
      done < "$team_plan_h"
    fi

    if (( effective_work > 0 )); then
      printf 'STAFF-UP %s/%s reason=queued_work work=%s blockers=%s prompts=%s scenario=%s action=factory-run mode=%s\n' "$project_name" "$h" "$work" "$blockers" "$prompts" "$scenario" "$mode"
      local args=("$project" "--host=$h" "--scenario=$scenario")
      [[ -n "$sessions_override" ]] && args+=("--sessions=$sessions_override")
      [[ -n "$workers_override" ]] && args+=("--workers=$workers_override")
      [[ -n "$max_workers_override" ]] && args+=("--max-workers=$max_workers_override")
      [[ -n "$max_panes_override" ]] && args+=("--max-panes=$max_panes_override")
      if [[ "$mode" == "apply" ]]; then
        args+=("--apply")
      else
        args+=("--dry-run")
      fi
      cmd_factory_run "${args[@]}"
    else
      local tasks_dir_h; tasks_dir_h=$(toml_get "$cfg" "hosts.$h" "tasks_dir")
      local remote_dir_h; remote_dir_h=$(project_dir_for_host "$cfg" "$h" "$project_dir")
      local tasks_abs_h=""
      [[ -n "$tasks_dir_h" ]] && tasks_abs_h=$(path_under_project_if_relative "$remote_dir_h" "$tasks_dir_h")
      local has_queue_files=0
      if [[ -n "$tasks_abs_h" ]]; then
        # Count non-empty task queue files for this host
        local q_count=0
        [[ "$h" == "$me" ]] && q_count=$(find "$tasks_abs_h" -name "*.txt" -size +0c 2>/dev/null | wc -l | tr -d ' ')
        [[ "$q_count" =~ ^[0-9]+$ ]] && (( q_count > 0 )) && has_queue_files=1
      fi
      printf 'STAFF-DOWN %s/%s session=%s reason=no_queued_work work=%s blockers=%s prompts=%s action=%s mode=%s\n' \
        "$project_name" "$h" "$session" "$work" "$blockers" "$prompts" \
        "$([[ "$mode" == "apply" && "$allow_stop" == "1" ]] && printf 'stop_configured_session' || printf 'recommend_stop_or_shrink')" "$mode"
      if (( ! has_queue_files )) && [[ -n "$tasks_abs_h" ]]; then
        printf 'BOOTSTRAP %s/%s: no task queue files found in %s. CEO must create %s/ceo.txt and write manager task files before staffing can proceed.\n' \
          "$project_name" "$h" "$tasks_abs_h" "$tasks_abs_h"
      fi
      if [[ "$mode" == "apply" && "$allow_stop" == "1" ]]; then
        # This is intentionally explicit and coarse: GM should use it only after
        # managers confirm the TEAM_PLAN has no unchecked acceptance work for
        # this host/session. Without --allow-stop, staff never kills sessions.
        cmd_stop "$project" "--host=$h"
      elif [[ "$scheduler" == "slurm" ]]; then
        printf 'GM-NOTE %s/%s: keep fixed GM/manager layer only; stop extra worker station sessions after manager acceptance audit.\n' "$project_name" "$h"
      else
        printf 'GM-NOTE %s/%s: no new workers; validator should stop/recycle idle dynamic panes.\n' "$project_name" "$h"
      fi
    fi
  done < <(toml_sections "$cfg" "hosts.")
  (( any )) || { err "project '$project' has no matching host stanza"; return 1; }
}

# ---------------------------------------------------------------------------
# Subcommand: station
# ---------------------------------------------------------------------------
station_remote_session_payload() {
  local project_dir="$1" cfg="$2" host="$3" session="$4" workers="$5" panes="$6"
  local prompts tasks_dir remote_dir supervisor prompts_abs tasks_abs task_env role ceo_enabled manager_enabled reviewer_enabled
  prompts=$(toml_get "$cfg" "hosts.$host" "prompts")
  tasks_dir=$(toml_get "$cfg" "hosts.$host" "tasks_dir")
  remote_dir=$(project_dir_for_host "$cfg" "$host" "$project_dir")
  supervisor=$(host_supervisor "$host")
  prompts_abs=$(path_under_project_if_relative "$remote_dir" "$prompts")
  tasks_abs=$(path_under_project_if_relative "$remote_dir" "$tasks_dir")
  task_env=""
  [[ -n "$tasks_dir" ]] && task_env=" CODEX_SUPERVISOR_TASKS_DIR=$(shell_quote "$tasks_abs")"
  role="${CSUP_STATION_PAYLOAD_ROLE:-team}"
  ceo_enabled=0
  manager_enabled=1
  reviewer_enabled=1
  if [[ "$role" == "ceo" || "$role" == "executive" ]]; then
    ceo_enabled=1
    manager_enabled=0
    reviewer_enabled=0
  fi
  printf '%s' "cd $(shell_quote "$remote_dir") || exit 1; CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$task_env CODEX_SUPERVISOR_GENERATED_ONLY=1 CODEX_SUPERVISOR_CEO=$(shell_quote "$ceo_enabled") CODEX_SUPERVISOR_MANAGER=$(shell_quote "$manager_enabled") CODEX_SUPERVISOR_REVIEWER=$(shell_quote "$reviewer_enabled") CODEX_SUPERVISOR_DEBUGGER=0 CODEX_SUPERVISOR_VALIDATOR=0 CODEX_SUPERVISOR_DYNAMIC_WORKERS=$(shell_quote "$workers") CODEX_SUPERVISOR_MAX_PANES=$(shell_quote "$panes") $(shell_quote "$supervisor") start --no-attach"
}

station_start_remote_session() {
  local project_dir="$1" cfg="$2" host="$3" job="$4" base_session="$5" session="$6" workers="$7" panes="$8" payload
  payload=$(station_remote_session_payload "$project_dir" "$cfg" "$host" "$session" "$workers" "$panes")
  remote_slurm_keepalive_start_job "$host" "$job" "$session" \
    "$payload" \
    2>&1 | tail -5
}

station_start_remote_sessions() {
  local project_dir="$1" cfg="$2" host="$3" job="$4" workers="$5" panes="$6" count i payload
  shift 6
  local sessions=("$@") payloads=()
  count="${#sessions[@]}"
  (( count > 0 )) || return 0
  for ((i=0; i<count; i++)); do
    payload=$(station_remote_session_payload "$project_dir" "$cfg" "$host" "${sessions[$i]}" "$workers" "$panes")
    payloads+=("$payload")
  done
  remote_slurm_keepalive_start_batch_job "$host" "$job" "$count" "${sessions[@]}" "${payloads[@]}" 2>&1 | tail -5
}

cmd_station() {
  local project="" target_host="" mode="dry-run" sessions=1 workers=0 fixed_panes="${CSUP_STATION_FIXED_PANES:-1}"
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --sessions=*) sessions="${1#--sessions=}" ;;
      --workers=*) workers="${1#--workers=}" ;;
      --dry-run) mode="dry-run" ;;
      --apply) mode="apply" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done
  [[ -n "$project" ]] || { err "usage: csup station <project> --sessions=N --workers=N [--host=<name>] [--dry-run|--apply]"; return 2; }
  [[ "$sessions" =~ ^[0-9]+$ && "$sessions" -gt 0 ]] || { err "--sessions must be a positive integer"; return 2; }
  [[ "$workers" =~ ^[0-9]+$ ]] || { err "--workers must be a non-negative integer"; return 2; }
  [[ "$fixed_panes" =~ ^[0-9]+$ ]] || fixed_panes=1

  local project_dir; project_dir=$(find_project_config "$project")
  [[ -n "$project_dir" ]] || { err "no .codex-supervisor.toml found for project '$project'"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"
  local requested_panes=$((workers + fixed_panes))
  (( requested_panes > 0 )) || requested_panes=1
  local remaining="$sessions" global_idx=1 any_host=0 h
  printf 'csup: station mode=%s project=%s host=%s sessions=%s workers=%s panes_per_session=%s\n' "$mode" "$project" "${target_host:-any}" "$sessions" "$workers" "$requested_panes"

  while read -r h; do
    [[ -n "$h" ]] || continue
    [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
    [[ "$(host_scheduler "$h")" == "slurm" ]] || continue
    any_host=1
    ssh_login_reachable "$h" || { printf 'HOLD %s/%s sessions_waiting=%s reason=login_unreachable\n' "$project" "$h" "$remaining"; continue; }

    local slots capacity slot first_empty_slot=0 start_batch_size
    slots=$(slurm_slots_for_host "$h")
    capacity=$(slurm_slot_capacity_panes "$h")
    start_batch_size=$(slurm_start_batch_size "$h")
    for ((slot=1; slot<=slots && remaining>0; slot++)); do
      local job_name info job node used room load_room fit started base_session
      local batch_sessions=()
      job_name=$(slurm_job_name_for_slot "$h" "$slot")
      info=$(slurm_active_job_info_named "$h" "$job_name" || true)
      job="${info%%|*}"
      node=""
      [[ "$info" == *"|"* ]] && node="${info#*|}"
      if [[ -z "$job" ]]; then
        (( first_empty_slot == 0 )) && first_empty_slot="$slot"
        continue
      fi

      used=$(slurm_remote_pane_count "$h" "$job")
      room=$((capacity - used))
      (( room < 0 )) && room=0
      load_room=$(slurm_remote_load_room "$h" "$job")
      (( load_room < room )) && room="$load_room"
      if (( room < requested_panes )); then
        printf 'FULL %s/%s slot=%s job=%s used=%s capacity=%s load_room=%s requested_panes=%s\n' "$project" "$h" "$slot" "$job" "$used" "$capacity" "$load_room" "$requested_panes"
        continue
      fi

      fit=$((room / requested_panes))
      (( fit > remaining )) && fit="$remaining"
      (( fit < 1 )) && continue
      base_session=$(toml_get "$cfg" "hosts.$h" "session")
      [[ -z "$base_session" ]] && base_session="${project}-${h}"
      for ((started=0; started<fit; started++)); do
        local session_name
        session_name="${base_session}-station-${global_idx}"
        if slurm_remote_session_running "$h" "$job" "$session_name"; then
          printf 'SKIP %s/%s slot=%s job=%s node=%s session=%s reason=session_running\n' "$project" "$h" "$slot" "$job" "${node:-unknown}" "$session_name"
          remaining=$((remaining - 1))
          global_idx=$((global_idx + 1))
          continue
        fi
        printf 'START %s/%s slot=%s job=%s node=%s session=%s workers=%s panes=%s\n' "$project" "$h" "$slot" "$job" "${node:-unknown}" "$session_name" "$workers" "$requested_panes"
        if [[ "$mode" == "apply" ]]; then
          batch_sessions+=("$session_name")
          if (( ${#batch_sessions[@]} >= start_batch_size )); then
            station_start_remote_sessions "$project_dir" "$cfg" "$h" "$job" "$workers" "$requested_panes" "${batch_sessions[@]}"
            batch_sessions=()
          fi
        fi
        remaining=$((remaining - 1))
        global_idx=$((global_idx + 1))
      done
      if [[ "$mode" == "apply" && ${#batch_sessions[@]} -gt 0 ]]; then
        station_start_remote_sessions "$project_dir" "$cfg" "$h" "$job" "$workers" "$requested_panes" "${batch_sessions[@]}"
      fi
    done

    if (( remaining > 0 && first_empty_slot > 0 )); then
      local slot job_name info job node room fit started waited wait_secs base_session
      local batch_sessions=()
      slot="$first_empty_slot"
      job_name=$(slurm_job_name_for_slot "$h" "$slot")
      if [[ "$mode" == "apply" ]]; then
        printf 'SUBMIT %s/%s slot=%s job_name=%s requested_panes=%s\n' "$project" "$h" "$slot" "$job_name" "$requested_panes"
        slurm_submit_holder_named "$h" "$job_name" >/dev/null || { printf 'HOLD %s/%s slot=%s job_name=%s sessions_waiting=%s reason=submit_failed\n' "$project" "$h" "$slot" "$job_name" "$remaining"; return 0; }
        wait_secs=$(nonnegative_int_or_default "${CSUP_SLURM_WAIT_SECS:-}" 120)
        waited=0
        info=""
        while (( waited < wait_secs )); do
          sleep 5
          waited=$((waited + 5))
          info=$(slurm_active_job_info_named "$h" "$job_name" || true)
          [[ -n "$info" ]] && break
        done
        if [[ -z "$info" ]]; then
          printf 'HOLD %s/%s slot=%s job_name=%s sessions_waiting=%s reason=slurm_queue\n' "$project" "$h" "$slot" "$job_name" "$remaining"
          return 0
        fi
        job="${info%%|*}"
        node=""
        [[ "$info" == *"|"* ]] && node="${info#*|}"
        load_room=$(slurm_remote_load_room "$h" "$job")
        room="$capacity"
        (( load_room < room )) && room="$load_room"
        fit=$((room / requested_panes))
        (( fit > remaining )) && fit="$remaining"
        base_session=$(toml_get "$cfg" "hosts.$h" "session")
        [[ -z "$base_session" ]] && base_session="${project}-${h}"
        for ((started=0; started<fit; started++)); do
          local session_name
          session_name="${base_session}-station-${global_idx}"
          if slurm_remote_session_running "$h" "$job" "$session_name"; then
            printf 'SKIP %s/%s slot=%s job=%s node=%s session=%s reason=session_running\n' "$project" "$h" "$slot" "$job" "${node:-unknown}" "$session_name"
            remaining=$((remaining - 1))
            global_idx=$((global_idx + 1))
            continue
          fi
          printf 'START %s/%s slot=%s job=%s node=%s session=%s workers=%s panes=%s\n' "$project" "$h" "$slot" "$job" "${node:-unknown}" "$session_name" "$workers" "$requested_panes"
          batch_sessions+=("$session_name")
          if (( ${#batch_sessions[@]} >= start_batch_size )); then
            station_start_remote_sessions "$project_dir" "$cfg" "$h" "$job" "$workers" "$requested_panes" "${batch_sessions[@]}"
            batch_sessions=()
          fi
          remaining=$((remaining - 1))
          global_idx=$((global_idx + 1))
        done
        if (( ${#batch_sessions[@]} > 0 )); then
          station_start_remote_sessions "$project_dir" "$cfg" "$h" "$job" "$workers" "$requested_panes" "${batch_sessions[@]}"
        fi
      else
        printf 'PLAN %s/%s slot=%s job_name=%s action=submit requested_panes=%s sessions_waiting=%s\n' "$project" "$h" "$slot" "$job_name" "$requested_panes" "$remaining"
        return 0
      fi
    fi
    (( remaining <= 0 )) && break
  done < <(toml_sections "$cfg" "hosts.")

  (( any_host )) || { err "project '$project' has no matching SLURM host stanza"; return 1; }
  if (( remaining > 0 )); then
    printf 'HOLD %s/%s sessions_waiting=%s reason=no_station_capacity\n' "$project" "${target_host:-slurm}" "$remaining"
  fi
  return 0
}

# ---------------------------------------------------------------------------
# Subcommand: steward
# ---------------------------------------------------------------------------
cmd_steward() {
  local target_project="" sample_secs="${CSUP_STEWARD_SAMPLE_SECS:-15}" dashboard_url="${CSUP_DASHBOARD_URL:-http://127.0.0.1:7777}"
  while (( $# > 0 )); do
    case "$1" in
      --project=*) target_project="${1#--project=}" ;;
      --sample-secs=*) sample_secs="${1#--sample-secs=}" ;;
      --dashboard-url=*) dashboard_url="${1#--dashboard-url=}" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) target_project="$1" ;;
    esac
    shift
  done
  [[ "$sample_secs" =~ ^[0-9]+([.][0-9]+)?$ ]] || sample_secs=15
  python3 - "$dashboard_url" "$target_project" "$sample_secs" <<'PY'
import hashlib
import json
import math
import re
import sys
import time
import urllib.parse
import urllib.request

base, target_project, sample_secs_raw = sys.argv[1:4]
try:
    sample_secs = float(sample_secs_raw or 0)
    if not math.isfinite(sample_secs) or sample_secs < 0:
        sample_secs = 0.0
except (TypeError, ValueError):
    sample_secs = 0.0

def project_slug(name):
    return re.sub(r"[^a-z0-9]+", "-", str(name or "project").lower()).strip("-") or "project"

def fetch_state():
    url = base.rstrip("/") + "/api/state.json?compact=1&tail=12"
    with urllib.request.urlopen(url, timeout=15) as r:
        return json.loads(r.read(2_000_000).decode("utf-8"))

def flatten(state):
    rows = {}
    for project in state.get("projects", []) or []:
        if target_project and target_project not in {project.get("name"), project.get("slug"), project_slug(project.get("name", ""))}:
            continue
        for inst in project.get("instances", []) or []:
            for pane in inst.get("panes", []) or []:
                key = (
                    str(project.get("name", "")),
                    str(inst.get("host", "")),
                    str(inst.get("session", "")),
                    str(pane.get("index", "")),
                )
                tail = "\n".join(str(x) for x in (pane.get("tail") or []))
                rows[key] = {
                    "project": project.get("name", ""),
                    "host": inst.get("host", ""),
                    "session": inst.get("session", ""),
                    "lane": pane.get("lane") or f"pane{pane.get('index')}",
                    "index": pane.get("index"),
                    "state": pane.get("state") or "",
                    "model": pane.get("model") or "",
                    "tail": tail,
                    "sig": hashlib.sha1(tail.encode("utf-8", "replace")).hexdigest(),
                }
    return rows

def classify(row, changed):
    text = re.sub(r"\s+", " ", (row.get("tail") or "").lower())
    state = (row.get("state") or "").lower()
    if state == "dead" or "pane is dead" in text:
        return "DEAD", "stop-or-replace"
    if state == "goal-done" or "goal achieved" in text or "marked complete" in text or "final budget usage" in text:
        return "DONE", "reassign-or-stop"
    if any(token in text for token in ["blocked", "no safe", "missing exact", "outside lease", "unclaimable", "cannot be validated"]):
        return "BLOCKED", "validator-requeue"
    if any(token in text for token in ["waiting for background terminal", "sleep ", "github", "actions job", "rate limit"]):
        return ("WAITING_ACTIVE" if changed else "WAITING_STALE"), "check-background-or-reassign"
    if changed:
        return "ACTIVE", "keep"
    if state in {"working", "idle", "ready"}:
        return "STALE_WORKING", "inspect-or-reassign"
    return "UNKNOWN", "inspect"

try:
    first = flatten(fetch_state())
except Exception as exc:
    print(f"STEWARD status=RED error=dashboard_unreachable detail={str(exc)[:180]}")
    raise SystemExit(1)

if sample_secs > 0:
    time.sleep(sample_secs)
    second = flatten(fetch_state())
else:
    second = dict(first)

counts = {}
actions = {}
for key, row in second.items():
    changed = key in first and first[key]["sig"] != row["sig"]
    bucket, action = classify(row, changed)
    counts[bucket] = counts.get(bucket, 0) + 1
    actions[action] = actions.get(action, 0) + 1

print(
    "STEWARD summary "
    + " ".join(f"{k.lower()}={counts[k]}" for k in sorted(counts))
    + f" total={len(second)} sample_secs={sample_secs:g}"
)
print(
    "STEWARD action "
    + " ".join(f"{k}={actions[k]}" for k in sorted(actions))
)

priority = {"DEAD": 0, "DONE": 1, "BLOCKED": 2, "WAITING_STALE": 3, "STALE_WORKING": 4, "UNKNOWN": 5, "WAITING_ACTIVE": 6, "ACTIVE": 7}
for key, row in sorted(second.items(), key=lambda kv: (priority.get(classify(kv[1], kv[0] in first and first[kv[0]]["sig"] != kv[1]["sig"])[0], 9), kv[0])):
    changed = key in first and first[key]["sig"] != row["sig"]
    bucket, action = classify(row, changed)
    if bucket in {"ACTIVE", "WAITING_ACTIVE"}:
        continue
    tail = re.sub(r"\s+", " ", row.get("tail") or "").strip()[-180:]
    print(
        f"STEWARD pane project={row['project']} host={row['host']} session={row['session']} "
        f"pane={row['index']} lane={row['lane']} status={bucket} changed={int(changed)} action={action} tail={tail}"
    )

if counts.get("DONE", 0) or counts.get("BLOCKED", 0) or counts.get("STALE_WORKING", 0) or counts.get("DEAD", 0):
    print("STEWARD recommendation: VALIDATOR should recycle DONE/DEAD panes, convert BLOCKED panes into blocker/open queue items, and reassign stale dynamic workers to the highest unchecked TEAM_PLAN acceptance gap.")
else:
    print("STEWARD recommendation: active panes are changing; keep current staffing and audit acceptance evidence.")
PY
}

# ---------------------------------------------------------------------------
# Subcommand: stop
# ---------------------------------------------------------------------------
cmd_stop() {
  local project="" target_host=""
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      *) project="$1" ;;
    esac
    shift
  done
  [[ -z "$project" ]] && { err "usage: csup stop <project> [--host=<name>]"; return 2; }
  local project_dir; project_dir=$(find_project_config "$project")
  [[ -z "$project_dir" ]] && { err "no project found"; return 1; }
  local cfg="$project_dir/.codex-supervisor.toml"
  local me; me=$(this_host)

  local hosts_to_stop=()
  if [[ -n "$target_host" ]]; then hosts_to_stop=("$target_host")
  else while read -r h; do [[ -n "$h" ]] && hosts_to_stop+=("$h"); done < <(toml_sections "$cfg" "hosts."); fi

  for h in "${hosts_to_stop[@]}"; do
    local session; session=$(toml_get "$cfg" "hosts.$h" "session")
    local supervisor; supervisor=$(host_supervisor "$h")
    [[ -z "$session" ]] && session="${project}-${h}"
    if is_same_machine "$h"; then
      info "stopping '$session' on $h"
      CODEX_SUPERVISOR_SESSION="$session" "$SUPERVISOR" stop 2>&1 | tail -3
    else
      if host_reachable "$h"; then
        info "stopping '$session' on $h"
        remote_run_existing "$h" "CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") $(shell_quote "$supervisor") stop" 2>&1 | tail -3
      else
        warn "host '$h' unreachable; can't stop '$session'"
      fi
    fi
  done
}

# ---------------------------------------------------------------------------
# Subcommand: tunnel
# Auto-discover all active SLURM compute nodes and establish SSH port-forwards
# so their dashboards are reachable on localhost.
#
# State file: ~/.config/csup/tunnels.tsv  (node TAB pid TAB port TAB ssh_target)
# Ports assigned from CSUP_TUNNEL_BASE_PORT (default 7778) upward, one per
# unique node, persisted so the same node always gets the same port.
# ---------------------------------------------------------------------------
TUNNEL_STATE="${CSUP_TUNNEL_STATE:-$HOME/.config/csup/tunnels.tsv}"
TUNNEL_BASE_PORT="${CSUP_TUNNEL_BASE_PORT:-7778}"
TUNNEL_REMOTE_PORT="${CSUP_TUNNEL_REMOTE_PORT:-7777}"
[[ "$TUNNEL_BASE_PORT" =~ ^[0-9]+$ && "$TUNNEL_BASE_PORT" -gt 0 ]] || TUNNEL_BASE_PORT=7778
[[ "$TUNNEL_REMOTE_PORT" =~ ^[0-9]+$ && "$TUNNEL_REMOTE_PORT" -gt 0 ]] || TUNNEL_REMOTE_PORT=7777

_tunnel_state_read() {
  # Emit lines: node pid port [ssh_target]  (tab-separated)
  [[ -f "$TUNNEL_STATE" ]] || return 0
  local data
  data=$(LC_ALL=C head -c 1000001 "$TUNNEL_STATE" 2>/dev/null || true)
  if (( ${#data} > 1000000 )); then
    warn "tunnel state skipped: $TUNNEL_STATE is too large"
    return 0
  fi
  printf '%s\n' "$data"
}

_tunnel_state_write() {
  # Args: assoc-array content as "node\tpid\tport" lines on stdin
  mkdir -p "$(dirname "$TUNNEL_STATE")"
  cat > "$TUNNEL_STATE"
}

_tunnel_pid_alive() {
  local pid="$1"
  [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null
}

_tunnel_port_for_node() {
  # Returns existing port for node, or picks next free one
  local node="$1"
  local existing
  existing=$(grep -m1 "^${node}	" "$TUNNEL_STATE" 2>/dev/null | cut -f3)
  if [[ "$existing" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$existing"
    return
  fi
  # Find highest used port and add 1
  local max_port=$(( TUNNEL_BASE_PORT - 1 ))
  while IFS=$'\t' read -r _n _p port _target; do
    [[ "$port" =~ ^[0-9]+$ ]] || continue
    [[ -n "$port" && "$port" -gt "$max_port" ]] && max_port="$port"
  done < <(_tunnel_state_read)
  printf '%d\n' $(( max_port + 1 ))
}

cmd_tunnel() {
  local auto=0 kill_all=0
  while (( $# > 0 )); do
    case "$1" in
      --auto)     auto=1 ;;
      --kill|--stop) kill_all=1 ;;
      -h|--help)
        printf 'Usage: csup tunnel [--kill]\n'
        printf '  Discovers all active SLURM compute nodes across every project,\n'
        printf '  establishes ssh -L tunnels so their dashboards are reachable\n'
        printf '  on localhost (starting at port %d).\n' "$TUNNEL_BASE_PORT"
        printf '  --kill  tear down all managed tunnels\n'
        return 0 ;;
      *) err "unknown flag: $1"; return 2 ;;
    esac
    shift
  done

  # --- Kill mode ---
  if (( kill_all )); then
    while IFS=$'\t' read -r node pid port ssh_target; do
      [[ -z "$node" || -z "$port" ]] && continue
      [[ -n "$ssh_target" ]] || ssh_target="lunarc"
      # Cancel ControlMaster forwards when possible, and also kill fallback
      # background ssh -N processes recorded in the state file.
      ssh -O cancel -L "${port}:${node}:${TUNNEL_REMOTE_PORT}" "$ssh_target" 2>/dev/null \
        && printf 'cancelled tunnel %s (port %s)\n' "$node" "$port" \
        || printf 'note: tunnel %s port %s already gone\n' "$node" "$port"
      if _tunnel_pid_alive "$pid"; then
        kill "$pid" 2>/dev/null || true
      fi
    done < <(_tunnel_state_read)
    : > "$TUNNEL_STATE"
    return 0
  fi

  # --- Discover active SLURM nodes from all project configs ---
  # Stored as temp file: node TAB ssh_target (no assoc arrays; bash 3 compat)
  local nodes_tmp; nodes_tmp=$(mktemp)
  trap 'rm -f "$nodes_tmp"' RETURN

  while read -r proj_line; do
    local pname; pname=$(printf '%s' "$proj_line" | awk '{print $1}')
    local pdir; pdir=$(find_project_config "$pname" 2>/dev/null) || true
    [[ -z "$pdir" ]] && continue
    local cfg="$pdir/.codex-supervisor.toml"
    [[ -f "$cfg" ]] || continue

    while read -r h; do
      [[ -z "$h" ]] && continue
      [[ "$(host_scheduler "$h" 2>/dev/null)" != "slurm" ]] && continue
      local ssh_target; ssh_target=$(host_ssh_target "$h" 2>/dev/null) || continue
      [[ -z "$ssh_target" || "$ssh_target" == "local" ]] && continue
      local node; node=$(slurm_active_job_node "$h" 2>/dev/null) || true
      [[ -z "$node" ]] && continue
      # Deduplicate by node
      grep -q "^${node}	" "$nodes_tmp" 2>/dev/null || printf '%s\t%s\n' "$node" "$ssh_target" >> "$nodes_tmp"
    done < <(toml_sections "$cfg" "hosts.")
  done < <(list_projects)

  if [[ ! -s "$nodes_tmp" ]]; then
    (( auto )) || printf 'no active SLURM compute nodes found — nothing to tunnel\n'
    return 0
  fi

  # --- Load existing state, cull dead tunnels ---
  local alive_tmp; alive_tmp=$(mktemp)
  trap 'rm -f "$nodes_tmp" "$alive_tmp"' RETURN

  while IFS=$'\t' read -r node pid port ssh_target; do
    [[ -z "$node" ]] && continue
    if _tunnel_pid_alive "$pid"; then
      printf '%s\t%s\t%s\t%s\n' "$node" "$pid" "$port" "$ssh_target" >> "$alive_tmp"
    else
      [[ -n "$pid" ]] && printf 'tunnel for %s (pid %s) was dead — removed\n' "$node" "$pid"
    fi
  done < <(_tunnel_state_read)

  # --- Set up missing tunnels ---
  local tmp_state; tmp_state=$(mktemp)
  cat "$alive_tmp" > "$tmp_state"

  while IFS=$'\t' read -r node ssh_target; do
    [[ -z "$node" ]] && continue
    # Already alive?
    local existing_port; existing_port=$(grep -m1 "^${node}	" "$alive_tmp" 2>/dev/null | cut -f3)
    if [[ -n "$existing_port" ]]; then
      (( auto )) || printf 'tunnel already up: %s → http://127.0.0.1:%s\n' "$node" "$existing_port"
      continue
    fi
    local port; port=$(_tunnel_port_for_node "$node")
    # Add port-forward to the existing ControlMaster — no new process needed.
    # Falls back to a background ssh -f -N if no ControlMaster socket exists.
    local fwd_ok=0 cm_pid=""
    if ssh -O check "$ssh_target" 2>/dev/null; then
      if ssh -O forward -L "${port}:${node}:${TUNNEL_REMOTE_PORT}" "$ssh_target" 2>/dev/null; then
        fwd_ok=1
        cm_pid=$(ssh -O check "$ssh_target" 2>&1 | grep -o 'pid=[0-9]*' | grep -o '[0-9]*') || cm_pid=""
      fi
    fi
    if (( ! fwd_ok )); then
      ssh -N -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 \
        -L "${port}:${node}:${TUNNEL_REMOTE_PORT}" "$ssh_target" >/dev/null 2>&1 &
      cm_pid=$!
      sleep 0.2
      if _tunnel_pid_alive "$cm_pid"; then
        fwd_ok=1
      else
        wait "$cm_pid" 2>/dev/null || true
        cm_pid=""
      fi
    fi
    (( fwd_ok )) || { printf 'WARNING: could not open tunnel to %s\n' "$node"; continue; }

    printf '%s\t%s\t%s\t%s\n' "$node" "${cm_pid:-0}" "$port" "$ssh_target" >> "$tmp_state"
    printf 'tunnel opened: %s → http://127.0.0.1:%s\n' "$node" "$port"
  done < "$nodes_tmp"

  cat "$tmp_state" | _tunnel_state_write
  rm -f "$tmp_state" "$alive_tmp" "$nodes_tmp"
  trap - RETURN

  printf '\nActive tunnels:\n'
  while IFS=$'\t' read -r node pid port ssh_target; do
    [[ -z "$node" ]] && continue
    printf '  %-10s http://127.0.0.1:%-5s (pid %s)\n' "$node" "$port" "$pid"
  done < <(_tunnel_state_read)
}

# ---------------------------------------------------------------------------
# Subcommand: status
# ---------------------------------------------------------------------------
cmd_status() {
  local project="" target_host=""
  while (( $# > 0 )); do
    case "$1" in
      --host=*) target_host="${1#--host=}" ;;
      --*) err "unknown flag: $1"; return 2 ;;
      *) project="$1" ;;
    esac
    shift
  done
  local me; me=$(this_host)

  local projects=()
  if [[ -n "$project" ]]; then
    projects=("$project")
  else
    while read -r line; do
      local name=$(echo "$line" | awk '{print $1}')
      [[ -n "$name" ]] && projects+=("$name")
    done < <(list_projects)
  fi

  for p in "${projects[@]}"; do
    local d; d=$(find_project_config "$p")
    [[ -z "$d" ]] && continue
    local cfg="$d/.codex-supervisor.toml"
    printf '\n=== %s ===\n' "$p"
    while read -r h; do
      [[ -z "$h" ]] && continue
      [[ -n "$target_host" && "$h" != "$target_host" ]] && continue
      local session; session=$(toml_get "$cfg" "hosts.$h" "session")
      local supervisor; supervisor=$(host_supervisor "$h")
      local prompts; prompts=$(toml_get "$cfg" "hosts.$h" "prompts")
      local host_role; host_role=$(toml_get "$cfg" "hosts.$h" "role")
      local remote_dir; remote_dir=$(project_dir_for_host "$cfg" "$h" "$d")
      [[ -z "$session" ]] && session="${p}-${h}"
      local runtime=""
      if [[ "$(host_scheduler "$h")" == "slurm" && "$h" != "$me" ]]; then
        local info job node; info=$(slurm_active_job_info "$h" || true)
        job="${info%%|*}"
        node=""
        [[ "$info" == *"|"* ]] && node="${info#*|}"
        [[ -n "$job" ]] && runtime="$runtime job=$job"
        [[ -n "$node" && "$node" != "$info" ]] && runtime="$runtime node=$node"
      fi
      printf '\n[%s] session=%s%s\n' "$h" "$session" "$runtime"
      local status_role_env=""
      case "${host_role:-}" in
        team|worker|remote-executor) status_role_env=" CODEX_SUPERVISOR_CEO=0 CODEX_SUPERVISOR_MANAGER=0 CODEX_SUPERVISOR_REVIEWER=0 CODEX_SUPERVISOR_DEBUGGER=0 CODEX_SUPERVISOR_VALIDATOR=0" ;;
        manager) status_role_env=" CODEX_SUPERVISOR_CEO=0 CODEX_SUPERVISOR_MANAGER=1 CODEX_SUPERVISOR_REVIEWER=0 CODEX_SUPERVISOR_DEBUGGER=0 CODEX_SUPERVISOR_VALIDATOR=0" ;;
        ceo|executive|meta|remote-meta) status_role_env=" CODEX_SUPERVISOR_CEO=1 CODEX_SUPERVISOR_MANAGER=0 CODEX_SUPERVISOR_REVIEWER=0 CODEX_SUPERVISOR_DEBUGGER=0 CODEX_SUPERVISOR_VALIDATOR=0" ;;
      esac
      if is_same_machine "$h"; then
        local prompts_abs; prompts_abs=$(path_under_project_if_relative "$d" "$prompts")
        ( cd "$d" && eval "CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$status_role_env $(shell_quote "$SUPERVISOR") status" 2>&1 | head -12 ) || echo "  (status command failed)"
      else
        if host_reachable "$h"; then
          local prompts_abs; prompts_abs=$(path_under_project_if_relative "$remote_dir" "$prompts")
          remote_run_existing "$h" "cd $(shell_quote "$remote_dir") || exit 1; CODEX_SUPERVISOR_SESSION=$(shell_quote "$session") CODEX_SUPERVISOR_PROMPTS=$(shell_quote "$prompts_abs")$status_role_env $(shell_quote "$supervisor") status 2>&1 | head -12" || echo "  (status command failed)"
        else
          echo "  (host unreachable)"
        fi
      fi
    done < <(toml_sections "$cfg" "hosts.")
  done
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
sub="${1:-}"; shift 2>/dev/null || true
case "$sub" in
  start)   cmd_start "$@" ;;
  submit)  cmd_submit "$@" ;;
  capacity) cmd_capacity "$@" ;;
  govern)  cmd_govern "$@" ;;
  factory-audit|audit-factory) cmd_factory_audit "$@" ;;
  factory-run|run-factory|ai-factory) cmd_factory_run "$@" ;;
  gm-start|general-manager-start|ceo-start) cmd_gm_start "$@" ;;
  staff|gm-staff|general-manager-staff|ceo-staff|scale|ceo-scale) cmd_staff "$@" ;;
  steward|factory-steward|reorg) cmd_steward "$@" ;;
  station|allocate|request) cmd_station "$@" ;;
  stop)    cmd_stop "$@" ;;
  status)  cmd_status "$@" ;;
  tunnel)  cmd_tunnel "$@" ;;
  ls|list) list_projects ;;
  hosts)   list_hosts ;;
  ""|help|-h|--help)
    cat <<'USAGE'
csup — codex-supervisor cross-host launcher

  csup start <project> [--host=<name>] [--fallback]
  csup submit <project> <lane> <goal text...>
  csup capacity [--json]
  csup govern [--dry-run|--apply] [--json] [--max-panes=N] [--project=<name>] [--host=<name>]
  csup factory-audit [--project=<name>|<project>]
  csup factory-run <project> [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply]
  csup gm-start <project> [--host=<name>] [--dry-run|--apply]
  csup staff <project> [--host=<name>] [--scenario=resume|balanced|full|blockers] [--dry-run|--apply] [--allow-stop]
  csup steward [--project=<name>|<project>] [--sample-secs=N]
  csup station <project> --sessions=N --workers=N [--host=<name>] [--dry-run|--apply]
  csup stop  <project> [--host=<name>]
  csup status [<project>]
  csup tunnel [--kill]
  csup ls            list projects with .codex-supervisor.toml
  csup hosts         list known hosts and reachability
  csup capacity      report local safe pane headroom and limiting resource
  csup govern --json emit dry-run plan as newline-delimited JSON events
  csup govern --max-panes=N cap this governor pass below computed capacity
USAGE
    ;;
  *) err "unknown subcommand: $sub"; exit 2 ;;
esac
